## Section

```elixir
defmodule DLM.ContextualEmbedTrainer do
  import Nx.Defn

  defn masked_prediction_loss(token_sequences, embeds) do
    seq_len = Nx.axis_size(token_sequences, 1)
    valid_len = seq_len - 4

    # 1. Sliding Window Extraction
    ctx1 = Nx.slice_along_axis(token_sequences, 0, valid_len, axis: 1)
    ctx2 = Nx.slice_along_axis(token_sequences, 1, valid_len, axis: 1)
    targets = Nx.slice_along_axis(token_sequences, 2, valid_len, axis: 1)
    ctx3 = Nx.slice_along_axis(token_sequences, 3, valid_len, axis: 1)
    ctx4 = Nx.slice_along_axis(token_sequences, 4, valid_len, axis: 1)

    # 2. Map targets to their 1024D Embeddings
    e1 = Nx.take(embeds, ctx1)
    e2 = Nx.take(embeds, ctx2)
    e3 = Nx.take(embeds, ctx3)
    e4 = Nx.take(embeds, ctx4)
    target_emb = Nx.take(embeds, targets)

    # 3. Pool the Context
    context_sum = Nx.add(e1, e2) |> Nx.add(e3) |> Nx.add(e4)
    context_emb = Nx.divide(context_sum, 4.0)

    # 4. Flatten for Point Cloud OT
    p_flat = Nx.reshape(context_emb, {:auto, 1024})
    t_flat = Nx.reshape(target_emb, {:auto, 1024})

    p_norm = DLM.Loss.l2_normalize(p_flat)
    t_norm = DLM.Loss.l2_normalize(t_flat)
    
    # 5. Core SinkhornOT Loss (Batch-specific)
    ot_loss = DLM.SinkhornOT.compute(p_norm, t_norm, 1.0, 16)

    # ====================================================================
    # ⚡ 6. NEW: Global Repulsion (Absence as Data)
    # ====================================================================
    # We L2 normalize the entire 256x1024 vocabulary matrix
    # all_vocab = DLM.Loss.l2_normalize(embeds)
    
    # # Calculate pairwise squared distances for ALL characters (Algebraic Expansion)
    # v_sq = Nx.sum(Nx.pow(all_vocab, 2), axes: [-1], keep_axes: true)
    # v_dot = Nx.dot(all_vocab, Nx.transpose(all_vocab))
    
    # pairwise_dist = 
    #   Nx.add(v_sq, Nx.transpose(v_sq)) 
    #   |> Nx.subtract(Nx.multiply(2.0, v_dot)) 
    #   |> Nx.max(0.0)
    
    # # We want to MAXIMIZE distance, which means MINIMIZING the inverse distance.
    # # We add 1.0 to the diagonal so a character doesn't violently repel itself.
    # safe_dist = Nx.add(pairwise_dist, Nx.eye({256, 256}))
    # inverse_dist = Nx.divide(1.0, Nx.add(safe_dist, 1.0e-6))
    
    # # Calculate the average repulsive force across the whole void
    # repulsion = Nx.mean(inverse_dist)
    
    # # Scale the repulsion so it gently inflates the space without overpowering the OT
    # repulsion_penalty = Nx.multiply(repulsion, 0.05) 

    # #7. Total Physics Loss
    # Nx.add(ot_loss, repulsion_penalty)
    ot_loss
  end

  defn compute_grad_and_step(embeds, m_embeds, v_embeds, token_sequences, _step, lr) do
    {loss, grad_e} = value_and_grad(embeds, fn e ->
      masked_prediction_loss(token_sequences, e)
    end)
  
    {new_embeds, new_m} = DLM.SparseSinkGD.step(embeds, grad_e, m_embeds, lr)
  
    {loss, new_embeds, new_m, v_embeds}
  end
end
