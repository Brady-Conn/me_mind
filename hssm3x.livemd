```elixir
defmodule DLM.Main_SSM_Trainer do
  import Nx.Defn

  defn get_real_coordinates(batch_tokens, frozen_embeds) do
    Nx.take(frozen_embeds, Nx.flatten(batch_tokens))
      |> Nx.reshape({Nx.axis_size(batch_tokens, 0), Nx.axis_size(batch_tokens, 1), 512})
      |> stop_grad()
  end

  # ⚡ 1. The Explicit Gradient Damper
  defn damp_mid_grads(mid_grads, damper) do
    # Unpack the 13 Mid Level gradients
    {g_a, g_bu, g_bv, g_cu, g_cv, g_du, g_dv, g_mu1, g_mv1, g_mu2, g_mv2, g_gw, g_gb} = mid_grads
    
    # Multiply each one by the damper (0.05) and repack
    {
      Nx.multiply(g_a, damper),
      Nx.multiply(g_bu, damper),
      Nx.multiply(g_bv, damper),
      Nx.multiply(g_cu, damper),
      Nx.multiply(g_cv, damper),
      Nx.multiply(g_du, damper),
      Nx.multiply(g_dv, damper),
      Nx.multiply(g_mu1, damper),
      Nx.multiply(g_mv1, damper),
      Nx.multiply(g_mu2, damper),
      Nx.multiply(g_mv2, damper),
      Nx.multiply(g_gw, damper),
      Nx.multiply(g_gb, damper)
    }
  end

  defn compute_sequence_loss(input_tokens, target_tokens, h_base_init, h_mid_init, h_top_init, frozen_base_p, frozen_map, mid_p, top_p) do
    seq_len = Nx.axis_size(input_tokens, 1)
    
    clean_coords = get_real_coordinates(input_tokens, frozen_map)
    inputs_time = Nx.transpose(clean_coords, axes: [1, 0, 2])
    targets_time = Nx.transpose(target_tokens, axes: [1, 0])

    zero_frame = Nx.broadcast(0.0, Nx.shape(h_top_init))

    result =
      while {i = 0, total_loss = 0.0, total_g1 = 0.0, total_g2 = 0.0,
             h_b = h_base_init, h_m = h_mid_init, h_t = h_top_init,
             x1_m = zero_frame, x2_m = zero_frame,
             x1_t = zero_frame, x2_t = zero_frame,
             in_t = inputs_time, targ_t = targets_time,
             b_p = frozen_base_p, m_p = mid_p, t_p = top_p, f_map = frozen_map}, 
            Nx.less(i, seq_len) do
            
        x_curr = in_t[i]
        
        # 1. Base Level
        {_y_base, h_b_new} = DLM.TinySSM.forward(x_curr, h_b, b_p)

        # 2. Mid Level (13 params)
        {a_m, bu_m, bv_m, cu_m, cv_m, du_m, dv_m, mu1_m, mv1_m, mu2_m, mv2_m, g1_w, g1_b} = m_p
        
        g1_logit = Nx.add(Nx.dot(h_b_new, g1_w), g1_b)
        g1 = Nx.sigmoid(g1_logit) 

        {_y_mid, h_m_cand} = DLM.Main_SSM.ssm_recurrence(h_b_new, x1_m, x2_m, h_m, a_m, bu_m, bv_m, cu_m, cv_m, du_m, dv_m, mu1_m, mv1_m, mu2_m, mv2_m)
        h_m_new = Nx.add(Nx.multiply(g1, h_m_cand), Nx.multiply(Nx.subtract(1.0, g1), h_m))
        h_b_flushed = Nx.multiply(h_b_new, Nx.subtract(1.0, g1))

        # ⚡ 3. Top Level (Syntax)
        {a_t, bu_t, bv_t, cu_t, cv_t, du_t, dv_t, mu1_t, mv1_t, mu2_t, mv2_t, g2_w, g2_b, gate_w, gate_b, spell_w, spell_b, out_w, out_b} = t_p
        
        g2_logit = Nx.add(Nx.dot(h_m_new, g2_w), g2_b)
        g2 = Nx.sigmoid(g2_logit) 

        # Normal Top Level routing (NO fast cursor here!)
        {y_top, h_t_cand} = DLM.Main_SSM.ssm_recurrence(h_m_new, x1_t, x2_t, h_t, a_t, bu_t, bv_t, cu_t, cv_t, du_t, dv_t, mu1_t, mv1_t, mu2_t, mv2_t)
        h_t_new = Nx.add(Nx.multiply(g2, h_t_cand), Nx.multiply(Nx.subtract(1.0, g2), h_t))
        h_m_flushed = Nx.multiply(h_m_new, Nx.subtract(1.0, g2))

        # ⚡ 4. The Cross-Swish Gate Output Head
        # Grammar generates the valve
        valve_raw = Nx.add(Nx.dot(y_top, gate_w), gate_b)
        valve_swish = Nx.multiply(valve_raw, Nx.sigmoid(valve_raw))

        # Fast cursor (Base) + Syllable (Mid) generates the spelling features
        local_context = Nx.add(h_b_new, h_m_new)
        spell_features = Nx.add(Nx.dot(local_context, spell_w), spell_b)

        # Multiplicative Fusion
        fused_h = Nx.multiply(valve_swish, spell_features)
        
        y_final = DLM.Main_SSM.rms_norm(fused_h)
        logits = Nx.add(Nx.dot(y_final, out_w), out_b)

        step_loss = DLM.SinkhornOT.compute(logits, targ_t[i])

        {i + 1, total_loss + step_loss, total_g1 + Nx.mean(g1), total_g2 + Nx.mean(g2),
         h_b_flushed, h_m_flushed, h_t_new,
         h_b_new, x1_m, 
         h_m_new, x1_t,
         in_t, targ_t, b_p, m_p, t_p, f_map}
      end
      
    {
      Nx.divide(elem(result, 1), seq_len), 
      elem(result, 4), elem(result, 5), elem(result, 6), 
      Nx.divide(elem(result, 2), seq_len), Nx.divide(elem(result, 3), seq_len)
    }
  end

  defn compute_grad_and_step(batch_tokens, h_b_init, h_m_init, h_t_init, frozen_base_p, frozen_map, combined_params) do
    seq_len = Nx.axis_size(batch_tokens, 1) - 1
    input_tokens = Nx.slice_along_axis(batch_tokens, 0, seq_len, axis: 1)
    target_tokens = Nx.slice_along_axis(batch_tokens, 1, seq_len, axis: 1)

    {loss, raw_grads} = value_and_grad(combined_params, fn {m_p, t_p} ->
      {avg_loss, _hb, _hm, _ht, avg_g1, avg_g2} = 
        compute_sequence_loss(input_tokens, target_tokens, h_b_init, h_m_init, h_t_init, frozen_base_p, frozen_map, m_p, t_p)
      
      # ⚡ Double Sparsity Penalty
      target_g1 = Nx.tensor(0.32, type: :f32) # ~3.1 chars
      target_g2 = Nx.tensor(0.10, type: :f32) # ~10 L2 chunks
      
      # ⚡ BOOSTED: Multiply by 40.0 to punch through the 0.05 damper!
      penalty_1 = Nx.multiply(40.0, Nx.pow(Nx.subtract(avg_g1, target_g1), 2))
      
      # Gate 2 is in the Top Level (not damped), so 2.0 is perfectly fine
      penalty_2 = Nx.multiply(2.0, Nx.pow(Nx.subtract(avg_g2, target_g2), 2))

      avg_loss |> Nx.add(penalty_1) |> Nx.add(penalty_2)
    end)

    {mid_grads, top_grads} = raw_grads

    # ⚡ THE GRADIENT DAMPER
    damper = Nx.tensor(0.05, type: :f32)
    
    # 👈 Make sure you are passing 'mid_grads' here, not 'raw_grads'
    damped_mid_grads = damp_mid_grads(mid_grads, damper) 
    
    # 👈 Make sure you are using 'top_grads' here
    final_grads = {damped_mid_grads, top_grads}
    
    # Run a clean pass to get states
    {_loss, final_h_base, final_h_mid, final_h_top, avg_g1, avg_g2} = 
        compute_sequence_loss(input_tokens, target_tokens, h_b_init, h_m_init, h_t_init, frozen_base_p, frozen_map, elem(combined_params, 0), elem(combined_params, 1))

    {loss, final_grads, final_h_base, final_h_mid, final_h_top, avg_g1, avg_g2}
  end

  def grad_norms({mid_grads, top_grads}) do
    {_ga, _gbu, _gbv, _gcu, _gcv, _gdu, _gdv, _gmu1, _gmv1, _gmu2, _gmv2, _g1_w, g1_b} = mid_grads
    
    # ⚡ Unpack the 19 Swish Gradients
    {g_a, _g_bu, _g_bv, _g_cu, _g_cv, _g_du, g_dv, _g_mu1, _g_mv1, _g_mu2, _g_mv2, _g2_w, g2_b, _g_gw, _g_gb, _g_sw, _g_sb, g_ow, _g_ob} = top_grads
    
    calc = fn g -> g |> Nx.pow(2) |> Nx.sum() |> Nx.sqrt() |> Nx.to_number() |> Float.round(4) end
    
    [
      top_a_diag: calc.(g_a), top_d_v: calc.(g_dv),
      lm_w: calc.(g_ow), # We track out_w now!
      g1_b: calc.(g1_b), g2_b: calc.(g2_b)
    ]
  end
end
