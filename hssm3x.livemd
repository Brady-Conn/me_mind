## Inferece

```elixir
defmodule DLM.BLiMP do
  import Nx.Defn

  # ⚡ 1. The 3-Tier Evaluation Forward Pass (Swish Edition)
  defn eval_loss(tokens, h_base_init, h_mid_init, h_top_init, frozen_base_p, frozen_map, mid_p, top_p) do
    seq_len = Nx.axis_size(tokens, 1) - 1
    
    input_tokens = Nx.slice_along_axis(tokens, 0, seq_len, axis: 1)
    target_tokens = Nx.slice_along_axis(tokens, 1, seq_len, axis: 1)

    clean_coords = Nx.take(frozen_map, Nx.flatten(input_tokens))
                   |> Nx.reshape({1, seq_len, 512})
                   
    in_t = Nx.transpose(clean_coords, axes: [1, 0, 2])
    targ_t = Nx.transpose(target_tokens, axes: [1, 0])

    zero_frame = Nx.broadcast(0.0, {1, 512})

    result =
      while {i = 0, total_loss = 0.0, 
             h_b = h_base_init, h_m = h_mid_init, h_t = h_top_init,
             x1_m = zero_frame, x2_m = zero_frame,
             x1_t = zero_frame, x2_t = zero_frame,
             x_in = in_t, y_targ = targ_t,
             b_p = frozen_base_p, m_p = mid_p, t_p = top_p, f_map = frozen_map}, 
            Nx.less(i, seq_len) do
            
        x_curr = x_in[i]

        # ⚡ 1. Base Level (Phonetics)
        {_y_base, h_b_new} = DLM.TinySSM.forward(x_curr, h_b, b_p)

        # ⚡ 2. Mid Level (Syllables - 13 params)
        {a_m, bu_m, bv_m, cu_m, cv_m, du_m, dv_m, mu1_m, mv1_m, mu2_m, mv2_m, g1_w, g1_b} = m_p
        
        g1_logit = Nx.add(Nx.dot(h_b_new, g1_w), g1_b)
        g1 = Nx.sigmoid(g1_logit) 

        {_y_mid, h_m_cand} = DLM.Main_SSM.ssm_recurrence(h_b_new, x1_m, x2_m, h_m, a_m, bu_m, bv_m, cu_m, cv_m, du_m, dv_m, mu1_m, mv1_m, mu2_m, mv2_m)
        h_m_new = Nx.add(Nx.multiply(g1, h_m_cand), Nx.multiply(Nx.subtract(1.0, g1), h_m))
        h_b_flushed = Nx.multiply(h_b_new, Nx.subtract(1.0, g1))

        # ⚡ 3. Top Level (Syntax - 19 params)
        {a_t, bu_t, bv_t, cu_t, cv_t, du_t, dv_t, mu1_t, mv1_t, mu2_t, mv2_t, g2_w, g2_b, gate_w, gate_b, spell_w, spell_b, out_w, out_b} = t_p
        
        g2_logit = Nx.add(Nx.dot(h_m_new, g2_w), g2_b)
        g2 = Nx.sigmoid(g2_logit) 

        # Normal Top Level routing
        {y_top, h_t_cand} = DLM.Main_SSM.ssm_recurrence(h_m_new, x1_t, x2_t, h_t, a_t, bu_t, bv_t, cu_t, cv_t, du_t, dv_t, mu1_t, mv1_t, mu2_t, mv2_t)
        h_t_new = Nx.add(Nx.multiply(g2, h_t_cand), Nx.multiply(Nx.subtract(1.0, g2), h_t))
        h_m_flushed = Nx.multiply(h_m_new, Nx.subtract(1.0, g2))

        # ⚡ 4. The Cross-Swish Gate Output Head
        # Grammar generates the valve
        valve_raw = Nx.add(Nx.dot(y_top, gate_w), gate_b)
        valve_swish = Nx.multiply(valve_raw, Nx.sigmoid(valve_raw))

        # Fast cursor (Base) + Syllable (Mid) generates the spelling features
        local_context = Nx.add(h_b_new, h_m_new)
        spell_features = Nx.add(Nx.dot(local_context, spell_w), spell_b)

        # Multiplicative Fusion
        fused_h = Nx.multiply(valve_swish, spell_features)
        
        y_final = DLM.Main_SSM.rms_norm(fused_h)
        logits = Nx.add(Nx.dot(y_final, out_w), out_b)
        
        step_loss = DLM.Loss.cross_entropy(logits, y_targ[i])

        {i + 1, total_loss + step_loss, 
         h_b_flushed, h_m_flushed, h_t_new, 
         h_b_new, x1_m, 
         h_m_new, x1_t,
         x_in, y_targ, b_p, m_p, t_p, f_map}
      end
      
    # ⚡ THE FIX: Return the pure Sum of Losses, NOT the average!
    # elem(result, 1)
    Nx.divide(elem(result, 1), seq_len)
  end

  # ⚡ 2. The Elixir Wrapper
  def evaluate_sentence(sentence, frozen_base_p, frozen_map, combined_top_p, gpu) do
    # Unpack the 3-Tier Tuple
    {mid_p, top_p} = combined_top_p

    # Convert string to {1, seq_len} tensor
    tokens = sentence |> to_charlist() |> Nx.tensor(type: :s32) |> Nx.new_axis(0) |> Nx.backend_copy(gpu)
    
    # Initialize blank memory for ALL 3 tiers
    h_base = Nx.broadcast(0.0, {1, 512}) |> Nx.backend_copy(gpu)
    h_mid  = Nx.broadcast(0.0, {1, 512}) |> Nx.backend_copy(gpu)
    h_top  = Nx.broadcast(0.0, {1, 512}) |> Nx.backend_copy(gpu)

    # Run the compiled XLA graph
    loss_tensor = eval_loss(tokens, h_base, h_mid, h_top, frozen_base_p, frozen_map, mid_p, top_p)
    Nx.to_number(loss_tensor)
  end
end
```

