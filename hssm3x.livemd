```elixir
defmodule DLM.MuonHybrid do
  import Nx.Defn

  defn newton_schulz(g, iters \\ 5) do
    frobenius_norm = Nx.sqrt(Nx.sum(Nx.pow(g, 2))) + 1.0e-7
    x = g / frobenius_norm
    
    {final_x, _} = while {curr_x = x, i = 0}, Nx.less(i, iters) do
      x_t_x = Nx.dot(Nx.transpose(curr_x), curr_x)
      next_x = 1.5 * curr_x - 0.5 * Nx.dot(curr_x, x_t_x)
      {next_x, i + 1}
    end
    final_x
  end

  defn muon_update(grad, lr) do
    Nx.subtract(0.0, Nx.multiply(lr, newton_schulz(grad)))
  end

  defn adam_update(param, grad, m, v, step, lr) do
    safe_step = step + 1.0
    beta1 = 0.9
    beta2 = 0.999
    eps = 1.0e-8
    
    new_m = beta1 * m + (1.0 - beta1) * grad
    new_v = beta2 * v + (1.0 - beta2) * Nx.pow(grad, 2)
    
    m_hat = new_m / (1.0 - Nx.pow(beta1, safe_step))
    v_hat = new_v / (1.0 - Nx.pow(beta2, safe_step))
    
    param_update = param - lr * m_hat / (Nx.sqrt(v_hat) + eps)
    {param_update, new_m, new_v}
  end

  # ⚡ 13-Parameter Step for MID LEVEL (No Output Head)
  defn step_mid(params, grads, ms, vs, step_count, lr) do
    {p_a, p_bu, p_bv, p_cu, p_cv, p_du, p_dv, p_mu1, p_mv1, p_mu2, p_mv2, p_gw, p_gb} = params
    {g_a, g_bu, g_bv, g_cu, g_cv, g_du, g_dv, g_mu1, g_mv1, g_mu2, g_mv2, g_gw, g_gb} = grads
    {m_a, m_bu, m_bv, m_cu, m_cv, m_du, m_dv, m_mu1, m_mv1, m_mu2, m_mv2, m_gw, m_gb} = ms
    {v_a, v_bu, v_bv, v_cu, v_cv, v_du, v_dv, v_mu1, v_mv1, v_mu2, v_mv2, v_gw, v_gb} = vs

    # Adam for scalars
    {up_a, nm_a, nv_a} = adam_update(p_a, g_a, m_a, v_a, step_count, lr)
    {up_gw, nm_gw, nv_gw} = adam_update(p_gw, g_gw, m_gw, v_gw, step_count, lr)
    {up_gb, nm_gb, nv_gb} = adam_update(p_gb, g_gb, m_gb, v_gb, step_count, lr)
    
    # Muon for SVD matrices
    up_bu  = p_bu  + muon_update(g_bu,  lr)
    up_bv  = p_bv  + muon_update(g_bv,  lr)
    up_cu  = p_cu  + muon_update(g_cu,  lr)
    up_cv  = p_cv  + muon_update(g_cv,  lr)
    up_du  = p_du  + muon_update(g_du,  lr)
    up_dv  = p_dv  + muon_update(g_dv,  lr)
    up_mu1 = p_mu1 + muon_update(g_mu1, lr)
    up_mv1 = p_mv1 + muon_update(g_mv1, lr)
    up_mu2 = p_mu2 + muon_update(g_mu2, lr)
    up_mv2 = p_mv2 + muon_update(g_mv2, lr)

    new_params = {up_a, up_bu, up_bv, up_cu, up_cv, up_du, up_dv, up_mu1, up_mv1, up_mu2, up_mv2, up_gw, up_gb}
    new_ms = {nm_a, m_bu, m_bv, m_cu, m_cv, m_du, m_dv, m_mu1, m_mv1, m_mu2, m_mv2, nm_gw, nm_gb}
    new_vs = {nv_a, v_bu, v_bv, v_cu, v_cv, v_du, v_dv, v_mu1, v_mv1, v_mu2, v_mv2, nv_gw, nv_gb}
    
    {new_params, new_ms, new_vs}
  end

  # Inside DLM.MuonHybrid
  defn step_top_swish(params, grads, ms, vs, step_count, lr) do
    {p_a, p_bu, p_bv, p_cu, p_cv, p_du, p_dv, p_mu1, p_mv1, p_mu2, p_mv2, p_g2w, p_g2b, p_gw, p_gb, p_sw, p_sb, p_ow, p_ob} = params
    {g_a, g_bu, g_bv, g_cu, g_cv, g_du, g_dv, g_mu1, g_mv1, g_mu2, g_mv2, g_g2w, g_g2b, g_gw, g_gb, g_sw, g_sb, g_ow, g_ob} = grads
    {m_a, m_bu, m_bv, m_cu, m_cv, m_du, m_dv, m_mu1, m_mv1, m_mu2, m_mv2, m_g2w, m_g2b, m_gw, m_gb, m_sw, m_sb, m_ow, m_ob} = ms
    {v_a, v_bu, v_bv, v_cu, v_cv, v_du, v_dv, v_mu1, v_mv1, v_mu2, v_mv2, v_g2w, v_g2b, v_gw, v_gb, v_sw, v_sb, v_ow, v_ob} = vs
  
    # Adam Updates (Applying to all non-SVD matrices)
    {up_a, nm_a, nv_a} = adam_update(p_a, g_a, m_a, v_a, step_count, lr)
    {up_g2w, nm_g2w, nv_g2w} = adam_update(p_g2w, g_g2w, m_g2w, v_g2w, step_count, lr)
    {up_g2b, nm_g2b, nv_g2b} = adam_update(p_g2b, g_g2b, m_g2b, v_g2b, step_count, lr)
    
    {up_gw, nm_gw, nv_gw} = adam_update(p_gw, g_gw, m_gw, v_gw, step_count, lr)
    {up_gb, nm_gb, nv_gb} = adam_update(p_gb, g_gb, m_gb, v_gb, step_count, lr)
    {up_sw, nm_sw, nv_sw} = adam_update(p_sw, g_sw, m_sw, v_sw, step_count, lr)
    {up_sb, nm_sb, nv_sb} = adam_update(p_sb, g_sb, m_sb, v_sb, step_count, lr)
    {up_ow, nm_ow, nv_ow} = adam_update(p_ow, g_ow, m_ow, v_ow, step_count, lr)
    {up_ob, nm_ob, nv_ob} = adam_update(p_ob, g_ob, m_ob, v_ob, step_count, lr)
    
    # Muon Updates for SVD
    up_bu  = p_bu  + muon_update(g_bu,  lr)
    up_bv  = p_bv  + muon_update(g_bv,  lr)
    up_cu  = p_cu  + muon_update(g_cu,  lr)
    up_cv  = p_cv  + muon_update(g_cv,  lr)
    up_du  = p_du  + muon_update(g_du,  lr)
    up_dv  = p_dv  + muon_update(g_dv,  lr)
    up_mu1 = p_mu1 + muon_update(g_mu1, lr)
    up_mv1 = p_mv1 + muon_update(g_mv1, lr)
    up_mu2 = p_mu2 + muon_update(g_mu2, lr)
    up_mv2 = p_mv2 + muon_update(g_mv2, lr)
  
    new_params = {up_a, up_bu, up_bv, up_cu, up_cv, up_du, up_dv, up_mu1, up_mv1, up_mu2, up_mv2, up_g2w, up_g2b, up_gw, up_gb, up_sw, up_sb, up_ow, up_ob}
    new_ms = {nm_a, m_bu, m_bv, m_cu, m_cv, m_du, m_dv, m_mu1, m_mv1, m_mu2, m_mv2, nm_g2w, nm_g2b, nm_gw, nm_gb, nm_sw, nm_sb, nm_ow, nm_ob}
    new_vs = {nv_a, v_bu, v_bv, v_cu, v_cv, v_du, v_dv, v_mu1, v_mv1, v_mu2, v_mv2, nv_g2w, nv_g2b, nv_gw, nv_gb, nv_sw, nv_sb, nv_ow, nv_ob}
  
    {new_params, new_ms, new_vs}
  end
end
