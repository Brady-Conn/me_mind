## Layer 2 import

```elixir
defmodule DLM.SwishSurgery do
  def build_genesis(phase3_ckpt_path, new_prefix) do
    IO.puts("🔪 Extracting Pristine Syllable Engine from Phase 3...")
    ckpt = File.read!(phase3_ckpt_path) |> :erlang.binary_to_term()
    
    # 1. Unpack the original 15 Phase 3 parameters
    {a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2, _old_lmw, _old_lmb, g1_w, g1_b} = ckpt.params
    
    # 2. Re-pack the 13 parameters for the Mid Level (Syllables)
    mid_p = {a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2, g1_w, g1_b}
    
    # 3. Initialize the BRAND NEW 19-Parameter Top Level + Swish Gate
    top_p = DLM.Main_SSM_Genesis.init_params(42) 
    
    # 4. Fresh Optimizer States
    zero_mid = DLM.Tree.map(mid_p, fn t -> Nx.broadcast(0.0, Nx.shape(t)) end)
    zero_top = DLM.Tree.map(top_p, fn t -> Nx.broadcast(0.0, Nx.shape(t)) end)
    
    # 5. Save the Safe Checkpoint (The CPU Air-Lock)
    safe_state = %{
      params: DLM.Tree.map({mid_p, top_p}, &Nx.backend_copy(&1, Nx.BinaryBackend)),
      ms: DLM.Tree.map({zero_mid, zero_top}, &Nx.backend_copy(&1, Nx.BinaryBackend)),
      vs: DLM.Tree.map({zero_mid, zero_top}, &Nx.backend_copy(&1, Nx.BinaryBackend)),
      step: 0
    }
    
    File.write!("#{new_prefix}_checkpoint_step_0.bin", :erlang.term_to_binary(safe_state))
    IO.puts("✅ Swish Genesis Created.")
  end
end

# Run it using your pristine 80k checkpoint:
# DLM.SwishSurgery.build_genesis("v34_DLM_Phase_3_Top_Biased_checkpoint_step_80000.bin", "v36_swish")
