## Inferece

```elixir
defmodule DLM.Phase3_Eval do
  import Nx.Defn

  # Run this on a held-out validation batch
  defn compute_accuracy(input_tokens, target_tokens, h_base_init, h_top_init, frozen_base_p, top_p, frozen_map) do
    seq_len = Nx.axis_size(input_tokens, 1)

    # 1. Map inputs to continuous space
    input_coords =
      Nx.take(frozen_map, Nx.flatten(input_tokens))
      |> Nx.reshape({1, seq_len, 512})
    
    in_t = Nx.transpose(input_coords, axes: [1, 0, 2])
    targ_t = Nx.transpose(target_tokens, axes: [1, 0])

    zero_frame = Nx.broadcast(0.0, {1, 512})

    result =
      # ⚡ 12 Elements exactly
      while {i = 0, correct_top1 = 0.0, total_chars = 0.0,
             h_base = h_base_init, h_top = h_top_init,
             xp1 = zero_frame, xp2 = zero_frame,
             x_in = in_t, y_targ = targ_t,
             b_p = frozen_base_p, t_p = top_p, f_map = frozen_map}, 
            Nx.less(i, seq_len) do
            
        x_curr = x_in[i]

        # ⚡ Grab the actual Phase 2 prediction!
        {y_base, h_base_new} = DLM.TinySSM.forward(x_curr, h_base, b_p)

        # ⚡ Unpack all 19 params, ignoring the dead gate weights
        {a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2, 
         _gate_w, _gate_b, spell_w, spell_b, valve_w, valve_b, out_w, out_b} = t_p

        # ⚡ Top SSM (Chunker) - Unchained!
        {_y_top, h_top_new} = DLM.Main_SSM.ssm_recurrence(
          h_base_new, xp1, xp2, h_top, 
          a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2
        )

        # ⚡ Swish Fusion
        f_spell = Nx.add(Nx.dot(h_base_new, spell_w), spell_b)
        v_syntax = DLM.Main_SSM.swish(Nx.add(Nx.dot(h_top_new, valve_w), valve_b))
        
        h_fused = Nx.multiply(v_syntax, f_spell)
        h_fused_norm = DLM.Main_SSM.rms_norm(h_fused)

        # ⚡ 3. Residual Prediction uses the True Output, not the hidden state
        p2_native_latent = y_base
        p3_adjustment = Nx.add(Nx.dot(h_fused_norm, out_w), out_b)
        
        pred_latent = Nx.add(p2_native_latent, p3_adjustment)

        # ⚡ Calculate Top-1 Accuracy against the map
        pred_norm = DLM.Loss.l2_normalize(pred_latent)
        similarities = Nx.dot(pred_norm, Nx.transpose(f_map))
        
        predicted_indices = Nx.argmax(similarities, axis: -1)
        true_indices = y_targ[i]
        
        matches = Nx.equal(predicted_indices, true_indices) |> Nx.sum()
        
        # ⚡ THE FIX: Restore the Shift Register here as well!
        {i + 1, Nx.add(correct_top1, matches), Nx.add(total_chars, Nx.axis_size(true_indices, 0)), 
         h_base_new, h_top_new, h_base_new, xp1, x_in, y_targ, b_p, t_p, f_map}
      end

    total_correct = elem(result, 1)
    total_count = elem(result, 2)
    
    Nx.multiply(Nx.divide(total_correct, total_count), 100.0)
  end

  defn compute_sentence_loss(input_tokens, target_tokens, h_base_init, h_top_init, frozen_base_p, top_p, frozen_map) do
    seq_len = Nx.axis_size(input_tokens, 1)
  
    input_coords =
      Nx.take(frozen_map, Nx.flatten(input_tokens))
      |> Nx.reshape({1, seq_len, 512})
  
    in_t = Nx.transpose(input_coords, axes: [1, 0, 2])
  
    target_coords =
      Nx.take(frozen_map, Nx.flatten(target_tokens))
      |> Nx.reshape({1, seq_len, 512})
  
    targ_t = Nx.transpose(target_coords, axes: [1, 0, 2])
  
    zero_frame = Nx.broadcast(0.0, {1, 512})
  
    result =
      while {i = 0, total_loss = 0.0,
             h_base = h_base_init, h_top = h_top_init,
             xp1 = zero_frame, xp2 = zero_frame,
             x_in = in_t, y_targ = targ_t,
             b_p = frozen_base_p, t_p = top_p, f_map = frozen_map},
            Nx.less(i, seq_len) do
  
        x_curr = x_in[i]
  
        {y_base, h_base_new} = DLM.TinySSM.forward(x_curr, h_base, b_p)
  
        {a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2,
         gate_w, gate_b, spell_w, spell_b, valve_w, valve_b, out_w, out_b} = t_p
  
        {_y_top, h_top_candidate} = DLM.Main_SSM.ssm_recurrence(
          h_base_new, xp1, xp2, h_top,
          a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2
        )
  
        {h_top_new, h_base_flushed, _g} =
          DLM.HierarchyBridge.apply_gate(h_base_new, h_top_candidate, h_top, gate_w, gate_b)
  
        f_spell = Nx.add(Nx.dot(h_base_new, spell_w), spell_b)
        v_syntax = DLM.Main_SSM.swish(Nx.add(Nx.dot(h_top_new, valve_w), valve_b))
  
        h_fused = Nx.multiply(v_syntax, f_spell)
        h_fused_norm = DLM.Main_SSM.rms_norm(h_fused)
  
        p3_adjustment = Nx.add(Nx.dot(h_fused_norm, out_w), out_b)
        pred_latent = Nx.add(y_base, p3_adjustment)
  
        step_loss = DLM.Loss.cosine_distance(pred_latent, y_targ[i])
  
        {i + 1, total_loss + step_loss,
         h_base_flushed, h_top_new, h_base_flushed, xp1,
         x_in, y_targ, b_p, t_p, f_map}
      end
  
    # Return average loss across the sequence
    Nx.divide(elem(result, 1), seq_len)
  end
end
