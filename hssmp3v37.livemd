```elixir
# 1. Load the completed Phase 1 state
%{params: phase1_p} = File.read!("phase1_shape_diffusion_COMPLETE.bin") |> :erlang.binary_to_term()

# 2. Unpack it (we only want the embeds, we can throw away the Phase 1 denoiser weights for now)
{cpu_embeds, _w1, _w2, _key} = phase1_p

# 3. Push the finalized map to the GPU and L2 Normalize it one last time to be safe
frozen_map = cpu_embeds
             |> Nx.backend_copy(gpu)
             |> DLM.Loss.l2_normalize()

phase2_p = File.read!("v37_DLM_Phase_2_lr3e5_softnn_checkpoint_step_10000.bin") |> :erlang.binary_to_term()

phase3_p = File.read!("v37_DLM_Phase_3_cosg_ec_checkpoint_step_24000.bin") |> :erlang.binary_to_term()

# 1. Use the EXACT same validation string from your Phase 2 eval
val_text = "The quick brown fox jumps over the lazy dog. It was the best of times, it was the worst of times."

# 2. Convert and shift
val_tokens = val_text |> to_charlist() |> Nx.tensor(type: :s32)
seq_len = Nx.size(val_tokens) - 1

input_tokens = Nx.slice_along_axis(val_tokens, 0, seq_len, axis: 0) |> Nx.new_axis(0) |> Nx.backend_copy(gpu)
target_tokens = Nx.slice_along_axis(val_tokens, 1, seq_len, axis: 0) |> Nx.new_axis(0) |> Nx.backend_copy(gpu)

# 3. Initialize dual states
h_init = Nx.broadcast(0.0, {1, 512}) |> Nx.backend_copy(gpu)

# 4. Evaluate!
# Make sure frozen_base_p is your 10k low-LR champion from Phase 2
accuracy_tensor = DLM.Phase3_Eval.compute_accuracy(
  input_tokens, target_tokens, h_init, h_init, phase2_p, phase3_p.params, frozen_map
)

accuracy = Nx.to_number(accuracy_tensor)
IO.puts("Phase 3 Top-1 Accuracy: #{Float.round(accuracy, 2)}%")
