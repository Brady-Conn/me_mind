```elixir
gpu = {EXLA.Backend, client: :rocm}
blimp_file = "./data/anaphor_gender_agreement.jsonl"

# 1. Load the completed Phase 1 state
%{params: phase1_p} = File.read!("phase1_shape_diffusion_COMPLETE.bin") |> :erlang.binary_to_term()

# 2. Unpack it (we only want the embeds, we can throw away the Phase 1 denoiser weights for now)
{cpu_embeds, _w1, _w2, _key} = phase1_p

# 3. Push the finalized map to the GPU and L2 Normalize it one last time to be safe
frozen_map = cpu_embeds
             |> Nx.backend_copy(gpu)
             |> DLM.Loss.l2_normalize()

phase2_p = File.read!("v37_DLM_Phase_2_lr3e5_softnn_checkpoint_step_10000.bin") |> :erlang.binary_to_term()

%{params: phase3_p} = File.read!("v37_DLM_Phase_3_cosg_ec_checkpoint_step_18000.bin") |> :erlang.binary_to_term()


# ==============================================================================
# 2. RUN BLIMP EVALUATION
# ==============================================================================
IO.puts("📖 Reading BLiMP Dataset: #{blimp_file}")

# Parse the JSON Lines
pairs = 
  File.read!(blimp_file)
  |> String.split("\n", trim: true)
  |> Enum.map(&Jason.decode!/1)

total_pairs = length(pairs)
IO.puts("⚖️ Evaluating #{total_pairs} minimalist pairs...")

# Tally the results
{passes, total_loss_diff} = 
  Enum.reduce(pairs, {0, 0.0}, fn pair, {pass_count, diff_acc} ->
    good_sentence = pair["sentence_good"]
    bad_sentence = pair["sentence_bad"]

    # 2. Convert and shift
    good_val_tokens = good_sentence |> to_charlist() |> Nx.tensor(type: :s32)
    good_seq_len = Nx.size(good_val_tokens) - 1

    bad_val_tokens = bad_sentence |> to_charlist() |> Nx.tensor(type: :s32)
    bad_seq_len = Nx.size(bad_val_tokens) - 1
    
    good_input_tokens = Nx.slice_along_axis(good_val_tokens, 0, good_seq_len, axis: 0) |> Nx.new_axis(0) |> Nx.backend_copy(gpu)
    good_target_tokens = Nx.slice_along_axis(good_val_tokens, 1, good_seq_len, axis: 0) |> Nx.new_axis(0) |> Nx.backend_copy(gpu)

    bad_input_tokens = Nx.slice_along_axis(bad_val_tokens, 0, bad_seq_len, axis: 0) |> Nx.new_axis(0) |> Nx.backend_copy(gpu)
    bad_target_tokens = Nx.slice_along_axis(bad_val_tokens, 1, bad_seq_len, axis: 0) |> Nx.new_axis(0) |> Nx.backend_copy(gpu)
    # 3. Initialize dual states
    h_init = Nx.broadcast(0.0, {1, 512}) |> Nx.backend_copy(gpu)

    good_loss = DLM.Phase3_Eval.compute_sentence_loss(good_input_tokens, good_target_tokens, h_init, h_init, phase2_p, phase3_p, frozen_map) |> Nx.to_number()
    bad_loss  = DLM.Phase3_Eval.compute_sentence_loss(bad_input_tokens, bad_target_tokens, h_init, h_init, phase2_p, phase3_p, frozen_map) |> Nx.to_number()

    # Did the model assign a lower loss (higher probability) to the grammatically correct sentence?
    is_pass? = good_loss < bad_loss
    
    new_pass_count = if is_pass?, do: pass_count + 1, else: pass_count

    {new_pass_count, diff_acc + (bad_loss - good_loss)}
  end)

# Calculate final metrics
accuracy = (passes / total_pairs) * 100.0
avg_margin = total_loss_diff / total_pairs

IO.puts(String.duplicate("=", 50))
IO.puts("🏆 BLiMP EVALUATION RESULTS")
IO.puts(String.duplicate("=", 50))
IO.puts("Dataset:   #{blimp_file}")
IO.puts("Accuracy:  #{Float.round(accuracy, 2)}% (#{passes}/#{total_pairs})")
IO.puts("Margin:    #{Float.round(avg_margin, 4)} (Avg loss difference)")
IO.puts(String.duplicate("=", 50))
```

