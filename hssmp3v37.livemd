```elixir
defmodule DLM.HierarchyBridge do
  import Nx.Defn

  @doc """
  Applies the hierarchical gate AFTER both SSMs have already stepped.
  
  - h_base_new: fresh output from TinySSM this step
  - h_top_candidate: fresh output from Main_SSM.ssm_recurrence this step  
  - h_top_prev: the top state from the previous step (before this step's update)
  - gate_w: the {512, 1} gating weight
  - gate_b: the {1} gating bias
  
  Returns:
  - h_top_gated: the interpolated top state (soft-updated or held)
  - h_base_flushed: the base state after soft reset
  - g: the gate value (useful for telemetry)
  """
  defn apply_gate(h_base_new, h_top_candidate, h_top_prev, gate_w, gate_b) do
    # 1. Compute gate from current base state → scalar per batch item
    boundary_logit = Nx.add(Nx.dot(h_base_new, gate_w), gate_b)
    g = Nx.sigmoid(boundary_logit)  # shape: {batch, 1}

    # 2. Soft interpolation of the top state
    #    g ≈ 0 (mid-concept): keep h_top_prev almost entirely
    #    g ≈ 1 (chunk boundary): pull fully toward h_top_candidate
    h_top_gated = Nx.add(
      Nx.multiply(g, h_top_candidate),
      Nx.multiply(Nx.subtract(1.0, g), h_top_prev)
    )

    # 3. Soft reset of the base state
    #    When a boundary fires, flush base memory so it starts fresh
    h_base_flushed = Nx.multiply(h_base_new, Nx.subtract(1.0, g))

    {h_top_gated, h_base_flushed, g}
  end
end
```

