## Trainer

```elixir
defmodule DLM.TokenizerTrainer do
  import Nx.Defn

  defn log_softmax(logits) do
    max_logits = Nx.reduce_max(logits, axes: [-1], keep_axes: true)
    safe_logits = logits - max_logits
    sum_exp = Nx.sum(Nx.exp(safe_logits), axes: [-1], keep_axes: true)
    safe_logits - Nx.log(sum_exp)
  end

  defn compute_loss(preds_sliced, targets) do
    log_probs = log_softmax(preds_sliced)
    target_probs = Nx.take_along_axis(log_probs, Nx.new_axis(targets, -1), axis: -1)
    target_probs = Nx.squeeze(target_probs, axes: [-1])
    mask = Nx.not_equal(targets, 0) |> Nx.as_type(:f32)
  
    total_tokens = Nx.sum(mask)
    min_tokens   = Nx.tensor(204.0, type: :f32)
    safe_denom   = Nx.max(total_tokens, min_tokens)
  
    masked_loss = -target_probs * mask
    Nx.sum(masked_loss) / safe_denom
  end

  defn adam_step(param, grad, m, v, step, lr) do
    beta1 = 0.9
    beta2 = 0.999
    eps = 1.0e-8
    
    new_m = beta1 * m + (1.0 - beta1) * grad
    new_v = beta2 * v + (1.0 - beta2) * Nx.pow(grad, 2)
    
    m_hat = new_m / (1.0 - Nx.pow(beta1, step + 1.0))
    v_hat = new_v / (1.0 - Nx.pow(beta2, step + 1.0))
    
    param_update = param - lr * m_hat / (Nx.sqrt(v_hat) + eps)
    {param_update, new_m, new_v}
  end

  defn compute_grad_and_step(params, ms, vs, batch, key, step, lr) do
    batch_s32 = Nx.as_type(batch, :s32)

    {loss, raw_grads} = value_and_grad(params, fn p ->
      # We use a noise scale of 0.15 during training to force robust manifolds
      {logits, _latents, _next_key} = DLM.LatentTokenizer.forward(batch_s32, p, key, 0.15)
      
      # The target is just the exact same batch! It's an Autoencoder.
      compute_loss(logits, batch_s32)
    end)

    # Note: You need to split the key here to return a new one for the next step, 
    # similar to how you did in V26.1
    keys_tensor = Nx.Random.split(key)
    next_key = keys_tensor[0]

    # Unpack
    {p1, p2, p3, p4} = params
    {g1, g2, g3, g4} = raw_grads
    {m1, m2, m3, m4} = ms
    {v1, v2, v3, v4} = vs

    # Adam Updates
    {u_p1, u_m1, u_v1} = adam_step(p1, g1, m1, v1, step, lr)
    {u_p2, u_m2, u_v2} = adam_step(p2, g2, m2, v2, step, lr)
    {u_p3, u_m3, u_v3} = adam_step(p3, g3, m3, v3, step, lr)
    {u_p4, u_m4, u_v4} = adam_step(p4, g4, m4, v4, step, lr)

    new_p = {u_p1, u_p2, u_p3, u_p4}
    new_m = {u_m1, u_m2, u_m3, u_m4}
    new_v = {u_v1, u_v2, u_v3, u_v4}

    {loss, new_p, new_m, new_v, next_key}
  end
end
```

