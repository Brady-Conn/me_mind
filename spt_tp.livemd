## Billiards

```elixir
defmodule DLM.Billiards do
  import Nx.Defn

  # 1. Check if the Predictor hallucinated
  defn check_intersection(predicted_coord, all_vocab_coords, threshold_radius \\ 3.5) do
    # Broadcast predicted coordinate to match vocab shape
    # predicted_coord: {512}, all_vocab_coords: {128, 512}
    
    # Calculate the squared distance to every character in the vocabulary simultaneously
    diff = Nx.subtract(all_vocab_coords, predicted_coord)
    distances = Nx.sqrt(Nx.sum(Nx.pow(diff, 2), axes: [-1]))
    
    # Find the closest character
    min_distance = Nx.reduce_min(distances)
    closest_char_index = Nx.argmin(distances)
    
    # Did it land inside the sphere?
    is_valid = Nx.less_equal(min_distance, threshold_radius)
    
    {is_valid, closest_char_index, min_distance}
  end
end
```

