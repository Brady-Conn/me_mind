    {_, len} = Nx.shape(acc)
    # Use the current weights from the loop (ce, ca1, etc.)
    x = Nx.add(Nx.take(ce, acc), DLM.Positional.build(len, 256))
    x = DLM.Transformer.block(x, ca1, cf1, ca2, cf2, DLM.Mask.causal(len))
    
    # Get the last character's logits
    logits = Nx.add(Nx.dot(x[0][-1], clmw), clmb)
    
    # Simple Greedy Search (pick the absolute best guess)
    next_id = logits |> Nx.argmax() |> Nx.reshape({1, 1})
    Nx.concatenate([acc, next_id], axis: 1)
  end)

  IO.puts("✨ Live Sample: #{sample |> Nx.to_flat_list() |> List.to_string()}")
end
