## Dict Check

```elixir
targets = ["Elixir", "Leather", "Aardvark", "Computer", "Mithril", "Zephyr", "Quartz", "Ascend"]
path = "v12_structured_map.txt"

# Loading the file
content = File.read!(path)

IO.puts("🔍 SCANNIG FOR VITAL ANCHORS...\n")

results = Enum.map(targets, fn word ->
  # Searching for the exact [W]Word[T] pattern to ensure it's a headword
  found = String.contains?(content, "[W]#{word}[T]")
  {word, found}
end)

Enum.each(results, fn {word, found} ->
  status = if found, do: "✅ FOUND ", else: "❌ MISSING"
  IO.puts("#{status}: #{word}")
end)

# Count total unique words for context
total_entries = content |> String.split("[W]") |> length() |> Kernel.-(1)
IO.puts("\n📊 Total Headwords in Map: #{total_entries}")
```

