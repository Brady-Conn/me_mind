## Burn

```elixir
# --- V12 PHASE 1: RESUMABLE SPELLING BURN ---
path = "v12_structured_map.txt"
checkpoint = "v12_phase1_spelling.bin"
seq_len = 128
batch_size = 16
lr = 0.001 # Slightly lower for stability in structured data
epochs = 3

pos_emb = DLM.Positional.build(seq_len, 256)
mask = DLM.Mask.causal(seq_len)

# 1. Initialization or Resume
{weights, global_step} = if File.exists?(checkpoint) do
  IO.puts("♻️ Existing brain found. Resuming from checkpoint...")
  {File.read!(checkpoint) |> :erlang.binary_to_term(), 0}
else
  IO.puts("✨ No checkpoint found. Initializing fresh student weights...")
  key = Nx.Random.key(System.system_time(:millisecond))
  init_fn = fn shape, k -> 
    {w, nk} = Nx.Random.normal(k, 0.0, 1.0, shape: shape)
    {Nx.divide(w, Nx.sqrt(elem(shape, 0))), nk}
  end
  {e, k} = init_fn.({128, 256}, key)
  {a1, k} = init_fn.({256}, k)
  {f1, k} = init_fn.({256, 512}, k)
  {f2, k} = init_fn.({512, 256}, k)
  {a2, k} = init_fn.({256}, k)
  {lmw, k} = init_fn.({256, 128}, k)
  {lmb, _} = init_fn.({128}, k)
  {%{e: e, a1: a1, f1: f1, a2: a2, f2: f2, lmw: lmw, lmb: lmb}, 0}
end

IO.puts("📖 Starting Curriculum Phase 1: Spelling & Type...")

# Extract weights from map for the loop
initial_state = {weights.e, weights.a1, weights.f1, weights.a2, weights.f2, weights.lmw, weights.lmb, global_step}

final_state = Enum.reduce(1..epochs, initial_state, fn epoch, acc_state ->
  IO.puts("\n🔥 SPELLING EPOCH #{epoch}/#{epochs}")
  
  V12.DataStreamer.stream_phase1(path, seq_len, batch_size)
  |> Enum.reduce(acc_state, fn {ins, tgs}, {ce, ca1, cf1, ca2, cf2, clmw, clmb, step} ->
    {ne, na1, nf1, na2, nf2, nlmw, nlmb, loss} = 
      DLM.Optimizer.multi_step(ins, tgs, ce, ca1, cf1, ca2, cf2, clmw, clmb, pos_emb, mask, lr)
    
    if rem(step, 200) == 0 do
      curr_loss = Float.round(Nx.to_number(loss), 4)
      mem = round(:erlang.memory(:total) / 1_048_576)
      IO.puts("Step #{step} | Loss: #{curr_loss} | RAM: #{mem}MB")
    end

    {Nx.backend_copy(ne, Nx.BinaryBackend), Nx.backend_copy(na1, Nx.BinaryBackend), 
     Nx.backend_copy(nf1, Nx.BinaryBackend), Nx.backend_copy(na2, Nx.BinaryBackend), 
     Nx.backend_copy(nf2, Nx.BinaryBackend), Nx.backend_copy(nlmw, Nx.BinaryBackend), 
     Nx.backend_copy(nlmb, Nx.BinaryBackend), step + 1}
  end)
end)

# 2. Final Save
{fe, fa1, ff1, fa2, ff2, flmw, flmb, _} = final_state
final_map = %{e: fe, a1: fa1, f1: ff1, a2: fa2, f2: ff2, lmw: flmw, lmb: flmb}
File.write!(checkpoint, :erlang.term_to_binary(final_map))
IO.puts("\n✅ Phase 1 Complete. Spelling Brain saved.")
```

```elixir
# --- V12.1: DEEP SPELLING BURN ---
path = "v12_structured_map.txt"
checkpoint = "v12_phase1_spelling.bin"

# UPGRADED SETTINGS
seq_len = 256      # Double the context for better word-memory
batch_size = 12    # Slightly lower to fit the larger seq_len in VRAM
lr = 0.0008        # Slower, more precise learning
epochs = 10        # Give it time to actually "read" the dictionary

# 1. Strict Whitelist Muzzle (Space, A-Z, a-z, digits, symbols, [W][T][D])
allowed = ' abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789.,:;-\'\"()[]'
muzzle = Nx.broadcast(Nx.tensor(-1.0e10), {128})
muzzle = Enum.reduce(allowed, muzzle, fn char, acc ->
  Nx.indexed_put(acc, Nx.tensor([[char]]), Nx.tensor([0.0]))
end)

# Load existing weights to build on progress
weights = File.read!(checkpoint) |> :erlang.binary_to_term()
pos_emb = DLM.Positional.build(seq_len, 256)
mask = DLM.Mask.causal(seq_len)

IO.puts("📖 Starting Phase 1.1: Deep Phonetic Hardening...")

initial_state = {weights.e, weights.a1, weights.f1, weights.a2, weights.f2, weights.lmw, weights.lmb, 0}

final_state = Enum.reduce(1..epochs, initial_state, fn epoch, acc_state ->
  IO.puts("\n🔥 DEEP BURN EPOCH #{epoch}/#{epochs}")
  
  V12.DataStreamer.stream_phase1(path, seq_len, batch_size)
  |> Enum.reduce(acc_state, fn {ins, tgs}, {ce, ca1, cf1, ca2, cf2, clmw, clmb, step} ->
    
    # We add the MUZZLE to the logits inside the optimizer to kill non-English bytes
    {ne, na1, nf1, na2, nf2, nlmw, nlmb, loss} = 
      DLM.Optimizer.multi_step_with_muzzle(ins, tgs, ce, ca1, cf1, ca2, cf2, clmw, clmb, pos_emb, mask, lr, muzzle)
    
    if rem(step, 250) == 0 do
      IO.puts("Step #{step} | Loss: #{Float.round(Nx.to_number(loss), 4)} | RAM: #{round(:erlang.memory(:total)/1.0e6)}MB")
    end

    {Nx.backend_copy(ne, Nx.BinaryBackend), Nx.backend_copy(na1, Nx.BinaryBackend), 
     Nx.backend_copy(nf1, Nx.BinaryBackend), Nx.backend_copy(na2, Nx.BinaryBackend), 
     Nx.backend_copy(nf2, Nx.BinaryBackend), Nx.backend_copy(nlmw, Nx.BinaryBackend), 
     Nx.backend_copy(nlmb, Nx.BinaryBackend), step + 1}
  end)
end)
