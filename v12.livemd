## Data pipeline

```elixir
# --- V12 DATA JANITOR & MAPPER ---
defmodule V12.DataPrep do
  @input_url "https://raw.githubusercontent.com/matthewreagan/WebstersEnglishDictionary/master/dictionary.csv"
  @output_path "v12_structured_map.txt"

  def run do
    IO.puts("📥 Downloading raw dictionary...")
    # Using Req or HTTPoison if available, or assume file exists
    # For now, let's process the existing local file
    
    File.stream!("english_dictionary.csv")
    |> Stream.drop(1) # Skip header: word,pos,definition
    |> Stream.map(fn line ->
      # Robust CSV parsing for the specific structure: "Word","POS","Definition"
      case String.split(line, ",", parts: 3) do
        [word, pos, definition] ->
          word = clean(word)
          pos = if clean(pos) == "", do: "none", else: clean(pos)
          definition = clean(definition)
          
          # Our new structured template
          "[W]#{word}[T]#{pos}[D]#{definition}\n"
        _ -> nil
      end
    end)
    |> Stream.reject(&is_nil/1)
    |> Stream.into(File.stream!(@output_path))
    |> Stream.run()

    IO.puts("✨ V12 Structured Map saved to: #{@output_path}")
  end

  defp clean(text) do
    text
    |> String.replace("\"", "") # Remove CSV quotes
    |> String.replace(~r/[^a-zA-Z0-9\s\.\,\:\;\-\'\"\( \)]/, "") # Remove Byte 253 and friends
    |> String.replace(~r/\s+/, " ") # Collapse whitespace
    |> String.trim()
  end
end

V12.DataPrep.run()
```

```elixir
# --- V12 MAP VALIDATOR ---
path = "v12_structured_map.txt"

if File.exists?(path) do
  IO.puts("✅ File found. Checking entries for token alignment...")

  File.stream!(path)
  |> Stream.take(20)
  |> Enum.each(fn line ->
    has_w = String.contains?(line, "[W]")
    has_t = String.contains?(line, "[T]")
    has_d = String.contains?(line, "[D]")

    if has_w and has_t and has_d do
      IO.puts("✔️ Valid entry: #{String.slice(line, 0, 60)}...")
    else
      IO.puts("❌ FORMAT ERROR in line: #{String.slice(line, 0, 40)}...")
    end
  end)
else
  IO.puts("⚠️ Map file not found. Please run the Data Janitor script first.")
end
