## Stream

```elixir
defmodule V12.DataStreamer do
  
  # --- PHASE 1: SPELLING (Shuffled) ---
  def stream_phase1(path, seq_len, batch_size) do
    # 1. Load entire file into RAM and split into a list of lines
    File.read!(path)
    |> String.split("\n", trim: true)
    # 2. SHUFFLE: Randomize the dictionary order for this epoch!
    |> Enum.shuffle()
    |> Stream.map(fn line ->
      case Regex.run(~r/(\[W\].*?\[T\].*?)\[D\]/, line) do
        [_, word_part] -> word_part <> " "
        _ -> ""
      end
    end)
    |> Stream.chunk_every(10)
    |> Stream.map(&Enum.join/1)
    |> Stream.flat_map(&String.to_charlist/1)
    |> Stream.chunk_every(seq_len + 1, seq_len, :discard)
    |> Stream.map(fn chunk ->
      {
        Nx.tensor(Enum.slice(chunk, 0..seq_len-1)) |> Nx.reshape({1, :auto}),
        Nx.tensor(Enum.slice(chunk, 1..seq_len)) |> Nx.reshape({1, :auto})
      }
    end)
    |> Stream.chunk_every(batch_size, batch_size, :discard)
    |> Stream.map(fn batch ->
      {ins, tgs} = Enum.unzip(batch)
      {Nx.concatenate(ins), Nx.concatenate(tgs)}
    end)
  end

  # --- PHASE 2: THE BRIDGE (Shuffled) ---
  def stream_phase2(path, seq_len, batch_size) do
    File.read!(path)
    |> String.split("\n", trim: true)
    |> Enum.shuffle()
    |> Stream.map(fn line ->
      case Regex.run(~r/(\[W\].*?\[T\].*?\[D\].{1,30})/, line) do
        [_, bridge_part] -> bridge_part <> " "
        _ -> ""
      end
    end)
    |> Stream.chunk_every(10)
    |> Stream.map(&Enum.join/1)
    |> Stream.flat_map(&String.to_charlist/1)
    |> Stream.chunk_every(seq_len + 1, seq_len, :discard)
    |> Stream.map(fn chunk ->
      {
        Nx.tensor(Enum.slice(chunk, 0..seq_len-1)) |> Nx.reshape({1, :auto}),
        Nx.tensor(Enum.slice(chunk, 1..seq_len)) |> Nx.reshape({1, :auto})
      }
    end)
    |> Stream.chunk_every(batch_size, batch_size, :discard)
    |> Stream.map(fn batch ->
      {ins, tgs} = Enum.unzip(batch)
      {Nx.concatenate(ins), Nx.concatenate(tgs)}
    end)
  end
end
