## Progress Checker

```elixir
# --- THE BACKEND CHECK ---
Nx.default_backend()
```

```elixir
# --- V12 PHASE 1: STANDALONE DE-LOOPING EVALUATOR ---
checkpoint = "v12_phase1_spelling.bin"

if File.exists?(checkpoint) do
  IO.puts("🧠 Loading Spelling Brain...")
  weights = File.read!(checkpoint) |> :erlang.binary_to_term()
  {ce, ca1, cf1, ca2, cf2, clmw, clmb} = 
    {weights.e, weights.a1, weights.f1, weights.a2, weights.f2, weights.lmw, weights.lmb}

  # --- SETTINGS TO BREAK THE BRACKET LOOP ---
  temp = 1.2            # Lowered slightly for better word cohesion
  rep_penalty = 3.0     # Punish repeating brackets/letters
  
  seeds = ["[W]ELIX", "[W]AARDV", "[W]COMPU", "[W]Z"]

  Enum.each(seeds, fn seed_text ->
    curr_ids = seed_text |> to_charlist() |> Nx.tensor() |> Nx.reshape({1, :auto})
    
    sample = Enum.reduce(1..40, curr_ids, fn _, acc ->
      {_, len} = Nx.shape(acc)
      
      # 1. Forward Pass
      x = Nx.add(Nx.take(ce, acc), DLM.Positional.build(len, 256))
      x = DLM.Transformer.block(x, ca1, cf1, ca2, cf2, DLM.Mask.causal(len))
      logits = Nx.add(Nx.dot(x[0][-1], clmw), clmb)

      # 2. Apply Repetition Penalty
      history = Nx.to_flat_list(acc)
      penalized_logits = Enum.reduce(history, logits, fn id, l_acc ->
        v = Nx.to_number(l_acc[id])
        # Crush the probability of characters we've already used recently
        new_v = if v > 0, do: v / rep_penalty, else: v * rep_penalty
        Nx.indexed_put(l_acc, Nx.tensor([[id]]), Nx.tensor([new_v]))
      end)

      # 3. Manual Softmax (Corrected for Nx 0.11.0)
      logits_scaled = Nx.divide(penalized_logits, temp)
      max_l = Nx.reduce_max(logits_scaled, axes: [-1], keep_axes: true)
      exps = Nx.exp(Nx.subtract(logits_scaled, max_l))
      probs = Nx.divide(exps, Nx.sum(exps, axes: [-1], keep_axes: true))

      # 4. Stochastic Sampling
      {next_id, _} = Nx.Random.choice(Nx.Random.key(System.system_time(:microsecond)), Nx.iota({128}), probs)
      Nx.concatenate([acc, Nx.reshape(next_id, {1, 1})], axis: 1)
    end)
  
    IO.puts("Result: #{sample |> Nx.to_flat_list() |> List.to_string()}")
  end)
else
  IO.puts("⚠️ Checkpoint not found.")
end
```

