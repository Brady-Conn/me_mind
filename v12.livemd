## Burn 1.1

```elixir
# --- V12.2: ADAM-POWERED SPELLING BURN ---
path = "v12_structured_map.txt"
checkpoint = "v12_phase1_spelling.bin"

seq_len = 256      
batch_size = 12    
# --- V12.2.1: THE DEEP BAKE (Fine-Grit Polishing) ---
lr = 0.0004   # Slower, more precise updates
epochs = 20    # Deepening the memory

allowed_chars = ~c" abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789.,:;-'\"()[]"
muzzle = Nx.broadcast(Nx.tensor(-1.0e10, type: :f32), {128})
muzzle = Enum.reduce(allowed_chars, muzzle, fn char, acc ->
  Nx.indexed_put(acc, Nx.tensor([[char]]), Nx.tensor([0.0]))
end)

pos_emb = DLM.Positional.build(seq_len, 256)
mask = DLM.Mask.causal(seq_len)

IO.puts("🧠 Loading existing brain for Adam Acceleration...")
weights = File.read!(checkpoint) |> :erlang.binary_to_term()
e = weights.e; a1 = weights.a1; f1 = weights.f1
a2 = weights.a2; f2 = weights.f2; lmw = weights.lmw; lmb = weights.lmb

params = {e, a1, f1, a2, f2, lmw, lmb}

# Initialize Adam States to Zero
zero_like = fn tensor -> Nx.broadcast(Nx.tensor(0.0), Nx.shape(tensor)) end
m_state = {zero_like.(e), zero_like.(a1), zero_like.(f1), zero_like.(a2), zero_like.(f2), zero_like.(lmw), zero_like.(lmb)}
v_state = m_state

IO.puts("🚀 Launching Phase 1.1: Adam-Powered Phonetic Hardening")

final_deep_state = Enum.reduce(1..epochs, {params, m_state, v_state, 1}, fn epoch, acc_state ->
  IO.puts("\n🔥 ADAM BURN EPOCH #{epoch}/#{epochs}")
  
  V12.DataStreamer.stream_phase1(path, seq_len, batch_size)
  |> Enum.reduce(acc_state, fn {ins, tgs}, {p_acc, m_acc, v_acc, step} ->
    
    # Run the Muzzled Adam Step
    {new_p, new_m, new_v, loss} = 
      DLM.Optimizer.adam_step_with_muzzle(ins, tgs, p_acc, m_acc, v_acc, pos_emb, mask, lr, step, muzzle)
    
    if rem(step, 250) == 0 do
      curr_loss = Float.round(Nx.to_number(loss), 4)
      mem = round(:erlang.memory(:total) / 1_048_576)
      IO.puts("Step #{step} | Loss: #{curr_loss} | RAM: #{mem}MB")

      # Live In-Loop Sampler (Sliced correctly!)
      {ce, ca1, cf1, ca2, cf2, clmw, clmb} = new_p
      seed_text = "[W]Elix"
      curr_ids = seed_text |> to_charlist() |> Nx.tensor() |> Nx.reshape({1, :auto})
      
      sample = Enum.reduce(1..15, curr_ids, fn _, acc ->
        {_, len} = Nx.shape(acc)
        curr_pos = Nx.slice(pos_emb, [0, 0], [len, 256])
        x = Nx.add(Nx.take(ce, acc), curr_pos)
        x = DLM.Transformer.block(x, ca1, cf1, ca2, cf2, DLM.Mask.causal(len))
        logits = Nx.add(Nx.dot(x[0][-1], clmw), clmb)
        masked_logits = Nx.add(logits, muzzle) 
        next_id = masked_logits |> Nx.argmax() |> Nx.reshape({1, 1})
        Nx.concatenate([acc, next_id], axis: 1)
      end)
      IO.puts("   -> Live Guess: #{sample |> Nx.to_flat_list() |> List.to_string()}")
    end

    # Binary Handoff for EXLA Memory Management
    {te, ta1, tf1, ta2, tf2, tlmw, tlmb} = new_p
    safe_p = {Nx.backend_copy(te, Nx.BinaryBackend), Nx.backend_copy(ta1, Nx.BinaryBackend), Nx.backend_copy(tf1, Nx.BinaryBackend), Nx.backend_copy(ta2, Nx.BinaryBackend), Nx.backend_copy(tf2, Nx.BinaryBackend), Nx.backend_copy(tlmw, Nx.BinaryBackend), Nx.backend_copy(tlmb, Nx.BinaryBackend)}
    
    {tme, tma1, tmf1, tma2, tmf2, tmlmw, tmlmb} = new_m
    safe_m = {Nx.backend_copy(tme, Nx.BinaryBackend), Nx.backend_copy(tma1, Nx.BinaryBackend), Nx.backend_copy(tmf1, Nx.BinaryBackend), Nx.backend_copy(tma2, Nx.BinaryBackend), Nx.backend_copy(tmf2, Nx.BinaryBackend), Nx.backend_copy(tmlmw, Nx.BinaryBackend), Nx.backend_copy(tmlmb, Nx.BinaryBackend)}
    
    {tve, tva1, tvf1, tva2, tvf2, tvlmw, tvlmb} = new_v
    safe_v = {Nx.backend_copy(tve, Nx.BinaryBackend), Nx.backend_copy(tva1, Nx.BinaryBackend), Nx.backend_copy(tvf1, Nx.BinaryBackend), Nx.backend_copy(tva2, Nx.BinaryBackend), Nx.backend_copy(tvf2, Nx.BinaryBackend), Nx.backend_copy(tvlmw, Nx.BinaryBackend), Nx.backend_copy(tvlmb, Nx.BinaryBackend)}

    {safe_p, safe_m, safe_v, step + 1}
  end)
end)

# FINAL SAVE
{final_p, _, _, _} = final_deep_state
{fe, fa1, ff1, fa2, ff2, flmw, flmb} = final_p
final_map = %{e: fe, a1: fa1, f1: ff1, a2: fa2, f2: ff2, lmw: flmw, lmb: flmb}
File.write!(checkpoint, :erlang.term_to_binary(final_map))
IO.puts("\n✅ Adam Hardening Complete. Spelling Brain saved.")
```

