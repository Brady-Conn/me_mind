## USSM, Positional, Muon_Optimizer

```elixir
defmodule DLM.UniversalSSM do
  import Nx.Defn

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  # ⚡ The Unbreakable Softplus
  defn softplus(x) do
    # ⚡ STABLE SOFTPLUS: Prevents Nx.exp() from blowing up to Infinity on huge activations
    Nx.select(x > 20.0, x, Nx.log1p(Nx.exp(x)))
  end
  
  defn silu(x), do: x * Nx.sigmoid(x)

  defn apply_svd_weight(x, u, v) do
    x |> Nx.dot(u) |> silu() |> Nx.dot(v)
  end

  defn ssm_recurrence(x_t, x_p1, x_p2, h_prev, a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2) do
    # unchanged — a is now passed in per-loop rather than shared
    x_mixed = x_t
      |> Nx.add(apply_svd_weight(x_p1, mu1, mv1))
      |> Nx.add(apply_svd_weight(x_p2, mu2, mv2))
    delta_proj = apply_svd_weight(x_mixed, du, dv)
    delta      = softplus(delta_proj)
    a_bar      = Nx.sigmoid(Nx.multiply(delta, a))
    b_proj     = apply_svd_weight(x_mixed, bu, bv)
    b_bar      = Nx.multiply(delta, b_proj)
    h_t        = Nx.tanh(Nx.add(Nx.multiply(a_bar, h_prev), b_bar))
    y_ssm      = apply_svd_weight(h_t, cu, cv)
    y_t        = Nx.add(y_ssm, x_mixed)
    {y_t, h_t}
  end

  defn run_ssm_loop(x_seq_first, h_init, a_diag, params) do
    {_emb, _a1, _a2, b_u, b_v, c_u, c_v, delta_u, delta_v,
     mx_u1, mx_v1, mx_u2, mx_v2, _lm_w, _lm_b} = params

    {seq_len, batch_size, embed_dim} = Nx.shape(x_seq_first)
    y_init    = Nx.broadcast(Nx.tensor(0.0, type: :f32), {seq_len, batch_size, embed_dim})
    zero_frame = Nx.broadcast(Nx.tensor(0.0, type: :f32), {batch_size, embed_dim})


    result_tuple =
      while {i = 0, y_acc = y_init, h_p = h_init,
             x_prev1 = zero_frame,
             x_prev2 = zero_frame,
             xs = x_seq_first,
             a = a_diag, bu = b_u, bv = b_v, cu = c_u, cv = c_v, # ⚡ Use safe_a here!
             du = delta_u, dv = delta_v,
             mu1 = mx_u1, mv1 = mx_v1, mu2 = mx_u2, mv2 = mx_v2},
            Nx.less(i, seq_len) do

        x_t = xs[i]
        {y_t, h_new} = ssm_recurrence(
          x_t, x_prev1, x_prev2, h_p,
          a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2
        )
        y_acc_new = Nx.put_slice(y_acc, [i, 0, 0], Nx.new_axis(y_t, 0))
        {i + 1, y_acc_new, h_new, x_t, x_prev1,
         xs, a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2}
      end

    elem(result_tuple, 1)
  end

  defn forward(indices, params, pos_emb) do
    {embed, a_diag1, a_diag2, _bu, _bv, _cu, _cv, _du, _dv,
     _mu1, _mv1, _mu2, _mv2, lm_w, lm_b} = params

    x_input = Nx.take(embed, indices) + pos_emb
    x_norm  = rms_norm(x_input)

    {batch_size, _seq_len, embed_dim} = Nx.shape(x_norm)
    h_init = Nx.broadcast(Nx.tensor(0.0, type: :f32), {batch_size, embed_dim})
    x_seq_first = Nx.transpose(x_norm, axes: [1, 0, 2])

    # Each loop now gets its own independent a_diag
    y1_seq = run_ssm_loop(x_seq_first, h_init, a_diag1, params)
    y2_seq = run_ssm_loop(y1_seq,      h_init, a_diag2, params)

    y_out   = Nx.transpose(y2_seq, axes: [1, 0, 2])
    y_final = rms_norm(y_out)
    Nx.dot(y_final, lm_w) + lm_b
  end
end
