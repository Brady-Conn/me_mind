## Train

```elixir
defmodule DLM.V21_10Trainer do
  import Nx.Defn

  def grad_norms(grads) do
  names = ~w[embed a_diag1 a_diag2 b_u b_v c_u c_v d_u d_v mx_u1 mx_v1 mx_u2 mx_v2 lm_w lm_b]
    grads
    |> Tuple.to_list()
    |> Enum.zip(names)
    |> Enum.map(fn {g, name} ->
      norm = g |> Nx.pow(2) |> Nx.sum() |> Nx.sqrt() |> Nx.to_number()
      {name, Float.round(norm, 4)}
    end)
  end

  defn log_softmax(logits) do
    max_logits = Nx.reduce_max(logits, axes: [-1], keep_axes: true)
    safe_logits = logits - max_logits
    sum_exp = Nx.sum(Nx.exp(safe_logits), axes: [-1], keep_axes: true)
    safe_logits - Nx.log(sum_exp)
  end

  defn compute_loss(preds_sliced, targets) do
    log_probs = log_softmax(preds_sliced)
    target_probs = Nx.take_along_axis(log_probs, Nx.new_axis(targets, -1), axis: -1)
    target_probs = Nx.squeeze(target_probs, axes: [-1])
    mask = Nx.not_equal(targets, 0) |> Nx.as_type(:f32)
  
    # Guard against near-empty batches — require at least 10% real content
    total_tokens = Nx.sum(mask)
    min_tokens   = Nx.tensor(408.0, type: :f32)  # 10% of batch
    safe_denom   = Nx.max(total_tokens, min_tokens)
  
    masked_loss = -target_probs * mask
    Nx.sum(masked_loss) / safe_denom
  end

  # ⚡ THE FIREWALL: Only zeroes out NaNs/Infinities. Leaves clipping to the global norm.
  defn sanitize_tensor(g) do
    bad_mask = Nx.logical_or(Nx.is_nan(g), Nx.is_infinity(g))
    Nx.select(bad_mask, 0.0, g)
  end
  
  # ⚡ Explicitly unpack and sanitize V21.10's 15 parameters
  defn clip_grads(grads) do
    {g_emb, g_a1, g_a2, g_bu, g_bv, g_cu, g_cv, g_du, g_dv, g_mu1, g_mv1, g_mu2, g_mv2, g_lmw, g_lmb} = grads
    {
      sanitize_tensor(g_emb),
      sanitize_tensor(g_a1),
      sanitize_tensor(g_a2),
      sanitize_tensor(g_bu),
      sanitize_tensor(g_bv),
      sanitize_tensor(g_cu),
      sanitize_tensor(g_cv),
      sanitize_tensor(g_du),
      sanitize_tensor(g_dv),
      sanitize_tensor(g_mu1),
      sanitize_tensor(g_mv1),
      sanitize_tensor(g_mu2),
      sanitize_tensor(g_mv2),
      sanitize_tensor(g_lmw),
      sanitize_tensor(g_lmb)
    }
  end

  defn compute_grad(params, pos_emb, batch) do
    {loss, raw_grads} = value_and_grad(params, fn p ->
      batch_s32 = Nx.as_type(batch, :s32)
      preds = DLM.UniversalSSM.forward(batch_s32, p, pos_emb)
      preds_sliced = Nx.slice_along_axis(preds, 0, 255, axis: 1)
      targets = Nx.slice_along_axis(batch_s32, 1, 255, axis: 1)
      compute_loss(preds_sliced, targets)
    end)

    {rg0, rg1, rg2, rg3, rg4, rg5, rg6, rg7, rg8, rg9, rg10, rg11, rg12, rg13, rg14} = raw_grads

    # ⚡ 1. Pass everything through the firewall FIRST
    g0 = sanitize_tensor(rg0)
    g1 = sanitize_tensor(rg1)
    g2 = sanitize_tensor(rg2)
    g3 = sanitize_tensor(rg3)
    g4 = sanitize_tensor(rg4)
    g5 = sanitize_tensor(rg5)
    g6 = sanitize_tensor(rg6)
    g7 = sanitize_tensor(rg7)
    g8 = sanitize_tensor(rg8)
    g9 = sanitize_tensor(rg9)
    g10 = sanitize_tensor(rg10)
    g11 = sanitize_tensor(rg11)
    g12 = sanitize_tensor(rg12)
    g13 = sanitize_tensor(rg13)
    g14 = sanitize_tensor(rg14)

    # ⚡ 2. Calculate Global Norm on the 100% clean gradients
    global_norm =
      Nx.sum(Nx.pow(g0, 2))
      |> Nx.add(Nx.sum(Nx.pow(g1, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g2, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g3, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g4, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g5, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g6, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g7, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g8, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g9, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g10, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g11, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g12, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g13, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g14, 2)))
      |> Nx.sqrt()

    max_norm = 0.33
    scale = Nx.min(1.0, max_norm / (global_norm + 1.0e-6))

    # ⚡ 3. Apply the scale
    clipped_grads = {
      g0  * scale, g1  * scale, g2  * scale,
      g3  * scale, g4  * scale, g5  * scale,
      g6  * scale, g7  * scale, g8  * scale,
      g9  * scale, g10 * scale, g11 * scale,
      g12 * scale, g13 * scale, g14 * scale
    }

    {loss, clipped_grads}
  end
end
```

<!-- livebook:{"output":true} -->

```
{:module, DLM.V21_10Trainer, <<70, 79, 82, 49, 0, 0, 44, ...>>, true}
```

```elixir
save_interval = 1000
gpu = {EXLA.Backend, client: :rocm}

IO.puts("🧠 Loading v21_10 Curriculum into CPU Memory...")
full_dataset = File.read!("scholar_full_mixed.bin") |> :erlang.binary_to_term()
dataset_size = Nx.axis_size(full_dataset, 0)
batch_size = 16

total_steps_per_epoch = div(dataset_size, batch_size)
max_epochs = 3
total_steps = total_steps_per_epoch * max_epochs

save_prefix = "v21_10_mixed"

latest_scholar =
  Path.wildcard("#{save_prefix}_*.bin")
  |> Enum.reject(&String.contains?(&1, "data.bin"))
  |> Enum.max_by(fn path -> File.stat!(path).mtime end, fn -> nil end)

{params, ms, vs, global_step, current_epoch, saved_key} =
  cond do
    latest_scholar != nil ->
      IO.puts("💾 Resuming from checkpoint: #{latest_scholar}")
      checkpoint = File.read!(latest_scholar) |> :erlang.binary_to_term()
      p = DLM.Tree.map(checkpoint.params, &Nx.backend_copy(&1, gpu))
      m = DLM.Tree.map(checkpoint.ms, &Nx.backend_copy(&1, gpu))
      v = DLM.Tree.map(checkpoint.vs, &Nx.backend_copy(&1, gpu))
      saved_key = Map.get(checkpoint, :shuffle_key, Nx.Random.key(42))
        |> Nx.backend_copy(gpu)
      {p, m, v, checkpoint.step, checkpoint.epoch, saved_key}

    true ->
      IO.puts("✨ No checkpoint found. Igniting FRESH Genesis state...")
      raw_p = DLM.V21_10Genesis.init_params(42)
      {raw_m, raw_v, _} = DLM.V21_10Genesis.init_optimizer(raw_p)
      p = raw_p |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple()
      m = raw_m |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple()
      v = raw_v |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple()
      saved_key = Nx.Random.key(42) |> Nx.backend_copy(gpu)
      {p, m, v, 0, 1, saved_key}
  end

base_lr = 3.0e-4
min_lr  = 1.0e-6
warmup_steps = 500

pos_emb = DLM.Positional.build(256, 256) |> Nx.backend_copy(gpu)
IO.puts("🚀 IGNITION: Starting V21.10 at Epoch #{current_epoch}, Global Step #{global_step}...")

Enum.reduce(current_epoch..max_epochs, {params, ms, vs, global_step, saved_key},
  fn epoch, {p, m, v, current_step, shuffle_key} ->
  IO.puts(String.duplicate("=", 50))
  IO.puts("🌊 EPOCH #{epoch} / #{max_epochs}")
  IO.puts("🔀 Shuffling dataset...")

  {shuffled_raw, next_shuffle_key} = Nx.Random.shuffle(shuffle_key, full_dataset, axis: 0)
  shuffled_dataset = Nx.backend_copy(shuffled_raw, Nx.BinaryBackend)

  start_offset = 
    if epoch == current_epoch do
      rem(current_step, total_steps_per_epoch) * batch_size
    else
      0
    end

  epoch_batches = Stream.unfold(start_offset, fn offset ->
    if offset + batch_size > dataset_size do
      nil
    else
      batch_2d = Nx.slice_along_axis(shuffled_dataset, offset, batch_size, axis: 0)
      {batch_2d, offset + batch_size}
    end
  end)

  {new_p, new_m, new_v, next_epoch_step, _final_skips} =
    epoch_batches
    |> Stream.with_index(1)
    |> Enum.reduce({p, m, v, current_step, 0}, fn {batch, step_in_epoch}, {cp, cm, cv, cs, s_count} ->
      gpu_batch = Nx.backend_copy(batch, gpu)

      {loss_tensor, grads} = DLM.V21_10Trainer.compute_grad(cp, pos_emb, gpu_batch)
      loss_val = Nx.to_number(loss_tensor)

      if loss_val == :nan or loss_val > 4.0 do
        cpu_batch = Nx.backend_copy(gpu_batch, Nx.BinaryBackend)
        sequences = Nx.to_list(cpu_batch)
        IO.puts("🔥 PATHOLOGICAL BATCH at global step #{cs}:")
        Enum.each(sequences, fn seq ->
          readable = seq |> Enum.reject(&(&1 == 0)) |> List.to_string()
          IO.puts("   > #{readable}")
        end)
      end

      if loss_val == :nan or loss_val > 4.0 do
        if rem(step_in_epoch, 10) == 0,
          do: IO.puts("⚠️ Step #{cs}: NaN/Spike detected. Skipping batch.")
        {cp, cm, cv, cs + 1, s_count + 1}
      else
        # Calculate LR strictly using the Current Global Step (cs)
        current_lr = 
          if cs < warmup_steps do
            # Linear Warmup
            base_lr * (cs / warmup_steps)
          else
            # Cosine Decay
            progress = (cs - warmup_steps) / (total_steps - warmup_steps)
            clamped_progress = min(max(progress, 0.0), 1.0)
            min_lr + 0.5 * (base_lr - min_lr) * (1.0 + :math.cos(:math.pi() * clamped_progress))
          end

          lr_tensor = Nx.tensor(current_lr, type: :f32) |> Nx.backend_copy(gpu)
          step_tensor = Nx.tensor(cs, type: :f32) |> Nx.backend_copy(gpu)
  
          {up_p, up_m, up_v} = DLM.MuonHybrid.step(cp, grads, cm, cv, step_tensor, lr_tensor)
  
          {p_emb, p_a1, p_a2, p_bu, p_bv, p_cu, p_cv, p_du, p_dv,
           p_mu1, p_mv1, p_mu2, p_mv2, p_lmw, p_lmb} = up_p
  
          du_norm = p_du |> Nx.pow(2) |> Nx.sum() |> Nx.sqrt() |> Nx.to_number()
  
          up_p = if du_norm < 0.01 do
            IO.puts("   🔧 Rescuing dead delta gate (d_u norm=#{Float.round(du_norm, 5)})")
            rescaled_du = Nx.multiply(p_du, Nx.tensor(0.02 / max(du_norm, 1.0e-8)))
            rescaled_dv = Nx.multiply(p_dv, Nx.tensor(0.02 / max(du_norm, 1.0e-8)))
            {p_emb, p_a1, p_a2, p_bu, p_bv, p_cu, p_cv, rescaled_du, rescaled_dv,
             p_mu1, p_mv1, p_mu2, p_mv2, p_lmw, p_lmb}
          else
            up_p
        end

        if rem(step_in_epoch, 50) == 0 do
          bpc = loss_val / :math.log(2)
          mem = :erlang.memory(:total) |> div(1024 * 1024)
          cpu_grads = grads |> Tuple.to_list()
            |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple()
          norms = DLM.V21_10Trainer.grad_norms(cpu_grads)
          {max_name, max_norm} = Enum.max_by(norms, fn {_name, n} -> n end)
          norm_str = norms |> Enum.map(fn {k, v} -> "#{k}=#{v}" end) |> Enum.join(" | ")
          IO.puts("➡️  Step #{step_in_epoch} | Global: #{cs} | Loss: #{Float.round(loss_val, 4)} | BPC: #{Float.round(bpc, 3)} | LR: #{Float.round(current_lr, 6)} | RAM: #{mem}MB")
          IO.puts("   📐 GRAD NORMS | MAX: #{max_name}=#{max_norm}")
          IO.puts("   #{norm_str}")
        end

        if rem(cs, save_interval) == 0 and cs > 0 do
          IO.puts("💾 Auto-Saving Checkpoint to #{save_prefix}_step#{cs}.bin...")
          state = %{
            params: up_p |> Tuple.to_list()
              |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
            ms: up_m |> Tuple.to_list()
              |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
            vs: up_v |> Tuple.to_list()
              |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
            step: cs, epoch: epoch,
            shuffle_key: next_shuffle_key |> Nx.backend_copy(Nx.BinaryBackend)
          }
          File.write!("#{save_prefix}_step#{cs}.bin", :erlang.term_to_binary(state))
        end

        if rem(step_in_epoch, 100) == 0, do: :erlang.garbage_collect(self())

        {up_p, up_m, up_v, cs + 1, s_count}
      end
    end)

  IO.puts("💾 Saving Completed Epoch #{epoch} State...")
  final_state = %{
    params: new_p |> Tuple.to_list()
      |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
    ms: new_m |> Tuple.to_list()
      |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
    vs: new_v |> Tuple.to_list()
      |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
    step: next_epoch_step, epoch: epoch,
    shuffle_key: next_shuffle_key |> Nx.backend_copy(Nx.BinaryBackend)
  }
  File.write!("#{save_prefix}_epoch#{epoch}_COMPLETE.bin", :erlang.term_to_binary(final_state))

  {new_p, new_m, new_v, next_epoch_step, next_shuffle_key}
end)

IO.puts("🎉 THE OVERNIGHT BAKE IS COMPLETE!")
```

