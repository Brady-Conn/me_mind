defmodule DLM.Sampler do
  import Nx.Defn

  # ⚡ The Gumbel-Max Trick: Using Nx's native Gumbel generator
  defn sample(logits, temperature, key) do
    # 1. Scale the raw logits to control the "creativity"
    scaled_logits = logits / temperature
    
    # 2. Ask Nx to natively generate Gumbel noise in the exact shape of our logits
    {gumbel_noise, next_key} = Nx.Random.gumbel(key, shape: Nx.shape(logits))
    
    # 3. Add the noise and pick the max!
    sampled_index = Nx.argmax(scaled_logits + gumbel_noise, axis: -1)
    
    {sampled_index, next_key}
  end
end

checkpoint_path = "v21_10_mixed_epoch3_COMPLETE.bin" # Update to your latest!
IO.puts("🧠 Awakening V21.10 from #{checkpoint_path}...")

checkpoint = File.read!(checkpoint_path) |> :erlang.binary_to_term()
params = DLM.Tree.map(checkpoint.params, &Nx.backend_transfer(&1, gpu))
pos_emb = DLM.Positional.build(256, 256) |> Nx.backend_transfer(gpu)

prompt = "Do state space models dream of recursive sheep?"
IO.puts("\nPrompt: \"#{prompt}\"\n")
IO.write("V21.10:  ")

prompt_tokens = prompt |> String.to_charlist() |> Enum.map(fn c -> if c < 128, do: c, else: 63 end)

# Setup the Random Key for the categorical sampler
key = Nx.Random.key(42)

max_new_tokens = 150
temperature = 0.65 # ⚡ 0.65 is the sweet spot for early character models

{_final_key, _final_tokens} = 
  Enum.reduce(1..max_new_tokens, {key, prompt_tokens}, fn _step, {current_key, current_tokens} ->
    
    window_tokens = Enum.take(current_tokens, -255)
    current_len = length(window_tokens)
    
    pad_len = 256 - current_len
    padded_list = window_tokens ++ List.duplicate(0, pad_len)
    
    input_tensor = Nx.tensor([padded_list], type: :s32) |> Nx.backend_transfer(gpu)
    
    logits = DLM.UniversalSSM.forward(input_tensor, params, pos_emb)
    last_token_logits = logits[0][current_len - 1]
    
    # ⚡ Use the new sampler
    {next_token_tensor, next_key} = DLM.Sampler.sample(last_token_logits, temperature, current_key) 
    next_token = Nx.to_number(next_token_tensor)
    
    IO.write(<<next_token::utf8>>)
    
    {next_key, current_tokens ++ [next_token]}
  end)

IO.puts("\n\n🐑 Dream Complete.")

