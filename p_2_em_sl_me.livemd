## SSM

```elixir
defmodule DLM.SvdSSM do
  import Nx.Defn

  defn rms_norm(x, gamma, beta, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    norm = x * Nx.rsqrt(variance + epsilon)
    scaled = norm * gamma
    scaled + beta
  end

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn gelu(x) do
    cdf = Nx.multiply(
      Nx.tensor(0.7978845608, type: :f32),
      Nx.add(x, Nx.multiply(Nx.tensor(0.044715, type: :f32), Nx.pow(x, 3)))
    )
    Nx.multiply(Nx.multiply(Nx.tensor(0.5, type: :f32), x), Nx.add(Nx.tensor(1.0, type: :f32), Nx.tanh(cdf)))
  end
  
  defn feed_forward_layer(x, um, ga, bi, dm) do
    up = Nx.dot(x, um) 
    act = gelu(up) #was tanh
    scaled = Nx.multiply(act, ga)
    biased = Nx.add(scaled, bi)
    Nx.dot(biased, dm) 
  end

  defn softmax(t) do
    max_val = Nx.reduce_max(t, axes: [-1], keep_axes: true)
    safe_t = Nx.subtract(t, max_val)
    exps = Nx.exp(safe_t)
    sum_exps = Nx.sum(exps, axes: [-1], keep_axes: true)
    Nx.divide(exps, Nx.add(sum_exps, 1.0e-8))
  end

  defn apply_xsa(x, y) do
    y_norm_sq = Nx.add(Nx.sum(Nx.pow(y, 2), axes: [-1], keep_axes: true), 1.0e-6)
    y_unit = Nx.divide(y, Nx.sqrt(y_norm_sq))
    # exclusive space attention
    y_ov = Nx.sum(Nx.multiply(x, y_unit), axes: [-1], keep_axes: true)
    Nx.subtract(x, Nx.multiply(y_ov, y_unit))
  end

  defn apply_attention(q, v) do
    k = Nx.transpose(v, axes: [0, 2, 1])
    r = Nx.axis_size(v, 1)
    score = Nx.dot(q, [2], [0], k, [1], [0])
    scaled_score = Nx.divide(score, Nx.sqrt(r))
    soft_scaled = softmax(scaled_score)
    Nx.dot(soft_scaled, [2], [0], v, [1], [0]) |> Nx.squeeze(axes: [1])
  end

  defn forward_step(x_t, h_prev, spell_prev, mem_prev, p, fzn) do
    {b1, b2, bb, bq, bg, be, c1, c2, cb, cq, cg, ce, qu, qh, qr} = p
    # map incomming character
    u_t = Nx.take(fzn, x_t) |> Nx.dot(fzn) # {batch, 128}
    z_u = Nx.multiply(u_t, 0.0)
    # apply time scale to previous states
    sp_scaled = Nx.divide(spell_prev, Nx.Constants.pi())
    mp_scaled = Nx.divide(mem_prev, Nx.Constants.pi())
    hp_scaled = Nx.divide(h_prev, Nx.Constants.pi())
    # attend next char to scaled prev states
    u_q = Nx.dot(u_t, qu) |> Nx.new_axis(1)
    spu_ctx = apply_attention(u_q, sp_scaled)
    mpu_ctx = apply_attention(u_q, mp_scaled)
    # 4x 128 -> 512 build incomming character context matrix
    com_u_ctx = Nx.concatenate([u_t, spu_ctx, mpu_ctx, z_u], axis: 1)
    # 512 -> 128 process current character context
    b_term = feed_forward_layer(com_u_ctx, b1, bq, bb, b2)
    b_norm = rms_norm(b_term, bg, be)
    # update hidden state
    h_new = Nx.add(hp_scaled, b_norm)
    # update spelling
    sl_sps = Nx.slice_along_axis(sp_scaled, 0, 15, axis: 1)
    sp_new =Nx.concatenate([sl_sps, Nx.new_axis(u_t, 1)], axis: 1)
    # get h attention query
    h_q = Nx.dot(h_new, qh) |> Nx.new_axis(1)
    # determin is reset
    sig_val = Nx.dot(h_new, qr) |> Nx.sigmoid()
    is_reset_hard = Nx.greater(sig_val, 0.5)
    # Forward uses hard values, backward uses sigmoid gradient
    is_reset = Nx.add(sig_val, stop_grad(Nx.subtract(Nx.as_type(is_reset_hard, :f32), sig_val)))
    is_reset_3d = Nx.new_axis(is_reset, 1)  # [batch, 1, 128]
    
    sl_mps_nonreset = Nx.slice_along_axis(mp_scaled, 0, 63, axis: 1)
    sl_mps_reset    = Nx.slice_along_axis(mp_scaled, 1, 63, axis: 1)

    # blended mem update
    sl_mps = Nx.multiply(sl_mps_reset, is_reset_3d)
               |> Nx.add(Nx.multiply(sl_mps_nonreset, Nx.subtract(1.0, is_reset_3d)))
    
    mem_new = Nx.concatenate([sl_mps, Nx.new_axis(h_new, 1)], axis: 1)

    # get attention 2 electric bugaloo
    hs_at = apply_attention(h_q, sp_new)
    hm_at = apply_attention(h_q, mem_new)
    xss = apply_xsa(hs_at, u_t)
    xsm = apply_xsa(hm_at, u_t)

    # 4x 128 -> 512 build final context matrix for prediction
    h_com = Nx.concatenate([b_norm, xss, xsm, z_u], axis: 1)
    
    # 512 -> 128
    c_term = feed_forward_layer(h_com, c1, cq, cb, c2)
    c_norm = rms_norm(c_term, cg, ce)
    # 128 -> 128
    logits = Nx.dot(c_norm, fzn)

    {logits, h_new, sp_new, mem_new}
  end
end
```

