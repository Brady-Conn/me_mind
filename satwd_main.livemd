```elixir
defmodule DLM.PhysicsGenesis do
  import Nx.Defn

  @dim 1024
  @rank 256

  defn ignite(key) do

    # ⚡ UPGRADE 1: Xavier/Glorot Initialization for all SVD Bottlenecks
    std_dev1024 = Nx.divide(1.0, Nx.sqrt(1024))
    std_dev256 = Nx.divide(1.0, Nx.sqrt(256))
    
    # a_diag: Friction/Inertia (1D Vector, fan-in doesn't apply)
    {a, k1} = Nx.Random.normal(key, -0.1, 0.01, shape: {@dim})
    
    # b: Input Force Matrices
    {bu, k2} = Nx.Random.normal(k1, 0.0, std_dev1024, shape: {@dim, @rank}) # Fan-in: 1024
    {bv, k3} = Nx.Random.normal(k2, 0.0, std_dev256, shape: {@rank, @dim})  # Fan-in: 256
    
    # c: Output Velocity Matrices
    {cu, k4} = Nx.Random.normal(k3, 0.0, std_dev1024, shape: {@dim, @rank}) # Fan-in: 1024
    {cv, k5} = Nx.Random.normal(k4, 0.0, std_dev256, shape: {@rank, @dim})  # Fan-in: 256

    # d: Dynamic Gating Matrices
    {du, k6} = Nx.Random.normal(k5, 0.0, std_dev1024, shape: {@dim, @rank}) # Fan-in: 1024
    {dv, k7} = Nx.Random.normal(k6, 0.0, std_dev256, shape: {@rank, @dim})  # Fan-in: 256

    # Vocab Probes (Compressing 1024D Void to 256D Vocab)
    {vocab_w, k8} = Nx.Random.normal(k7, 0.0, std_dev1024, shape: {@dim, @rank}) # Fan-in: 1024
    {rw, next_key} = Nx.Random.normal(k8, 0.0, std_dev1024, shape: {@dim, @rank}) # Fan-in: 1024
    
    vocab_b = Nx.broadcast(0.0, {@rank}) |> Nx.as_type(:f32)
    rb = Nx.broadcast(0.0, {@rank}) |> Nx.as_type(:f32)

    # Initialize tau_w as a single scalar value
    tau_w = Nx.tensor(-2.25, type: :f32)
    

    {{a, bu, bv, cu, cv, du, dv, vocab_w, vocab_b, rb, rw, tau_w}, next_key}
  end

  def init_optimizer(params) do
    zero_state = DLM.Tree.map(params, fn p -> Nx.broadcast(0.0, Nx.shape(p)) end)
    {zero_state, zero_state, Nx.tensor(0)}
  end
end
