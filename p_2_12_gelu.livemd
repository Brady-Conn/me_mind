## Train

```elixir
defmodule DLM.Phase2Trainer do
  import Nx.Defn

  # ⚡ 1. Local un-meaned CE to prevent pre-diluting the loss
  defn step_cross_entropy(logits, targets) do
    vocab_size = Nx.axis_size(logits, -1)
    one_hot = Nx.equal(Nx.iota({vocab_size}), Nx.new_axis(targets, -1))
    
    max_logits = Nx.reduce_max(logits, axes: [-1], keep_axes: true)
    safe_logits = Nx.subtract(logits, max_logits)
    log_probs = Nx.subtract(safe_logits, Nx.log(Nx.sum(Nx.exp(safe_logits), axes: [-1], keep_axes: true)))
    
    # Returns a {batch_size} 1D tensor of individual sequence losses
    Nx.negate(Nx.sum(Nx.multiply(one_hot, log_probs), axes: [-1]))
  end

  defn compute_sequence_loss(input_tokens, target_tokens, params, embeds) do
    # hidden state init
    h_start = Nx.broadcast(0.0, {32, 512})
    
    input_coords =
      Nx.take(embeds, Nx.flatten(input_tokens))
      |> Nx.reshape({Nx.axis_size(input_tokens, 0), Nx.axis_size(input_tokens, 1), 512})
      |> stop_grad()
  
    inputs_time_first = Nx.transpose(input_coords, axes: [1, 0, 2])
    targets_fwd_time_first = Nx.transpose(target_tokens, axes: [1, 0])
    targets_retro_time_first = Nx.transpose(input_tokens, axes: [1, 0])
  
    # ⚡ 2. THE FIX: Explicitly initialize accumulator tensors
    zero_scalar = Nx.tensor(0.0, type: :f32)
  
    result =
      while {i = 0, 
             total_fwd = zero_scalar, 
             total_retro = zero_scalar, 
             valid_fwd = zero_scalar, 
             valid_retro = zero_scalar, 
             h = h_start, 
             inf = inputs_time_first, tf = targets_fwd_time_first, tr = targets_retro_time_first, p = params},
            Nx.less(i, Nx.axis_size(inf, 0)) do
        
        x_curr = inf[i]
        t_fwd = tf[i]
        t_retro = tr[i]
        
        {logits_fwd, logits_retro, h_new} = DLM.SinkhornSSM.forward_step(x_curr, h, p)
        
        # ⚡ Get raw losses per item in the batch (Shape: {32})
        l_fwd = step_cross_entropy(logits_fwd, t_fwd)
        l_retro = step_cross_entropy(logits_retro, t_retro)
        
        # ⚡ Generate the mask (Shape: {32})
        mask_fwd = Nx.not_equal(t_fwd, 1) |> Nx.as_type(:f32)
        mask_retro = Nx.not_equal(t_retro, 1) |> Nx.as_type(:f32)
        
        # ⚡ Mask the individual losses and sum across the batch to get a true scalar
        step_loss_fwd = Nx.sum(Nx.multiply(l_fwd, mask_fwd))
        step_loss_retro = Nx.sum(Nx.multiply(l_retro, mask_retro))
        
        # ⚡ Count the valid tokens in this timestep
        step_valid_fwd = Nx.sum(mask_fwd)
        step_valid_retro = Nx.sum(mask_retro)
        
        {i + 1, 
         Nx.add(total_fwd, step_loss_fwd), 
         Nx.add(total_retro, step_loss_retro), 
         Nx.add(valid_fwd, step_valid_fwd), 
         Nx.add(valid_retro, step_valid_retro), 
         h_new, inf, tf, tr, p}
      end
  
    {_, acc_fwd, acc_retro, val_fwd, val_retro, _final_h, _, _, _, _} = result
    
    # ⚡ Divide ONLY by the actual number of valid tokens 
    mean_fwd = Nx.divide(acc_fwd, Nx.add(val_fwd, 1.0e-8))
    mean_retro = Nx.divide(acc_retro, Nx.add(val_retro, 1.0e-8))
    
    total_loss = Nx.add(mean_fwd, Nx.multiply(0.3, mean_retro))
    
    {total_loss, {mean_fwd, mean_retro}}
  end

  defn compute_grad(params, batch_tokens, frozen_embeds) do
    {_batch_size, full_seq_len} = Nx.shape(batch_tokens)
    seq_len = full_seq_len - 1
    
    input_tokens  = Nx.slice_along_axis(batch_tokens, 0, seq_len, axis: 1)
    target_tokens = Nx.slice_along_axis(batch_tokens, 1, seq_len, axis: 1)

    # Your function returns: {total_loss, {fwd_loss, retro_loss}}
    # &elem(&1, 0) tells Nx to calculate gradients based strictly on the first element (total_loss)
    {{total_loss, {fwd_loss, retro_loss}}, raw_grads} = 
      value_and_grad(
        params, 
        fn p -> compute_sequence_loss(input_tokens, target_tokens, p, frozen_embeds) end, 
        &elem(&1, 0)
      )
  
    {total_loss, fwd_loss, retro_loss, raw_grads}
  end
end
