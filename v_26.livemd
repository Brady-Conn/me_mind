```
{:module, DLM.V26Trainer, <<70, 79, 82, 49, 0, 0, 45, ...>>, true}
```

```elixir
save_interval = 1000
gpu = {EXLA.Backend, client: :rocm}

IO.puts("🧠 Loading v23 Curriculum into CPU Memory...")
full_dataset = File.read!("scholar_full_mixed_128.bin") |> :erlang.binary_to_term()
dataset_size = Nx.axis_size(full_dataset, 0)
batch_size = 16

total_steps_per_epoch = div(dataset_size, batch_size)
max_epochs = 3
total_steps = total_steps_per_epoch * max_epochs

save_prefix = "v26_bitwise"

latest_scholar =
  Path.wildcard("#{save_prefix}_*.bin")
  |> Enum.reject(&String.contains?(&1, "data.bin"))
  |> Enum.max_by(fn path -> File.stat!(path).mtime end, fn -> nil end)

{params, ms, vs, global_step, current_epoch, saved_key} =
  cond do
    latest_scholar != nil ->
      IO.puts("💾 Resuming from checkpoint: #{latest_scholar}")
      checkpoint = File.read!(latest_scholar) |> :erlang.binary_to_term()
      p = DLM.Tree.map(checkpoint.params, &Nx.backend_copy(&1, gpu))
      m = DLM.Tree.map(checkpoint.ms, &Nx.backend_copy(&1, gpu))
      v = DLM.Tree.map(checkpoint.vs, &Nx.backend_copy(&1, gpu))
      saved_key = Map.get(checkpoint, :shuffle_key, Nx.Random.key(42))
        |> Nx.backend_copy(gpu)
      {p, m, v, checkpoint.step, checkpoint.epoch, saved_key}

    true ->
      IO.puts("✨ No checkpoint found. Igniting FRESH Genesis state...")
      raw_p = DLM.V26Genesis.init_params(42)
      {raw_m, raw_v, _} = DLM.V26Genesis.init_optimizer(raw_p)
      p = raw_p |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple()
      m = raw_m |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple()
      v = raw_v |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple()
      saved_key = Nx.Random.key(42) |> Nx.backend_copy(gpu)
      {p, m, v, 0, 1, saved_key}
  end

base_lr = 3.0e-4
min_lr  = 1.0e-6
warmup_steps = 500

pos_emb = DLM.Positional.build(128, 512) |> Nx.backend_copy(gpu)
IO.puts("🚀 IGNITION: Starting V26 at Epoch #{current_epoch}, Global Step #{global_step}...")

Enum.reduce(current_epoch..max_epochs, {params, ms, vs, global_step, saved_key},
  fn epoch, {p, m, v, current_step, shuffle_key} ->
  IO.puts(String.duplicate("=", 50))
  IO.puts("🌊 EPOCH #{epoch} / #{max_epochs}")
  IO.puts("🔀 Shuffling dataset...")

  {shuffled_raw, next_shuffle_key} = Nx.Random.shuffle(shuffle_key, full_dataset, axis: 0)
  shuffled_dataset = Nx.backend_copy(shuffled_raw, Nx.BinaryBackend)

  start_offset = 
    if epoch == current_epoch do
      rem(current_step, total_steps_per_epoch) * batch_size
    else
      0
    end

  epoch_batches = Stream.unfold(start_offset, fn offset ->
    if offset + batch_size > dataset_size do
      nil
    else
      batch_2d = Nx.slice_along_axis(shuffled_dataset, offset, batch_size, axis: 0)
      {batch_2d, offset + batch_size}
    end
  end)

  initial_key = Nx.Random.key(System.system_time(:second))

  {new_p, new_m, new_v, next_epoch_step, _final_skips, _final_key} =
    epoch_batches
    |> Stream.with_index(1)
    |> Enum.reduce({p, m, v, current_step, 0, initial_key}, fn {batch, step_in_epoch}, {cp, cm, cv, cs, s_count, cur_key} ->
      gpu_batch = Nx.backend_copy(batch, gpu)

      {loss_tensor, grads, new_key} = DLM.V26Trainer.compute_grad(cp, pos_emb, gpu_batch, cur_key)
      loss_val = Nx.to_number(loss_tensor)

      if loss_val == :nan or loss_val > 10.0 do
        cpu_batch = Nx.backend_copy(gpu_batch, Nx.BinaryBackend)
        sequences = Nx.to_list(cpu_batch)
        IO.puts("🔥 PATHOLOGICAL BATCH at global step #{cs}:")
        Enum.each(sequences, fn seq ->
          readable = seq |> Enum.reject(&(&1 == 0)) |> List.to_string()
          IO.puts("   > #{readable}")
        end)
      end

      if loss_val == :nan or loss_val > 10.0 do
        if rem(step_in_epoch, 10) == 0,
          do: IO.puts("⚠️ Step #{cs}: NaN/Spike detected. Skipping batch.")
        {cp, cm, cv, cs + 1, s_count + 1, new_key}
      else
        # Calculate LR strictly using the Current Global Step (cs)
        current_lr = 
          if cs < warmup_steps do
            # Linear Warmup
            base_lr * (cs / warmup_steps)
          else
            # Cosine Decay
            progress = (cs - warmup_steps) / (total_steps - warmup_steps)
            clamped_progress = min(max(progress, 0.0), 1.0)
            min_lr + 0.5 * (base_lr - min_lr) * (1.0 + :math.cos(:math.pi() * clamped_progress))
          end

          lr_tensor = Nx.tensor(current_lr, type: :f32) |> Nx.backend_copy(gpu)
          step_tensor = Nx.tensor(cs, type: :f32) |> Nx.backend_copy(gpu)
  
          {up_p, up_m, up_v} = DLM.MuonHybrid.step(cp, grads, cm, cv, step_tensor, lr_tensor)

          # ⚡ FIX 1: Unpack 14 elements (Only one p_a)
          {p_bit_proj, p_a, p_bu, p_bv, p_cu, p_cv, p_du, p_dv,
           p_mu1, p_mv1, p_mu2, p_mv2, p_lmw, p_lmb} = up_p
  
          du_norm = p_du |> Nx.pow(2) |> Nx.sum() |> Nx.sqrt() |> Nx.to_number()
  
          up_p = if du_norm < 0.01 do
            IO.puts("   🔧 Rescuing dead delta gate (d_u norm=#{Float.round(du_norm, 5)})")
            rescaled_du = Nx.multiply(p_du, Nx.tensor(0.02 / max(du_norm, 1.0e-8)))
            rescaled_dv = Nx.multiply(p_dv, Nx.tensor(0.02 / max(du_norm, 1.0e-8)))
            
            # ⚡ FIX 2: Repack 14 elements (Only one p_a)
            {p_bit_proj, p_a, p_bu, p_bv, p_cu, p_cv, rescaled_du, rescaled_dv,
             p_mu1, p_mv1, p_mu2, p_mv2, p_lmw, p_lmb}
          else
            up_p
        end

        if rem(step_in_epoch, 50) == 0 do
          bpc = loss_val / :math.log(2)
          mem = :erlang.memory(:total) |> div(1024 * 1024)
          cpu_grads = grads |> Tuple.to_list()
            |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple()
          norms = DLM.V26Trainer.grad_norms(cpu_grads)
          {max_name, max_norm} = Enum.max_by(norms, fn {_name, n} -> n end)
          norm_str = norms |> Enum.map(fn {k, v} -> "#{k}=#{v}" end) |> Enum.join(" | ")
          IO.puts("➡️  Step #{step_in_epoch} | Global: #{cs} | Loss: #{Float.round(loss_val, 4)} | BPC: #{Float.round(bpc, 3)} | LR: #{Float.round(current_lr, 6)} | RAM: #{mem}MB")
          IO.puts("   📐 GRAD NORMS | MAX: #{max_name}=#{max_norm}")
          IO.puts("   #{norm_str}")
        end

        if rem(cs, save_interval) == 0 and cs > 0 do
          IO.puts("💾 Auto-Saving Checkpoint to #{save_prefix}_step#{cs}.bin...")
          state = %{
            params: up_p |> Tuple.to_list()
              |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
            ms: up_m |> Tuple.to_list()
              |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
            vs: up_v |> Tuple.to_list()
              |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
            step: cs, epoch: epoch,
            shuffle_key: next_shuffle_key |> Nx.backend_copy(Nx.BinaryBackend)
          }
          File.write!("#{save_prefix}_step#{cs}.bin", :erlang.term_to_binary(state))
        end

        if rem(step_in_epoch, 100) == 0, do: :erlang.garbage_collect(self())

        {up_p, up_m, up_v, cs + 1, s_count, new_key}
      end
    end)

  IO.puts("💾 Saving Completed Epoch #{epoch} State...")
  final_state = %{
    params: new_p |> Tuple.to_list()
      |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
    ms: new_m |> Tuple.to_list()
      |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
    vs: new_v |> Tuple.to_list()
      |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
    step: next_epoch_step, epoch: epoch,
    shuffle_key: next_shuffle_key |> Nx.backend_copy(Nx.BinaryBackend)
  }
  File.write!("#{save_prefix}_epoch#{epoch}_COMPLETE.bin", :erlang.term_to_binary(final_state))

  {new_p, new_m, new_v, next_epoch_step, next_shuffle_key}
end)

IO.puts("🎉 THE OVERNIGHT BAKE IS COMPLETE!")
