## USSM, Positional, Muon_Optimizer

```elixir
defmodule DLM.BitTensor do
  import Nx.Defn

  @num_bits 8

  @doc """
  Converts integer character tokens into continuous 8-bit float tensors.
  Input:  {batch_size, seq_len}
  Output: {batch_size, seq_len, 8}
  """
  defn to_bits(tokens) do
    # The bit-shifts required to read an 8-bit integer from left to right
    shifts = Nx.tensor([7, 6, 5, 4, 3, 2, 1, 0], type: :u32)
    
    # Expand tokens to {batch, seq_len, 1} so we can broadcast against shifts
    tokens_expanded = Nx.new_axis(tokens, -1)
    
    # Shift bits and mask to extract exact 1s and 0s
    shifted = Nx.right_shift(tokens_expanded, shifts)
    Nx.bitwise_and(shifted, 1) |> Nx.as_type(:f32)
  end

  @doc """
  Projects the 8-bit continuous tensor into the 512-dimension hidden space.
  bit_proj_matrix shape MUST be {8, 512}
  """
  defn project(tokens, bit_proj_matrix) do
    bits = to_bits(tokens)
    # Math: [batch, seq_len, 8] dot [8, 512] -> [batch, seq_len, 512]
    Nx.dot(bits, bit_proj_matrix)
  end
end
```

