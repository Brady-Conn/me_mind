## SSM

```elixir
defmodule DLM.SvdSSM do
  import Nx.Defn

  defn l2_normalize(tensor) do
    # Calculate Euclidean norm across the last axis natively
    norm = Nx.sqrt(Nx.sum(Nx.pow(tensor, 2), axes: [-1], keep_axes: true))
    # Divide by norm with a tiny epsilon to prevent divide-by-zero
    Nx.divide(tensor, Nx.add(norm, 1.0e-6))
  end

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn gelu(x) do
    cdf = Nx.multiply(
      Nx.tensor(0.7978845608, type: :f32),
      Nx.add(x, Nx.multiply(Nx.tensor(0.044715, type: :f32), Nx.pow(x, 3)))
    )
    Nx.multiply(Nx.multiply(Nx.tensor(0.5, type: :f32), x), Nx.add(Nx.tensor(1.0, type: :f32), Nx.tanh(cdf)))
  end

  defn swish(x) do
    Nx.multiply(x, Nx.sigmoid(x))
  end

  defn apply_svd(x, u, v) do
    gelu(x) |> Nx.dot(u) |> Nx.dot(v) |> rms_norm()
  end

  defn softplus(x) do
    Nx.log1p(Nx.exp(x))
  end

  defn softmax(t) do
    max_val = Nx.reduce_max(t, axes: [-1], keep_axes: true)
    safe_t = Nx.subtract(t, max_val)
    exps = Nx.exp(safe_t)
    sum_exps = Nx.sum(exps, axes: [-1], keep_axes: true)
    Nx.divide(exps, Nx.add(sum_exps, 1.0e-8))
  end

  defn forward_step(x_t, h_prev, trainable, frozen) do
    {c1, c2, c3, d} = trainable
    {a_frozen, b_frozen} = frozen
    
    # 1. Update the Reservoir (The physics engine ticks forward)
    # The current state rotates, and the new character kicks the water.
    h_new = Nx.dot(h_prev, a_frozen) + Nx.take(b_frozen, x_t)

    # 2. Readout (The microphone listens to the water)
    # Trainable MLP translates the 128D spectrogram into 128 ASCII probabilities
    logits = Nx.dot(h_new, c1) |> apply_svd(c2, c3) |> Nx.dot(d)
    
    {logits, h_new}
  end
end
```

```elixir
defmodule DLM.SvdOptimizer do
  import Nx.Defn

  defn update(params, grads, step, lr) do
     {c1, c2, c3, d} = params   
     {gc1, gc2, gc3, gd} = grads
    
    new_step = Nx.add(step, 1)

    # optimizer update step
    c1_new = DLM.StatelessMuon.muon_step(c1, gc1, lr)
    c2_new = DLM.StatelessMuon.muon_step(c2, gc2, lr)
    c3_new = DLM.StatelessMuon.muon_step(c3, gc3, lr)
    d_new = DLM.StatelessMuon.muon_step(d, gd, lr)
    
    new_params = {c1_new, c2_new, c3_new, d_new}

    {new_params, new_step}
  end
end
```

```elixir
defmodule DLM.PhysicsGenesis do
  import Nx.Defn

  @vocab 128
  @dim 256 # Must be an even number! (128 / 2 = 64 frequency oscillators)

  @a_frozen_list (
    pairs = div(@dim, 2)

    for row <- 0..(@dim - 1), col <- 0..(@dim - 1) do
      pair_row = div(row, 2)
      pair_col = div(col, 2)

      if pair_row == pair_col do
        w = 0.01 + pair_row * (:math.pi() - 0.01) / max(1, pairs - 1)

        cond do
          rem(row, 2) == 0 and rem(col, 2) == 0 -> :math.cos(w)
          rem(row, 2) == 0 and rem(col, 2) == 1 -> -:math.sin(w)
          rem(row, 2) == 1 and rem(col, 2) == 0 -> :math.sin(w)
          rem(row, 2) == 1 and rem(col, 2) == 1 -> :math.cos(w)
        end
      else
        0.0
      end
    end
  )

  defn ignite(k1) do
    a_frozen = Nx.tensor(@a_frozen_list, type: :f32) |> Nx.reshape({@dim, @dim})

    {b_frozen, k2} = Nx.Random.normal(k1, 0.0, 1.0, shape: {@vocab, @dim})
    
    std_dim = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@dim, type: :f32)))

    {c1, k3} = Nx.Random.normal(k2, 0.0, std_dim, shape: {@dim, @dim})
    {c2, k4} = Nx.Random.normal(k3, 0.0, std_dim, shape: {@dim, @dim})
    {c3, k5} = Nx.Random.normal(k4, 0.0, std_dim, shape: {@dim, @dim})
    {d, k6} = Nx.Random.normal(k5, 0.0, std_dim, shape: {@dim, @vocab})

    trainable_params = {c1, c2, c3, d}
    frozen_params = {a_frozen, b_frozen}

    {trainable_params, frozen_params, k6}
  end
end
