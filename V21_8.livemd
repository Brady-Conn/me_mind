## Stream

```elixir
defmodule DLM.DataStreamer do
  def stream(path, seq_len, batch_size) do
    lines = path |> File.read!() |> String.split("\n", trim: true) |> Enum.shuffle()

    lines
    |> Enum.join("\n")
    |> to_charlist()
    |> Stream.chunk_every(seq_len + 1, seq_len, :discard)
    |> Stream.map(fn chunk ->
      ins = chunk |> Enum.take(seq_len) |> Nx.tensor(type: :s32)
      tgs = chunk |> Enum.drop(1)      |> Nx.tensor(type: :s32)
      {ins, tgs}
    end)
    |> Stream.chunk_every(batch_size, batch_size, :discard)
    |> Stream.map(fn batch ->
      {ins_list, tgs_list} = Enum.unzip(batch)
      {Nx.stack(ins_list), Nx.stack(tgs_list)}
    end)
  end
end
```

```elixir
defmodule DLM.DataBuilder do
  @rank 32
  @dim 256
  @seq_len 256
  @pad_token 0
  @eos_token 3        # ASCII ETX — signals clean end of entry
  @min_content_chars 64   # discard chunks that are mostly padding

  @doc """
  Takes a list of file paths, combines them, shuffles the lines 
  to prevent overfitting, and builds the static training tensors.
  """
  def build_combined_tensors(file_paths) when is_list(file_paths) do
    raw_lines =
      Enum.flat_map(file_paths, fn path ->
        File.stream!(path)
        |> Stream.map(&String.trim/1)
        |> Stream.reject(&String.starts_with?(&1, "  "))
        |> Enum.to_list()
      end)
  
    shuffled_lines = Enum.shuffle(raw_lines)
  
    shuffled_lines
    |> Enum.flat_map(&parse_synset/1)   # flat_map since each line now yields 1..N chunks
    |> Enum.reject(&is_nil/1)
    |> Nx.tensor(type: :s32)
  end

  defp parse_synset(line) do
    case String.split(line, " | ") do
      [data_chunk, gloss] ->
        tokens = String.split(data_chunk, " ", trim: true)
        w_cnt  = String.to_integer(Enum.at(tokens, 3), 16)
  
        words =
          Enum.reduce(0..(w_cnt - 1), [], fn i, acc ->
            word_index = 4 + (i * 2)
            raw_word   = Enum.at(tokens, word_index)
            [String.replace(raw_word, "_", " ") | acc]
          end)
          |> Enum.reverse()
  
        [main_word | synonyms] = words
  
        base_entry =
          if Enum.empty?(synonyms) do
            "#{main_word} = #{gloss}"
          else
            "#{main_word} = #{gloss} | #{Enum.join(synonyms, ", ")}"
          end
  
        # No more synonym cross-reference entries — just chunk the main entry
        chunk_entry(base_entry)
  
      _ -> []
    end
  end
  
  

  defp chunk_entry(str) do
    chars = String.to_charlist(str <> <<@eos_token>>)
    total = length(chars)
  
    if total <= @seq_len do
      padded = chars ++ List.duplicate(@pad_token, @seq_len - total)
      # Only keep if there's enough real content
      if total >= @min_content_chars, do: [padded], else: []
    else
      overlap = 64  # increased from 32 to reduce boundary artifacts
      step    = @seq_len - overlap
  
      0
      |> Stream.iterate(&(&1 + step))
      |> Stream.take_while(&(&1 < total))
      |> Enum.map(fn offset ->
        raw_window = Enum.slice(chars, offset, @seq_len)
  
        # Snap to nearest space so we don't cut mid-word
        snapped_window =
          if length(raw_window) == @seq_len do
            # Find last space in window and trim there
            last_space =
              raw_window
              |> Enum.with_index()
              |> Enum.filter(fn {c, _} -> c == ?\s end)
              |> List.last()
  
            case last_space do
              {_, idx} -> Enum.take(raw_window, idx + 1)
              nil      -> raw_window  # no space found, keep as-is
            end
          else
            raw_window
          end
  
        content_len = length(snapped_window)
        # Discard near-empty tail chunks
        if content_len >= @min_content_chars do
          pad_len = @seq_len - content_len
          snapped_window ++ List.duplicate(@pad_token, pad_len)
        else
          nil
        end
      end)
      |> Enum.reject(&is_nil/1)
    end
  end

  defp format_to_tensor(raw_str) do
    chars = String.to_charlist(raw_str)
    actual_len = length(chars)

    cond do
      actual_len == @seq_len -> 
        chars
      actual_len > @seq_len -> 
        Enum.take(chars, @seq_len)
      actual_len < @seq_len -> 
        chars ++ List.duplicate(@pad_token, @seq_len - actual_len)
    end
  end
end
```

