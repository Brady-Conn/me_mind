## USSM, Positional, Muon_Optimizer

```elixir
defmodule DLM.UniversalSSM do
  import Nx.Defn

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn softplus(x), do: Nx.log1p(Nx.exp(x))
  defn silu(x), do: x * Nx.sigmoid(x)

  defn apply_svd_weight(x, u, v) do
    x |> Nx.dot(u) |> silu() |> Nx.dot(v)
  end

  defn ssm_recurrence(x_t, x_p1, x_p2, h_prev, a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2) do
    # unchanged — a is now passed in per-loop rather than shared
    x_mixed = x_t
      |> Nx.add(apply_svd_weight(x_p1, mu1, mv1))
      |> Nx.add(apply_svd_weight(x_p2, mu2, mv2))
    delta_proj = apply_svd_weight(x_mixed, du, dv)
    delta      = softplus(delta_proj)
    a_bar      = Nx.sigmoid(Nx.multiply(delta, a))
    b_proj     = apply_svd_weight(x_mixed, bu, bv)
    b_bar      = Nx.multiply(delta, b_proj)
    h_t        = Nx.tanh(Nx.add(Nx.multiply(a_bar, h_prev), b_bar))
    y_ssm      = apply_svd_weight(h_t, cu, cv)
    y_t        = Nx.add(y_ssm, x_mixed)
    {y_t, h_t}
  end

  defn run_ssm_loop(x_seq_first, h_init, a_diag, params) do
    {_emb, _a1, _a2, b_u, b_v, c_u, c_v, delta_u, delta_v,
     mx_u1, mx_v1, mx_u2, mx_v2, _lm_w, _lm_b} = params

    {seq_len, batch_size, embed_dim} = Nx.shape(x_seq_first)
    y_init    = Nx.broadcast(Nx.tensor(0.0, type: :f32), {seq_len, batch_size, embed_dim})
    zero_frame = Nx.broadcast(Nx.tensor(0.0, type: :f32), {batch_size, embed_dim})

    result_tuple =
      while {i = 0, y_acc = y_init, h_p = h_init,
             x_prev1 = zero_frame,
             x_prev2 = zero_frame,
             xs = x_seq_first,
             a = a_diag, bu = b_u, bv = b_v, cu = c_u, cv = c_v,
             du = delta_u, dv = delta_v,
             mu1 = mx_u1, mv1 = mx_v1, mu2 = mx_u2, mv2 = mx_v2},
            Nx.less(i, seq_len) do

        x_t = xs[i]
        {y_t, h_new} = ssm_recurrence(
          x_t, x_prev1, x_prev2, h_p,
          a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2
        )
        y_acc_new = Nx.put_slice(y_acc, [i, 0, 0], Nx.new_axis(y_t, 0))
        {i + 1, y_acc_new, h_new, x_t, x_prev1,
         xs, a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2}
      end

    elem(result_tuple, 1)
  end

  defn forward(indices, params, pos_emb) do
    {embed, a_diag1, a_diag2, _bu, _bv, _cu, _cv, _du, _dv,
     _mu1, _mv1, _mu2, _mv2, lm_w, lm_b} = params

    x_input = Nx.take(embed, indices) + pos_emb
    x_norm  = rms_norm(x_input)

    {batch_size, _seq_len, embed_dim} = Nx.shape(x_norm)
    h_init = Nx.broadcast(Nx.tensor(0.0, type: :f32), {batch_size, embed_dim})
    x_seq_first = Nx.transpose(x_norm, axes: [1, 0, 2])

    # Each loop now gets its own independent a_diag
    y1_seq = run_ssm_loop(x_seq_first, h_init, a_diag1, params)
    y2_seq = run_ssm_loop(y1_seq,      h_init, a_diag2, params)

    y_out   = Nx.transpose(y2_seq, axes: [1, 0, 2])
    y_final = rms_norm(y_out)
    Nx.dot(y_final, lm_w) + lm_b
  end
end
```

```elixir
defmodule DLM.Positional do
  def build(len, dim) do
    i = Nx.iota({len, 1})
    d = Nx.iota({1, dim})
    dim_f = Nx.tensor(dim, type: :f32) # 🔥 Force float math
    Nx.sin(Nx.divide(i, Nx.pow(10000.0, Nx.divide(d, dim_f))))
  end
end
```

```elixir
defmodule DLM.MuonHybrid do
  import Nx.Defn

  # --- The Muon Newton-Schulz Engine ---
  defn newton_schulz(g, iters \\ 5) do
    frobenius_norm = Nx.sqrt(Nx.sum(Nx.pow(g, 2))) + 1.0e-7
    x = g / frobenius_norm
    
    {final_x, _} = while {curr_x = x, i = 0}, Nx.less(i, iters) do
      x_t_x = Nx.dot(Nx.transpose(curr_x), curr_x)
      next_x = 1.5 * curr_x - 0.5 * Nx.dot(curr_x, x_t_x)
      {next_x, i + 1}
    end
    final_x
  end

  defn muon_update(grad, lr) do
    Nx.subtract(0.0, Nx.multiply(lr, newton_schulz(grad)))
  end

  # --- Standard Adam Component ---
  defn adam_update(param, grad, m, v, step, lr) do
    # ⚡ THE FIX: Adam internally ensures the step is at least 1.0 to prevent division by zero
    safe_step = step + 1.0

    beta1 = 0.9
    beta2 = 0.999
    eps = 1.0e-8
    
    new_m = beta1 * m + (1.0 - beta1) * grad
    new_v = beta2 * v + (1.0 - beta2) * Nx.pow(grad, 2)
    
    m_hat = new_m / (1.0 - Nx.pow(beta1, safe_step))
    v_hat = new_v / (1.0 - Nx.pow(beta2, safe_step))
    
    param_update = param - lr * m_hat / (Nx.sqrt(v_hat) + eps)
    {param_update, new_m, new_v}
  end

  # --- The Hybrid Step ---
  defn step(params, grads, ms, vs, step_count, lr) do
    {p_emb, p_a1, p_a2, p_bu, p_bv, p_cu, p_cv, p_du, p_dv,
      p_mu1, p_mv1, p_mu2, p_mv2, p_lmw, p_lmb} = params
  
    {g_emb, g_a1, g_a2, g_bu, g_bv, g_cu, g_cv, g_du, g_dv,
      g_mu1, g_mv1, g_mu2, g_mv2, g_lmw, g_lmb} = grads
  
    {m_emb, m_a1, m_a2, m_bu, m_bv, m_cu, m_cv, m_du, m_dv,
      m_mu1, m_mv1, m_mu2, m_mv2, m_lmw, m_lmb} = ms
  
    {v_emb, v_a1, v_a2, v_bu, v_bv, v_cu, v_cv, v_du, v_dv,
      v_mu1, v_mv1, v_mu2, v_mv2, v_lmw, v_lmb} = vs
  
    # Adam for scalars and vocab tensors — now two a_diag entries
    {up_emb, nm_emb, nv_emb} = adam_update(p_emb, g_emb, m_emb, v_emb, step_count, lr)
    {up_a1,  nm_a1,  nv_a1}  = adam_update(p_a1,  g_a1,  m_a1,  v_a1,  step_count, lr)
    {up_a2,  nm_a2,  nv_a2}  = adam_update(p_a2,  g_a2,  m_a2,  v_a2,  step_count, lr)
    {up_lmw, nm_lmw, nv_lmw} = adam_update(p_lmw, g_lmw, m_lmw, v_lmw, step_count, lr)
    {up_lmb, nm_lmb, nv_lmb} = adam_update(p_lmb, g_lmb, m_lmb, v_lmb, step_count, lr)
  
    # Muon for all SVD matrices — unchanged
    up_bu  = p_bu  + muon_update(g_bu,  lr)
    up_bv  = p_bv  + muon_update(g_bv,  lr)
    up_cu  = p_cu  + muon_update(g_cu,  lr)
    up_cv  = p_cv  + muon_update(g_cv,  lr)
    up_du  = p_du  + muon_update(g_du,  lr)
    up_dv  = p_dv  + muon_update(g_dv,  lr)
    up_mu1 = p_mu1 + muon_update(g_mu1, lr)
    up_mv1 = p_mv1 + muon_update(g_mv1, lr)
    up_mu2 = p_mu2 + muon_update(g_mu2, lr)
    up_mv2 = p_mv2 + muon_update(g_mv2, lr)
  
    new_params = {up_emb, up_a1, up_a2, up_bu, up_bv, up_cu, up_cv, up_du, up_dv,
                  up_mu1, up_mv1, up_mu2, up_mv2, up_lmw, up_lmb}
  
    new_ms = {nm_emb, nm_a1, nm_a2, m_bu, m_bv, m_cu, m_cv, m_du, m_dv,
              m_mu1, m_mv1, m_mu2, m_mv2, nm_lmw, nm_lmb}
  
    new_vs = {nv_emb, nv_a1, nv_a2, v_bu, v_bv, v_cu, v_cv, v_du, v_dv,
              v_mu1, v_mv1, v_mu2, v_mv2, nv_lmw, nv_lmb}
  
    {new_params, new_ms, new_vs}
  end
end
```

```elixir
defmodule DLM.V21_8Genesis do
  @vocab_size 128
  @dim 256
  @rank 32

  def init_params(seed \\ 42) do
    key = Nx.Random.key(seed)
    {embed,  key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@vocab_size, @dim})
    # Two independent a_diag parameters — one per SSM loop
    {a_diag1, key} = Nx.Random.normal(key, 0.0, 1.0,  shape: {@dim})
    {a_diag2, key} = Nx.Random.normal(key, 0.0, 1.0,  shape: {@dim})
    {b_u,    key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@dim, @rank})
    {b_v,    key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@rank, @dim})
    {c_u,    key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@dim, @rank})
    {c_v,    key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@rank, @dim})
    {d_u,    key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@dim, @rank})
    {d_v,    key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@rank, @dim})
    {mx_u1,  key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@dim, @rank})
    {mx_v1,  key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@rank, @dim})
    {mx_u2,  key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@dim, @rank})
    {mx_v2,  key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@rank, @dim})
    {lm_w,   key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@dim, @vocab_size})
    {lm_b,  _key} = Nx.Random.normal(key, 0.0, 0.0,  shape: {@vocab_size})

    {embed, a_diag1, a_diag2, b_u, b_v, c_u, c_v, d_u, d_v,
     mx_u1, mx_v1, mx_u2, mx_v2, lm_w, lm_b}
  end

  def init_optimizer(params) do
    zero_like = fn t -> Nx.broadcast(Nx.tensor(0.0, type: :f32), t) end
    ms = params |> Tuple.to_list() |> Enum.map(zero_like) |> List.to_tuple()
    vs = params |> Tuple.to_list() |> Enum.map(zero_like) |> List.to_tuple()
    {ms, vs, 1}
  end
end
