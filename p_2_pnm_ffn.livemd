```elixir
defmodule DLM.SvdOptimizer do
  import Nx.Defn

  defn update(params, grads, step, lr) do
    {b1, b2, bb, bq, bg, be, 
     c1, c2, cb, cq, cg, ce,
     s1, s2, sb, sq, sg, se,
     m1, m2, mb, mq, mg, me, qu, qp, em}  = params   
    {gb1, gb2, gbb, gbq, gbg, gbe, 
     gc1, gc2, gcb, gcq, gcg, gce,
     gs1, gs2, gsb, gsq, gsg, gse,
     gm1, gm2, gmb, gmq, gmg, gme, gqu, gqp, gem}  = grads
    
    new_step = Nx.add(step, 1)

    # optimizer update step    
    b1_new = DLM.StatelessMuon.muon_step(b1, gb1, lr)
    b2_new = DLM.StatelessMuon.muon_step(b2, gb2, lr)
    bb_new = DLM.StatelessMuon.muon_step(bb, gbb, lr)
    bq_new = DLM.StatelessMuon.muon_step(bq, gbq, lr)
    be_new = DLM.StatelessMuon.muon_step(be, gbe, lr)
    bg_new = DLM.StatelessMuon.muon_step(bg, gbg, lr)

    c1_new = DLM.StatelessMuon.muon_step(c1, gc1, lr)
    c2_new = DLM.StatelessMuon.muon_step(c2, gc2, lr)
    cb_new = DLM.StatelessMuon.muon_step(cb, gcb, lr)
    cq_new = DLM.StatelessMuon.muon_step(cq, gcq, lr)
    ce_new = DLM.StatelessMuon.muon_step(ce, gce, lr)
    cg_new = DLM.StatelessMuon.muon_step(cg, gcg, lr)

    s1_new = DLM.StatelessMuon.muon_step(s1, gs1, lr)
    s2_new = DLM.StatelessMuon.muon_step(s2, gs2, lr)
    sb_new = DLM.StatelessMuon.muon_step(sb, gsb, lr)
    sq_new = DLM.StatelessMuon.muon_step(sq, gsq, lr)
    se_new = DLM.StatelessMuon.muon_step(se, gse, lr)
    sg_new = DLM.StatelessMuon.muon_step(sg, gsg, lr)

    m1_new = DLM.StatelessMuon.muon_step(m1, gm1, lr)
    m2_new = DLM.StatelessMuon.muon_step(m2, gm2, lr)
    mb_new = DLM.StatelessMuon.muon_step(mb, gmb, lr)
    mq_new = DLM.StatelessMuon.muon_step(mq, gmq, lr)
    me_new = DLM.StatelessMuon.muon_step(me, gme, lr)
    mg_new = DLM.StatelessMuon.muon_step(mg, gmg, lr)

    qu_new = DLM.StatelessMuon.muon_step(qu, gqu, lr)
    qp_new = DLM.StatelessMuon.muon_step(qp, gqp, lr)

    em_new = DLM.StatelessMuon.muon_step(em, gem, lr)
    
    new_params = {b1_new, b2_new, bb_new, bq_new, bg_new, be_new,
                  c1_new, c2_new, cb_new, cq_new, cg_new, ce_new,
                  s1_new, s2_new, sb_new, sq_new, sg_new, se_new,
                  m1_new, m2_new, mb_new, mq_new, mg_new, me_new,
                  qu_new, qp_new, em_new}

    {new_params, new_step}
  end
end
