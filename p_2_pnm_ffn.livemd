```elixir
defmodule DLM.PhysicsGenesis do
  import Nx.Defn

  @vocab 128
  @dim 512

  defn init(k1) do
    std_dim = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@dim, type: :f32)))
    std_voc = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@vocab, type: :f32)))

    # projection matrices
    {b1, k2} = Nx.Random.normal(k1, 0.0, std_voc, shape: {@vocab, @dim})
    {b2, k3} = Nx.Random.normal(k2, 0.0, std_dim, shape: {@dim, @vocab})
    {c1, k4} = Nx.Random.normal(k3, 0.0, std_voc, shape: {@vocab, @dim})
    {c2, k5} = Nx.Random.normal(k4, 0.0, std_dim, shape: {@dim, @vocab})
    {s1, k6} = Nx.Random.normal(k5, 0.0, std_voc, shape: {@vocab, @dim})
    {s2, k7} = Nx.Random.normal(k6, 0.0, std_dim, shape: {@dim, @vocab})
    {m1, k8} = Nx.Random.normal(k7, 0.0, std_voc, shape: {@vocab, @dim})
    {m2, k9} = Nx.Random.normal(k8, 0.0, std_dim, shape: {@dim, @vocab})

    {qu, k10} = Nx.Random.normal(k9, 0.0, std_voc, shape: {@vocab, @vocab})
    {qp, k11} = Nx.Random.normal(k10, 0.0, std_voc, shape: {@vocab, @vocab})

    {em, k12} = Nx.Random.normal(k11, 0.0, std_voc, shape: {@vocab, @vocab})

    # projection bias vectors
    bb = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    cb = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    sb = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    mb = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    # projection scaling vectors
    bq = Nx.broadcast(1.0, {@dim}) |> Nx.as_type(:f32)
    cq = Nx.broadcast(1.0, {@dim}) |> Nx.as_type(:f32)
    sq = Nx.broadcast(1.0, {@dim}) |> Nx.as_type(:f32)
    mq = Nx.broadcast(1.0, {@dim}) |> Nx.as_type(:f32)
    # rms norm beta and gamma vectors
    be = Nx.broadcast(0.0, {@vocab}) |> Nx.as_type(:f32)
    bg = Nx.broadcast(1.0, {@vocab}) |> Nx.as_type(:f32)
    ce = Nx.broadcast(0.0, {@vocab}) |> Nx.as_type(:f32)
    cg = Nx.broadcast(1.0, {@vocab}) |> Nx.as_type(:f32)
    se = Nx.broadcast(0.0, {@vocab}) |> Nx.as_type(:f32)
    sg = Nx.broadcast(1.0, {@vocab}) |> Nx.as_type(:f32)
    me = Nx.broadcast(0.0, {@vocab}) |> Nx.as_type(:f32)
    mg = Nx.broadcast(1.0, {@vocab}) |> Nx.as_type(:f32)
    
    trainable_params = { b1, b2, bb, bq, bg, be, 
                         c1, c2, cb, cq, cg, ce,
                         s1, s2, sb, sq, sg, se,
                         m1, m2, mb, mq, mg, me, qu, qp, em} 
    
    {trainable_params, k12}
  end
end
