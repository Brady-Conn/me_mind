## SSM

```elixir
defmodule DLM.SvdSSM do
  import Nx.Defn

  defn rms_norm(x, gamma, beta, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    norm = x * Nx.rsqrt(variance + epsilon)
    scaled = norm * gamma
    scaled + beta
  end

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn gelu(x) do
    cdf = Nx.multiply(
      Nx.tensor(0.7978845608, type: :f32),
      Nx.add(x, Nx.multiply(Nx.tensor(0.044715, type: :f32), Nx.pow(x, 3)))
    )
    Nx.multiply(Nx.multiply(Nx.tensor(0.5, type: :f32), x), Nx.add(Nx.tensor(1.0, type: :f32), Nx.tanh(cdf)))
  end
  
  defn feed_forward_layer(x, um, ga, bi, dm) do
    up = Nx.dot(x, um) 
    act = gelu(up) #was tanh
    scaled = Nx.multiply(act, ga)
    biased = Nx.add(scaled, bi)
    Nx.dot(biased, dm) 
  end

  defn softmax(t) do
    max_val = Nx.reduce_max(t, axes: [-1], keep_axes: true)
    safe_t = Nx.subtract(t, max_val)
    exps = Nx.exp(safe_t)
    sum_exps = Nx.sum(exps, axes: [-1], keep_axes: true)
    Nx.divide(exps, Nx.add(sum_exps, 1.0e-8))
  end

  defn apply_xsa(x, y) do
    y_norm_sq = Nx.add(Nx.sum(Nx.pow(y, 2), axes: [-1], keep_axes: true), 1.0e-6)
    y_unit = Nx.divide(y, Nx.sqrt(y_norm_sq))
    # exclusive space attention
    y_ov = Nx.sum(Nx.multiply(x, y_unit), axes: [-1], keep_axes: true)
    Nx.subtract(x, Nx.multiply(y_ov, y_unit))
  end

  defn apply_attention(q, v) do
    k = Nx.transpose(v, axes: [0, 2, 1])
    # r = Nx.axis_size(v, 1)
    score = Nx.dot(q, [2], [0], k, [1], [0])
    # scaled_score = Nx.divide(score, Nx.sqrt(r))
    soft_score = softmax(score)
    Nx.dot(soft_score, [2], [0], v, [1], [0]) |> Nx.squeeze(axes: [1])
  end

  defn forward_step(x_t, spell_prev, mem_prev, tm_prev, p) do
    {b1, b2, bb, bq, bg, be, 
     c1, c2, cb, cq, cg, ce,
     s1, s2, sb, sq, sg, se,
     m1, m2, mb, mq, mg, me, qu, qp, em} = p
    u_t = Nx.take(em, x_t) # {batch, 128} learned em?
    # 128->512->128 process incomming character
    b_term = feed_forward_layer(u_t, b1, bq, bb, b2)
    b_norm = rms_norm(b_term, bg, be)
    # apply time scale
    sp_scaled = Nx.divide(spell_prev, Nx.Constants.pi())
    mp_scaled = Nx.divide(mem_prev, Nx.Constants.pi())
    # update spelling
    sl_sps = Nx.slice_along_axis(sp_scaled, 0, 255, axis: 1)
    sp_new =Nx.concatenate([sl_sps, Nx.new_axis(u_t, 1)], axis: 1)
    # get spelling attention
    q_u = Nx.dot(b_norm, qu) |> Nx.new_axis(1)
    q_p = Nx.dot(b_norm, qp) |> Nx.new_axis(1)
    ctxspb = apply_attention(q_u, sp_new)
    xsb = apply_xsa(ctxspb, b_norm) # feed forward layer to proces ctx?
    s_term = feed_forward_layer(xsb, s1, sq, sb, s2)
    s_norm = rms_norm(s_term, sg, se)
    # update mem
    sl_mem = Nx.slice_along_axis(mp_scaled, 0, 255, axis: 1)
    mem_new = Nx.concatenate([sl_mem, Nx.new_axis(s_norm, 1)], axis: 1)
    # get mem attention
    ctxmemb = apply_attention(q_u, mem_new)
    xmb = apply_xsa(ctxmemb, b_norm) # feed forward layer to proces ctx?
    m_term = feed_forward_layer(xmb, m1, mq, mb, m2)
    m_norm = rms_norm(m_term, mg, me)
    # create new thinking matrix - concat empty 128 matrices instead of up project for ffw layers?
    sl_tmp = Nx.slice_along_axis(tm_prev, 1, 126, axis: 1)
    ts_new = Nx.concatenate([Nx.new_axis(s_norm, 1), sl_tmp, Nx.new_axis(m_norm, 1)], axis: 1)
    ctxp = apply_attention(q_p, ts_new)
    xpat = apply_xsa(ctxp, b_norm)
    # 128 -> 512 -> 128
    c_term = feed_forward_layer(xpat, c1, cq, cb, c2)
    c_norm = rms_norm(c_term, cg, ce) # try without norm?
    # 128 -> 128
    logits = Nx.dot(c_norm, em)

    {logits, sp_new, mem_new, tm_prev}
  end
end
```

