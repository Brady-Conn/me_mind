```elixir
defmodule DLM.PhysicsGenesis do
  import Nx.Defn

  @dim 128
  @vocab 128

  defn ignite(k1) do
    # 1. Variance Scalars
    std_vocab = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@vocab, type: :f32)))
    std_dim   = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@dim, type: :f32)))

    # 2. Block Positional Embeddings (Vocab/Dim -> Dim)
    {e1, k2} = Nx.Random.normal(k1, 0.0, std_dim, shape: {@vocab, @dim})
    {e2, k3} = Nx.Random.normal(k2, 0.0, std_dim, shape: {@vocab, @dim})
    {e3, k4} = Nx.Random.normal(k3, 0.0, std_dim, shape: {@vocab, @dim})
   
    # 3. a: Hidden State Down-Projection (Dim -> Rank)
    {a1, k5} = Nx.Random.normal(k4, 0.0, std_dim, shape: {@dim, @dim})
    {a2, k6} = Nx.Random.normal(k5, 0.0, std_dim, shape: {@dim, @dim})
    {a3, k7} = Nx.Random.normal(k6, 0.0, std_dim, shape: {@dim, @dim})
    
    # 4. b: Input Down-Projection (Dim -> Rank)
    {b1, k8}  = Nx.Random.normal(k7,  0.0, std_dim, shape: {@dim, @dim})
    {b2, k9}  = Nx.Random.normal(k8,  0.0, std_dim, shape: {@dim, @dim})
    {b3, k10}  = Nx.Random.normal(k9,  0.0, std_dim, shape: {@dim, @dim})
    
    # 5. c: Latent Up-Projection (Rank -> Dim)
    # ⚡ SHAPE FIXED: Taking the 64D attention mix back to 128D
    {c1, k11} = Nx.Random.normal(k10, 0.0, std_dim, shape: {@dim, @dim})
    {c2, k12} = Nx.Random.normal(k11, 0.0, std_dim, shape: {@dim, @dim})
    {c3, k13} = Nx.Random.normal(k12, 0.0, std_dim, shape: {@dim, @dim})
    
    # 6. d: Output Pathway 1 (Dim -> Dim)
    # ⚡ SHAPE FIXED: d3 correctly maps Dim -> Vocab probabilities
    {d1, k14} = Nx.Random.normal(k13, 0.0, std_vocab, shape: {@dim, @vocab})
    {d2, k15} = Nx.Random.normal(k14, 0.0, std_vocab, shape: {@dim, @vocab})
    {d3, k16} = Nx.Random.normal(k15, 0.0, std_vocab, shape: {@dim, @vocab})
    
    # 9. h: Recurrent State Up-Projection (Rank -> Dim)
    # This prepares hn1/2/3 to become the h1p/2/3p for the NEXT time step
    {h1, k17} = Nx.Random.normal(k16, 0.0, std_dim, shape: {@dim, @dim})
    {h2, k18} = Nx.Random.normal(k17, 0.0, std_dim, shape: {@dim, @dim})
    {h3, k19} = Nx.Random.normal(k18, 0.0, std_dim, shape: {@dim, @dim})
  
    {q1, k20} = Nx.Random.normal(k19, 0.0, std_dim, shape: {@dim, @dim})
    {q2, k21} = Nx.Random.normal(k20, 0.0, std_dim, shape: {@dim, @dim})
    {q3, k22} = Nx.Random.normal(k21, 0.0, std_dim, shape: {@dim, @dim})

    {i1, k23} = Nx.Random.normal(k22, 0.0, std_dim, shape: {@dim, @dim})
    {i2, k24} = Nx.Random.normal(k23, 0.0, std_dim, shape: {@dim, @dim})
    {i3, k25} = Nx.Random.normal(k24, 0.0, std_dim, shape: {@dim, @dim})

    {j1, k26} = Nx.Random.normal(k25, 0.0, std_dim, shape: {@dim, @dim})
    {j2, k27} = Nx.Random.normal(k26, 0.0, std_dim, shape: {@dim, @dim})
    {j3, k28} = Nx.Random.normal(k27, 0.0, std_dim, shape: {@dim, @dim})

    {k1, k29} = Nx.Random.normal(k28, 0.0, std_dim, shape: {@dim, @dim})
    {k2, k30} = Nx.Random.normal(k29, 0.0, std_dim, shape: {@dim, @dim})
    {k3, k31} = Nx.Random.normal(k30, 0.0, std_dim, shape: {@dim, @dim})

    {r1, k32} = Nx.Random.normal(k31, 0.0, std_dim, shape: {@dim, @dim})
    {r2, k33} = Nx.Random.normal(k32, 0.0, std_dim, shape: {@dim, @dim})
    {r3, k34} = Nx.Random.normal(k33, 0.0, std_dim, shape: {@dim, @dim})

    {s1, k35} = Nx.Random.normal(k34, 0.0, std_dim, shape: {@dim, @dim})
    {s2, k36} = Nx.Random.normal(k35, 0.0, std_dim, shape: {@dim, @dim})
    {s3, k37} = Nx.Random.normal(k36, 0.0, std_dim, shape: {@dim, @dim})

    {f1, k38} = Nx.Random.normal(k37, 0.0, std_dim, shape: {@dim, @dim})
    {f2, k39} = Nx.Random.normal(k38, 0.0, std_dim, shape: {@dim, @dim})
    {f3, k40} = Nx.Random.normal(k39, 0.0, std_dim, shape: {@dim, @dim})

    {g1, k41} = Nx.Random.normal(k40, 0.0, std_dim, shape: {@dim, @dim})
    {g2, k42} = Nx.Random.normal(k41, 0.0, std_dim, shape: {@dim, @dim})
    {g3, k43} = Nx.Random.normal(k42, 0.0, std_dim, shape: {@dim, @dim})

    {n1, k44} = Nx.Random.normal(k43, 0.0, std_dim, shape: {@dim, @dim})
    {n2, k45} = Nx.Random.normal(k44, 0.0, std_dim, shape: {@dim, @dim})
    {n3, k46} = Nx.Random.normal(k45, 0.0, std_dim, shape: {@dim, @dim})

    # Return exactly the tuple structure your forward_step unpacks
    params_tuple = {e1, e2, e3, a1, a2, a3, b1, b2, b3, c1, c2, c3, 
                    d1, d2, d3, h1, h2, h3, q1, q2, q3, i1, i2, i3,
                    j1, j2, j3, k1, k2, k3, r1, r2, r3, s1, s2, s3,
                    f1, f2, f3, g1, g2, g3, n1, n2, n3}

    {params_tuple, k46}
  end
end
