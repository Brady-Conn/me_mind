```elixir
defmodule DLM.SvdOptimizer do
  import Nx.Defn

  defn update(params, grads, step, lr) do
     {e1, e2, e3, a1, a2, a3, b1, b2, b3, c1, c2, c3, 
      d1, d2, d3, h1, h2, h3, q1, q2, q3, i1, i2, i3,
      j1, j2, j3, k1, k2, k3, r1, r2, r3, s1, s2, s3,
      f1, f2, f3, g1, g2, g3, n1, n2, n3} = params   
     {ge1, ge2, ge3, ga1, ga2, ga3, gb1, gb2, gb3, gc1, gc2, gc3, 
      gd1, gd2, gd3, gh1, gh2, gh3, gq1, gq2, gq3, gi1, gi2, gi3,
      gj1, gj2, gj3, gk1, gk2, gk3, gr1, gr2, gr3, gs1, gs2, gs3,
      gf1, gf2, gf3, gg1, gg2, gg3, gn1, gn2, gn3} = grads
    
    new_step = Nx.add(step, 1)

    # optimizer update step
    e1_new = DLM.StatelessMuon.muon_step(e1, ge1, lr)
    e2_new = DLM.StatelessMuon.muon_step(e2, ge2, lr)
    e3_new = DLM.StatelessMuon.muon_step(e3, ge3, lr)
    a1_new = DLM.StatelessMuon.muon_step(a1, ga1, lr)
    a2_new = DLM.StatelessMuon.muon_step(a2, ga2, lr)
    a3_new = DLM.StatelessMuon.muon_step(a3, ga3, lr)
    b1_new = DLM.StatelessMuon.muon_step(b1, gb1, lr)
    b2_new = DLM.StatelessMuon.muon_step(b2, gb2, lr)
    b3_new = DLM.StatelessMuon.muon_step(b3, gb3, lr)
    c1_new = DLM.StatelessMuon.muon_step(c1, gc1, lr)
    c2_new = DLM.StatelessMuon.muon_step(c2, gc2, lr)
    c3_new = DLM.StatelessMuon.muon_step(c3, gc3, lr)
    d1_new = DLM.StatelessMuon.muon_step(d1, gd1, lr)
    d2_new = DLM.StatelessMuon.muon_step(d2, gd2, lr)
    d3_new = DLM.StatelessMuon.muon_step(d3, gd3, lr)
    h1_new = DLM.StatelessMuon.muon_step(h1, gh1, lr)
    h2_new = DLM.StatelessMuon.muon_step(h2, gh2, lr)
    h3_new = DLM.StatelessMuon.muon_step(h3, gh3, lr)
    q1_new = DLM.StatelessMuon.muon_step(q1, gq1, lr)
    q2_new = DLM.StatelessMuon.muon_step(q2, gq2, lr)
    q3_new = DLM.StatelessMuon.muon_step(q3, gq3, lr)
    i1_new = DLM.StatelessMuon.muon_step(i1, gi1, lr)
    i2_new = DLM.StatelessMuon.muon_step(i2, gi2, lr)
    i3_new = DLM.StatelessMuon.muon_step(i3, gi3, lr)
    j1_new = DLM.StatelessMuon.muon_step(j1, gj1, lr)
    j2_new = DLM.StatelessMuon.muon_step(j2, gj2, lr)
    j3_new = DLM.StatelessMuon.muon_step(j3, gj3, lr)
    k1_new = DLM.StatelessMuon.muon_step(k1, gk1, lr)
    k2_new = DLM.StatelessMuon.muon_step(k2, gk2, lr)
    k3_new = DLM.StatelessMuon.muon_step(k3, gk3, lr)
    r1_new = DLM.StatelessMuon.muon_step(r1, gr1, lr)
    r2_new = DLM.StatelessMuon.muon_step(r2, gr2, lr)
    r3_new = DLM.StatelessMuon.muon_step(r3, gr3, lr)
    s1_new = DLM.StatelessMuon.muon_step(s1, gs1, lr)
    s2_new = DLM.StatelessMuon.muon_step(s2, gs2, lr)
    s3_new = DLM.StatelessMuon.muon_step(s3, gs3, lr)
    f1_new = DLM.StatelessMuon.muon_step(f1, gf1, lr)
    f2_new = DLM.StatelessMuon.muon_step(f2, gf2, lr)
    f3_new = DLM.StatelessMuon.muon_step(f3, gf3, lr)
    g1_new = DLM.StatelessMuon.muon_step(g1, gg1, lr)
    g2_new = DLM.StatelessMuon.muon_step(g2, gg2, lr)
    g3_new = DLM.StatelessMuon.muon_step(g3, gg3, lr)
    n1_new = DLM.StatelessMuon.muon_step(n1, gn1, lr)
    n2_new = DLM.StatelessMuon.muon_step(n2, gn2, lr)
    n3_new = DLM.StatelessMuon.muon_step(n3, gn3, lr)
   
    
    new_params = {e1_new, e2_new, e3_new, a1_new, a2_new, a3_new, b1_new, b2_new, b3_new, c1_new, c2_new, c3_new, 
      d1_new, d2_new, d3_new, h1_new, h2_new, h3_new, q1_new, q2_new, q3_new, i1_new, i2_new, i3_new,
      j1_new, j2_new, j3_new, k1_new, k2_new, k3_new, r1_new, r2_new, r3_new, s1_new, s2_new, s3_new,
      f1_new, f2_new, f3_new, g1_new, g2_new, g3_new, n1_new, n2_new, n3_new}

    {new_params, new_step}
  end
end
