## SSM

```elixir
defmodule DLM.SvdSSM do
  import Nx.Defn

  defn l2_normalize(tensor) do
    # Calculate Euclidean norm across the last axis natively
    norm = Nx.sqrt(Nx.sum(Nx.pow(tensor, 2), axes: [-1], keep_axes: true))
    # Divide by norm with a tiny epsilon to prevent divide-by-zero
    Nx.divide(tensor, Nx.add(norm, 1.0e-6))
  end

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn gelu(x) do
    cdf = Nx.multiply(
      Nx.tensor(0.7978845608, type: :f32),
      Nx.add(x, Nx.multiply(Nx.tensor(0.044715, type: :f32), Nx.pow(x, 3)))
    )
    Nx.multiply(Nx.multiply(Nx.tensor(0.5, type: :f32), x), Nx.add(Nx.tensor(1.0, type: :f32), Nx.tanh(cdf)))
  end

  defn swish(x) do
    Nx.multiply(x, Nx.sigmoid(x))
  end

  defn apply_svd(x, u, v) do
    gelu(x) |> Nx.dot(u) |> Nx.tanh() |> Nx.dot(v)
  end

  defn softplus(x) do
    Nx.log1p(Nx.exp(x))
  end

  defn softmax(t) do
    max_val = Nx.reduce_max(t, axes: [-1], keep_axes: true)
    safe_t = Nx.subtract(t, max_val)
    exps = Nx.exp(safe_t)
    sum_exps = Nx.sum(exps, axes: [-1], keep_axes: true)
    Nx.divide(exps, Nx.add(sum_exps, 1.0e-8))
  end

  defn forward_step(x_t1, x_t2, x_t3, h1p, h2p, h3p, p, mb) do 
    {e1, e2, e3, a1, a2, a3, b1, b2, b3, c1, c2, c3, 
     d1, d2, d3, h1, h2, h3, q1, q2, q3, i1, i2, i3,
     j1, j2, j3, k1, k2, k3, r1, r2, r3, s1, s2, s3,
     f1, f2, f3, g1, g2, g3, n1, n2, n3} = p
    
    # 1. FIX: Input on the left, weights on the right
    xt_1 = Nx.dot(Nx.take(e1, x_t1), b1) |> gelu()
    xt_2 = Nx.dot(Nx.take(e2, x_t2), b2) |> gelu()
    xt_3 = Nx.dot(Nx.take(e3, x_t3), b3) |> gelu()

    # 2. FIX: Hadamard Multiplication for Batch-Safe Attention!
    xt1_1 = Nx.multiply(xt_1, xt_1) 
    xt1_2 = Nx.multiply(xt_1, xt_2) 
    xt1_3 = Nx.multiply(xt_1, xt_3) 
    
    xt2_1 = Nx.multiply(xt_2, xt_1) 
    xt2_2 = Nx.multiply(xt_2, xt_2) 
    xt2_3 = Nx.multiply(xt_2, xt_3) 
    
    xt3_1 = Nx.multiply(xt_3, xt_1)
    xt3_2 = Nx.multiply(xt_3, xt_2) 
    xt3_3 = Nx.multiply(xt_3, xt_3)

    # 3. FIX: Parentheses before pipes!
    xt1t = (xt1_1 + xt1_2 + xt1_3)
    xt2t = (xt2_1 + xt2_2 + xt2_3) 
    xt3t = (xt3_1 + xt3_2 + xt3_3)

    xt_1t = Nx.dot(xt1t, i1) |> Nx.dot(j1)
    xt_2t = Nx.dot(xt2t, i2) |> Nx.dot(j2)
    xt_3t = Nx.dot(xt3t, i3) |> Nx.dot(j3)

    # Re-project hidden states (Inputs on left!)
    h1a = Nx.dot(h1p, a1) |> gelu()
    h2a = Nx.dot(h2p, a2) |> gelu()
    h3a = Nx.dot(h3p, a3) |> gelu()

    # Hidden State Batch-Safe Attention
    h1_p1 = Nx.multiply(h1a, h1a) 
    h1_p2 = Nx.multiply(h1a, h2a) 
    h1_p3 = Nx.multiply(h1a, h3a) 
    
    h2_p1 = Nx.multiply(h2a, h1a) 
    h2_p2 = Nx.multiply(h2a, h2a) 
    h2_p3 = Nx.multiply(h2a, h3a) 
    
    h3_p1 = Nx.multiply(h3a, h1a) 
    h3_p2 = Nx.multiply(h3a, h2a)
    h3_p3 = Nx.multiply(h3a, h3a)

    h1t = (h1_p2 + h1_p3 + h1_p1)
    h2t = (h2_p1 + h2_p2 + h2_p3)
    h3t = (h3_p1 + h3_p2 + h3_p3)

    ht_1t = Nx.dot(h1t, k1) |> Nx.dot(n1)
    ht_2t = Nx.dot(h2t, k2) |> Nx.dot(n2)
    ht_3t = Nx.dot(h3t, k3) |> Nx.dot(n3)

    # 4. Mix Memory and Inputs cleanly
    hn1 = (ht_1t + xt_1t) |> rms_norm()
    hn2 = (ht_2t + xt_2t) |> rms_norm()
    hn3 = (ht_3t + xt_3t) |> rms_norm()

    # Latent Layer Attention
    l1_1latent = Nx.dot(Nx.multiply(hn1, hn1), c1)
    l1_2latent = Nx.dot(Nx.multiply(hn1, hn2), c1)
    l1_3latent = Nx.dot(Nx.multiply(hn1, hn3), c1)
    
    l2_1latent = Nx.dot(Nx.multiply(hn2, hn1), c2)
    l2_2latent = Nx.dot(Nx.multiply(hn2, hn2), c2)
    l2_3latent = Nx.dot(Nx.multiply(hn2, hn3), c2)
    
    l3_1latent = Nx.dot(Nx.multiply(hn3, hn1), c3) 
    l3_2latent = Nx.dot(Nx.multiply(hn3, hn2), c3)
    l3_3latent = Nx.dot(Nx.multiply(hn3, hn3), c3)

    l1t = (l1_2latent + l1_3latent + l1_1latent)
    l2t = (l2_1latent + l2_3latent + l2_2latent)
    l3t = (l3_1latent + l3_2latent + l3_3latent)

    lt_1t = Nx.dot(l1t, r1) |> Nx.dot(s1)
    lt_2t = Nx.dot(l2t, r2) |> Nx.dot(s2)
    lt_3t = Nx.dot(l3t, r3) |> Nx.dot(s3)

    ltt = (lt_1t + lt_2t + lt_3t) |> rms_norm()

     # ⚡ 2. THE STABILIZED LIGHTNING INDEXER ⚡
    ql1 = Nx.dot(ltt, q1) |> Nx.new_axis(1)
    ql2 = Nx.dot(ltt, q2) |> Nx.new_axis(1)
    ql3 = Nx.dot(ltt, q3) |> Nx.new_axis(1)
    mbt = Nx.transpose(mb, axes: [0, 2, 1]) 
    
    # 1. Calculate raw scores
    rsl1 = Nx.dot(ql1, [2], [0], mbt, [1], [0])
    rsl2 = Nx.dot(ql2, [2], [0], mbt, [1], [0])
    rsl3 = Nx.dot(ql3, [2], [0], mbt, [1], [0])


    # 2. SCALE DOWN THE VARIANCE (sqrt of 128 - 11.3137)
    scsl1 = Nx.divide(rsl1, 16.0)
    scsl2 = Nx.divide(rsl2, 16.0)
    scsl3 = Nx.divide(rsl3, 16.0)

    # 3. SOFTMAX FOR GUARANTEED GRADIENT FLOW
    atwl1 = Nx.exp(scsl1)
    suwl1 = Nx.sum(atwl1, axes: [-1], keep_axes: true)
    sawl1 = Nx.divide(atwl1, Nx.add(suwl1, 1.0e-8))

    atwl2 = Nx.exp(scsl2)
    suwl2 = Nx.sum(atwl2, axes: [-1], keep_axes: true)
    sawl2 = Nx.divide(atwl2, Nx.add(suwl2, 1.0e-8))

    atwl3 = Nx.exp(scsl3)
    suwl3 = Nx.sum(atwl3, axes: [-1], keep_axes: true)
    sawl3 = Nx.divide(atwl3, Nx.add(suwl3, 1.0e-8))

    # 4. Retrieve Context
    rctxl1 = Nx.dot(sawl1, [2], [0], mb, [1], [0]) |> Nx.squeeze(axes: [1])
    rctxl2 = Nx.dot(sawl2, [2], [0], mb, [1], [0]) |> Nx.squeeze(axes: [1])
    rctxl3 = Nx.dot(sawl3, [2], [0], mb, [1], [0]) |> Nx.squeeze(axes: [1])

    lt1 = ltt + rctxl1
    lt2 = ltt + rctxl2
    lt3 = ltt + rctxl3

    lg1 = Nx.dot(lt1, f1) |> Nx.dot(g1)
    lg2 = Nx.dot(lt2, f2) |> Nx.dot(g2)
    lg3 = Nx.dot(lt3, f3) |> Nx.dot(g3)

    # Output Projections (Inputs on left!)
    lg_1 = Nx.dot(lg1, d1)
    lg_2 = Nx.dot(lg2, d2)
    lg_3 = Nx.dot(lg3, d3)

    h1_raw = Nx.dot(hn1, h1)
    h2_raw = Nx.dot(hn2, h2)
    h3_raw = Nx.dot(hn3, h3)
    
    hcf = (h1_raw + h2_raw + h3_raw) 
    
    # Still keep the normalized versions to pass to the next time step!
    h1f = h1_raw |> rms_norm()
    h2f = h2_raw |> rms_norm()
    h3f = h3_raw |> rms_norm()

    smb = Nx.slice_along_axis(mb, 1, 127, axis: 1)
    nmb = Nx.concatenate([smb, Nx.new_axis(hcf, 1)], axis: 1)
    
    {lg_1, lg_2, lg_3, h1f, h2f, h3f, nmb}
  end
end
```

