## SSM

```elixir
defmodule DLM.SvdSSM do
  import Nx.Defn

  defn l2_normalize(tensor) do
    # Calculate Euclidean norm across the last axis natively
    norm = Nx.sqrt(Nx.sum(Nx.pow(tensor, 2), axes: [-1], keep_axes: true))
    # Divide by norm with a tiny epsilon to prevent divide-by-zero
    Nx.divide(tensor, Nx.add(norm, 1.0e-6))
  end

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn gelu(x) do
    cdf = Nx.multiply(
      Nx.tensor(0.7978845608, type: :f32),
      Nx.add(x, Nx.multiply(Nx.tensor(0.044715, type: :f32), Nx.pow(x, 3)))
    )
    Nx.multiply(Nx.multiply(Nx.tensor(0.5, type: :f32), x), Nx.add(Nx.tensor(1.0, type: :f32), Nx.tanh(cdf)))
  end

  defn swish(x) do
    Nx.multiply(x, Nx.sigmoid(x))
  end

  defn apply_svd(x, u, v) do
    gelu(x) |> Nx.dot(u) |> Nx.tanh() |> Nx.dot(v)
  end

  defn softplus(x) do
    Nx.log1p(Nx.exp(x))
  end

  defn softmax(t) do
    max_val = Nx.reduce_max(t, axes: [-1], keep_axes: true)
    safe_t = Nx.subtract(t, max_val)
    exps = Nx.exp(safe_t)
    sum_exps = Nx.sum(exps, axes: [-1], keep_axes: true)
    Nx.divide(exps, Nx.add(sum_exps, 1.0e-8))
  end

  defn forward_project(xt_1, xt_2, xt_3, h1p, h2p, h3p, p, mb) do
    {_em, _eq, _er, _es, qp, _qq, au, av, aw, ax, ay, az, bu, bv, bw, bx, by, bz, 
      _cu, _cv, _cw, _cx, _cy, _cz, _du, _dv, _dw, _dx, _dy, _dz} = p
     
    h1_proj = apply_svd(h1p, au, av)
    h2_proj = apply_svd(h2p, aw, ax)
    h3_proj = apply_svd(h3p, ay, az)

    c_h_proj = (h1_proj + h2_proj + h3_proj)

    xt1_proj = apply_svd(xt_1, bu, bv)
    xt2_proj = apply_svd(xt_2, bw, bx)
    xt3_proj = apply_svd(xt_3, by, bz)

    # csa 1 h1p base to remember what's going to dropp off

    c_x_proj = (xt1_proj + xt2_proj + xt3_proj)

    # ⚡ 2. THE STABILIZED LIGHTNING INDEXER ⚡
    query = Nx.dot(c_x_proj, qp) |> Nx.new_axis(1) 
    mt = Nx.transpose(mb, axes: [0, 2, 1]) 
    
    # 1. Calculate raw scores
    rs = Nx.dot(query, [2], [0], mt, [1], [0])

    # 2. SCALE DOWN THE VARIANCE (sqrt of 128)
    scs = Nx.divide(rs, 11.3137)

    # 3. SOFTMAX FOR GUARANTEED GRADIENT FLOW
    # (We apply it across the 'Slots' axis, which is axis -1)
    atw = Nx.exp(scs)
    suw = Nx.sum(atw, axes: [-1], keep_axes: true)
    saw = Nx.divide(atw, Nx.add(suw, 1.0e-8))

    # 4. Retrieve Context
    rctx = Nx.dot(saw, [2], [0], mb, [1], [0]) |> Nx.squeeze(axes: [1])

    Nx.add(c_h_proj, c_x_proj) |> Nx.add(rctx) |> rms_norm()
  end

  defn forward_latent(xt_1, xt_2, xt_3, h1n, h2n, h3n, p, mc) do
    {_em, _eq, _er, _es, _qp, qq, _au, _av, _aw, _ax, _ay, _az, _bu, _bv, _bw, _bx, _by, _bz, 
      cu, cv, cw, cx, cy, cz, du, dv, dw, dx, dy, dz} = p
    
    h1_latent = apply_svd(h1n, cu, cv)
    h2_latent = apply_svd(h2n, cw, cx)
    h3_latent = apply_svd(h3n, cy, cz)

    c_h_latent = (h1_latent + h2_latent + h3_latent)

    x1_latent = apply_svd(xt_1, du, dv)
    x2_latent = apply_svd(xt_2, dw, dx)
    x3_latent = apply_svd(xt_3, dy, dz)

    c_x_latent = (x1_latent + x2_latent + x3_latent)

    # ⚡ 2. THE STABILIZED LIGHTNING INDEXER ⚡
    lq = Nx.dot(c_x_latent, qq) |> Nx.new_axis(1) 
    mct = Nx.transpose(mc, axes: [0, 2, 1]) 
    
    # 1. Calculate raw scores
    rsc = Nx.dot(lq, [2], [0], mct, [1], [0])

    # 2. SCALE DOWN THE VARIANCE (sqrt of 128)
    scsc = Nx.divide(rsc, 11.3137)

    # 3. SOFTMAX FOR GUARANTEED GRADIENT FLOW
    # (We apply it across the 'Slots' axis, which is axis -1)
    atwc = Nx.exp(scsc)
    suwc = Nx.sum(atwc, axes: [-1], keep_axes: true)
    sawc = Nx.divide(atwc, Nx.add(suwc, 1.0e-8))

    # 4. Retrieve Context
    rctxc = Nx.dot(sawc, [2], [0], mc, [1], [0]) |> Nx.squeeze(axes: [1])

    Nx.add(c_h_latent, c_x_latent) |> Nx.add(rctxc) |> rms_norm()
  end

  defn forward_step(x_t1, x_t2, x_t3, h1_prev, h2_prev, h3_prev, params, mb, mc) do 
    em = elem(params, 0)
    eq = elem(params, 1) 
    er = elem(params, 2) 
    es = elem(params, 3) 
    xt_1 = Nx.take(em, x_t1)
    xt_2 = Nx.take(em, x_t2)
    xt_3 = Nx.take(em, x_t3)
    
    h1n = forward_project(xt_1, xt_2, xt_3, h1_prev, h2_prev, h3_prev, params, mb)
    l4 = forward_latent(xt_1, xt_2, xt_3, h1n, h1_prev, h2_prev, params, mc)
    lg_4 = Nx.dot(l4, eq)
    xt_4 = softmax(lg_4) |> Nx.dot(em)
    smb = Nx.slice_along_axis(mb, 1, 63, axis: 1)
    mb2 = Nx.concatenate([smb, Nx.new_axis(h1n, 1)], axis: 1)
    smc = Nx.slice_along_axis(mc, 1, 63, axis: 1)
    mc2 = Nx.concatenate([smc, Nx.new_axis(h1n, 1)], axis: 1)
    
    h2n = forward_project(xt_2, xt_3, xt_4, h2_prev, h3_prev, h1n, params, mb2)
    l5 = forward_latent(xt_2, xt_3, xt_4, h2n, h1n, h1_prev, params, mc2)
    lg_5 = Nx.dot(l5, er)
    xt_5 = softmax(lg_5) |> Nx.dot(em)
    smb2 = Nx.slice_along_axis(mb2, 1, 63, axis: 1)
    mb3 = Nx.concatenate([smb2, Nx.new_axis(h2n, 1)], axis: 1)
    smc2 = Nx.slice_along_axis(mc2, 1, 63, axis: 1)
    mc3 = Nx.concatenate([smc2, Nx.new_axis(h2n, 1)], axis: 1)
    
    h3n = forward_project(xt_3, xt_4, xt_5, h3_prev, h1n, h2n, params, mb3)
    l6 = forward_latent(xt_3, xt_4, xt_5, h3n, h2n, h1n, params, mc3)
    lg_6 = Nx.dot(l6, es)
    smb3 = Nx.slice_along_axis(mb3, 1, 63, axis: 1)
    mb4 = Nx.concatenate([smb3, Nx.new_axis(h3n, 1)], axis: 1)
    smc3 = Nx.slice_along_axis(mc3, 1, 63, axis: 1)
    mc4 = Nx.concatenate([smc3, Nx.new_axis(h3n, 1)], axis: 1)
    
    {lg_4, lg_5, lg_6, h1n, h2n, h3n, mb4, mc4}
  end
end
```

