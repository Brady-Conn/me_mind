## SSM

```elixir
defmodule DLM.SvdSSM do
  import Nx.Defn

  defn rms_norm(x, gamma, beta, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    norm = x * Nx.rsqrt(variance + epsilon)
    scaled = norm * Nx.sigmoid(gamma)# sigmoid for gamma?
    scaled + beta
  end

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn gelu(x) do
    cdf = Nx.multiply(
      Nx.tensor(0.7978845608, type: :f32),
      Nx.add(x, Nx.multiply(Nx.tensor(0.044715, type: :f32), Nx.pow(x, 3)))
    )
    Nx.multiply(Nx.multiply(Nx.tensor(0.5, type: :f32), x), Nx.add(Nx.tensor(1.0, type: :f32), Nx.tanh(cdf)))
  end
  
  defn feed_forward_layer(x, um, ga, bi, dm) do
    up = Nx.dot(x, um) 
    act = gelu(up) #was tanh
    scaled = Nx.multiply(act, Nx.sigmoid(ga))
    biased = Nx.add(scaled, bi)
    Nx.dot(biased, dm) 
  end

  defn softmax(t) do
    max_val = Nx.reduce_max(t, axes: [-1], keep_axes: true)
    safe_t = Nx.subtract(t, max_val)
    exps = Nx.exp(safe_t)
    sum_exps = Nx.sum(exps, axes: [-1], keep_axes: true)
    Nx.divide(exps, Nx.add(sum_exps, 1.0e-8))
  end

  defn forward_step(x_t, h_prev, ctx_prev, p) do
    {a, b1, b2, bb, bs, bg, be, c1, c2, cb, cs, d1, d2, db, ds, qa, em} = p
    # apply time scale
    ts = Nx.sigmoid(a)
    hpsc = Nx.multiply(h_prev, ts)
    ctxpsc = Nx.multiply(ctx_prev, ts)
    # process incomming token
    u_t = Nx.take(em, x_t) # -> {batch, 128}
    # 128 -> 512 -> 128
    b_term = feed_forward_layer(u_t, b1, bs, bb, b2)
    b_norm = rms_norm(b_term, bg, be)
    # slice, concat next token - hn_base
    hpsl = Nx.slice_along_axis(hpsc, 1, 255, axis: 1)
    h_new = Nx.concatenate([hpsl, Nx.new_axis(b_norm, 1)], axis: 1)
    # query - apply time scale to hl_prev before query?
    qh = Nx.dot(b_norm, qa) |> Nx.new_axis(1)
    hnt = Nx.transpose(h_new, axes: [0, 2, 1])
    # score
    rshn = Nx.dot(qh, [2], [0], hnt, [1], [0])
    # scale (sqrt of 128 - 11.3137, 256 -> 16.0, 512 -> 22.6274)
    # sscrh = Nx.divide(rsh, 11.3137)
    # softmax normalization
    sfschn = softmax(rshn)
    ctxhn = Nx.dot(sfschn, [2], [0], h_new, [1], [0]) |> Nx.squeeze(axes: [1])
    # calculate change in state
    c_term = feed_forward_layer(ctxhn, c1, cs, cb, c2)
    
    d_term = feed_forward_layer(ctxpsc, d1, ds, db, d2)
    
    # look at change in state over time 128->128
    logits = Nx.subtract(c_term, d_term)

    {logits, h_new, ctxhn}
  end
end
