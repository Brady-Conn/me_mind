```elixir
defmodule DLM.PhysicsGenesis do
  import Nx.Defn

  @vocab 128
  @dim 512
  # @seq_len 256

  defn init(k1) do
    std_dim = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@dim, type: :f32)))
    std_voc = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@vocab, type: :f32)))
    # std_sql = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@seq_len, type: :f32)))

    # time step scaling vector
    a = Nx.broadcast(0.0, {@vocab}) |> Nx.as_type(:f32)
    # projection matrices
    {b1, k2} = Nx.Random.normal(k1, 0.0, std_voc, shape: {@vocab, @dim})
    {b2, k3} = Nx.Random.normal(k2, 0.0, std_dim, shape: {@dim, @vocab})
    {c1, k4} = Nx.Random.normal(k3, 0.0, std_dim, shape: {@vocab, @dim})
    {c2, k5} = Nx.Random.normal(k4, 0.0, std_dim, shape: {@dim, @vocab})
    {d1, k6} = Nx.Random.normal(k5, 0.0, std_dim, shape: {@vocab, @dim})
    {d2, k7} = Nx.Random.normal(k6, 0.0, std_dim, shape: {@dim, @vocab})

    # projection bias vectors
    bb = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    cb = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    db = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    # projection scaling vectors
    bs = Nx.broadcast(1.0, {@dim}) |> Nx.as_type(:f32)
    cs = Nx.broadcast(1.0, {@dim}) |> Nx.as_type(:f32)
    ds = Nx.broadcast(1.0, {@dim}) |> Nx.as_type(:f32)
    # rms norm beta and gamma vectors
    be = Nx.broadcast(0.0, {@vocab}) |> Nx.as_type(:f32)
    bg = Nx.broadcast(1.0, {@vocab}) |> Nx.as_type(:f32)
    # embedding map matrix
    {em, k8} = Nx.Random.normal(k7, 0.0, std_voc, shape: {@vocab, @vocab})
    # query matrix
    {qa, k9} = Nx.Random.normal(k8, 0.0, std_dim, shape: {@vocab, @vocab})
    
    trainable_params = {a, b1, b2, bb, bs, bg, be, c1, c2, cb, cs, d1, d2, db, ds, qa, em}
    
    {trainable_params, k9}
  end
end
