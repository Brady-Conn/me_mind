## SSM

```elixir
defmodule DLM.SvdSSM do
  import Nx.Defn

  defn rms_norm(x, gamma, beta, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    norm = x * Nx.rsqrt(variance + epsilon)
    scale = Nx.sigmoid(gamma) * 2.0 # allow for scaling above 1 but max 2
    scaled = norm * scale
    scaled + beta
  end

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn gelu(x) do
    cdf = Nx.multiply(
      Nx.tensor(0.7978845608, type: :f32),
      Nx.add(x, Nx.multiply(Nx.tensor(0.044715, type: :f32), Nx.pow(x, 3)))
    )
    Nx.multiply(Nx.multiply(Nx.tensor(0.5, type: :f32), x), Nx.add(Nx.tensor(1.0, type: :f32), Nx.tanh(cdf)))
  end
  
  defn feed_forward_layer(x, um, ga, bi, dm) do
    up = Nx.dot(x, um) 
    act = gelu(up) #was tanh
    scale = Nx.sigmoid(ga) * 2.0 # allow for scaling above 1 but max 2
    scaled = Nx.multiply(act, scale)
    biased = Nx.add(scaled, bi)
    Nx.dot(biased, dm) 
  end

  defn softmax(t) do
    max_val = Nx.reduce_max(t, axes: [-1], keep_axes: true)
    safe_t = Nx.subtract(t, max_val)
    exps = Nx.exp(safe_t)
    sum_exps = Nx.sum(exps, axes: [-1], keep_axes: true)
    Nx.divide(exps, Nx.add(sum_exps, 1.0e-8))
  end

  defn softplus_elementwise(x) do
    Nx.log(1 + Nx.exp(x))
  end

  defn forward_step(x_t, h_prev, ctx_prev, p, fm) do
    # add the 3 char input -> sliding 3 char prediction
    # or pred 3 + per itr but only calc loss on next which is a weighted sum of the prior predictions
    {_hb, b1, b2, bb, bs, bg, be, d1, d2, db, ds, cq} = p
    # use markov chain for em and ed
    # apply time scale
    time_scale = Nx.sqrt(512) # seq len
    scaled_hp = Nx.divide(h_prev, time_scale)
    # process incomming token
    u_t = Nx.take(fm, x_t) # -> {batch, 128}
    
    # query
    qctx = Nx.dot(u_t, cq) |> Nx.new_axis(1)
    ctxnt = Nx.transpose(ctx_prev, axes: [0, 2, 1])
    # score
    rsctx = Nx.dot(qctx, [2], [0], ctxnt, [1], [0])
    # scale
    scsctx = Nx.divide(rsctx, Nx.sqrt(16))
    # softmax normalization
    sfscctx = softmax(scsctx) # try with out softmax but root-dim scaling and without both
    ctxattn = Nx.dot(sfscctx, [2], [0], ctx_prev, [1], [0]) |> Nx.squeeze(axes: [1])
    # add atten for last 16 characters
    u_atten = Nx.add(u_t, ctxattn)
    # update ctx
    ctx_sl = Nx.slice_along_axis(ctx_prev, 1, 15, axis: 1)
    ctx_new = Nx.concatenate([ctx_sl, Nx.new_axis(u_t, 1)], axis: 1)
    # 128 -> 512 -> 128
    b_term = feed_forward_layer(u_atten, b1, bs, bb, b2)
    b_norm = rms_norm(b_term, bg, be)
    # initial hiddden state update
    h_new = Nx.add(scaled_hp, b_norm)
    # look at change in state over time 128->128
    delta_h = Nx.subtract(h_new, h_prev)
    # process delta h 512->512->128
    logits = feed_forward_layer(delta_h, d1, ds, db, d2)
    
    {logits, h_new, ctx_new}
  end
end
