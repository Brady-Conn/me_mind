```elixir
defmodule DLM.PhysicsGenesis do
  import Nx.Defn

  @vocab 128
  @dim 512
  # @seq_len 256

  defn init(k1) do
    std_dim = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@dim, type: :f32)))
    std_voc = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@vocab, type: :f32)))
    std_16 = Nx.divide(1.0, Nx.sqrt(Nx.tensor(16, type: :f32)))

    # projection matrices
    {b1, k2} = Nx.Random.normal(k1, 0.0, std_voc, shape: {@vocab, @dim})
    {b2, k3} = Nx.Random.normal(k2, 0.0, std_dim, shape: {@dim, @dim})
    {d1, k4} = Nx.Random.normal(k3, 0.0, std_dim, shape: {@dim, @dim})
    {d2, k5} = Nx.Random.normal(k4, 0.0, std_dim, shape: {@dim, @vocab})

    {hb, k6} = Nx.Random.normal(k5, 0.0, std_16, shape: {16, @vocab})
    {cq, k7} = Nx.Random.normal(k6, 0.0, std_voc, shape: {@vocab, @vocab})

    # projection bias vectors
    bb = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    db = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    # projection scaling vectors
    bs = Nx.broadcast(0.5, {@dim}) |> Nx.as_type(:f32)
    ds = Nx.broadcast(0.5, {@dim}) |> Nx.as_type(:f32)
    # rms norm beta and gamma vectors
    be = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    bg = Nx.broadcast(0.5, {@dim}) |> Nx.as_type(:f32)
    
    trainable_params = {hb, b1, b2, bb, bs, bg, be, d1, d2, db, ds, cq}
    
    {trainable_params, k7}
  end
end
