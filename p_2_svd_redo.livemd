```elixir
defmodule DLM.PhysicsGenesis do
  import Nx.Defn

  @dim 256
  @rank 128
  @vocab_size 128

  defn ignite(key) do

    # Xavier/Glorot Initialization
    # std_512 = Nx.divide(1.0, Nx.sqrt(512))
    std_256 = Nx.divide(1.0, Nx.sqrt(256))
    std_128 = Nx.divide(1.0, Nx.sqrt(128))
    # a: Friction/Inertia
    {au, k1} = Nx.Random.normal(key, 0.0, std_256, shape: {@dim, @rank})
    {av, k2} = Nx.Random.normal(k1, 0.0, std_128, shape: {@rank, @dim})
    
    # b: Input Force Matrices
    {zu, k3} = Nx.Random.normal(k2, 0.0, std_256, shape: {@dim, @rank})
    {zv, k4} = Nx.Random.normal(k3, 0.0, std_128, shape: {@rank, @dim})

    {em, k5} = Nx.Random.normal(k4, 0.0, std_128, shape: {@vocab_size, @dim})

    {{em, au, av, zu, zv}, k5}
  end
end
