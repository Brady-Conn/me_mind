```elixir
defmodule DLM.SvdOptimizer do
  import Nx.Defn

  # Correctly scales the entire matrix to preserve geometric direction
  defn clip_norm(tensor, max_norm) do
    norm = Nx.add(Nx.sqrt(Nx.sum(Nx.pow(tensor, 2))), 1.0e-8)
    scale = Nx.min(1.0, Nx.divide(max_norm, norm))
    Nx.multiply(tensor, scale)
  end

  # Adaptive Decay Function
  defn adaptive_decay(old_w, new_w, cg_w, lr, decay \\ 1.0e-4) do
    # 1. Norms (using the CLIPPED gradients)
    w_norm = Nx.add(Nx.LinAlg.norm(old_w), 1.0e-8)
    g_norm = Nx.add(Nx.LinAlg.norm(cg_w), 1.0e-8)
    
    # 2. LARS-style adaptation: w_norm / g_norm
    dynamic_scale = Nx.divide(w_norm, g_norm) |> Nx.clip(0.01, 10.0)
    
    # 3. Apply
    tailored_wd = Nx.multiply(decay, dynamic_scale)
    penalty = Nx.multiply(old_w, Nx.multiply(lr, tailored_wd))
    
    Nx.subtract(new_w, penalty)
  end

  defn update(params, grads, step, lr) do
    {em, au, av, zu, zv} = params
    {gem, gau, gav, gzu, gzv} = grads

    new_step = Nx.add(step, 1)
    # optimizer update step
    em_new = DLM.SparseSinkGD.step(em, gem, lr)
    au_new = DLM.SparseSinkGD.step(au, gau, lr)
    av_new = DLM.SparseSinkGD.step(av, gav, lr)
    zu_new = DLM.SparseSinkGD.step(zu, gzu, lr)
    zv_new = DLM.SparseSinkGD.step(zv, gzv, lr)

    new_params = {em_new, au_new, av_new, zu_new, zv_new}

    {new_params, new_step}
  end
end
