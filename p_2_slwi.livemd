```elixir
defmodule DLM.SvdOptimizer do
  import Nx.Defn

  defn update(params, grads, step, lr) do
    {h, b1, b2, bb, bq, bg, be, 
     c1, c2, cb, cq, cg, ce,
     d1, d2, db, dq, dg, de,
     e1, e2, eb, eq, eg, ee,
     em, ed} = params   
    {gh, gb1, gb2, gbb, gbq, gbg, gbe, 
      gc1, gc2, gcb, gcq, gcg, gce,
      gd1, gd2, gdb, gdq, gdg, gde,
      ge1, ge2, geb, geq, geg, gee,
      gem, ged} = grads
    
    new_step = Nx.add(step, 1)

    # optimizer update step
    b1_new = DLM.StatelessMuon.muon_step(b1, gb1, lr)
    b2_new = DLM.StatelessMuon.muon_step(b2, gb2, lr)
    c1_new = DLM.StatelessMuon.muon_step(c1, gc1, lr)
    c2_new = DLM.StatelessMuon.muon_step(c2, gc2, lr)
    d1_new = DLM.StatelessMuon.muon_step(d1, gd1, lr)
    d2_new = DLM.StatelessMuon.muon_step(d2, gd2, lr)
    e1_new = DLM.StatelessMuon.muon_step(e1, ge1, lr)
    e2_new = DLM.StatelessMuon.muon_step(e2, ge2, lr)

    bb_new = DLM.StatelessMuon.muon_step(bb, gbb, lr)
    cb_new = DLM.StatelessMuon.muon_step(cb, gcb, lr)
    db_new = DLM.StatelessMuon.muon_step(db, gdb, lr)
    eb_new = DLM.StatelessMuon.muon_step(eb, geb, lr)

    bq_new = DLM.StatelessMuon.muon_step(bq, gbq, lr)
    cq_new = DLM.StatelessMuon.muon_step(cq, gcq, lr)
    dq_new = DLM.StatelessMuon.muon_step(eq, gdq, lr)
    eq_new = DLM.StatelessMuon.muon_step(dq, geq, lr)

    be_new = DLM.StatelessMuon.muon_step(be, gbe, lr)
    bg_new = DLM.StatelessMuon.muon_step(bg, gbg, lr)
    ce_new = DLM.StatelessMuon.muon_step(ce, gce, lr)
    cg_new = DLM.StatelessMuon.muon_step(cg, gcg, lr)
    de_new = DLM.StatelessMuon.muon_step(de, gde, lr)
    dg_new = DLM.StatelessMuon.muon_step(dg, gdg, lr)
    ee_new = DLM.StatelessMuon.muon_step(ee, gee, lr)
    eg_new = DLM.StatelessMuon.muon_step(eg, geg, lr)
    
    em_new = DLM.StatelessMuon.muon_step(em, gem, lr)
    ed_new = DLM.StatelessMuon.muon_step(ed, ged, lr)

    h_new = DLM.StatelessMuon.muon_step(h, gh, lr)
    
    new_params = {h_new, b1_new, b2_new, bb_new, bq_new, bg_new, be_new,
                  c1_new, c2_new, cb_new, cq_new, cg_new, ce_new,
                  d1_new, d2_new, db_new, dq_new, dg_new, ee_new,
                  e1_new, e2_new, eb_new, eq_new, eg_new, de_new,
                  em_new, ed_new}

    {new_params, new_step}
  end
end
