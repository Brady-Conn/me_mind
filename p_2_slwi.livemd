```elixir
defmodule DLM.PhysicsGenesis do
  import Nx.Defn

  @vocab 128
  @rank 512

  defn init(k1) do
    std_rnk = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@rank, type: :f32)))
    std_voc = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@vocab, type: :f32)))
    std_16 = Nx.divide(1.0, Nx.sqrt(Nx.tensor(16, type: :f32)))
    std_256 = Nx.divide(1.0, Nx.sqrt(Nx.tensor(256, type: :f32)))

    # projection matrices
    {b1, k2} = Nx.Random.normal(k1, 0.0, std_voc, shape: {@vocab, @rank})
    {b2, k3} = Nx.Random.normal(k2, 0.0, std_rnk, shape: {@rank, @vocab})
    {c1, k4} = Nx.Random.normal(k3, 0.0, std_voc, shape: {@vocab, @rank})
    {c2, k5} = Nx.Random.normal(k4, 0.0, std_rnk, shape: {@rank, @vocab})
    {d1, k6} = Nx.Random.normal(k5, 0.0, std_voc, shape: {@vocab, @rank})
    {d2, k7} = Nx.Random.normal(k6, 0.0, std_rnk, shape: {@rank, @vocab})
    {e1, k8} = Nx.Random.normal(k7, 0.0, std_voc, shape: {@vocab, @rank})
    {e2, k9} = Nx.Random.normal(k8, 0.0, std_rnk, shape: {@rank, @vocab})

    # projection bias'
    bb = Nx.broadcast(0.0, {@rank}) |> Nx.as_type(:f32)
    cb = Nx.broadcast(0.0, {@rank}) |> Nx.as_type(:f32)
    db = Nx.broadcast(0.0, {@rank}) |> Nx.as_type(:f32)
    eb = Nx.broadcast(0.0, {@rank}) |> Nx.as_type(:f32)

    bq = Nx.broadcast(1.0, {@rank}) |> Nx.as_type(:f32)
    cq = Nx.broadcast(1.0, {@rank}) |> Nx.as_type(:f32)
    dq = Nx.broadcast(1.0, {@rank}) |> Nx.as_type(:f32)
    eq = Nx.broadcast(1.0, {@rank}) |> Nx.as_type(:f32)
    
    # rms norm beta and gamma
    be = Nx.broadcast(0.0, {@vocab}) |> Nx.as_type(:f32)
    bg = Nx.broadcast(1.0, {@vocab}) |> Nx.as_type(:f32)
    ce = Nx.broadcast(0.0, {@vocab}) |> Nx.as_type(:f32)
    cg = Nx.broadcast(1.0, {@vocab}) |> Nx.as_type(:f32)
    de = Nx.broadcast(0.0, {@vocab}) |> Nx.as_type(:f32)
    dg = Nx.broadcast(1.0, {@vocab}) |> Nx.as_type(:f32)
    ee = Nx.broadcast(0.0, {@vocab}) |> Nx.as_type(:f32)
    eg = Nx.broadcast(1.0, {@vocab}) |> Nx.as_type(:f32)

    {em, k10} = Nx.Random.normal(k9, 0.0, std_voc, shape: {@vocab, 8})
    {ed, k11} = Nx.Random.normal(k10, 0.0, std_256, shape: {@vocab, @vocab})

    {h, k12} = Nx.Random.normal(k11, 0.0, std_16, shape: {16, 8})

    trainable_params =  {h, b1, b2, bb, bq, bg, be, 
                         c1, c2, cb, cq, cg, ce,
                         d1, d2, db, dq, dg, de,
                         e1, e2, eb, eq, eg, ee,
                         em, ed}

    {trainable_params, k12}
  end
end
