## SSM

```elixir
defmodule DLM.SvdSSM do
  import Nx.Defn

  defn l2_normalize(tensor) do
    # Calculate Euclidean norm across the last axis natively
    norm = Nx.sqrt(Nx.sum(Nx.pow(tensor, 2), axes: [-1], keep_axes: true))
    # Divide by norm with a tiny epsilon to prevent divide-by-zero
    Nx.divide(tensor, Nx.add(norm, 1.0e-6))
  end

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn gelu(x) do
    cdf = Nx.multiply(
      Nx.tensor(0.7978845608, type: :f32),
      Nx.add(x, Nx.multiply(Nx.tensor(0.044715, type: :f32), Nx.pow(x, 3)))
    )
    Nx.multiply(Nx.multiply(Nx.tensor(0.5, type: :f32), x), Nx.add(Nx.tensor(1.0, type: :f32), Nx.tanh(cdf)))
  end

  defn swish(x) do
    Nx.multiply(x, Nx.sigmoid(x))
  end

  defn apply_svd(x, u, v) do
    gelu(x) |> Nx.dot(u) |> Nx.tanh() |> Nx.dot(v)
  end

  defn softplus(x) do
    Nx.log1p(Nx.exp(x))
  end

  defn softmax(t) do
    max_val = Nx.reduce_max(t, axes: [-1], keep_axes: true)
    safe_t = Nx.subtract(t, max_val)
    exps = Nx.exp(safe_t)
    sum_exps = Nx.sum(exps, axes: [-1], keep_axes: true)
    Nx.divide(exps, Nx.add(sum_exps, 1.0e-8))
  end

  defn forward_step(x_t1, x_t2, x_t3, h1p, h2p, h3p, params, mb, mc) do 
    {em, en, eo, eq, er, es, qm, qn, qo, qq, qr, qs, 
      au, av, aw, ax, ay, az, bu, bw, by, 
      cu, cv, cw, cx, cy, cz, du, dw, dy} = params
    
    xt_1 = Nx.take(em, x_t1)
    xt_2 = Nx.take(en, x_t2)
    xt_3 = Nx.take(eo, x_t3)

    h1_proj = Nx.dot(h1p, au)
    h2_proj = Nx.dot(h2p, aw)
    h3_proj = Nx.dot(h3p, ay)

    c_h_proj = Nx.add(h1_proj, h2_proj) |> Nx.add(h3_proj)

    xt1_proj = Nx.dot(xt_1, bu)
    xt2_proj = Nx.dot(xt_2, bw)
    xt3_proj = Nx.dot(xt_3, by)

    c_x_proj = Nx.add(xt1_proj, xt2_proj) |> Nx.add(xt3_proj)

    # ⚡ 2. THE STABILIZED LIGHTNING INDEXER ⚡
    q1 = Nx.dot(xt1_proj, qm) |> Nx.new_axis(1)
    q2 = Nx.dot(xt2_proj, qn) |> Nx.new_axis(1)
    q3 = Nx.dot(xt3_proj, qo) |> Nx.new_axis(1)
    mt = Nx.transpose(mb, axes: [0, 2, 1]) 
    
    # 1. Calculate raw scores
    rs1 = Nx.dot(q1, [2], [0], mt, [1], [0])
    rs2 = Nx.dot(q2, [2], [0], mt, [1], [0])
    rs3 = Nx.dot(q3, [2], [0], mt, [1], [0])

    # 2. SCALE DOWN THE VARIANCE (sqrt of 128)
    scs1 = Nx.divide(rs1, 16.0)
    scs2 = Nx.divide(rs2, 16.0)
    scs3 = Nx.divide(rs3, 16.0)

    # 3. SOFTMAX FOR GUARANTEED GRADIENT FLOW
    atw1 = Nx.exp(scs1)
    suw1 = Nx.sum(atw1, axes: [-1], keep_axes: true)
    saw1 = Nx.divide(atw1, Nx.add(suw1, 1.0e-8))

    atw2 = Nx.exp(scs2)
    suw2 = Nx.sum(atw2, axes: [-1], keep_axes: true)
    saw2 = Nx.divide(atw2, Nx.add(suw2, 1.0e-8))

    atw3 = Nx.exp(scs3)
    suw3 = Nx.sum(atw3, axes: [-1], keep_axes: true)
    saw3 = Nx.divide(atw3, Nx.add(suw3, 1.0e-8))

    # 4. Retrieve Context
    rctx1 = Nx.dot(saw1, [2], [0], mb, [1], [0]) |> Nx.squeeze(axes: [1])
    rctx2 = Nx.dot(saw2, [2], [0], mb, [1], [0]) |> Nx.squeeze(axes: [1])
    rctx3 = Nx.dot(saw3, [2], [0], mb, [1], [0]) |> Nx.squeeze(axes: [1])

    rctxc = Nx.add(rctx1, rctx2) |> Nx.add(rctx3)

    hnc = Nx.add(c_h_proj, c_x_proj) |> Nx.add(rctxc) |> rms_norm()

    h1_latent = Nx.dot(hnc, cu)
    h2_latent = Nx.dot(hnc, cw)
    h3_latent = Nx.dot(hnc, cy) 

    h_c_latent = Nx.add(h1_latent, h2_latent) |> Nx.add(h3_latent)

    x1_latent = Nx.dot(xt1_proj, du)
    x2_latent = Nx.dot(xt2_proj, dw) 
    x3_latent = Nx.dot(xt3_proj, dy) 

    x_c_latent = Nx.add(x1_latent, x2_latent) |> Nx.add(x3_latent)

     # ⚡ 2. THE STABILIZED LIGHTNING INDEXER ⚡
    ql1 = Nx.dot(x1_latent, qq) |> Nx.new_axis(1)
    ql2 = Nx.dot(x2_latent, qr) |> Nx.new_axis(1)
    ql3 = Nx.dot(x3_latent, qs) |> Nx.new_axis(1)
    mct = Nx.transpose(mc, axes: [0, 2, 1]) 
    
    # 1. Calculate raw scores
    rsl1 = Nx.dot(ql1, [2], [0], mct, [1], [0])
    rsl2 = Nx.dot(ql2, [2], [0], mct, [1], [0])
    rsl3 = Nx.dot(ql3, [2], [0], mct, [1], [0])

    # 2. SCALE DOWN THE VARIANCE (sqrt of 128)
    scsl1 = Nx.divide(rsl1, 16.0)
    scsl2 = Nx.divide(rsl2, 16.0)
    scsl3 = Nx.divide(rsl3, 16.0)

    # 3. SOFTMAX FOR GUARANTEED GRADIENT FLOW
    atwl1 = Nx.exp(scsl1)
    suwl1 = Nx.sum(atwl1, axes: [-1], keep_axes: true)
    sawl1 = Nx.divide(atwl1, Nx.add(suwl1, 1.0e-8))

    atwl2 = Nx.exp(scsl2)
    suwl2 = Nx.sum(atwl2, axes: [-1], keep_axes: true)
    sawl2 = Nx.divide(atwl2, Nx.add(suwl2, 1.0e-8))

    atwl3 = Nx.exp(scsl3)
    suwl3 = Nx.sum(atwl3, axes: [-1], keep_axes: true)
    sawl3 = Nx.divide(atwl3, Nx.add(suwl3, 1.0e-8))

    # 4. Retrieve Context
    rctxl1 = Nx.dot(sawl1, [2], [0], mc, [1], [0]) |> Nx.squeeze(axes: [1])
    rctxl2 = Nx.dot(sawl2, [2], [0], mc, [1], [0]) |> Nx.squeeze(axes: [1])
    rctxl3 = Nx.dot(sawl3, [2], [0], mc, [1], [0]) |> Nx.squeeze(axes: [1])

    rctxlc = Nx.add(rctxl1, rctxl2) |> Nx.add(rctxl3)

    hl1 = Nx.add(h1_latent, x1_latent) |> Nx.add(rctxl1) |> Nx.dot(av) |> rms_norm()
    hl2 = Nx.add(h2_latent, x2_latent) |> Nx.add(rctxl2) |> Nx.dot(ax) |> rms_norm()
    hl3 = Nx.add(h3_latent, x3_latent) |> Nx.add(rctxl3) |> Nx.dot(az) |> rms_norm()

    logits = Nx.add(h_c_latent, x_c_latent) |> Nx.add(rctxlc) |> rms_norm()
    
    lg_1 = Nx.dot(logits, cv) |> Nx.dot(eq)
    lg_2 = Nx.dot(logits, cx) |> Nx.dot(er)
    lg_3 = Nx.dot(logits, cz) |> Nx.dot(es)

    smb = Nx.slice_along_axis(mb, 1, 127, axis: 1)
    nmb = Nx.concatenate([smb, Nx.new_axis(hnc, 1)], axis: 1)

    smc = Nx.slice_along_axis(mc, 1, 127, axis: 1)
    nmc = Nx.concatenate([smc, Nx.new_axis(logits, 1)], axis: 1)
    
    {lg_1, lg_2, lg_3, hl1, hl2, hl3, nmb, nmc}
  end
end
```

