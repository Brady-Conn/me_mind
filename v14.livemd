## v12 migration

```elixir
# Choose which V12 checkpoint to migrate from
# phase2_bridge has seen more training including some definition context
# phase1_spelling has the purest morphological knowledge
# grammar_foundation_archive may have the most overall training
# Try phase2_bridge first as the best balance

source_path = "v12_phase2_bridge.bin"
out_path    = "dlm_v12_migrated.bin"

embed_dim  = 256
ff_dim     = 1024  # current model's ff dim
vocab_size = 128

v12 = File.read!(source_path) |> :erlang.binary_to_term()

IO.puts("Loaded #{source_path}")
IO.puts("Migrating V12 weights to current 13-tensor format...")

# ---------------------------------------------------------------------------
# Weights that transfer directly
# ---------------------------------------------------------------------------
embed = v12.e    # {128, 256} — carries morphological knowledge ✅
lm_w  = v12.lmw  # {256, 128} — output projection ✅
lm_b  = v12.lmb  # {128}      — output bias ✅

# Layer norm params — V12 used 1D gamma vectors, beta was hardcoded 0.0
# a1 was the gamma for the first layer norm
# a2 was the gamma for the second layer norm
g1 = v12.a1  # {256} ✅
g2 = v12.a2  # {256} ✅
b1 = Nx.broadcast(Nx.tensor(0.0, type: :f32), {embed_dim})  # was hardcoded 0
b2 = Nx.broadcast(Nx.tensor(0.0, type: :f32), {embed_dim})

# ---------------------------------------------------------------------------
# Weights that need fresh init (shape mismatch or didn't exist in V12)
# ---------------------------------------------------------------------------
key = Nx.Random.key(42)

# Attention projections — V12 had none, start fresh
# Using same 0.01 std as your genesis init
{w_q, key} = Nx.Random.normal(key, 0.0, 0.01, shape: {embed_dim, embed_dim}, type: :f32)
{w_k, key} = Nx.Random.normal(key, 0.0, 0.01, shape: {embed_dim, embed_dim}, type: :f32)
{w_v, key} = Nx.Random.normal(key, 0.0, 0.01, shape: {embed_dim, embed_dim}, type: :f32)
{w_o, key} = Nx.Random.normal(key, 0.0, 0.01, shape: {embed_dim, embed_dim}, type: :f32)

# FF weights — V12 was {256,512}/{512,256}, current is {256,1024}/{1024,256}
# Can't transfer directly, init fresh
# Using slightly larger std since ff_dim is bigger
{w_ff1, key} = Nx.Random.normal(key, 0.0, 0.01, shape: {embed_dim, ff_dim}, type: :f32)
{w_ff2, _}   = Nx.Random.normal(key, 0.0, 0.01, shape: {ff_dim, embed_dim}, type: :f32)

# ---------------------------------------------------------------------------
# Build the 13-tensor params tuple
# Order must match loss_fn/adam_step exactly
# ---------------------------------------------------------------------------
new_params = {
  embed,               # {128, 256}  ← V12 morphological embeddings
  w_q, w_k, w_v, w_o, # {256, 256}  ← fresh attention projections
  w_ff1, w_ff2,        # {256,1024}/{1024,256} ← fresh ff (bigger than V12)
  lm_w, lm_b,          # {256,128}/{128} ← V12 output projection
  g1, b1, g2, b2       # {256} ← V12 layer norm gammas, fresh betas
}

IO.puts("\nParam shapes:")
new_params |> Tuple.to_list() |> Enum.each(fn t ->
  IO.puts("  #{inspect(Nx.shape(t))}")
end)

# ---------------------------------------------------------------------------
# Zero Adam states
# ---------------------------------------------------------------------------
zero_like = fn t ->
  Nx.broadcast(Nx.tensor(0.0), Nx.shape(t)) |> Nx.backend_copy(Nx.BinaryBackend)
end

new_m = new_params |> Tuple.to_list() |> Enum.map(zero_like) |> List.to_tuple()

# ---------------------------------------------------------------------------
# Save in {p, m, v, step} quad format
# ---------------------------------------------------------------------------
to_binary = fn tuple ->
  tuple
  |> Tuple.to_list()
  |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend))
  |> List.to_tuple()
end

full_state = {to_binary.(new_params), new_m, new_m, 1}
File.write!(out_path, :erlang.term_to_binary(full_state))

IO.puts("\n✅ Migration complete → #{out_path}")
IO.puts("Transferred: embed, lm_w, lm_b, g1, g2 (V12 morphological knowledge)")
IO.puts("Fresh init:  w_q, w_k, w_v, w_o, w_ff1, w_ff2, b1, b2")
```

