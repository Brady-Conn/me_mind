## Train-13

```elixir
path            = "v13_lean_dictionary.txt"
full_state_path = "dlm_full_state.bin"

seq_len               = 256
batch_size            = 12
start_lr              = 0.00020
end_lr                = 0.00008
epochs                = 15
batches_per_epoch     = 178_718 |> div(batch_size)
total_steps           = epochs * batches_per_epoch

IO.puts("📊 #{batches_per_epoch} batches/epoch → #{total_steps} total steps")
```

```elixir
# ===========================================================================
# Configuration
# ===========================================================================
path            = "v13_lean_dictionary.txt"
full_state_path = "dlm_full_state.bin"
genesis_path    = "dlm_genesis.bin"

seq_len                = 256
batch_size             = 12
start_lr               = 0.00020
end_lr                 = 0.00005
epochs                 = 15
total_estimated_steps  = epochs * 5000

# ===========================================================================
# 1. Auto-Restorer — resumes from checkpoint or loads genesis weights
# ===========================================================================
to_active = fn tuple ->
  tuple |> Tuple.to_list() |> Enum.map(&Nx.backend_copy/1) |> List.to_tuple()
end

{params, m_state, v_state, start_step, start_epoch} =
  cond do
    File.exists?(full_state_path) ->
      IO.puts("♻️  Resuming from checkpoint...")
      raw = File.read!(full_state_path) |> :erlang.binary_to_term()

      case raw do
        # New map format with all five keys
        %{params: p, m_state: m, v_state: v, step: step, epoch: epoch} ->
          IO.puts("📍 Step #{step}, Epoch #{epoch} (new format)")
          {to_active.(p), to_active.(m), to_active.(v), step, epoch}

        # Old tuple format fallback
        {p, m, v, step} ->
          IO.puts("📍 Step #{step} (old format, assuming epoch 1)")
          {to_active.(p), to_active.(m), to_active.(v), step, 1}
      end

    File.exists?(genesis_path) ->
      IO.puts("🌱 Loading genesis weights...")
      p = File.read!(genesis_path) |> :erlang.binary_to_term() |> to_active.()
      zero_like = fn t ->
        Nx.broadcast(Nx.tensor(0.0), Nx.shape(t)) |> Nx.backend_copy()
      end
      m = p |> Tuple.to_list() |> Enum.map(zero_like) |> List.to_tuple()
      {p, m, m, 1, 1}

    true ->
      IO.puts("❌ No checkpoint or genesis found.")
      System.halt(1)
  end

IO.puts("📍 Starting at step #{start_step}")

# ===========================================================================
# 2. Static assets — built once, reused every step
# ===========================================================================
pos_emb = DLM.Positional.build(seq_len, 256) |> Nx.backend_copy()
mask    = DLM.Mask.causal(seq_len) |> Nx.backend_copy()

# ===========================================================================
# 3. Checkpoint helper — called every 500 steps
# ===========================================================================
save_checkpoint = fn path, p, m, v, step, epoch ->
  to_binary = fn tuple ->
    tuple
    |> Tuple.to_list()
    |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend))
    |> List.to_tuple()
  end
  state = %{
    params:   to_binary.(p),
    m_state:  to_binary.(m),
    v_state:  to_binary.(v),
    step:     step,
    epoch:    epoch
  }
  File.write!(path, :erlang.term_to_binary(state))
  IO.puts("💾 Checkpoint saved at step #{step} (epoch #{epoch})")
end

# ===========================================================================
# 4. Training loop — multi-epoch with RAM safety
# ===========================================================================
IO.puts("🚀 DLM Training — seq_len=#{seq_len} batch=#{batch_size}")

batches_per_epoch = 178_718 |> div(batch_size)
total_steps       = epochs * batches_per_epoch

IO.puts("📊 #{batches_per_epoch} batches/epoch → #{total_steps} total steps")

final_state = Enum.reduce_while(1..epochs, {params, m_state, v_state, start_step}, fn epoch, epoch_acc ->

  IO.puts("\n--- Epoch #{epoch} ---")

  # Seed changes every epoch AND every restart within an epoch
  # Using start_step ensures different restarts get different shuffles
  epoch_seed = epoch * 31337 + start_step

  epoch_result =
    DLM.DataStreamer.stream(path, seq_len, batch_size, epoch_seed)
    |> Stream.chunk_every(200)
    |> Enum.reduce_while(epoch_acc, fn batch_chunk, chunk_acc ->

      {p, m, v, step} = Enum.reduce(batch_chunk, chunk_acc, fn {ins, tgs}, {p, m, v, step} ->
        progress = min(step / total_steps, 1.0)
        lr       = Nx.tensor(start_lr - progress * (start_lr - end_lr), type: :f32)
        step_t   = Nx.tensor(step, type: :s32)

        {new_p, new_m, new_v, loss} =
          DLM.Optimizer.adam_step(ins, tgs, p, m, v, pos_emb, mask, lr, step_t)

        loss_val = Nx.to_number(loss)

        if is_float(loss_val) and (loss_val != loss_val or abs(loss_val) > 1_000_000) do
          IO.puts("🛑 Step #{step}: Halting — instability (#{loss_val})")
          System.halt(1)
        end

        if rem(step, 200) == 0 do
          mem_mb = round(:erlang.memory(:total) / 1_048_576)
          IO.puts("🌱 Step #{step} | Epoch #{epoch} | Loss: #{Float.round(loss_val, 4)} | RAM: #{mem_mb}MB")
          save_checkpoint.(full_state_path, new_p, new_m, new_v, step, epoch)
        end

        {new_p, new_m, new_v, step + 1}
      end)

      # GC between chunks
      :erlang.garbage_collect(self())
      Process.sleep(50)

      mem_mb = round(:erlang.memory(:total) / 1_048_576)

      if mem_mb > 4800 do
        IO.puts("♻️  RAM limit reached at step #{step - 1} — re-run cell to continue")
        {:halt, {p, m, v, step}}
      else
        {:cont, {p, m, v, step}}
      end
    end)

  # Check if we halted due to RAM — stop outer epoch loop too
  {_, _, _, _step} = epoch_result
  mem_mb = round(:erlang.memory(:total) / 1_048_576)

  if mem_mb > 1200 do
    {:halt, epoch_result}
  else
    {:cont, epoch_result}
  end
end)
```

