## Sanity Check

````elixir
# Read the existing checkpoint correctly as {p, m, v, step}
{old_p, old_m, old_v, last_step} = 
  File.read!("v13_full_state.bin") |> :erlang.binary_to_term()

IO.puts("Last step: #{last_step}")
IO.puts("Param count: #{tuple_size(old_p)}")

# Destructure the 11 old tensors
{e, a1, f1, a2, f2, lm_w, lm_b, g1, b1, g2, b2} = old_p
{m_e, m_a1, m_f1, m_a2, m_f2, m_lmw, m_lmb, m_g1, m_b1, m_g2, m_b2} = old_m
{v_e, v_a1, v_f1, v_a2, v_f2, v_lmw, v_lmb, v_g1, v_b1, v_g2, v_b2} = old_v

# Migrate params — reuse a1 for w_q/w_k/w_v, a2 maps cleanly to w_o
new_p = {e, a1, a1, a1, a2, f1, f2, lm_w, lm_b, g1, b1, g2, b2}

# Zero out Adam states — momentum is invalid for the new graph shape
zero_like = fn t -> 
  Nx.broadcast(Nx.tensor(0.0), Nx.shape(t)) |> Nx.backend_copy(Nx.BinaryBackend) 
end
new_m = new_p |> Tuple.to_list() |> Enum.map(zero_like) |> List.to_tuple()

IO.puts("New param count: #{tuple_size(new_p)}")

# Verify shapes before saving
new_p |> Tuple.to_list() |> Enum.each(fn t ->
  IO.puts("  #{inspect(Nx.shape(t))}")
end)

# Save in new format — reset step to 1 so LR decay starts fresh
to_binary = fn tuple ->
  tuple |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple()
end

full_state = {to_binary.(new_p), new_m, new_m, 1}
File.write!("dlm_full_state.bin", :erlang.term_to_binary(full_state))
IO.puts("✅ Migrated to dlm_full_state.bin — #{tuple_size(new_p)} params, step reset to 1")
# ```

# If the shape printout looks like this you're good to proceed:
# ```
# {128, 256}    ← embed
# {256, 256}    ← w_q
# {256, 256}    ← w_k
# {256, 256}    ← w_v
# {256, 256}    ← w_o
# {256, 1024}   ← w_ff1
# {1024, 256}   ← w_ff2
# {256, 128}    ← lm_w
# {128}         ← lm_b
# {256}         ← g1
# {256}         ← b1
# {256}         ← g2
# {256}         ← b2
````

