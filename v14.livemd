## GPU 13 train

```elixir
path            = "v13_lean_dictionary.txt"
full_state_path = "dlm_full_state.bin"
genesis_path    = "v14_genesis.bin" 

seq_len    = 256
batch_size = 12 
start_lr   = 0.00020
end_lr     = 0.00005
epochs     = 15

gpu = {EXLA.Backend, client: :rocm}
cpu = Nx.BinaryBackend

# 1. PUSH to GPU on load
to_active = fn tuple ->
  tuple |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple()
end

{params, m_state, v_state, start_step, start_epoch} =
  cond do
    File.exists?(full_state_path) ->
      IO.puts("♻️  Resuming from checkpoint...")
      %{params: p, m_state: m, v_state: v, step: step, epoch: epoch} = 
        File.read!(full_state_path) |> :erlang.binary_to_term()
      {to_active.(p), to_active.(m), to_active.(v), step, epoch}

    File.exists?(genesis_path) ->
      IO.puts("🌱 Loading V14 Genesis weights...")
      p = File.read!(genesis_path) |> :erlang.binary_to_term() |> to_active.()
      zero_like = fn t -> Nx.broadcast(Nx.tensor(0.0), Nx.shape(t)) |> Nx.backend_copy(gpu) end
      m = p |> Tuple.to_list() |> Enum.map(zero_like) |> List.to_tuple()
      {p, m, m, 1, 1}

    true -> System.halt(1)
  end

# 2. Keep Static Assets on GPU
pos_emb = DLM.Positional.build(seq_len, 256) |> Nx.backend_copy(gpu)
mask    = DLM.Mask.causal(seq_len) |> Nx.backend_copy(gpu)

# 3. PULL to CPU on save
save_checkpoint = fn path, p, m, v, step, epoch ->
  to_binary = fn tuple ->
    tuple |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, cpu)) |> List.to_tuple()
  end
  state = %{params: to_binary.(p), m_state: to_binary.(m), v_state: to_binary.(v), step: step, epoch: epoch}
  File.write!(path, :erlang.term_to_binary(state))
end

# 4. The Loop
batches_per_epoch = 178_718 |> div(batch_size)
total_steps       = epochs * batches_per_epoch

IO.puts("🚀 [V14 GPU] Training — seq_len=#{seq_len} batch=#{batch_size}")

Enum.reduce_while(start_epoch..epochs, {params, m_state, v_state, start_step}, fn epoch, epoch_acc ->
  IO.puts("\n--- Epoch #{epoch} ---")
  epoch_seed = epoch * 31337 + start_step

  epoch_result =
    DLM.DataStreamer.stream(path, seq_len, batch_size, epoch_seed)
    |> Enum.reduce(epoch_acc, fn {ins, tgs}, {p, m, v, step} ->
      progress = min(step / total_steps, 1.0)
      lr       = Nx.tensor(start_lr - progress * (start_lr - end_lr), type: :f32)
      step_t   = Nx.tensor(step, type: :s32)

      {new_p, new_m, new_v, loss} =
        DLM.Optimizer.adam_step(ins, tgs, p, m, v, pos_emb, mask, lr, step_t)

      loss_val = Nx.to_number(loss)

      if is_float(loss_val) and (loss_val != loss_val or abs(loss_val) > 1_000_000) do
        IO.puts("🛑 Step #{step}: Halting — instability (#{loss_val})")
        System.halt(1)
      end

      if rem(step, 200) == 0 do
        mem_mb = round(:erlang.memory(:total) / 1_048_576)
        IO.puts("🔥 Step #{step} | Loss: #{Float.round(loss_val, 4)} | Sys RAM: #{mem_mb}MB")
        save_checkpoint.(full_state_path, new_p, new_m, new_v, step, epoch)
      end

      {new_p, new_m, new_v, step + 1}
    end)

  {:cont, epoch_result}
end)
```

