## Probe

```elixir
# Redefine inference module — run this cell before the probe
defmodule DLM.Inference do
  @allowed_chars ~c" abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789.,:;-'\"()[]"

  def build_muzzle(vocab_size \\ 128, allowed \\ @allowed_chars) do
    muzzle = Nx.broadcast(Nx.tensor(-1.0e10, type: :f32), {vocab_size})
    Enum.reduce(allowed, muzzle, fn char, acc ->
      Nx.indexed_put(acc, Nx.tensor([[char]]), Nx.tensor([0.0]))
    end)
  end

  def greedy(params, pos_emb, mask, prompt, max_new_chars \\ 200, muzzle \\ nil) do
    generate(params, pos_emb, mask, prompt |> to_charlist(), max_new_chars, muzzle, &greedy_sample/1)
  end

  def sample(params, pos_emb, mask, prompt, max_new_chars \\ 200, temp \\ 0.8, muzzle \\ nil) do
    generate(params, pos_emb, mask, prompt |> to_charlist(), max_new_chars, muzzle, &temperature_sample(&1, temp))
  end

  def top_k(params, pos_emb, mask, prompt, max_new_chars \\ 200, k \\ 5, temp \\ 0.8, muzzle \\ nil) do
    generate(params, pos_emb, mask, prompt |> to_charlist(), max_new_chars, muzzle, &top_k_sample(&1, k, temp))
  end

  defp generate(params, pos_emb, mask, prompt_chars, max_new_chars, muzzle, sample_fn) do
    seq_len = elem(Nx.shape(pos_emb), 0)
    Enum.reduce(1..max_new_chars, prompt_chars, fn _, chars ->
      context     = chars |> Enum.take(-seq_len) |> pad_or_trim(seq_len)
      ins         = context |> Nx.tensor(type: :s64) |> Nx.new_axis(0)
      logits      = forward(params, ins, pos_emb, mask)
      last_pos    = min(length(chars), seq_len) - 1
      next_logits = logits[[0, last_pos, 0..-1//1]]
      next_logits = if muzzle, do: Nx.add(next_logits, muzzle), else: next_logits
      next_char   = sample_fn.(next_logits)
      chars ++ [next_char]
    end)
    |> List.to_string()
  end

  defp forward(params, ins, pos_emb, mask) do
    {embed, w_q, w_k, w_v, w_o, w_ff1, w_ff2, lm_w, lm_b, g1, b1, g2, b2} = params
    x = Nx.add(Nx.take(embed, ins), pos_emb)
    x = DLM.Transformer.block(x, w_q, w_k, w_v, w_o, w_ff1, w_ff2, g1, b1, g2, b2, mask)
    Nx.add(Nx.dot(x, lm_w), lm_b)
  end

  defp greedy_sample(logits) do
    logits |> Nx.to_flat_list() |> Enum.with_index() |> Enum.max_by(&elem(&1, 0)) |> elem(1)
  end

  defp temperature_sample(logits, temp) do
    logits |> Nx.divide(temp) |> softmax() |> Nx.to_flat_list() |> sample_from_probs()
  end

  defp top_k_sample(logits, k, temp) do
    logits_list = Nx.to_flat_list(logits)
    top_k_indices =
      logits_list
      |> Enum.with_index()
      |> Enum.sort_by(&elem(&1, 0), :desc)
      |> Enum.take(k)
      |> Enum.map(&elem(&1, 1))
    logits_list
    |> Enum.with_index()
    |> Enum.map(fn {v, i} -> if i in top_k_indices, do: v, else: -1.0e9 end)
    |> Nx.tensor(type: :f32)
    |> Nx.divide(temp)
    |> softmax()
    |> Nx.to_flat_list()
    |> sample_from_probs()
  end

  defp softmax(logits) do
    max_l = Nx.reduce_max(logits)
    exp   = Nx.exp(Nx.subtract(logits, max_l))
    Nx.divide(exp, Nx.sum(exp))
  end

  defp sample_from_probs(probs) do
    r = :rand.uniform()
    probs
    |> Enum.with_index()
    |> Enum.reduce_while(0.0, fn {p, i}, acc ->
      new_acc = acc + p
      if new_acc >= r, do: {:halt, i}, else: {:cont, new_acc}
    end)
  end

  defp pad_or_trim(chars, seq_len) do
    len = length(chars)
    if len >= seq_len do
      Enum.take(chars, -seq_len)
    else
      List.duplicate(0, seq_len - len) ++ chars
    end
  end
end

defmodule DLM.Probe do

  def run(params, pos_emb, mask) do
    # Build muzzle once, reuse across all probes
    muzzle = DLM.Inference.build_muzzle()

    IO.puts("\n" <> String.duplicate("=", 60))
    IO.puts("DLM INFERENCE PROBE")
    IO.puts(String.duplicate("=", 60))

    IO.puts("\n📚 IN-DISTRIBUTION (training format)")
    IO.puts(String.duplicate("-", 40))
    probe(params, pos_emb, mask, "[W]happy [T]adj [D]",   "Definition of 'happy'",  muzzle)
    probe(params, pos_emb, mask, "[W]water [T]noun [D]",  "Definition of 'water'",  muzzle)
    probe(params, pos_emb, mask, "[W]run [T]verb [D]",    "Definition of 'run'",    muzzle)

    IO.puts("\n🔄 REVERSE FORMAT (jeopardy)")
    IO.puts(String.duplicate("-", 40))
    probe(params, pos_emb, mask, "[D]A feeling of great pleasure [W]", "Word for pleasure", muzzle)
    probe(params, pos_emb, mask, "[D]To move swiftly on foot [W]",     "Word for swift",    muzzle)

    IO.puts("\n🔀 NEAR-DISTRIBUTION")
    IO.puts(String.duplicate("-", 40))
    probe(params, pos_emb, mask, "The word 'happy' means",      "Prose definition",  muzzle)
    probe(params, pos_emb, mask, "[W]love [R]Related:",         "Relational format", muzzle)
    probe(params, pos_emb, mask, "[W]cold [T]adj [D]The opposite", "Partial def",    muzzle)

    IO.puts("\n💬 OUT-OF-DISTRIBUTION (conversational)")
    IO.puts(String.duplicate("-", 40))
    probe(params, pos_emb, mask, "What is the meaning of life?", "Philosophical",    muzzle)
    probe(params, pos_emb, mask, "Hello, how are you?",          "Greeting",         muzzle)
    probe(params, pos_emb, mask, "Can you define the word",      "Conversational",   muzzle)

    # Morphology probes — comparing to V12 personality audit
    IO.puts("\n🔤 MORPHOLOGY (V12 comparison)")
    IO.puts(String.duplicate("-", 40))
    probe(params, pos_emb, mask, "[W]Electr",  "Electr-",  muzzle)
    probe(params, pos_emb, mask, "[W]Mecha",   "Mecha-",   muzzle)
    probe(params, pos_emb, mask, "[W]Inter",   "Inter-",   muzzle)
    probe(params, pos_emb, mask, "[W]Ortho",   "Ortho-",   muzzle)
    probe(params, pos_emb, mask, "[W]Trans",   "Trans-",   muzzle)

    IO.puts("\n" <> String.duplicate("=", 60))
  end

  defp probe(params, pos_emb, mask, prompt, label, muzzle) do
    IO.puts("\n▶ #{label}")
    IO.puts("  Prompt:  #{inspect(prompt)}")

    greedy  = DLM.Inference.greedy(params, pos_emb, mask, prompt, 120, muzzle)
    sampled = DLM.Inference.top_k(params, pos_emb, mask, prompt, 120, 5, 0.8, muzzle)

    suffix_g = String.slice(greedy,  String.length(prompt)..-1//1)
    suffix_s = String.slice(sampled, String.length(prompt)..-1//1)

    IO.puts("  Greedy:  #{inspect(suffix_g)}")
    IO.puts("  Top-k:   #{inspect(suffix_s)}")
  end
end
```

