## Init

```elixir
vocab_size = 128
embed_dim  = 256
ff_dim     = embed_dim * 4  

gpu = {EXLA.Backend, client: :rocm}
cpu = Nx.BinaryBackend

init_param = fn shape, current_key ->
  {tensor, next_key} = Nx.Random.normal(current_key, 0.0, 0.01, shape: shape, type: :f32)
  {Nx.backend_copy(tensor, gpu), next_key} # Force to VRAM
end

key = Nx.Random.key(42)

{embed, key} = init_param.({vocab_size, embed_dim}, key)
{w_q, key}   = init_param.({embed_dim, embed_dim}, key)
{w_k, key}   = init_param.({embed_dim, embed_dim}, key)
{w_v, key}   = init_param.({embed_dim, embed_dim}, key)
{w_o, key}   = init_param.({embed_dim, embed_dim}, key)
{w_ff1, key} = init_param.({embed_dim, ff_dim}, key)
{w_ff2, key} = init_param.({ff_dim, embed_dim}, key)
{lm_w, key}  = init_param.({embed_dim, vocab_size}, key)

# Biases and Gammas
lm_b = Nx.broadcast(Nx.tensor(0.0, type: :f32), {vocab_size}) |> Nx.backend_copy(gpu)
g1   = Nx.broadcast(Nx.tensor(1.0, type: :f32), {embed_dim})  |> Nx.backend_copy(gpu)
b1   = Nx.broadcast(Nx.tensor(0.0, type: :f32), {embed_dim})  |> Nx.backend_copy(gpu)
g2   = Nx.broadcast(Nx.tensor(1.0, type: :f32), {embed_dim})  |> Nx.backend_copy(gpu)
b2   = Nx.broadcast(Nx.tensor(0.0, type: :f32), {embed_dim})  |> Nx.backend_copy(gpu)

genesis_weights = {embed, w_q, w_k, w_v, w_o, w_ff1, w_ff2, lm_w, lm_b, g1, b1, g2, b2}

# Safely copy back to CPU before saving
to_binary = fn tuple ->
  tuple |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, cpu)) |> List.to_tuple()
end

File.write!("v14_genesis.bin", :erlang.term_to_binary(to_binary.(genesis_weights)))
IO.puts("✅ v14_genesis.bin saved to SSD.")
```

