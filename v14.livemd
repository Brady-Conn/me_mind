## v12 Compare train

````elixir
# ---------------------------------------------------------------------------
# V12-migrated training run — runs in parallel with current dlm_full_state.bin
# Keep in a separate Livebook cell or section so they don't share state
# ---------------------------------------------------------------------------
path              = "v13_lean_dictionary.txt"
full_state_path   = "dlm_v12_migrated.bin"   # ← different checkpoint file
save_state_path   = "dlm_v12_migrated.bin"   # ← saves back to same file

seq_len               = 256
batch_size            = 12
# start_lr = 0.00035   # ~1.75x current, not 3x
# end_lr   = 0.00008   # same as main run
start_lr               = 0.00020
end_lr                 = 0.00005
epochs                = 15
batches_per_epoch     = 178_718 |> div(batch_size)
total_steps           = epochs * batches_per_epoch

to_active = fn tuple ->
  tuple |> Tuple.to_list() |> Enum.map(&Nx.backend_copy/1) |> List.to_tuple()
end

{params, m_state, v_state, start_step} =
  File.read!(full_state_path)
  |> :erlang.binary_to_term()
  |> then(fn {p, m, v, step} ->
    {to_active.(p), to_active.(m), to_active.(v), step}
  end)

IO.puts("📍 V12-migrated run starting at step #{start_step}")

pos_emb = DLM.Positional.build(seq_len, 256) |> Nx.backend_copy()
mask    = DLM.Mask.causal(seq_len) |> Nx.backend_copy()

# Enhanced checkpoint save
save_checkpoint = fn path, p, m, v, step, epoch ->
  to_binary = fn tuple ->
    tuple
    |> Tuple.to_list()
    |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend))
    |> List.to_tuple()
  end

  state = %{
    params:  to_binary.(p),
    m_state: to_binary.(m),
    v_state: to_binary.(v),
    step:    step,
    epoch:   epoch,
    # Save a fixed seed offset so we can reproduce
    # the same shuffle for the current epoch on resume
    epoch_seed: step * 7919  # deterministic from step
  }

  File.write!(path, :erlang.term_to_binary(state))
  IO.puts("💾 Checkpoint saved at step #{step} (epoch #{epoch})")
end

chunk_size = 200

# ===========================================================================
# 4. V12-Migrated Training loop — multi-epoch with RAM safety
# ===========================================================================
IO.puts("🚀 [V12] Training — seq_len=#{seq_len} batch=#{batch_size}")

batches_per_epoch = 178_718 |> div(batch_size)
total_steps       = epochs * batches_per_epoch

IO.puts("📊 [V12] #{batches_per_epoch} batches/epoch → #{total_steps} total steps")

final_state = Enum.reduce_while(1..epochs, {params, m_state, v_state, start_step}, fn epoch, epoch_acc ->

  IO.puts("\n--- [V12] Epoch #{epoch} ---")

  epoch_seed = epoch * 31337 + start_step

  epoch_result =
    DLM.DataStreamer.stream(path, seq_len, batch_size, epoch_seed)
    |> Stream.chunk_every(200)
    |> Enum.reduce_while(epoch_acc, fn batch_chunk, chunk_acc ->

      {p, m, v, step} = Enum.reduce(batch_chunk, chunk_acc, fn {ins, tgs}, {p, m, v, step} ->
        progress = min(step / total_steps, 1.0)
        lr       = Nx.tensor(start_lr - progress * (start_lr - end_lr), type: :f32)
        step_t   = Nx.tensor(step, type: :s32)

        {new_p, new_m, new_v, loss} =
          DLM.Optimizer.adam_step(ins, tgs, p, m, v, pos_emb, mask, lr, step_t)

        loss_val = Nx.to_number(loss)

        if is_float(loss_val) and (loss_val != loss_val or abs(loss_val) > 1_000_000) do
          IO.puts("🛑 [V12] Step #{step}: Halting — instability (#{loss_val})")
          System.halt(1)
        end

        if rem(step, 200) == 0 do
          mem_mb = round(:erlang.memory(:total) / 1_048_576)
          IO.puts("🌱 [V12] Step #{step} | Epoch #{epoch} | Loss: #{Float.round(loss_val, 4)} | RAM: #{mem_mb}MB")
          save_checkpoint.(save_state_path, new_p, new_m, new_v, step)
        end

        {new_p, new_m, new_v, step + 1}
      end)

      :erlang.garbage_collect(self())
      Process.sleep(50)

      mem_mb = round(:erlang.memory(:total) / 1_048_576)

      if mem_mb > 4800 do
        IO.puts("♻️  [V12] RAM limit reached at step #{step - 1} — re-run cell to continue")
        {:halt, {p, m, v, step}}
      else
        {:cont, {p, m, v, step}}
      end
    end)

  {_, _, _, current_step} = epoch_result
  mem_mb = round(:erlang.memory(:total) / 1_048_576)

  if mem_mb > 1200 do
    {:halt, epoch_result}
  else
    {:cont, epoch_result}
  end
end)
# ```

# The only real differences from your current training loop are the `[V12]` labels in the log output so you can tell them apart, and the checkpoint paths pointing to `dlm_v12_migrated.bin`.

# The key comparison to watch for at each probe checkpoint:
# ```
# Current model (dlm_full_state.bin):
#   Started from random genesis weights
#   ~5000 steps of dictionary training
#   Still in vowel-soup territory

# V12-migrated (dlm_v12_migrated.bin):
#   Started from V12 morphological embeddings
#   Fresh attention/FF weights
#   Question: does the head start show up immediately,
#   or does it take the same number of steps to converge?
````

