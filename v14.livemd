## v15 train

```elixir
# --- V15 Universal Training (3-Loop Recursion) ---
path            = "v13_lean_dictionary.txt"
full_state_path = "v15_full_state.bin"
genesis_path    = "v15_genesis.bin"

seq_len    = 256
batch_size = 4
epochs     = 10
start_lr   = 0.0001  
end_lr     = 0.00001

# 🔥 FIX 1: The Asynchronous GPU Allocator (Prevents Fragmentation)
System.put_env("TF_GPU_ALLOCATOR", "cuda_malloc_async")

gpu = {EXLA.Backend, client: :rocm}
Nx.global_default_backend(gpu)

# 1. Load weights (Genesis or Checkpoint)
{params, m_state, v_state, start_step, start_epoch} = 
  if File.exists?(full_state_path) do
    IO.puts("♻️ Resuming V15 from checkpoint...")
    %{params: p, m: m, v: v, step: s, epoch: e} = File.read!(full_state_path) |> :erlang.binary_to_term()
    {p, m, v, s, e}
  else
    IO.puts("🌱 Initializing V15 from Genesis...")
    p = File.read!(genesis_path) |> :erlang.binary_to_term()
    m = p |> Tuple.to_list() |> Enum.map(fn t -> Nx.broadcast(0.0, Nx.shape(t)) end) |> List.to_tuple()
    v = m
    {p, m, v, 0, 1}
  end

# Push to GPU
to_gpu = fn tpl -> tpl |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple() end
params = to_gpu.(params)
m_state = to_gpu.(m_state)
v_state = to_gpu.(v_state)

# 2. Static Assets
pos_emb = DLM.Positional.build(seq_len, 256) |> Nx.backend_copy(gpu)
mask    = DLM.Mask.causal(seq_len) |> Nx.backend_copy(gpu)

# 3. Training Loop
batches_per_epoch = 178_718 |> div(batch_size)
total_steps = epochs * batches_per_epoch

IO.puts("🚀 [V15 UNIVERSAL] Training — 3 Loops | seq_len=256 batch=12")

Enum.reduce_while(start_epoch..epochs, {params, m_state, v_state, start_step}, fn epoch, epoch_acc ->
  IO.puts("\n--- Epoch #{epoch} ---")
  
  epoch_result = 
    DLM.DataStreamer.stream(path, seq_len, batch_size, epoch * 31337 + start_step)
    |> Stream.chunk_every(500)
    |> Enum.reduce(epoch_acc, fn batch_chunk, chunk_acc ->
      
      {p, m, v, step, last_loss} = Enum.reduce(batch_chunk, Tuple.insert_at(chunk_acc, 4, 0.0), fn {ins, tgs}, {p, m, v, step, _} ->
        progress = min(step / total_steps, 1.0)
        lr = Nx.tensor(start_lr - progress * (start_lr - end_lr), type: :f32)
        step_t = Nx.tensor(step + 1, type: :s32)

        {new_p, new_m, new_v, loss} = 
          DLM.Optimizer.adam_step(ins, tgs, p, m, v, pos_emb, mask, lr, step_t)
        
        # 🔥 THE RUNAWAY CPU FIX: Force Host/Device Synchronization!
        # This halts the Elixir loop until the GPU finishes calculating this specific step.
        # It prevents the CPU from queuing up 500 steps of XLA memory buffers.
        loss_float = Nx.to_number(loss)

        if rem(step, 10) == 0, do: :erlang.garbage_collect(self())

        # Pass the extracted float to the accumulator, NOT the tensor!
        {new_p, new_m, new_v, step + 1, loss_float}
      end)

      # Pit Stop: Status & GC
      mem = round(:erlang.memory(:total) / 1_048_576)
      
      # Since last_loss is already a float now, we can just round it
      formatted_loss = Float.round(last_loss, 4)
        
      IO.puts("🔥 Step #{step} | Loss: #{formatted_loss} | Sys RAM: #{mem}MB")
      
      # Save Checkpoint
      to_cpu = fn tpl -> tpl |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple() end
      checkpoint = %{params: to_cpu.(p), m: to_cpu.(m), v: to_cpu.(v), step: step, epoch: epoch}
      File.write!(full_state_path, :erlang.term_to_binary(checkpoint))

      :erlang.garbage_collect(self())
      Process.sleep(10)

      {p, m, v, step}
    end)
  {:cont, epoch_result}
end)
```

