# 0. The GPU Disguise (Tricks ROCm into thinking the RX 7600 is a supported gfx1100 card)
System.put_env("HSA_OVERRIDE_GFX_VERSION", "11.0.0")

# 1. Force EXLA to compile for your RX 7600
System.put_env("XLA_TARGET", "rocm")

# 2. Hard-cap the XLA memory allocator to 60% of your 8GB VRAM
System.put_env("XLA_PYTHON_CLIENT_MEM_FRACTION", "0.60")

# 3. Stop XLA from instantly reserving the memory the second it boots
System.put_env("XLA_PYTHON_CLIENT_PREALLOCATE", "false")

# 4. Use the smarter, fragmentation-resistant memory allocator
System.put_env("TF_GPU_ALLOCATOR", "cuda_malloc_async")

Mix.install([
  {:nx, "~> 0.11.0"},
  {:exla, "~> 0.11.0"}
])

# 1. Force the GPU to be the default
gpu = {EXLA.Backend, client: :rocm}
Nx.global_default_backend(gpu)

# 2. Hardware Pulse Check
platforms = EXLA.Client.get_supported_platforms()
if platforms[:rocm] do
  IO.puts("✅ SUCCESS: AMD RX 7600 is online!")
else
  IO.puts("❌ WARNING: GPU missing. Did you export HSA_OVERRIDE_GFX_VERSION in the terminal?")
end
