```elixir
# ---- correct these to match your actual filenames ----
full_state_path = "dlm_full_state.bin"   # the migrated 13-param file
data_path       = "v13_lean_dictionary.txt"  # or whatever your dict file is named
# ------------------------------------------------------

embed_dim  = 256
ff_dim     = embed_dim * 4
vocab_size = 128
seq_len    = 256
batch_size = 12

{params, m_state, v_state, start_step} =
  File.read!(full_state_path)
  |> :erlang.binary_to_term()
  |> then(fn {p, m, v, step} ->
    to_active = fn t ->
      t |> Tuple.to_list() |> Enum.map(&Nx.backend_copy/1) |> List.to_tuple()
    end
    {to_active.(p), to_active.(m), to_active.(v), step}
  end)

IO.puts("Loaded #{full_state_path} — #{tuple_size(params)} params, step #{start_step}")

expected = [
  {:embed, {vocab_size, embed_dim}},
  {:w_q,   {embed_dim, embed_dim}},
  {:w_k,   {embed_dim, embed_dim}},
  {:w_v,   {embed_dim, embed_dim}},
  {:w_o,   {embed_dim, embed_dim}},
  {:w_ff1, {embed_dim, ff_dim}},
  {:w_ff2, {ff_dim,    embed_dim}},
  {:lm_w,  {embed_dim, vocab_size}},
  {:lm_b,  {vocab_size}},
  {:g1,    {embed_dim}},
  {:b1,    {embed_dim}},
  {:g2,    {embed_dim}},
  {:b2,    {embed_dim}}
]

all_ok =
  params
  |> Tuple.to_list()
  |> Enum.zip(expected)
  |> Enum.reduce(true, fn {tensor, {name, exp}}, acc ->
    actual = Nx.shape(tensor)
    ok     = actual == exp
    IO.puts("  #{if ok, do: "✅", else: "❌"} #{name}: #{inspect(actual)}")
    acc and ok
  end)

pos_emb = DLM.Positional.build(seq_len, embed_dim) |> Nx.backend_copy()
mask    = DLM.Mask.causal(seq_len) |> Nx.backend_copy()

IO.puts("pos_emb: #{inspect(Nx.shape(pos_emb))}")
IO.puts("mask:    #{inspect(Nx.shape(mask))}")

if all_ok do
  IO.puts("\nShapes OK — running test step...")

  {test_ins, test_tgs} =
    DLM.DataStreamer.stream(data_path, seq_len, batch_size)
    |> Enum.take(1)
    |> hd()

  {_, _, _, test_loss} =
    DLM.Optimizer.adam_step(
      test_ins, test_tgs, params, m_state, v_state,
      pos_emb, mask,
      Nx.tensor(0.0002, type: :f32),
      Nx.tensor(1, type: :s32)
    )

  IO.puts("✅ Test step passed — loss: #{Float.round(Nx.to_number(test_loss), 4)}")
  IO.puts("RAM: #{round(:erlang.memory(:total) / 1_048_576)}MB")
else
  IO.puts("\n❌ Fix shape mismatches before training")
end
```

