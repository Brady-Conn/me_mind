## stream

```elixir
defmodule DLM.DataStreamer do
  def stream(path, seq_len, batch_size, seed \\ nil) do
    lines =
      path
      |> File.read!()
      |> String.split("\n", trim: true)

    shuffled =
      case seed do
        nil ->
          Enum.shuffle(lines)
        s ->
          # Reset the process RNG state completely before shuffling
          # Using :rand.seed with explicit state tuple guarantees
          # the seed takes effect before Enum.shuffle is called
          rng_state = :rand.seed_s(:exsss, {s, s + 1, s + 2})
          Process.put(:rand_seed, rng_state)
          Enum.shuffle(lines)
      end

    shuffled
    |> Enum.join("\n")
    |> to_charlist()
    |> Stream.chunk_every(seq_len + 1, seq_len, :discard)
    |> Stream.map(fn chunk ->
      ins = chunk |> Enum.take(seq_len) |> Nx.tensor(type: :s64)
      tgs = chunk |> Enum.drop(1) |> Nx.tensor(type: :s64)
      {ins, tgs}
    end)
    |> Stream.chunk_every(batch_size, batch_size, :discard)
    |> Stream.map(fn batch ->
      {ins_list, tgs_list} = Enum.unzip(batch)
      {Nx.stack(ins_list), Nx.stack(tgs_list)}
    end)
  end
end
```

```elixir
# ===========================================================================
# Fixed Shuffle Determinism Check
# ===========================================================================
IO.puts("--- Shuffle Determinism Check ---")

# Instead of checking first token (always '['), 
# check which LINE appears first after shuffling
lines = File.read!("v13_lean_dictionary.txt") |> String.split("\n", trim: true)
total = length(lines)
IO.puts("Total lines: #{total}")

# Shuffle with different seeds and check first 3 lines
shuffle_with_seed = fn s ->
  rng_state = :rand.seed_s(:exsss, {s, s + 1, s + 2})
  Process.put(:rand_seed, rng_state)
  lines |> Enum.shuffle() |> Enum.take(3) |> Enum.map(&String.slice(&1, 0, 40))
end

first_a = shuffle_with_seed.(31337)
first_b = shuffle_with_seed.(31338)
first_c = shuffle_with_seed.(31337)

IO.puts("\nSeed 31337 first 3 lines:")
Enum.each(first_a, &IO.puts("  #{&1}"))

IO.puts("\nSeed 31338 first 3 lines:")
Enum.each(first_b, &IO.puts("  #{&1}"))

IO.puts("\nSeed 31337 again first 3 lines:")
Enum.each(first_c, &IO.puts("  #{&1}"))

if first_a == first_c do
  IO.puts("\n✅ Same seed → same shuffle (deterministic)")
else
  IO.puts("\n❌ Same seed produced different results")
end

if first_a != first_b do
  IO.puts("✅ Different seeds → different shuffles")
else
  IO.puts("❌ Different seeds produced same shuffle — seed not working")
end
