## SSM

```elixir
defmodule DLM.SvdSSM do
  import Nx.Defn

  defn rms_norm(x, gamma, beta, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    norm = x * Nx.rsqrt(variance + epsilon)
    scaled = norm * gamma
    scaled + beta
  end

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn gelu(x) do
    cdf = Nx.multiply(
      Nx.tensor(0.7978845608, type: :f32),
      Nx.add(x, Nx.multiply(Nx.tensor(0.044715, type: :f32), Nx.pow(x, 3)))
    )
    Nx.multiply(Nx.multiply(Nx.tensor(0.5, type: :f32), x), Nx.add(Nx.tensor(1.0, type: :f32), Nx.tanh(cdf)))
  end
  
  defn feed_forward_layer(x, um, ga, bi, dm) do
    up = Nx.dot(x, um) 
    act = gelu(up) #was tanh
    scaled = Nx.multiply(act, ga)
    biased = Nx.add(scaled, bi)
    Nx.dot(biased, dm) 
  end

  defn softmax(t) do
    max_val = Nx.reduce_max(t, axes: [-1], keep_axes: true)
    safe_t = Nx.subtract(t, max_val)
    exps = Nx.exp(safe_t)
    sum_exps = Nx.sum(exps, axes: [-1], keep_axes: true)
    Nx.divide(exps, Nx.add(sum_exps, 1.0e-8))
  end

  defn apply_xsa(x, y) do
    y_norm_sq = Nx.add(Nx.sum(Nx.pow(y, 2), axes: [-1], keep_axes: true), 1.0e-6)
    y_unit = Nx.divide(y, Nx.sqrt(y_norm_sq))
    y_ov = Nx.sum(Nx.multiply(x, y_unit), axes: [-1], keep_axes: true)
    Nx.subtract(x, Nx.multiply(y_ov, y_unit))
  end

  defn apply_attention(q, v) do
    k = Nx.transpose(v, axes: [0, 2, 1])
    r = Nx.axis_size(v, 1)
    qu = Nx.new_axis(q, 1)
    score = Nx.dot(qu, [2], [0], k, [1], [0])
    scaled_score = Nx.divide(score, Nx.sqrt(r))
    soft_score = softmax(scaled_score)
    Nx.dot(soft_score, [2], [0], v, [1], [0]) |> Nx.squeeze(axes: [1])
  end

  defn forward_step(x_t, s_prev, h_prev, p_prev, p) do
    {c1, c2, cb, cq, cg, ce,
     b1, b2, bb, bq, bg, be, em} = p
    # apply time scale
    time_scale = Nx.rsqrt(Nx.Constants.pi())
    s_scaled = Nx.multiply(s_prev, time_scale)
    h_scaled = Nx.multiply(h_prev, time_scale)
    p_scaled = Nx.multiply(p_prev, time_scale)
    # process current character -> {batch, 128}
    u_t = Nx.take(em, x_t)
    z_t = Nx.broadcast(0.0, u_t)
    # update 'context' window
    sl_s = Nx.slice_along_axis(s_scaled, 1, 3, axis: 1)
    s_new = Nx.concatenate([sl_s, Nx.new_axis(u_t, 1)], axis: 1)
    # reshape for processing {batch, 4, 128} -> {batch, 512}
    wrd = Nx.reshape(s_new, {:auto, 512})
    b_term = feed_forward_layer(wrd, b1, bq, bb, b2)
    b_norm = rms_norm(b_term, bg, be)
    # update prediction memory - remove 'oldest' prediction used in last pass, rotate and add zero state to the 'end'
    sl_p = Nx.slice_along_axis(p_scaled, 1, 3, axis: 1)
    pb_nb = Nx.concatenate([sl_p, Nx.new_axis(z_t, 1)], axis: 1) |> Nx.reshape({:auto, 512})
    # update prediction matrix with processed ctx window
    pb_n = Nx.add(pb_nb, b_norm)
    # update hidden staet
    h_new = Nx.add(h_scaled, b_norm)
    # attend updated prediction matrix to h_new
    sp_ctx = apply_attention(pb_n, Nx.new_axis(h_new, 1))
    spxa = apply_xsa(sp_ctx, pb_n)
    # add exclusive h_new attention to prediction matrix
    c_in = Nx.add(pb_n, spxa)
    # 512 -> 512 -> 512
    c_term = feed_forward_layer(c_in, c1, cq, cb, c2)
    c_norm = rms_norm(c_term, cg, ce)

    # reshape for return
    p_new = Nx.reshape(c_norm, {:auto, 4, 128})
    # take 'oldest' prediction
    logits = Nx.take(p_new, 0, axis: 1)
    
    {logits, s_new, h_new, p_new}
  end
end
```

