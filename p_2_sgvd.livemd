```elixir
defmodule DLM.SvdOptimizer do
  import Nx.Defn

  # Correctly scales the entire matrix to preserve geometric direction
  defn clip_norm(tensor, max_norm) do
    norm = Nx.add(Nx.sqrt(Nx.sum(Nx.pow(tensor, 2))), 1.0e-8)
    scale = Nx.min(1.0, Nx.divide(max_norm, norm))
    Nx.multiply(tensor, scale)
  end

  # Adaptive Decay Function
  defn adaptive_decay(old_w, new_w, cg_w, lr, decay \\ 1.0e-4) do
    # 1. Norms (using the CLIPPED gradients)
    w_norm = Nx.add(Nx.LinAlg.norm(old_w), 1.0e-8)
    g_norm = Nx.add(Nx.LinAlg.norm(cg_w), 1.0e-8)
    
    # 2. LARS-style adaptation: w_norm / g_norm
    dynamic_scale = Nx.divide(w_norm, g_norm) |> Nx.clip(0.01, 10.0)
    
    # 3. Apply
    tailored_wd = Nx.multiply(decay, dynamic_scale)
    penalty = Nx.multiply(old_w, Nx.multiply(lr, tailored_wd))
    
    Nx.subtract(new_w, penalty)
  end

  defn svd_step(p, g, lr) do
    # Scale the whole matrix by its "size" in high-dimensional space
    norm = Nx.LinAlg.norm(g)
    update = Nx.divide(g, norm) |> Nx.multiply(lr)
    np = Nx.subtract(p, update)

    np
  end


  defn update(params, grads, step, lr) do
    {em, au, av, bu, bv, cu, cv, du, dv, eu, ev, fu, fv} = params
    {gem, gau, gav, gbu, gbv, gcu, gcv, gdu, gdv, geu, gev, gfu, gfv} = grads

    new_step = Nx.add(step, 1)

    # clip grad norms
    norm_cap = Nx.tensor(10.0, type: :f32)
    c_gem = clip_norm(gem, norm_cap)
    c_gau = clip_norm(gau, norm_cap)
    c_gav = clip_norm(gav, norm_cap)
    c_gbu = clip_norm(gbu, norm_cap)
    c_gbv = clip_norm(gbv, norm_cap)
    c_gcu = clip_norm(gcu, norm_cap)
    c_gcv = clip_norm(gcv, norm_cap)
    c_gdu = clip_norm(gdu, norm_cap)
    c_gdv = clip_norm(gdv, norm_cap)
    c_geu = clip_norm(geu, norm_cap)
    c_gev = clip_norm(gev, norm_cap)
    c_gfu = clip_norm(gfu, norm_cap)
    c_gfv = clip_norm(gfv, norm_cap)

    # optimizer update step
    em_new = DLM.SparseSinkGD.step(em, c_gem, lr)
    au_new = DLM.SparseSinkGD.step(au, c_gau, lr)
    av_new = DLM.SparseSinkGD.step(av, c_gav, lr)
    bu_new = DLM.SparseSinkGD.step(bu, c_gbu, lr)
    bv_new = DLM.SparseSinkGD.step(bv, c_gbv, lr)
    cu_new = DLM.SparseSinkGD.step(cu, c_gcu, lr)
    cv_new = DLM.SparseSinkGD.step(cv, c_gcv, lr)
    du_new = DLM.SparseSinkGD.step(du, c_gdu, lr)
    dv_new = DLM.SparseSinkGD.step(dv, c_gdv, lr)
    eu_new = DLM.SparseSinkGD.step(eu, c_geu, lr)
    ev_new = DLM.SparseSinkGD.step(ev, c_gev, lr)
    fu_new = DLM.SparseSinkGD.step(fu, c_gfu, lr)
    fv_new = DLM.SparseSinkGD.step(fv, c_gfv, lr)
    

    # weight decay
    # d_au = adaptive_decay(au, au_new, c_gau, lr)
    # d_av = adaptive_decay(av, av_new, c_gav, lr)
    # d_bu = adaptive_decay(bu, bu_new, c_gbu, lr)
    # d_bv = adaptive_decay(bv, bv_new, c_gbv, lr)
    # d_cu = adaptive_decay(cu, cu_new, c_gcu, lr)
    # d_cv = adaptive_decay(cv, cv_new, c_gcv, lr)
    # d_du = adaptive_decay(du, du_new, c_gdu, lr)
    # d_dv = adaptive_decay(dv, dv_new, c_gdv, lr)
    # d_eu = adaptive_decay(eu, eu_new, c_geu, lr)
    # d_ev = adaptive_decay(ev, ev_new, c_gev, lr)

    # new_params = {em_new, d_au, d_av, d_bu, d_bv, d_cu, d_cv, d_du, d_dv, d_eu, d_ev}

    new_params = {em_new, au_new, av_new, bu_new, bv_new, cu_new, cv_new, du_new, dv_new, eu_new, ev_new, fu_new, fv_new}
 
    {new_params, new_step}
  end
end
