```elixir
defmodule DLM.SvdOptimizer do
  import Nx.Defn

  defn update(params, grads, step, lr) do
    {a, b, c1, c2, c3, d} = params   
    {ga, gb, gc1, gc2, gc3, gd} = grads
    
    new_step = Nx.add(step, 1)

    # optimizer update step
     a_new = DLM.StatelessMuon.muon_step(a, ga, lr)
     b_new = DLM.StatelessMuon.muon_step(b, gb, lr)
    c1_new = DLM.StatelessMuon.muon_step(c1, gc1, lr)
    c2_new = DLM.StatelessMuon.muon_step(c2, gc2, lr)
    c3_new = DLM.StatelessMuon.muon_step(c3, gc3, lr)
    d_new = DLM.StatelessMuon.muon_step(d, gd, lr)
    
    new_params = {a_new, b_new, c1_new, c2_new, c3_new, d_new}

    {new_params, new_step}
  end
end
