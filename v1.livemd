```elixir
defmodule DLM.Tokenizer do
  @doc """
  Runs on the BEAM. Takes a standard Elixir string and converts 
  it into an Nx tensor of integers representing raw UTF-8 bytes.
  """
  def encode(string) do
    # 1. 'for <<b <- string>>' is Elixir's hyper-fast binary comprehension.
    # It rips the string apart into exact UTF-8 byte integers.
    bytes = for <<b <- string>>, do: b
    
    # 2. We wrap it in a list to represent a batch_size of 1, 
    # and explicitly cast it as an unsigned 8-bit integer tensor.
    Nx.tensor([bytes], type: :u8)
  end
end

defmodule DLM.Embedder do
  import Nx.Defn

  @doc """
  Runs on the EXLA compiler. Takes the integer tensor and a 
  256-row weight matrix, returning continuous floats.
  """
  defn embed(input_ids, embedding_matrix) do
    # Nx.take acts like a massive switchboard. 
    # If the input_id is 97 (for 'a'), it grabs the 97th row of the matrix.
    Nx.take(embedding_matrix, input_ids)
  end
end
```

