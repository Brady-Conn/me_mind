```elixir
defmodule DLM.Positional do
  # Changed 'defn' to 'def' so seq_len and embed_dim stay as standard integers
  def build(seq_len, embed_dim) do
    half_dim = div(embed_dim, 2)
    positions = Nx.iota({seq_len, 1})
    
    # Calculate the frequency wavelengths
    div_term = Nx.exp(Nx.multiply(Nx.iota({half_dim}), -(:math.log(10000.0) / half_dim)))
    args = Nx.multiply(positions, div_term)
    
    # Generate the waves and stick them together
    pe = Nx.concatenate([Nx.sin(args), Nx.cos(args)], axis: 1)
    
    # Scale to 0.1 so it acts as a subtle watermark!
    Nx.multiply(Nx.reshape(pe, {1, seq_len, embed_dim}), 0.1)
  end
end
```

```elixir
defmodule DLM.Mask do
  import Nx.Defn

  # Build the mathematical blindfold
  defn causal(seq_len) do
    # Create row and column coordinates
    row_idx = Nx.iota({seq_len, 1})
    col_idx = Nx.iota({1, seq_len})
    
    # Identify the "future" (upper triangle of the matrix)
    future_mask = Nx.greater(col_idx, row_idx)
    
    # Replace the future with -1 billion, keep the past as 0.0
    Nx.select(future_mask, Nx.tensor(-1.0e9), Nx.tensor(0.0))
  end
end
```

```elixir
defmodule DLM.Training do
  import Nx.Defn

  defn softmax(logits) do
    exps = Nx.exp(Nx.subtract(logits, Nx.reduce_max(logits, axes: [-1], keep_axes: true)))
    Nx.divide(exps, Nx.sum(exps, axes: [-1], keep_axes: true))
  end

  defn loss_fn(nx, _tn, cx, aw, fw, _its) do
    # Get the sequence length dynamically so it works for 7 chars or 40 chars
    {_batch, seq_len, _dim} = Nx.shape(nx)
    
    # 1. Raw Attention
    attn_logits = Nx.dot(nx, aw)
    
    # 2. Scale it (Keeps Softmax from freezing)
    scaled_logits = Nx.divide(attn_logits, 11.3137) 
    
    # 3. APPLY THE BLINDFOLD
    # We add the mask (-1.0e9) to the future, which Softmax will turn to 0.0
    mask = DLM.Mask.causal(seq_len)
    masked_logits = Nx.add(scaled_logits, mask)
    
    # 4. Softmax (The future is now completely gone)
    attn_weights = softmax(masked_logits)
    x = Nx.add(nx, attn_weights) |> DLM.ThoughtBlock.norm()
    
    # Step 2: Feed Forward
    ff = Nx.dot(x, fw)
    ff = Nx.select(Nx.greater(ff, 0), ff, Nx.multiply(ff, 0.01))
    final_x = Nx.add(x, ff) |> DLM.ThoughtBlock.norm()
    
    diff = Nx.subtract(final_x, cx)
    Nx.mean(Nx.pow(diff, 2))
  end
end
```

```elixir
defmodule DLM.Optimizer do
  import Nx.Defn

  defn step(nx, tn, cx, aw, fw, lr) do
    # Note: we don't need 'its' anymore for training
    {loss, {ga, gf}} = value_and_grad({aw, fw}, fn {a, f} -> 
      DLM.Training.loss_fn(nx, tn, cx, a, f, 1) 
    end)
    
    ga = Nx.clip(ga, -0.5, 0.5)
    gf = Nx.clip(gf, -0.5, 0.5)
    
    {loss, Nx.subtract(aw, Nx.multiply(ga, lr)), Nx.subtract(fw, Nx.multiply(gf, lr))}
  end

  defn run_chunk(nx, tn, cx, aw, fw, lr, epochs) do
    {_i, _nx, _tn, _cx, f_aw, f_fw, _lr, _e, f_loss} = 
      while {i = 0, nx, tn, cx, c_aw = aw, c_fw = fw, lr, e = epochs, _l = 0.0}, Nx.less(i, e) do
        {loss, n_aw, n_fw} = step(nx, tn, cx, c_aw, c_fw, lr)
        {i + 1, nx, tn, cx, n_aw, n_fw, lr, e, loss}
      end
    {f_aw, f_fw, f_loss}
  end
end
```

```elixir
# --- 1. SETUP (128-D + Sine/Cosine Positional Encoding) ---
batch_size = 32
embed_dim = 128
key = Nx.Random.key(42)

{emb_w, key} = Nx.Random.uniform(key, -1.0, 1.0, shape: {256, embed_dim})
target_bytes = Nx.tensor([[69, 108, 105, 120, 105, 114, 33]])
clean_x_single = Nx.dot(Nx.equal(Nx.iota({1, 7, 256}, axis: 2), Nx.reshape(target_bytes, {1, 7, 1})), emb_w)
clean_x = Nx.tile(clean_x_single, [batch_size, 1, 1])

# NEW: The Smooth Sine/Cosine Watermark
pos_emb = DLM.Positional.build(7, embed_dim)

{target_noise, key} = Nx.Random.normal(key, 0.0, 0.3, shape: {batch_size, 7, embed_dim})

# Add the noise and the subtle positional watermark
noisy_batch = Nx.add(clean_x, target_noise) |> Nx.add(pos_emb)

he_stddev = :math.sqrt(2 / embed_dim)
{attn_w, key} = Nx.Random.normal(key, 0.0, he_stddev, shape: {128, 128})
{ff_w, _key}  = Nx.Random.normal(key, 0.0, he_stddev, shape: {128, 128})

# --- 2. THE SINE WAVE BURN ---
max_lr = 0.6
min_lr = 0.01
chunks = 10
epochs_per_chunk = 1000

IO.puts("--- Starting 128-D Sine Wave Positional Burn ---")

{final_attn, final_ff, _} = 
  Enum.reduce(1..chunks, {attn_w, ff_w, 0.0}, fn c, {aw, fw, _} ->
    cos_val = :math.cos((c - 1) * :math.pi() / chunks)
    current_lr = min_lr + 0.5 * (max_lr - min_lr) * (1 + cos_val)
    
    {next_aw, next_fw, loss} = 
       DLM.Optimizer.run_chunk(noisy_batch, target_noise, clean_x, aw, fw, current_lr, epochs_per_chunk)
    
    l_val = Nx.to_number(loss)
    aw_safe = Nx.backend_copy(next_aw, Nx.BinaryBackend)
    fw_safe = Nx.backend_copy(next_fw, Nx.BinaryBackend)
    
    Nx.backend_deallocate(next_aw); Nx.backend_deallocate(next_fw); Nx.backend_deallocate(loss)
    Process.sleep(1200); :erlang.garbage_collect()
    
    IO.puts("Chunk #{c} | LR: #{Float.round(current_lr, 4)} | MSE: #{Float.round(l_val, 8)} | RAM: #{round(:erlang.memory(:total) / 1_000_000)}MB")
    {aw_safe, fw_safe, l_val}
  end)

# --- 3. THE REVEAL ---
{test_noise, _} = Nx.Random.normal(key, 0.0, 0.3, shape: {1, 7, embed_dim})
test_noisy = Nx.add(clean_x_single, test_noise) |> Nx.add(pos_emb)

thought_output = DLM.ThoughtBlock.recursive_pass(test_noisy, final_attn, final_ff, 50)
predicted_ids = Nx.dot(thought_output, Nx.transpose(emb_w)) |> Nx.argmax(axis: 2) |> Nx.to_flat_list()
safe_string = predicted_ids |> Enum.map(fn x -> if x in 32..126, do: x, else: ?. end) |> List.to_string()

IO.puts("\nPredicted IDs: #{inspect(predicted_ids)}")
IO.puts("Result String: #{safe_string}")
```

```elixir
# --- 3. THE REVEAL (THE 1-PASS FIX) ---
{test_noise, _} = Nx.Random.normal(key, 0.0, 0.3, shape: {1, 7, embed_dim})

# Create a fresh noisy string with the watermark
test_noisy = Nx.add(clean_x_single, test_noise) |> Nx.add(pos_emb)

# THE FIX: 1 Pass. We trained a 1-step denoiser, not a loop!
thought_output = DLM.ThoughtBlock.recursive_pass(test_noisy, final_attn, final_ff, 1)

predicted_ids = Nx.dot(thought_output, Nx.transpose(emb_w)) |> Nx.argmax(axis: 2) |> Nx.to_flat_list()
safe_string = predicted_ids |> Enum.map(fn x -> if x in 32..126, do: x, else: ?. end) |> List.to_string()

IO.puts("\nPredicted IDs: #{inspect(predicted_ids)}")
IO.puts("Result String: #{safe_string}")
```

```elixir
# --- 4. THE GENERALIZATION TEST (DOUBLE NOISE) ---
# We are cranking the noise standard deviation up from 0.3 to 0.6
{extreme_noise, _} = Nx.Random.normal(key, 0.0, 0.6, shape: {1, 7, embed_dim})

# Add the extreme noise and the positional watermark to the clean target
extreme_noisy_data = Nx.add(clean_x_single, extreme_noise) |> Nx.add(pos_emb)

# Pass it through your trained 1-Step Denoiser
thought_output = DLM.ThoughtBlock.recursive_pass(extreme_noisy_data, final_attn, final_ff, 1)

predicted_ids = Nx.dot(thought_output, Nx.transpose(emb_w)) |> Nx.argmax(axis: 2) |> Nx.to_flat_list()
safe_string = predicted_ids |> Enum.map(fn x -> if x in 32..126, do: x, else: ?. end) |> List.to_string()

IO.puts("\n--- EXTREME NOISE TEST (0.6 StdDev) ---")
IO.puts("Predicted IDs: #{inspect(predicted_ids)}")
IO.puts("Result String: #{safe_string}")
```

```elixir
# --- SAVE TRAINED WEIGHTS ---
save_path = "elixir_128d_weights.etf"

# We pack the tensors and metadata into a simple map
model_state = %{
  attn: final_attn,
  ff: final_ff,
  embed_dim: 128,
  word: "Elixir!"
}

# Convert the map to a highly compressed Erlang binary
binary_data = :erlang.term_to_binary(model_state)

# Write it to the hard drive
File.write!(save_path, binary_data)

IO.puts("✅ Successfully saved #{byte_size(binary_data) / 1_000_000} MB of weights to: #{save_path}")
