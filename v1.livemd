IO.puts("Step 1 (Mostly Signal): #{Nx.to_number(alphas_cumprod[0])}")
IO.puts("Step 10 (Halfway):      #{Nx.to_number(alphas_cumprod[9])}")
IO.puts("Step 20 (Mostly Noise): #{Nx.to_number(alphas_cumprod[19])}")

IO.inspect(Nx.shape(alphas_cumprod), label: "\nShape of Schedule Tensors")
