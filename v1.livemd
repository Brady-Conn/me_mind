```elixir
# 1. Setup (64-D)
embed_dim = 64
key = Nx.Random.key(777)
{emb_w, key} = Nx.Random.uniform(key, -1.0, 1.0, shape: {256, embed_dim})
target_bytes = Nx.tensor([[69, 108, 105, 120, 105, 114, 33]])
one_hot = Nx.equal(Nx.iota({1, 7, 256}, axis: 2), Nx.reshape(target_bytes, {1, 7, 1}))
clean_x = Nx.dot(one_hot, emb_w)
{target_noise, _key} = Nx.Random.normal(key, shape: {1, 7, embed_dim})
noisy_data = Nx.add(clean_x, target_noise)

# Initialize weights with "Quiet" values (-0.02 to 0.02)
{attn_w, key} = Nx.Random.uniform(key, -0.02, 0.02, shape: {64, 64})
{ff_w, _key}  = Nx.Random.uniform(key, -0.02, 0.02, shape: {64, 64})

# 2. Hybrid Loop
total_chunks = 10
chunk_size = 250
iterations = 5

IO.puts("--- Starting Stable Hybrid Burn ---")

{final_attn, final_ff, _} = 
  Enum.reduce(1..total_chunks, {attn_w, ff_w, Nx.tensor(0.0)}, fn chunk, {aw, fw, _} ->
    
    # Lower, safer Learning Rate
    lr = 0.01 # Keep it steady at 0.01 for the first 1000 epochs
    
    # Run 250 epochs in C++
    {next_aw, next_fw, loss} = 
      DLM.Optimizer.chunk_loop(noisy_data, target_noise, clean_x, aw, fw, iterations, lr, chunk_size)
    
    # Air-gap the result
    safe_aw = Nx.backend_copy(next_aw, Nx.BinaryBackend)
    safe_fw = Nx.backend_copy(next_fw, Nx.BinaryBackend)
    safe_loss = Nx.backend_copy(loss, Nx.BinaryBackend)

    IO.puts("Epoch #{chunk * chunk_size} | Loss: #{safe_loss |> Nx.squeeze() |> Nx.to_number()}")
    
    {safe_aw, safe_fw, safe_loss}
  end)

IO.puts("\nTraining Complete! No NaNs, No Crashes.")
```

```elixir
defmodule DLM.Inference do
  import Nx.Defn

  @doc """
  The 'Denoising Step'. It takes the current noisy data, asks the model
  to predict the noise, and then subtracts that noise to get a 'cleaner' version.
  """
  defn p_sample(x, t, alphas, alphas_cumprod, attn_w, ff_w, iterations) do
    # 1. Ask the model: "What part of this is noise?"
    predicted_noise = DLM.ThoughtBlock.recursive_pass(x, attn_w, ff_w, iterations)

    # 2. Grab the schedule constants for this specific timestep
    alpha_t = Nx.take(alphas, t)
    alpha_bar_t = Nx.take(alphas_cumprod, t)
    
    # 3. The Reverse Formula: This 'un-mixes' the signal from the noise
    # We remove the predicted noise scaled by the schedule
    coeff = (1 - alpha_t) / Nx.sqrt(1 - alpha_bar_t)
    mean = (1 / Nx.sqrt(alpha_t)) * (x - coeff * predicted_noise)

    # Return the slightly cleaner version of the data
    mean
  end
end
```

```elixir
# 1. THE DICTIONARY SYNC
# We re-derive the head from whatever emb_w is currently in the system memory
current_head = Nx.transpose(emb_w)

# 2. SANITY CHECK: "Does the dictionary work?"
# We take the 'clean_x' (the perfect target) and try to decode it directly.
# If this doesn't say "Elixir!", then our emb_w and clean_x are out of sync.
sanity_logits = Nx.dot(clean_x, current_head)
sanity_ids = Nx.argmax(sanity_logits, axis: 2) |> Nx.to_flat_list()
IO.puts("Sanity Check (Clean Data): #{List.to_string(sanity_ids)}")

# 3. THE ACTUAL INFERENCE
# Now we run the noisy data through the trained brain
inference_iterations = 20
thought_output = DLM.ThoughtBlock.recursive_pass(noisy_data, final_attn, final_ff, inference_iterations)

# 4. DECODE
inference_logits = Nx.dot(thought_output, current_head)
predicted_ids = Nx.argmax(inference_logits, axis: 2) |> Nx.to_flat_list()

IO.puts("--- The 64-D Final Reveal ---")
IO.puts("Predicted IDs: #{inspect(predicted_ids)}")
IO.puts("Decoded String: #{List.to_string(predicted_ids)}")
```

