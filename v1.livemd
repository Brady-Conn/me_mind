```elixir
defmodule DLM.Forward do
  import Nx.Defn

  @doc """
  Runs on EXLA. Instantly corrupts the clean text to match the exact 
  noise level required for a specific timestep.
  """
  defn add_noise(clean_x, t, alphas_cumprod, key) do
    # 1. Grab the cumulative alpha for our specific timestep 't'
    # This acts as a scalar value (e.g., 0.85)
    alpha_bar_t = Nx.take(alphas_cumprod, t)

    # 2. Calculate the weights for the signal and the noise
    sqrt_alpha_bar_t = Nx.sqrt(alpha_bar_t)
    sqrt_one_minus_alpha_bar_t = Nx.sqrt(1.0 - alpha_bar_t)

    # 3. Generate pure random static of the exact same shape as our text
    {noise, new_key} = Nx.Random.normal(key, shape: Nx.shape(clean_x))

    # 4. Mix them together using the formula!
    signal_part = Nx.multiply(clean_x, sqrt_alpha_bar_t)
    noise_part = Nx.multiply(noise, sqrt_one_minus_alpha_bar_t)
    noisy_x = Nx.add(signal_part, noise_part)

    # We return the noisy data, the pure noise (we need this to train!), and the key
    {noisy_x, noise, new_key}
  end
end
```

