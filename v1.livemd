```elixir
defmodule DLM.ThoughtBlock do
  import Nx.Defn

  # Keeps the data centered and at a consistent scale
  defn norm(t), do: Nx.divide(t, Nx.add(Nx.standard_deviation(t), 1.0e-6))

  defn recursive_pass(nx, aw, fw, iterations) do
    {final_nx, _aw, _fw, _i, _iters} = 
      while {x = nx, aw, fw, i = 0, iterations}, Nx.less(i, iterations) do
        
        # 1. Attention + Normalize
        attn = Nx.dot(x, aw) |> Nx.tanh()
        x = Nx.add(x, Nx.multiply(attn, 0.5)) |> norm()
        
        # 2. Feed Forward + Normalize
        ff = Nx.dot(x, fw) |> Nx.tanh()
        x = Nx.add(x, Nx.multiply(ff, 0.5)) |> norm()
        
        {x, aw, fw, i + 1, iterations}
      end
    final_nx
  end
end
```

```elixir
# 1. Frozen, Tied Weights
key = Nx.Random.key(777)
# Eyes: Create a strong, static signal (-1.0 to 1.0)
{emb_w, key} = Nx.Random.uniform(key, -1.0, 1.0, shape: {256, 16})
# Voice: The exact reverse of the eyes
head_w = Nx.transpose(emb_w)

# 2. Re-embed "Elixir!" using our new frozen Eyes
target_bytes = Nx.tensor([[69, 108, 105, 120, 105, 114, 33]])
one_hot = Nx.equal(Nx.iota({1, 7, 256}, axis: 2), Nx.reshape(target_bytes, {1, 7, 1}))
clean_x = Nx.dot(one_hot, emb_w)

# 3. Re-create the Noise Canvas for training
{target_noise, _key} = Nx.Random.normal(key, shape: {1, 7, 16})
# For simplicity in this step, we'll just add the noise directly
noisy_data = Nx.add(clean_x, target_noise) 

IO.puts("Tied Weights and Static Targets Created!")
```

