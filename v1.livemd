```elixir
defmodule DLM.Schedule do
  import Nx.Defn

  @doc """
  Runs on the BEAM (standard def). 
  Keeps 'timesteps' as a raw integer to satisfy the shape requirements.
  """
  def linear_beta_schedule(timesteps, start_beta \\ 0.0001, end_beta \\ 0.02) do
    Nx.linspace(start_beta, end_beta, n: timesteps)
  end

  @doc """
  Runs on EXLA (defn). 
  Takes the generated tensor and calculates the alphas.
  """
  defn calculate_alphas(betas) do
    alphas = Nx.subtract(1.0, betas)
    alphas_cumprod = Nx.cumulative_product(alphas)
    
    {alphas, alphas_cumprod}
  end
end
```

