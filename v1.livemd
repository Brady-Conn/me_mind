```elixir
# 1. Create a "Canvas" of pure random noise
# We use a different seed (777) to prove it's not just "remembering" the training noise
key = Nx.Random.key(777)
{canvas, _key} = Nx.Random.normal(key, shape: {1, 7, 16})

# 2. The Reverse Diffusion Pass
# We step backward from Step 19 (Pure Noise) to Step 0 (Clean Text)
final_denoised_tensor = 
  Enum.reduce(19..0//-1, canvas, fn t_idx, current_canvas ->
    t_tensor = Nx.tensor(t_idx)
    
    DLM.Inference.p_sample(
      current_canvas, 
      t_tensor, 
      alphas, 
      alphas_cumprod, 
      final_attn, 
      final_ff, 
      5 # iterations inside the ThoughtBlock
    )
  end)

# 3. Decode the result
predicted_ids = DLM.LanguageHead.predict(final_denoised_tensor, output_weights)
decoded_string = DLM.Decoder.decode(predicted_ids)

IO.puts("--- Inference Results ---")
IO.inspect(predicted_ids, label: "Predicted Byte IDs")
IO.inspect(decoded_string, label: "Generated String (Raw)")

# 4. Let's see how close we got to "Elixir!" (69, 108, 105, 120, 105, 114, 33)
target = [69, 108, 105, 120, 105, 114, 33]
output = predicted_ids |> Nx.flatten() |> Nx.to_flat_list()
diff = Enum.zip(target, output) |> Enum.map(fn {t, o} -> abs(t - o) end)

IO.inspect(diff, label: "Distance from Target Bytes")
```

```elixir
# --- 1. The 64-Dimensional Setup ---
embed_dim = 64
key = Nx.Random.key(777)

IO.puts("Setting up 64-D Space...")

# Eyes & Voice (Frozen, wide dimensions)
{emb_w, key} = Nx.Random.uniform(key, -1.0, 1.0, shape: {256, embed_dim})
head_w = Nx.transpose(emb_w)

# Target Data mapped to 64-D
target_bytes = Nx.tensor([[69, 108, 105, 120, 105, 114, 33]])
one_hot = Nx.equal(Nx.iota({1, 7, 256}, axis: 2), Nx.reshape(target_bytes, {1, 7, 1}))
clean_x = Nx.dot(one_hot, emb_w)

# Re-create Noise with 64 dimensions
{target_noise, _key} = Nx.Random.normal(key, shape: {1, 7, embed_dim})
noisy_data = Nx.add(clean_x, target_noise)

# --- 2. Initialize the 64-D Brain ---
{attn_w, key} = Nx.Random.uniform(key, -0.1, 0.1, shape: {embed_dim, embed_dim})
{ff_w, _key}  = Nx.Random.uniform(key, -0.1, 0.1, shape: {embed_dim, embed_dim})

# --- 3. The Power Loop ---
total_epochs = 500
chunk_size = 50
learning_rate = 0.05
iterations = 5

IO.puts("--- Starting 64-Dimensional Web Worker Training ---")

{final_attn, final_ff, _} = 
  Enum.reduce(1..div(total_epochs, chunk_size), {attn_w, ff_w, Nx.tensor(0.0)}, fn chunk, {aw, fw, _} ->
    
    worker = Task.async(fn ->
      {next_aw, next_fw, loss} = 
        DLM.Optimizer.train_loop(
          noisy_data, target_noise, clean_x,
          aw, fw, iterations, learning_rate, chunk_size
        )
      
      {Nx.backend_transfer(next_aw), Nx.backend_transfer(next_fw), Nx.backend_transfer(loss)}
    end)

    {safe_aw, safe_fw, safe_loss} = Task.await(worker, 60_000)
    
    IO.puts("Chunk #{chunk} | Total Epochs: #{chunk * chunk_size} | Loss: #{Nx.to_number(safe_loss)}")
    {safe_aw, safe_fw, safe_loss}
  end)

IO.puts("\n64-D Training Complete! Ready for Inference.")
```
