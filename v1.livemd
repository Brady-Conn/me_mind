```elixir
defmodule DLM.LanguageHead do
  import Nx.Defn

  @doc """
  Runs on EXLA. Projects the continuous tensor back to a 256-vocab space
  and selects the most likely byte.
  """
  defn predict(x, output_weights) do
    # 1. Project the embeddings back to the vocabulary size
    # Shape transition: {1, 7, 16} * {16, 256} -> {1, 7, 256}
    logits = Nx.dot(x, output_weights)
    
    # 2. Find the index (0-255) with the highest score along the last axis
    # Shape transition: {1, 7, 256} -> {1, 7}
    Nx.argmax(logits, axis: -1)
  end
end

defmodule DLM.Decoder do
  @doc """
  Runs on the BEAM. Takes the tensor of predicted integer bytes 
  and converts it back into an Elixir string.
  """
  def decode(byte_tensor) do
    # Flatten the tensor and convert it to a standard Elixir list of integers
    byte_list = byte_tensor |> Nx.flatten() |> Nx.to_flat_list()
    
    # Pack the integers back into a binary string. 
    # (Using a comprehension here safely ignores invalid visual characters)
    for b <- byte_list, into: "", do: <<b>>
  end
end
```

