## Training - base modules

```elixir
defmodule DLM.V19Trainer do
  import Nx.Defn

  # --- Our Custom, Bulletproof Log-Softmax ---
  defn log_softmax(logits) do
    # 1. Find the highest value to act as an anchor (prevents Infinity)
    max_logits = Nx.reduce_max(logits, axes: [-1], keep_axes: true)
    
    # 2. Subtract the max (makes the highest value 0, preventing overflow)
    safe_logits = logits - max_logits
    
    # 3. Calculate the Log-Sum-Exp
    sum_exp = Nx.sum(Nx.exp(safe_logits), axes: [-1], keep_axes: true)
    log_sum_exp = Nx.log(sum_exp)
    
    # 4. Final log probabilities
    safe_logits - log_sum_exp
  end

  defn loss_fn(params, pos_emb, x, y) do
    logits = DLM.UniversalSSM.forward(x, params, pos_emb)
    
    # Standard Cross-Entropy preparation
    flat_logits = Nx.reshape(logits, {:auto, 128})
    flat_targets = Nx.reshape(y, {:auto})
    
    targets_one_hot = Nx.equal(Nx.new_axis(flat_targets, -1), Nx.iota({128}, axis: 0))
    
    # USE OUR NEW CUSTOM FUNCTION!
    log_probs = log_softmax(flat_logits)
    
    -Nx.mean(Nx.sum(targets_one_hot * log_probs, axes: [-1]))
  end

  defn train_step(params, ms, vs, pos_emb, x, y, step_count, lr) do
    {loss, grads} = value_and_grad(params, &loss_fn(&1, pos_emb, x, y))
    
    # The Muon Hybrid
    {new_params, new_ms, new_vs} = DLM.MuonHybrid.step(params, grads, ms, vs, step_count, lr)
    
    {loss, new_params, new_ms, new_vs}
  end
end
