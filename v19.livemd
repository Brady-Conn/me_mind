# ===========================================================================
# V19 Probe — Dictionary & Semantic Integrity
# ===========================================================================
defmodule DLM.ProbeV19 do
  def run() do
    gpu = {EXLA.Backend, client: :rocm}
    full_state_path = "v19_full_state.bin"

    if File.exists?(full_state_path) do
      %{params: p, step: s} = File.read!(full_state_path) |> :erlang.binary_to_term()
      to_gpu = fn tpl -> tpl |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple() end
      params = to_gpu.(p)
      pos_emb = DLM.Positional.build(256, 256) |> Nx.backend_copy(gpu)
      muzzle = DLM.InferenceV19.build_muzzle() |> Nx.backend_copy(gpu)

      IO.puts("\n" <> String.duplicate("=", 60))
      IO.puts("DLM UNIVERSAL SSM PROBE (V19 - STEP #{s})")
      IO.puts(String.duplicate("=", 60))

      IO.puts("\n🛠️ CORE DICTIONARY (In-Distribution)")
      IO.puts(String.duplicate("-", 40))
      probe(params, pos_emb, "[W]leather [T]noun [D]", "Leather Def", muzzle)
      probe(params, pos_emb, "[W]dwarf [T]noun [D]",   "Dwarf Def",   muzzle)
      probe(params, pos_emb, "[W]forge [T]verb [D]",   "Forge Def",   muzzle)

      IO.puts("\n🔄 REVERSE LOOKUP")
      IO.puts(String.duplicate("-", 40))
      probe(params, pos_emb, "[D]A tough material made from animal hide [W]", "Word for hide", muzzle)
      probe(params, pos_emb, "[D]To strike metal with a hammer [W]",         "Word for strike", muzzle)

      IO.puts("\n🔀 FORMAT AGNOSTIC (Near-Distribution)")
      IO.puts(String.duplicate("-", 40))
      probe(params, pos_emb, "The word 'tannin' means",          "Prose definition", muzzle)
      probe(params, pos_emb, "[W]armor [R]Related:",             "Relational tag", muzzle)
      probe(params, pos_emb, "[W]elven [T]adj [D]Relating to", "Partial def", muzzle)

      IO.puts("\n🔤 MORPHOLOGY & STEMS")
      IO.puts(String.duplicate("-", 40))
      probe(params, pos_emb, "[W]Craft", "Craft-", muzzle)
      probe(params, pos_emb, "[W]Tann",  "Tann-",  muzzle)

      IO.puts("\n" <> String.duplicate("=", 60))
    else
      IO.puts("❌ No V19 checkpoint found!")
    end
  end

  defp probe(params, pos_emb, prompt, label, muzzle) do
    IO.puts("\n▶ #{label}")
    IO.puts("  Prompt:  #{inspect(prompt)}")

    greedy  = DLM.InferenceV19.greedy(params, pos_emb, prompt, 50, muzzle)
    sampled = DLM.InferenceV19.top_k(params, pos_emb, prompt, 50, 5, 0.8, muzzle)

    IO.puts("  Greedy:  #{inspect(String.slice(greedy,  String.length(prompt)..-1//1))}")
    IO.puts("  Top-k:   #{inspect(String.slice(sampled, String.length(prompt)..-1//1))}")

    :erlang.garbage_collect(self())
  end
end

# Run the suite!
DLM.ProbeV19.run()
