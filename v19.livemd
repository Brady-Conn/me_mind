## P3.1 Training

```elixir
defmodule DLM.Phase3Resume do
  def run() do
    gpu = {EXLA.Backend, client: :rocm}
    phase3_state_path = "v19_phase3_state.bin"

    IO.puts("🧠 Loading Phase 3 Brain...")
    %{params: p, ms: m, vs: v, step: start_step} = File.read!(phase3_state_path) |> :erlang.binary_to_term()
    to_gpu = fn tpl -> tpl |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple() end
    {params, ms, vs} = {to_gpu.(p), to_gpu.(m), to_gpu.(v)}

    pos_emb = DLM.Positional.build(256, 256) |> Nx.backend_copy(gpu)

    target_steps = 15000 
    base_lr = 3.0e-5  # Slightly higher to help break the dictionary habit
    min_lr = 1.0e-6

    data_stream = DLM.DataStreamer.stream("v19_chat_data.txt", 256, 2)

    IO.puts("🚀 Resuming PHASE 3 from Step #{start_step} to #{target_steps}...")

    data_stream
    |> Stream.cycle()
    |> Stream.zip((start_step + 1)..target_steps)
    |> Enum.reduce({params, ms, vs, Nx.tensor(0.0)}, fn {{_x_cpu, _y_cpu}, current_step} = item, acc ->
      
      # Adjusted progress calculation for the remaining steps
      progress = (current_step - start_step) / (target_steps - start_step)
      current_lr = min_lr + 0.5 * (base_lr - min_lr) * (1.0 + :math.cos(:math.pi() * progress))

      DLM.Phase3Core.run_step(item, acc, gpu, pos_emb, current_lr)
    end)

    IO.puts("✅ Phase 3 Extension Complete!")
  end
end

DLM.Phase3Resume.run()
```

