## Training

```elixir
defmodule DLM.V19Trainer do
  import Nx.Defn

  # --- Our Custom, Bulletproof Log-Softmax ---
  defn log_softmax(logits) do
    # 1. Find the highest value to act as an anchor (prevents Infinity)
    max_logits = Nx.reduce_max(logits, axes: [-1], keep_axes: true)
    
    # 2. Subtract the max (makes the highest value 0, preventing overflow)
    safe_logits = logits - max_logits
    
    # 3. Calculate the Log-Sum-Exp
    sum_exp = Nx.sum(Nx.exp(safe_logits), axes: [-1], keep_axes: true)
    log_sum_exp = Nx.log(sum_exp)
    
    # 4. Final log probabilities
    safe_logits - log_sum_exp
  end

  defn loss_fn(params, pos_emb, x, y) do
    logits = DLM.UniversalSSM.forward(x, params, pos_emb)
    
    # Standard Cross-Entropy preparation
    flat_logits = Nx.reshape(logits, {:auto, 128})
    flat_targets = Nx.reshape(y, {:auto})
    
    targets_one_hot = Nx.equal(Nx.new_axis(flat_targets, -1), Nx.iota({128}, axis: 0))
    
    # USE OUR NEW CUSTOM FUNCTION!
    log_probs = log_softmax(flat_logits)
    
    -Nx.mean(Nx.sum(targets_one_hot * log_probs, axes: [-1]))
  end

  defn train_step(params, ms, vs, pos_emb, x, y, step_count, lr) do
    {loss, grads} = value_and_grad(params, &loss_fn(&1, pos_emb, x, y))
    
    # The Muon Hybrid
    {new_params, new_ms, new_vs} = DLM.MuonHybrid.step(params, grads, ms, vs, step_count, lr)
    
    {loss, new_params, new_ms, new_vs}
  end
end

defmodule DLM.TrainingCore do
  def run_step({{x_cpu, y_cpu}, current_step}, {p_acc, m_acc, v_acc, _last_loss}, gpu, pos_emb, lr, epoch) do
    x = x_cpu |> Nx.as_type(:s32) |> Nx.backend_copy(gpu)
    y = y_cpu |> Nx.as_type(:s32) |> Nx.backend_copy(gpu)

    {loss, next_p, next_m, next_v} = DLM.V19Trainer.train_step(
      p_acc, m_acc, v_acc, pos_emb, x, y, Nx.tensor(current_step), Nx.tensor(lr)
    )

    # 🧹 THE FIX: Force Elixir to tell EXLA to free dead memory
    if rem(current_step, 10) == 0 do
      :erlang.garbage_collect(self())
    end

    if rem(current_step, 200) == 0 do
      loss_cpu = Nx.backend_copy(loss, Nx.BinaryBackend)
      loss_val = Nx.to_number(loss_cpu)
      
      sys_ram = :erlang.memory(:total) |> div(1024 * 1024)
      IO.puts("🔥 Step #{current_step} | Loss: #{loss_val} | BEAM RAM: #{sys_ram}MB")
      
      state = %{
        params: next_p |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
        ms: next_m |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
        vs: next_v |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
        step: current_step,
        epoch: epoch
      }
      File.write!("v19_full_state.bin", :erlang.term_to_binary(state))
    end

    {next_p, next_m, next_v, loss}
  end
end

# --- PHASE 2 RE-LAUNCHER ---
gpu = {EXLA.Backend, client: :rocm}
full_state_path = "v19_full_state.bin"

# Load your pristine Step 5000 Skeleton
IO.puts("♻️ Resuming V19 Skeleton (Step 5000)...")
%{params: p, ms: m, vs: v, step: start_step, epoch: epoch} = File.read!(full_state_path) |> :erlang.binary_to_term()
to_gpu = fn tpl -> tpl |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple() end
{params, ms, vs} = {to_gpu.(p), to_gpu.(m), to_gpu.(v)}

pos_emb = DLM.Positional.build(256, 256) |> Nx.backend_copy(gpu)

# 📉 Phase 2 Learning Rate Setup
max_steps = 50_000 
base_lr = 5.0e-5   # Lower starting point since the skeleton exists
min_lr = 1.0e-5

# 🔥 POINT TO THE NEW MASSIVE DICTIONARY
data_stream = DLM.DataStreamer.stream("v19_massive_dictionary.txt", 256, 2)

IO.puts("🚀 PHASE 2: Training engaged on 274k entries...")

data_stream
|> Stream.drop(start_step)
|> Stream.zip((start_step + 1)..max_steps)
|> Enum.reduce({params, ms, vs, Nx.tensor(0.0)}, fn {{x_cpu, y_cpu}, current_step} = item, acc ->
  
  # Stretched Cosine Decay for the long haul
  progress = current_step / max_steps
  current_lr = min_lr + 0.5 * (base_lr - min_lr) * (1.0 + :math.cos(:math.pi() * progress))

  DLM.TrainingCore.run_step(item, acc, gpu, pos_emb, current_lr, epoch)
end)
```

