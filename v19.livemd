## d2(unused) should it be used?

```elixir
defmodule DLM.Phase2Parser do
  @doc """
  Parses WordNet 'data.pos' files.
  Format: synset_offset lex_filenum ss_type w_cnt word lex_id ... | gloss
  """
  def parse_wordnet(file_path, pos_tag) do
    File.stream!(file_path)
    |> Stream.reject(&String.starts_with?(&1, "  ")) # Skip copyright header
    |> Stream.map(fn line ->
      [content, gloss_part] = String.split(line, "|")
      parts = String.split(content, " ", trim: true)
      
      # WordNet replaces spaces with underscores; we swap them back
      words = Enum.slice(parts, 4, String.to_integer(Enum.at(parts, 3), 16) * 2)
              |> Enum.take_every(2)
              |> Enum.map(&String.replace(&1, "_", " "))

      [primary | synonyms] = words
      definition = String.trim(gloss_part)
      
      # Build the 'Flesh' entry
      syn_str = if Enum.empty?(synonyms), do: "", else: "[R]Synonyms: #{Enum.join(synonyms, ", ")} "
      "[W]#{primary} [T]#{pos_tag} #{syn_str}[D]#{definition}"
    end)
  end

  @doc """
  Parses Moby Thesaurus CSV format.
  Format: root,syn1,syn2,syn3...
  """
  def parse_moby(file_path) do
    File.stream!(file_path)
    |> Stream.map(fn line ->
      [root | related] = String.split(line, ",", trim: true)
      # Moby is massive, so we take the top 10 related terms to keep it punchy
      synonyms = Enum.take(related, 10) |> Enum.map(&String.trim/1)
      "[W]#{root} [R]Related: #{Enum.join(synonyms, ", ")} [D]See also related concepts."
    end)
  end

  @doc """
  Wraps Parallel Shakespeare text.
  Expected input: List of %{modern: "...", shakespeare: "..."}
  """
  def wrap_shakespeare(pairs) do
    pairs
    |> Enum.map(fn %{modern: mod, shakespeare: shake} ->
      # We use [S] for 'Style' or 'Soul' to distinguish it from a definition
      "[W]#{mod} [S]Shakespearean [D]#{shake}"
    end)
  end
end
