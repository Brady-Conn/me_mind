## Chat Probe

```elixir
defmodule DLM.ChatProbe do
  def ask(user_input, assistant_start \\ "") do
    gpu = {EXLA.Backend, client: :rocm}
    phase3_state_path = "v19_phase3_state.bin"

    if File.exists?(phase3_state_path) do
      %{params: p, step: s} = File.read!(phase3_state_path) |> :erlang.binary_to_term()
      to_gpu = fn tpl -> tpl |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple() end
      params = to_gpu.(p)
      
      pos_emb = DLM.Positional.build(256, 256) |> Nx.backend_copy(gpu)
      muzzle = DLM.InferenceV19.build_muzzle() |> Nx.backend_copy(gpu)

      IO.puts("🧠 V19 Online (Step #{s})")
      IO.puts(String.duplicate("=", 50))
      
      # 🎯 INJECT THE RUNNING START
      formatted_prompt = "[User] #{user_input}\n[Assistant] #{assistant_start}"
      
      IO.write("👤 You: #{user_input}\n🤖 V19: #{assistant_start}")
      
      # 🎛️ SLIGHTLY LOOSENED DECODING
      raw_output = DLM.InferenceV19.top_k(params, pos_emb, formatted_prompt, 150, 3, 0.4, muzzle)
      
      clean_response = 
        raw_output
        |> String.replace(formatted_prompt, "") 
        |> String.split("[End]")                
        |> hd()                                 
        |> String.trim()

      IO.puts(clean_response)
      IO.puts(String.duplicate("=", 50))
    else
      IO.puts("❌ No Phase 3 weights found.")
    end
  end
end
```

