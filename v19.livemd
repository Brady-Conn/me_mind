```elixir
defmodule DLM.MuonHybrid do
  import Nx.Defn

  # --- The Muon Newton-Schulz Engine ---
  defn newton_schulz(g, iters \\ 5) do
    # THE FIX: Calculate the Frobenius Norm
    # This guarantees the matrix's spectral norm is <= 1.0, 
    # making it impossible for the iteration to explode to NaN.
    frobenius_norm = Nx.sqrt(Nx.sum(Nx.pow(g, 2))) + 1.0e-7
    x = g / frobenius_norm
    
    # Iteratively orthogonalize the matrix
    {final_x, _} = while {curr_x = x, i = 0}, Nx.less(i, iters) do
      x_t_x = Nx.dot(Nx.transpose(curr_x), curr_x)
      next_x = 1.5 * curr_x - 0.5 * Nx.dot(curr_x, x_t_x)
      {next_x, i + 1}
    end
    final_x
  end

  # --- Standard Adam Component ---
  defn adam_update(param, grad, m, v, step, lr) do
    beta1 = 0.9
    beta2 = 0.999
    eps = 1.0e-8
    
    new_m = beta1 * m + (1.0 - beta1) * grad
    new_v = beta2 * v + (1.0 - beta2) * Nx.pow(grad, 2)
    
    m_hat = new_m / (1.0 - Nx.pow(beta1, step))
    v_hat = new_v / (1.0 - Nx.pow(beta2, step))
    
    param_update = param - lr * m_hat / (Nx.sqrt(v_hat) + eps)
    {param_update, new_m, new_v}
  end

  # --- The Hybrid Step ---
  defn step(params, grads, ms, vs, step_count, lr) do
    {p_emb, p_a, p_bu, p_bv, p_cu, p_cv, p_du, p_dv, p_lmw, p_lmb} = params
    {g_emb, g_a, g_bu, g_bv, g_cu, g_cv, g_du, g_dv, g_lmw, g_lmb} = grads
    {m_emb, m_a, m_bu, m_bv, m_cu, m_cv, m_du, m_dv, m_lmw, m_lmb} = ms
    {v_emb, v_a, v_bu, v_bv, v_cu, v_cv, v_du, v_dv, v_lmw, v_lmb} = vs

    # 1. Apply Adam to 1D and Vocab Tensors
    {up_emb, nm_emb, nv_emb} = adam_update(p_emb, g_emb, m_emb, v_emb, step_count, lr)
    {up_a, nm_a, nv_a}       = adam_update(p_a, g_a, m_a, v_a, step_count, lr)
    {up_lmw, nm_lmw, nv_lmw} = adam_update(p_lmw, g_lmw, m_lmw, v_lmw, step_count, lr)
    {up_lmb, nm_lmb, nv_lmb} = adam_update(p_lmb, g_lmb, m_lmb, v_lmb, step_count, lr)

    # 2. Apply Muon to SVD Matrices
    up_bu = p_bu - lr * newton_schulz(g_bu)
    up_bv = p_bv - lr * newton_schulz(g_bv)
    up_cu = p_cu - lr * newton_schulz(g_cu)
    up_cv = p_cv - lr * newton_schulz(g_cv)
    up_du = p_du - lr * newton_schulz(g_du)
    up_dv = p_dv - lr * newton_schulz(g_dv)

    new_params = {up_emb, up_a, up_bu, up_bv, up_cu, up_cv, up_du, up_dv, up_lmw, up_lmb}
    new_ms = {nm_emb, nm_a, m_bu, m_bv, m_cu, m_cv, m_du, m_dv, nm_lmw, nm_lmb}
    new_vs = {nv_emb, nv_a, v_bu, v_bv, v_cu, v_cv, v_du, v_dv, nv_lmw, nv_lmb}

    {new_params, new_ms, new_vs}
  end
end
