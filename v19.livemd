## deep probe

```elixir
# ===========================================================================
# V19 Inference — Dynamic Sequence Slicing
# ===========================================================================
defmodule DLM.InferenceV19 do
  import Nx.Defn

  @allowed_chars ~c" abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789.,:;-'\"()[]"

  def build_muzzle(vocab_size \\ 128, allowed \\ @allowed_chars) do
    muzzle = Nx.broadcast(Nx.tensor(-1.0e10, type: :f32), {vocab_size})
    Enum.reduce(allowed, muzzle, fn char, acc ->
      Nx.indexed_put(acc, Nx.tensor([[char]]), Nx.tensor([0.0]))
    end)
  end

  defn get_next_logits(ins_padded, actual_len_tensor, params, pos_emb, muzzle) do
    # 1. Forward pass on the fully static {1, 256} tensor
    logits = DLM.UniversalSSM.forward(ins_padded, params, pos_emb)
    
    # 2. Find the index of the last REAL character
    target_idx = actual_len_tensor - 1
    
    # 3. Extract only the prediction for that specific character
    logits[0][target_idx] + muzzle
  end

  defn apply_rep_penalty(logits, recent_tokens, penalty_weight) do
    # 1. Dynamically grab the vocabulary size (128) directly from the logits
    vocab_size = elem(Nx.shape(logits), 0)

    # 2. Build the mask matching the exact vocabulary size
    mask =
      recent_tokens
      |> Nx.new_axis(-1)
      |> Nx.equal(Nx.iota({vocab_size}))
      |> Nx.any(axes: [0])

    # 3. Apply the math
    penalized = Nx.select(
      logits > 0.0,
      logits / penalty_weight,
      logits * penalty_weight
    )

    # 4. Return the safely penalized logits
    Nx.select(mask, penalized, logits)
  end

  # defn sample_top_k(ins, params, pos_emb, muzzle, temp, key, opts \\ []) do
  #   logits = get_next_logits(ins, params, pos_emb, muzzle) / temp
  #   {top_values, top_indices} = Nx.top_k(logits, k: opts[:k])
    
  #   # Safe Softmax
  #   safe_vals = top_values - Nx.reduce_max(top_values)
  #   probs = Nx.exp(safe_vals) / Nx.sum(Nx.exp(safe_vals))
    
  #   {sampled_tensor, new_key} = Nx.Random.choice(key, top_indices, probs)
  #   {sampled_tensor[0], new_key}
  # end

  # def greedy(params, pos_emb, prompt, max_new_chars \\ 120, muzzle \\ nil) do
  #   gpu    = {EXLA.Backend, client: :rocm}
  #   muzzle = (muzzle || build_muzzle()) |> Nx.backend_copy(gpu)
  #   prompt_chars = String.to_charlist(prompt)
  #   max_seq = elem(Nx.shape(pos_emb), 0)

  #   Enum.reduce(1..max_new_chars, prompt_chars, fn step, chars ->
  #     # V19 FIX: No zero padding. Just take up to the max window size.
  #     current_window = Enum.take(chars, -max_seq)
  #     ins = Nx.tensor([current_window], type: :s64) |> Nx.backend_copy(gpu)

  #     raw_logits = get_next_logits(ins, params, pos_emb, muzzle)
  #     recent     = Enum.take(chars, -20)
  #     penalized  = apply_rep_penalty(raw_logits, recent, 1.3)
  #     next_token = penalized |> Nx.argmax() |> Nx.to_number()

  #     if rem(step, 10) == 0, do: :erlang.garbage_collect(self())
  #     chars ++ [next_token]
  #   end)
  #   |> List.to_string()
  # end

  def top_k(params, pos_emb, prompt, max_new_chars \\ 120, k \\ 3, temp \\ 0.4, muzzle \\ nil) do
    gpu = {EXLA.Backend, client: :rocm}
    muzzle = (muzzle || build_muzzle()) |> Nx.backend_copy(gpu)
    prompt_chars = String.to_charlist(prompt)
    max_seq = elem(Nx.shape(pos_emb), 0)
    
    penalty_weight = Nx.tensor(1.2, type: :f32) |> Nx.backend_copy(gpu)

    Enum.reduce(1..max_new_chars, {prompt_chars, Nx.Random.key(42)}, fn step, {chars, key} ->
      # 1. Grab our real characters
      window_chars = Enum.take(chars, -max_seq)
      actual_len = length(window_chars)
      
      # 2. THE FIX: Right-pad with zeros to force a static {1, 256} shape
      pad_len = max_seq - actual_len
      padded_chars = window_chars ++ List.duplicate(0, pad_len)
      
      # 3. Send the static tensor and the "cursor" to the GPU
      ins_padded = Nx.tensor([padded_chars], type: :s64) |> Nx.backend_copy(gpu)
      len_tensor = Nx.tensor(actual_len, type: :s32) |> Nx.backend_copy(gpu)

      # 4. Get logits (This will now only trigger autotuning ONCE)
      logits = get_next_logits(ins_padded, len_tensor, params, pos_emb, muzzle)
      
      recent_chars = Enum.take(chars, -50)
      recent_tensor = Nx.tensor(recent_chars, type: :s64) |> Nx.backend_copy(gpu)
      penalized_logits = apply_rep_penalty(logits, recent_tensor, penalty_weight)

      {next_token, next_key} = sample_top_k_logits(penalized_logits, temp, key, k: k)

      if rem(step, 10) == 0, do: :erlang.garbage_collect(self())
      {chars ++ [Nx.to_number(next_token)], next_key}
    end)
    |> elem(0)
    |> List.to_string()
  end

  # Helper to sample directly from logits since we split the forward pass
  defn sample_top_k_logits(logits, temp, key, opts \\ []) do
    k = opts[:k]
    scaled_logits = logits / temp
    {values, indices} = Nx.top_k(scaled_logits, k: k)
    
    probs = Nx.exp(values) / Nx.sum(Nx.exp(values))
    {sample_val, next_key} = Nx.Random.uniform(key)
    
    cumulative_probs =
      probs
      |> Nx.window_sum({k}, padding: :valid)
      |> Nx.squeeze()

    selected_idx = Nx.argmax(cumulative_probs > sample_val)
    {indices[selected_idx], next_key}
  end
end

