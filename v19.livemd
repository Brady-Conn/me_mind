```elixir
defmodule DLM.V19Doctor do
  def check_and_clean() do
    checkpoint = "v19_full_state.bin"
    genesis = "v19_genesis.bin"

    IO.puts("=== V19 CLINIC ===")

    # 1. Delete the potentially poisoned checkpoint
    if File.exists?(checkpoint) do
      File.rm!(checkpoint)
      IO.puts("🗑️ DELETED: Corrupted checkpoint removed.")
    else
      IO.puts("✅ CLEAN: No checkpoint found to delete.")
    end

    # 2. Inspect the Genesis file
    if File.exists?(genesis) do
      IO.puts("\n🔍 Inspecting Genesis weights...")
      params = File.read!(genesis) |> :erlang.binary_to_term()
      
      # Check every single tensor for NaN (Not a Number) corruption
      has_nans = 
        params
        |> Tuple.to_list()
        |> Enum.any?(fn tensor -> 
          Nx.is_nan(tensor) |> Nx.sum() |> Nx.to_number() > 0
        end)

      if has_nans do
        IO.puts("❌ FATAL: Genesis file contains NaNs! You must rerun the Genesis cell.")
      else
        IO.puts("✅ HEALTHY: Genesis file is pristine. No NaNs detected.")
        
        # Pull the Embed matrix just to verify the initialization scale (~0.02)
        {embed, _, _, _, _, _, _, _, _, _} = params
        min = Nx.reduce_min(embed) |> Nx.to_number()
        max = Nx.reduce_max(embed) |> Nx.to_number()
        IO.puts("📊 Embed Range: #{Float.round(min, 4)} to #{Float.round(max, 4)} (Target: ~0.02)")
      end
    else
      IO.puts("❌ ERROR: Genesis file not found! Did you run Cell 4?")
    end
    
    IO.puts("==================")
  end
end

# Run the Doctor
DLM.V19Doctor.check_and_clean()
