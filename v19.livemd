## Phase 3 Training

```elixir
defmodule DLM.Phase3Core do
  def run_step({{x_cpu, y_cpu}, current_step}, {p_acc, m_acc, v_acc, _last_loss}, gpu, pos_emb, lr) do
    x = x_cpu |> Nx.as_type(:s32) |> Nx.backend_copy(gpu)
    y = y_cpu |> Nx.as_type(:s32) |> Nx.backend_copy(gpu)

    {loss, next_p, next_m, next_v} = DLM.V19Trainer.train_step(
      p_acc, m_acc, v_acc, pos_emb, x, y, Nx.tensor(current_step), Nx.tensor(lr)
    )

    # 🧹 The GC Whip
    if rem(current_step, 10) == 0 do
      :erlang.garbage_collect(self())
    end

    if rem(current_step, 100) == 0 do
      loss_cpu = Nx.backend_copy(loss, Nx.BinaryBackend)
      loss_val = Nx.to_number(loss_cpu)
      
      sys_ram = :erlang.memory(:total) |> div(1024 * 1024)
      IO.puts("🗣️ Chat Step #{current_step} | Loss: #{Float.round(loss_val, 4)} | BEAM RAM: #{sys_ram}MB")
      
      # 💾 Save as a NEW Phase 3 file
      state = %{
        params: next_p |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
        ms: next_m |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
        vs: next_v |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
        step: current_step
      }
      File.write!("v19_phase3_state.bin", :erlang.term_to_binary(state))
    end

    {next_p, next_m, next_v, loss}
  end
end

# ==========================================
# PHASE 3: INSTRUCTION TUNING LAUNCHER
# ==========================================
gpu = {EXLA.Backend, client: :rocm}
phase2_state_path = "v19_full_state.bin"

IO.puts("🧠 Loading Phase 2 Dictionary Brain...")
%{params: p, ms: m, vs: v} = File.read!(phase2_state_path) |> :erlang.binary_to_term()
to_gpu = fn tpl -> tpl |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple() end
{params, ms, vs} = {to_gpu.(p), to_gpu.(m), to_gpu.(v)}

pos_emb = DLM.Positional.build(256, 256) |> Nx.backend_copy(gpu)

# 📉 Phase 3 Hyperparameters
max_steps = 5000 
base_lr = 1.0e-5   # Very gentle to protect the English structure
min_lr = 1.0e-6

# 🗣️ POINT TO THE NEW CHAT DATA
data_stream = DLM.DataStreamer.stream("v19_chat_data.txt", 256, 2)

IO.puts("🚀 PHASE 3: Conversational Shift engaged...")

data_stream
|> Stream.cycle()  # 🔁 THE FIX: Loop the data infinitely
|> Stream.zip(1..max_steps)
|> Enum.reduce({params, ms, vs, Nx.tensor(0.0)}, fn {{_x_cpu, _y_cpu}, current_step} = item, acc ->

  progress = current_step / max_steps
  current_lr = min_lr + 0.5 * (base_lr - min_lr) * (1.0 + :math.cos(:math.pi() * progress))
  DLM.Phase3Core.run_step(item, acc, gpu, pos_emb, current_lr)
end)

IO.puts("✅ Phase 3 Complete! V19 is ready to talk.")
