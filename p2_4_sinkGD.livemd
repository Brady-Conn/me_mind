## BLiMP

```elixir
defmodule DLM.Phase2_Eval do
  import Nx.Defn

  defn compute_sentence_loss(input_tokens, target_tokens, orig_seq_len, h_init, params, frozen_map) do
    seq_len = Nx.axis_size(input_tokens, 1) 
    
    # 1. Map BOTH inputs and targets to the continuous 512D Sinkhorn space
    input_coords =
      Nx.take(frozen_map, Nx.flatten(input_tokens))
      |> Nx.reshape({1, seq_len, 512})
      |> stop_grad()

    # ⚡ NEW: We need the targets as coordinates, not integer IDs
    target_coords =
      Nx.take(frozen_map, Nx.flatten(target_tokens))
      |> Nx.reshape({1, seq_len, 512})
      |> stop_grad()
  
    in_t = Nx.transpose(input_coords, axes: [1, 0, 2])
    targ_t = Nx.transpose(target_coords, axes: [1, 0, 2]) 

    int_lt = Nx.tensor(0.0, type: :f32)
  
    # 2. The Physics Loop
    result =
      while {i = 0, total_loss = int_lt,
             h = h_init,
             x_in = in_t, y_targ = targ_t,
             p = params, f_map = frozen_map, sq_ln = orig_seq_len},
            Nx.less(i, seq_len) do
  
        x_curr = x_in[i]
  
        # ⚡ 3. The Core Physics
        {logits_fwd, _logits_retro, h_new} = DLM.TinySSM.forward_step(x_curr, h, p)
        
        # ⚡ 4. Trajectory Error (Spatial Distance)
        # L2 normalize both points to match the space your model was trained in
        p_norm = DLM.Loss.l2_normalize(logits_fwd)
        t_norm = DLM.Loss.l2_normalize(y_targ[i])
        
        # Calculate Squared Euclidean Distance between predicted and actual coordinates
        diff = Nx.subtract(p_norm, t_norm)
        step_loss = Nx.sum(Nx.pow(diff, 2), axes: [-1]) |> Nx.squeeze()
        
        # 5. THE MASK: Zero out the loss if we are in the padded void
        valid_mask = Nx.select(Nx.less(i, sq_ln), 1.0, 0.0)
        masked_loss = Nx.multiply(step_loss, valid_mask)

        {i + 1, Nx.add(total_loss, masked_loss), h_new, x_in, y_targ, p, f_map, sq_ln}
      end
  
    # Divide the accumulated spatial deviation by the original true sentence length
    Nx.divide(elem(result, 1), Nx.as_type(orig_seq_len, :f32))
  end
end
