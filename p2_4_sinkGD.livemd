```elixir
defmodule DLM.PhysicsGenesis do
  import Nx.Defn

  @dim 512
  @rank 256

  defn ignite(key) do
    # a_diag: Friction/Inertia (Kept stable)
    {a, k1} = Nx.Random.normal(key, -0.1, 0.01, shape: {@dim})
    
    # ⚡ UPGRADE 1: Xavier/Glorot Initialization for all SVD Bottlenecks
    std_dev = Nx.divide(1.0, Nx.sqrt(512))
    
    # b: Input Force Matrices
    {bu, k2} = Nx.Random.normal(k1, 0.0, std_dev, shape: {@dim, @rank})
    {bv, k3} = Nx.Random.normal(k2, 0.0, std_dev, shape: {@rank, @dim})
    
    # c: Output Velocity Matrices
    {cu, k4} = Nx.Random.normal(k3, 0.0, std_dev, shape: {@dim, @rank})
    {cv, k5} = Nx.Random.normal(k4, 0.0, std_dev, shape: {@rank, @dim})

    # d: Dynamic Gating Matrices (Now with healthy variance!)
    {du, k6} = Nx.Random.normal(k5, 0.0, std_dev, shape: {@dim, @rank})
    {dv, k7} = Nx.Random.normal(k6, 0.0, std_dev, shape: {@rank, @dim})

    # ⚡ UPGRADE 2: Identity Initialization for Final Spatial Rotations
    identity = Nx.eye({@dim, @dim}, type: :f32)
    # Scale by 0.5 so it isn't completely rigid on Step 0
    vocab_w = Nx.multiply(identity, 0.5) 
    rw = Nx.multiply(identity, 0.5)
    
    # Biases
    vocab_b = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    rb = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    
    {{a, bu, bv, cu, cv, du, dv, vocab_w, vocab_b, rb, rw}, k7}
  end

  def init_optimizer(params) do
    zero_state = DLM.Tree.map(params, fn p -> Nx.broadcast(0.0, Nx.shape(p)) end)
    {zero_state, zero_state, Nx.tensor(0)}
  end
end
