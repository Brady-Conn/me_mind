## USSM, Positional, Muon_Optimizer

```elixir
defmodule DLM.UniversalSSM do
  import Nx.Defn

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn softplus(x), do: Nx.log1p(Nx.exp(x))

  # ⚡ The clean, dense recurrence (No complex SVD bottleneck during the loop)
  defn ssm_recurrence(x_t, x_prev1, x_prev2, h_p, a, b, c, d, m1, m2) do
    x_mixed = x_t 
      |> Nx.add(Nx.dot(x_prev1, m1))
      |> Nx.add(Nx.dot(x_prev2, m2))
  
    delta_proj = Nx.dot(x_mixed, d)
    delta = delta_proj |> softplus() |> Nx.max(1.0e-4)
    a_bar = Nx.sigmoid(Nx.multiply(delta, a))
    
    b_proj = Nx.dot(x_mixed, b)
    b_bar = Nx.multiply(delta, b_proj)
    
    h_t = Nx.tanh(Nx.add(Nx.multiply(a_bar, h_p), b_bar))
    
    y_ssm = Nx.dot(h_t, c)
    y_t = Nx.add(y_ssm, x_mixed) 
   
    {y_t, h_t}
  end

  # ⚡ THE ELEVATOR: All 3 layers fused into a single loop to save Host RAM!
  defn run_block_loop(x_seq, h_init, a_diag, b_mat, c_mat, d_mat, m1_mat, m2_mat) do
    {seq_len, batch_size, embed_dim} = Nx.shape(x_seq)
    y_init     = Nx.broadcast(Nx.tensor(0.0, type: :f32), {seq_len, batch_size, embed_dim})
    zero_frame = Nx.broadcast(Nx.tensor(0.0, type: :f32), {batch_size, embed_dim})
  
    result_tuple =
      while {
        i = 0, y_acc = y_init, xs = x_seq,
        h1 = h_init, xp1_1 = zero_frame, xp2_1 = zero_frame,
        h2 = h_init, xp1_2 = zero_frame, xp2_2 = zero_frame,
        h3 = h_init, xp1_3 = zero_frame, xp2_3 = zero_frame,
        a = a_diag, b = b_mat, c = c_mat, d = d_mat, m1 = m1_mat, m2 = m2_mat
      }, Nx.less(i, seq_len) do

        # 🧱 Layer 1
        x_t_1 = xs[i]
        {y_t_1, h_new_1} = ssm_recurrence(x_t_1, xp1_1, xp2_1, h1, a, b, c, d, m1, m2)

        # 🧱 Layer 2
        x_t_2 = y_t_1
        {y_t_2, h_new_2} = ssm_recurrence(x_t_2, xp1_2, xp2_2, h2, a, b, c, d, m1, m2)

        # 🧱 Layer 3
        x_t_3 = y_t_2
        {y_t_3, h_new_3} = ssm_recurrence(x_t_3, xp1_3, xp2_3, h3, a, b, c, d, m1, m2)

        y_acc_new = Nx.put_slice(y_acc, [i, 0, 0], Nx.new_axis(y_t_3, 0))

        {
          i + 1, y_acc_new, xs,
          h_new_1, x_t_1, xp1_1,
          h_new_2, x_t_2, xp1_2,
          h_new_3, x_t_3, xp1_3,
          a, b, c, d, m1, m2
        }
      end
  
    elem(result_tuple, 1)
  end

  defn process_block(x_input, h_init, block_params) do
    {a_diag, b_u, b_v, c_u, c_v, d_u, d_v, mx_u1, mx_v1, mx_u2, mx_v2} = block_params
    
    # ⚡ Precompute to dense matrices OUTSIDE the loop
    b_mat = Nx.dot(b_u, b_v)
    c_mat = Nx.dot(c_u, c_v)
    d_mat = Nx.dot(d_u, d_v)
    m1_mat = Nx.dot(mx_u1, mx_v1)
    m2_mat = Nx.dot(mx_u2, mx_v2)

    # Call the fused 3-layer elevator loop
    run_block_loop(x_input, h_init, a_diag, b_mat, c_mat, d_mat, m1_mat, m2_mat)
  end

  defn forward_train(indices, params, pos_emb) do
    {embed, block1, block2, block3, _lm_w, _lm_b} = params
    
    x_input = Nx.take(embed, indices) + pos_emb
    x_norm  = rms_norm(x_input)
    
    {batch_size, _seq_len, embed_dim} = Nx.shape(x_norm)
    h_init = Nx.broadcast(Nx.tensor(0.0, type: :f32), {batch_size, embed_dim})
    x_seq_first = Nx.transpose(x_norm, axes: [1, 0, 2])
    
    b1_out = process_block(x_seq_first, h_init, block1)
    b2_out = process_block(b1_out,      h_init, block2)
    b3_out = process_block(b2_out,      h_init, block3)
    
    out1 = rms_norm(Nx.transpose(b1_out, axes: [1, 0, 2]))
    out2 = rms_norm(Nx.transpose(b2_out, axes: [1, 0, 2]))
    out3 = rms_norm(Nx.transpose(b3_out, axes: [1, 0, 2]))

    {out1, out2, out3}
  end
  
  defn forward_inference(indices, params, pos_emb) do
    {_out1, _out2, out3} = forward_train(indices, params, pos_emb)
    {_embed, _b1, _b2, _b3, lm_w, lm_b} = params
    Nx.dot(out3, lm_w) + lm_b
  end
end
```

