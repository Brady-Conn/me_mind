```elixir
defmodule DLM.MuonHybrid do
  import Nx.Defn

  # --- The Muon Newton-Schulz Engine ---
  defn newton_schulz(g, iters \\ 5) do
    frobenius_norm = Nx.sqrt(Nx.sum(Nx.pow(g, 2))) + 1.0e-7
    x = g / frobenius_norm
    
    {final_x, _} = while {curr_x = x, i = 0}, Nx.less(i, iters) do
      x_t_x = Nx.dot(Nx.transpose(curr_x), curr_x)
      next_x = 1.5 * curr_x - 0.5 * Nx.dot(curr_x, x_t_x)
      {next_x, i + 1}
    end
    final_x
  end

  # --- Standard Adam Component ---
  defn adam_update(param, grad, m, v, step, lr) do
    # ⚡ THE FIX: Adam internally ensures the step is at least 1.0 to prevent division by zero
    safe_step = step + 1.0

    beta1 = 0.9
    beta2 = 0.999
    eps = 1.0e-8
    
    new_m = beta1 * m + (1.0 - beta1) * grad
    new_v = beta2 * v + (1.0 - beta2) * Nx.pow(grad, 2)
    
    m_hat = new_m / (1.0 - Nx.pow(beta1, safe_step))
    v_hat = new_v / (1.0 - Nx.pow(beta2, safe_step))
    
    param_update = param - lr * m_hat / (Nx.sqrt(v_hat) + eps)
    {param_update, new_m, new_v}
  end

  # --- The Missing Muon Wrapper ---
  defn muon_update(param, grad, m, v, _step, lr) do
    # 1. Orthogonalize the gradient using the Newton-Schulz engine
    ortho_grad = newton_schulz(grad, 5)

    # 2. Standard Momentum Update (Muon typically uses beta1 = 0.9)
    beta1 = 0.9
    new_m = beta1 * m + (1.0 - beta1) * ortho_grad

    # 3. Apply the update
    # (Note: Muon scales updates differently than Adam, we just use LR * momentum here)
    param_update = param - lr * new_m

    # 4. Return unchanged 'v' to maintain the tuple arity for DLM.Tree.map
    {param_update, new_m, v}
  end

  # --- Fully Fleshed-Out Block Helper ---
  defn step_block(p_block, g_block, m_block, v_block, step_count, lr) do
    {p_a, p_bu, p_bv, p_cu, p_cv, p_du, p_dv, p_mu1, p_mv1, p_mu2, p_mv2} = p_block
    {g_a, g_bu, g_bv, g_cu, g_cv, g_du, g_dv, g_mu1, g_mv1, g_mu2, g_mv2} = g_block
    {m_a, m_bu, m_bv, m_cu, m_cv, m_du, m_dv, m_mu1, m_mv1, m_mu2, m_mv2} = m_block
    {v_a, v_bu, v_bv, v_cu, v_cv, v_du, v_dv, v_mu1, v_mv1, v_mu2, v_mv2} = v_block

    # ⚡ Adam for 1D vectors
    {up_a,  nm_a,  nv_a}  = adam_update(p_a,  g_a,  m_a,  v_a,  step_count, lr)

    # ⚡ Muon for 2D matrices
    {up_bu,  nm_bu,  nv_bu}  = muon_update(p_bu,  g_bu,  m_bu,  v_bu,  step_count, lr)
    {up_bv,  nm_bv,  nv_bv}  = muon_update(p_bv,  g_bv,  m_bv,  v_bv,  step_count, lr)
    {up_cu,  nm_cu,  nv_cu}  = muon_update(p_cu,  g_cu,  m_cu,  v_cu,  step_count, lr)
    {up_cv,  nm_cv,  nv_cv}  = muon_update(p_cv,  g_cv,  m_cv,  v_cv,  step_count, lr)
    {up_du,  nm_du,  nv_du}  = muon_update(p_du,  g_du,  m_du,  v_du,  step_count, lr)
    {up_dv,  nm_dv,  nv_dv}  = muon_update(p_dv,  g_dv,  m_dv,  v_dv,  step_count, lr)
    {up_mu1, nm_mu1, nv_mu1} = muon_update(p_mu1, g_mu1, m_mu1, v_mu1, step_count, lr)
    {up_mv1, nm_mv1, nv_mv1} = muon_update(p_mv1, g_mv1, m_mv1, v_mv1, step_count, lr)
    {up_mu2, nm_mu2, nv_mu2} = muon_update(p_mu2, g_mu2, m_mu2, v_mu2, step_count, lr)
    {up_mv2, nm_mv2, nv_mv2} = muon_update(p_mv2, g_mv2, m_mv2, v_mv2, step_count, lr)

    up_p = {up_a, up_bu, up_bv, up_cu, up_cv, up_du, up_dv, up_mu1, up_mv1, up_mu2, up_mv2}
    up_m = {nm_a, nm_bu, nm_bv, nm_cu, nm_cv, nm_du, nm_dv, nm_mu1, nm_mv1, nm_mu2, nm_mv2}
    up_v = {nv_a, nv_bu, nv_bv, nv_cu, nv_cv, nv_du, nv_dv, nv_mu1, nv_mv1, nv_mu2, nv_mv2}

    {up_p, up_m, up_v}
  end

  defn step(params, grads, ms, vs, step_count, lr) do
    # ⚡ Unpack the new 6-element tuple
    {p_emb, p_b1, p_b2, p_b3, p_lmw, p_lmb} = params
    {g_emb, g_b1, g_b2, g_b3, g_lmw, g_lmb} = grads
    {m_emb, m_b1, m_b2, m_b3, m_lmw, m_lmb} = ms
    {v_emb, v_b1, v_b2, v_b3, v_lmw, v_lmb} = vs

    # Optimize outer layers
    {up_emb, nm_emb, nv_emb} = muon_update(p_emb, g_emb, m_emb, v_emb, step_count, lr)
    {up_lmw, nm_lmw, nv_lmw} = muon_update(p_lmw, g_lmw, m_lmw, v_lmw, step_count, lr)
    {up_lmb, nm_lmb, nv_lmb} = adam_update(p_lmb, g_lmb, m_lmb, v_lmb, step_count, lr)

    # Optimize the 3 inner blocks using the helper
    {up_b1, nm_b1, nv_b1} = step_block(p_b1, g_b1, m_b1, v_b1, step_count, lr)
    {up_b2, nm_b2, nv_b2} = step_block(p_b2, g_b2, m_b2, v_b2, step_count, lr)
    {up_b3, nm_b3, nv_b3} = step_block(p_b3, g_b3, m_b3, v_b3, step_count, lr)

    # Repack and return
    up_p = {up_emb, up_b1, up_b2, up_b3, up_lmw, up_lmb}
    up_m = {nm_emb, nm_b1, nm_b2, nm_b3, nm_lmw, nm_lmb}
    up_v = {nv_emb, nv_b1, nv_b2, nv_b3, nv_lmw, nv_lmb}

    {up_p, up_m, up_v}
  end
end
