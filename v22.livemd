```elixir
defmodule DLM.MuonHybrid do
  import Nx.Defn

  # --- The Muon Newton-Schulz Engine ---
  defn newton_schulz(g, iters \\ 5) do
    frobenius_norm = Nx.sqrt(Nx.sum(Nx.pow(g, 2))) + 1.0e-7
    x = g / frobenius_norm
    
    {final_x, _} = while {curr_x = x, i = 0}, Nx.less(i, iters) do
      x_t_x = Nx.dot(Nx.transpose(curr_x), curr_x)
      next_x = 1.5 * curr_x - 0.5 * Nx.dot(curr_x, x_t_x)
      {next_x, i + 1}
    end
    final_x
  end

  # --- Standard Adam Component ---
  defn adam_update(param, grad, m, v, step, lr) do
    # ⚡ THE FIX: Adam internally ensures the step is at least 1.0 to prevent division by zero
    safe_step = step + 1.0

    beta1 = 0.9
    beta2 = 0.999
    eps = 1.0e-8
    
    new_m = beta1 * m + (1.0 - beta1) * grad
    new_v = beta2 * v + (1.0 - beta2) * Nx.pow(grad, 2)
    
    m_hat = new_m / (1.0 - Nx.pow(beta1, safe_step))
    v_hat = new_v / (1.0 - Nx.pow(beta2, safe_step))
    
    param_update = param - lr * m_hat / (Nx.sqrt(v_hat) + eps)
    {param_update, new_m, new_v}
  end

  # 🧱 HELPER: Process a single 11-parameter SSM block
  defn step_block(p_block, g_block, m_block, v_block, step_count, lr) do
    wd = 1.0e-4 # 🛡️ Anti-Explosion Gravity

    {p_a, p_bu, p_bv, p_cu, p_cv, p_du, p_dv, p_mu1, p_mv1, p_mu2, p_mv2} = p_block
    {g_a, g_bu, g_bv, g_cu, g_cv, g_du, g_dv, g_mu1, g_mv1, g_mu2, g_mv2} = g_block
    {m_a, m_bu, m_bv, m_cu, m_cv, m_du, m_dv, m_mu1, m_mv1, m_mu2, m_mv2} = m_block
    {v_a, v_bu, v_bv, v_cu, v_cv, v_du, v_dv, v_mu1, v_mv1, v_mu2, v_mv2} = v_block

    # Apply Weight Decay to 'a' and use Adam
    {up_a, nm_a, nv_a} = adam_update(p_a * (1.0 - lr * wd), g_a, m_a, v_a, step_count, lr)

    # Apply Weight Decay and Muon to all SVD matrices
    up_bu = (p_bu * (1.0 - lr * wd)) - lr * newton_schulz(g_bu)
    up_bv = (p_bv * (1.0 - lr * wd)) - lr * newton_schulz(g_bv)
    up_cu = (p_cu * (1.0 - lr * wd)) - lr * newton_schulz(g_cu)
    up_cv = (p_cv * (1.0 - lr * wd)) - lr * newton_schulz(g_cv)
    up_du = (p_du * (1.0 - lr * wd)) - lr * newton_schulz(g_du)
    up_dv = (p_dv * (1.0 - lr * wd)) - lr * newton_schulz(g_dv)
    
    up_mu1 = (p_mu1 * (1.0 - lr * wd)) - lr * newton_schulz(g_mu1)
    up_mv1 = (p_mv1 * (1.0 - lr * wd)) - lr * newton_schulz(g_mv1)
    up_mu2 = (p_mu2 * (1.0 - lr * wd)) - lr * newton_schulz(g_mu2)
    up_mv2 = (p_mv2 * (1.0 - lr * wd)) - lr * newton_schulz(g_mv2)

    new_p = {up_a, up_bu, up_bv, up_cu, up_cv, up_du, up_dv, up_mu1, up_mv1, up_mu2, up_mv2}
    new_m = {nm_a, m_bu, m_bv, m_cu, m_cv, m_du, m_dv, m_mu1, m_mv1, m_mu2, m_mv2}
    new_v = {nv_a, v_bu, v_bv, v_cu, v_cv, v_du, v_dv, v_mu1, v_mv1, v_mu2, v_mv2}

    {new_p, new_m, new_v}
  end

  # 🚀 MAIN: The Hybrid Step for V22 nested params
  defn step(params, grads, ms, vs, step_count, lr) do
    wd = 1.0e-4

    {p_emb, p_b1, p_b2, p_b3, p_lmw, p_lmb} = params
    {g_emb, g_b1, g_b2, g_b3, g_lmw, g_lmb} = grads
    {m_emb, m_b1, m_b2, m_b3, m_lmw, m_lmb} = ms
    {v_emb, v_b1, v_b2, v_b3, v_lmw, v_lmb} = vs

    # 1. Adam for the Vocab/Embedding shells
    {up_emb, nm_emb, nv_emb} = adam_update(p_emb * (1.0 - lr * wd), g_emb, m_emb, v_emb, step_count, lr)
    {up_lmw, nm_lmw, nv_lmw} = adam_update(p_lmw * (1.0 - lr * wd), g_lmw, m_lmw, v_lmw, step_count, lr)
    {up_lmb, nm_lmb, nv_lmb} = adam_update(p_lmb * (1.0 - lr * wd), g_lmb, m_lmb, v_lmb, step_count, lr)

    # 2. Process all 3 blocks through the helper
    {up_b1, nm_b1, nv_b1} = step_block(p_b1, g_b1, m_b1, v_b1, step_count, lr)
    {up_b2, nm_b2, nv_b2} = step_block(p_b2, g_b2, m_b2, v_b2, step_count, lr)
    {up_b3, nm_b3, nv_b3} = step_block(p_b3, g_b3, m_b3, v_b3, step_count, lr)

    # 3. Pack them back into the V22 nested structure
    new_params = {up_emb, up_b1, up_b2, up_b3, up_lmw, up_lmb}
    new_ms     = {nm_emb, nm_b1, nm_b2, nm_b3, nm_lmw, nm_lmb}
    new_vs     = {nv_emb, nv_b1, nv_b2, nv_b3, nv_lmw, nv_lmb}

    {new_params, new_ms, new_vs}
  end
end
