## Train

```elixir
defmodule DLM.V22Trainer do
  import Nx.Defn

  defn log_softmax(logits) do
    max_logits = Nx.reduce_max(logits, axes: [-1], keep_axes: true)
    safe_logits = logits - max_logits
    sum_exp = Nx.sum(Nx.exp(safe_logits), axes: [-1], keep_axes: true)
    safe_logits - Nx.log(sum_exp)
  end

  defn compute_loss(preds_sliced, targets) do
    log_probs = log_softmax(preds_sliced)
    target_probs = Nx.take_along_axis(log_probs, Nx.new_axis(targets, -1), axis: -1)
    target_probs = Nx.squeeze(target_probs, axes: [-1])
    mask = Nx.not_equal(targets, 0) |> Nx.as_type(:f32)
    
    total_tokens = Nx.sum(mask)
    # ⚡ 12.8 is exactly 10% of your new 128 sequence length!
    safe_denom   = Nx.max(total_tokens, 12.8) 

    masked_loss = -target_probs * mask
    Nx.sum(masked_loss) / safe_denom
  end

  # 🛡️ Explicitly define the clipping so the C++ compiler AST doesn't get confused
  defn clip_block(b) do
    {a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2} = b
    {
      Nx.clip(a, -1.0, 1.0), Nx.clip(bu, -1.0, 1.0), Nx.clip(bv, -1.0, 1.0),
      Nx.clip(cu, -1.0, 1.0), Nx.clip(cv, -1.0, 1.0), Nx.clip(du, -1.0, 1.0),
      Nx.clip(dv, -1.0, 1.0), Nx.clip(mu1, -1.0, 1.0), Nx.clip(mv1, -1.0, 1.0),
      Nx.clip(mu2, -1.0, 1.0), Nx.clip(mv2, -1.0, 1.0)
    }
  end

  defn compute_grad(params, pos_emb, batch) do
    {loss, grads} = value_and_grad(params, fn p ->
      {_embed, _b1, _b2, _b3, lm_w, lm_b} = p
      
      batch_s32 = Nx.as_type(batch, :s32)
      
      # ⚡ Dynamically slice targets based on the new sequence length
      seq_len = Nx.axis_size(batch_s32, 1)
      targets = Nx.slice_along_axis(batch_s32, 1, seq_len - 1, axis: 1)

      # The forward pass stays the same, keeping the 9-layer depth!
      {_out1, _out2, out3} = DLM.UniversalSSM.forward_train(batch_s32, p, pos_emb)

      # ⚡ THE FIX: Only project the final layer into the vocabulary!
      # This deletes massive matrices from the compiler's memory.
      logits3 = Nx.slice_along_axis(Nx.dot(out3, lm_w) + lm_b, 0, seq_len - 1, axis: 1)

      # Return the single loss
      compute_loss(logits3, targets)
    end)

    {g_emb, g_b1, g_b2, g_b3, g_lmw, g_lmb} = grads

    clipped_grads = {
      Nx.clip(g_emb, -1.0, 1.0),
      clip_block(g_b1),
      clip_block(g_b2),
      clip_block(g_b3),
      Nx.clip(g_lmw, -1.0, 1.0),
      Nx.clip(g_lmb, -1.0, 1.0)
    }

    {loss, clipped_grads}
  end
end
```

