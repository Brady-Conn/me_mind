```elixir
defmodule DLM.V22Genesis do
  import Nx.Defn

  @vocab_size 128
  @dim 256
  @rank 32

  # ⚡ Helper to generate one complete USSM block (All 11 Tensors)
  defn init_block(key) do
    # Nx.Random.normal safely returns {tensor, next_key}, chaining it perfectly!
    {a_raw, key} = Nx.Random.normal(key, 0.0, 0.1, shape: {@dim}, type: :f32)
    a_diag = Nx.add(Nx.broadcast(-2.0, {@dim}), a_raw)
    
    {b_u,   key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@dim, @rank}, type: :f32)
    {b_v,   key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@rank, @dim}, type: :f32)
    {c_u,   key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@dim, @rank}, type: :f32)
    {c_v,   key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@rank, @dim}, type: :f32)
    {d_u,   key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@dim, @rank}, type: :f32)
    {d_v,   key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@rank, @dim}, type: :f32)
    {mx_u1, key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@dim, @rank}, type: :f32)
    {mx_v1, key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@rank, @dim}, type: :f32)
    {mx_u2, key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@dim, @rank}, type: :f32)
    {mx_v2, key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@rank, @dim}, type: :f32)

    block = {a_diag, b_u, b_v, c_u, c_v, d_u, d_v, mx_u1, mx_v1, mx_u2, mx_v2}
    {block, key}
  end

  defn init_params(seed \\ 42) do
    safe_seed = Nx.as_type(seed, :s64)
    key = Nx.Random.key(safe_seed)
    
    {embed,  key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@vocab_size, @dim}, type: :f32)
    
    {block1, key} = init_block(key)
    {block2, key} = init_block(key)
    {block3, key} = init_block(key)
    
    {lm_w,  _key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@dim, @vocab_size}, type: :f32)
    lm_b          = Nx.broadcast(0.0, {@vocab_size})

    # The new V22 Parameter Tuple
    {embed, block1, block2, block3, lm_w, lm_b}
  end

  # ⚡ Must be 'def' (not 'defn') so Tree.map can walk the tuple structure in standard Elixir!
  def init_optimizer(params) do
    zero_like = fn t -> Nx.broadcast(Nx.tensor(0.0, type: :f32), t) end
    ms = DLM.Tree.map(params, zero_like)
    vs = DLM.Tree.map(params, zero_like)
    {ms, vs, 0}
  end
end
