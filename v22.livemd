## Inference

```elixir
defmodule DLM.V22Probe do
  import Nx.Defn

  # ⚡ Predicts the next single token using the 9-Layer USSM
  defn predict_next(tokens, params, pos_emb, current_len) do
    # tokens shape: {1, 128}
    logits = DLM.UniversalSSM.forward_inference(tokens, params, pos_emb)
    
    # Grab the logits for the specific token we just submitted
    # current_len is a scalar tensor. We want the index `current_len - 1`
    idx = current_len - 1
    
    # Slice out the specific vocab predictions for that time-step
    step_logits = Nx.slice_along_axis(logits[0], idx, 1, axis: 0) |> Nx.squeeze(axes: [0])
    
    # Greedy Argmax for the raw, un-filtered probe
    Nx.argmax(step_logits)
  end
end

# ===========================================================================
# The Generation Loop
# ===========================================================================
IO.puts("🧠 Loading latest V22 Checkpoint for Inference...")
save_prefix = "v22_auto"

latest_checkpoint = 
  Path.wildcard("#{save_prefix}_*.bin")
  |> Enum.reject(&String.contains?(&1, "data.bin"))
  |> Enum.reject(&String.contains?(&1, "COMPLETE"))
  |> Enum.max_by(fn path -> File.stat!(path).mtime end, fn -> nil end)

if latest_checkpoint do
  IO.puts("🔍 Waking V22 from: #{latest_checkpoint}")
  checkpoint = File.read!(latest_checkpoint) |> :erlang.binary_to_term()
  
  # Transfer parameters to GPU
  params = DLM.Tree.map(checkpoint.params, &Nx.backend_transfer(&1, gpu))
  pos_emb = DLM.Positional.build(128, 256) |> Nx.backend_transfer(gpu)
  
  # ⚡ 1. The Prompt
  prompt_text = "Do state space models dream of"
  
  # ⚡ 2. Basic ASCII Tokenization (Matching V21.10)
  prompt_tokens = 
    prompt_text 
    |> String.to_charlist() 
    |> Enum.map(fn c -> if c < 128, do: c, else: 32 end)
  
  max_length = 128
  
  # ⚡ 3. The Autoregressive Loop
  final_tokens = 
    Enum.reduce_while(length(prompt_tokens)..(max_length - 1), prompt_tokens, fn current_len, acc_tokens ->
      
      # Pad to exactly 128 tokens for the static XLA graph
      padded_list = acc_tokens ++ List.duplicate(0, max_length - current_len)
      
      # Convert to 2D tensor {1, 128} and send to GPU
      input_tensor = 
        Nx.tensor([padded_list], type: :s32) 
        |> Nx.backend_transfer(gpu)
      
      len_tensor = Nx.tensor(current_len, type: :s32) |> Nx.backend_transfer(gpu)
      
      # Predict next token
      next_token_tensor = DLM.V22Probe.predict_next(input_tensor, params, pos_emb, len_tensor)
      next_token = Nx.to_number(next_token_tensor)
      
      # Append and continue
      {:cont, acc_tokens ++ [next_token]}
    end)
    
  # ⚡ 4. Decode and Print
  dream = List.to_string(final_tokens)
  IO.puts("\n🐑 V22 Dream Probe:")
  IO.puts("--------------------------------------------------")
  IO.puts(dream)
  IO.puts("--------------------------------------------------")
else
  IO.puts("❌ No checkpoint found to run inference on.")
end
