{:module, DLM.V22Trainer, <<70, 79, 82, 49, 0, 0, 35, ...>>, true}
```

```elixir
IO.puts("🧠 Loading Dataset into CPU Memory...")
full_dataset = File.read!("scholar_full_mixed_128.bin") 
  |> :erlang.binary_to_term()

dataset_size = Nx.axis_size(full_dataset, 0)

# ⚡ The Accumulation Math
effective_batch_size = 16
micro_batch_size = 4
accumulation_steps = div(effective_batch_size, micro_batch_size) # 4
total_steps_per_epoch = div(dataset_size, effective_batch_size)
max_epochs = 10
total_steps = total_steps_per_epoch * max_epochs
save_interval = 1000
base_lr = 3.0e-4
min_lr = 1.0e-6
warmup_steps = 100
# 🔍 AUTO-RESUME OR GENESIS (V22)
save_prefix = "v22_auto" # <-- CHANGED to protect V21.5
latest_checkpoint = 
  Path.wildcard("#{save_prefix}_*.bin")
  |> Enum.reject(&String.contains?(&1, "data.bin"))
  |> Enum.max_by(fn path -> File.stat!(path).mtime end, fn -> nil end)

{params, ms, vs, global_step, current_epoch, shuffle_key} = 
  if latest_checkpoint do
    IO.puts("💾 Found V22 checkpoint: #{latest_checkpoint}")
    checkpoint = File.read!(latest_checkpoint) |> :erlang.binary_to_term()
    
    p = DLM.Tree.map(checkpoint.params, &Nx.backend_transfer(&1, gpu))
    m = DLM.Tree.map(checkpoint.ms, &Nx.backend_transfer(&1, gpu))
    v = DLM.Tree.map(checkpoint.vs, &Nx.backend_transfer(&1, gpu))
    
    # ⚡ Retrieve saved key or fallback to default
    saved_key = Map.get(checkpoint, :shuffle_key, Nx.Random.key(42)) |> Nx.backend_transfer(gpu)
    
    {p, m, v, checkpoint.step, checkpoint.epoch, saved_key}
  else
    IO.puts("✨ No V22 checkpoint found. Igniting FRESH Genesis state...")
    raw_p = DLM.V22Genesis.init_params(42)
    {raw_m, raw_v, _} = DLM.V22Genesis.init_optimizer(raw_p)
    
    p = DLM.Tree.map(raw_p, &Nx.backend_transfer(&1, gpu))
    m = DLM.Tree.map(raw_m, &Nx.backend_transfer(&1, gpu))
    v = DLM.Tree.map(raw_v, &Nx.backend_transfer(&1, gpu))
    
    # ⚡ Generate fresh key
    saved_key = Nx.Random.key(42) |> Nx.backend_transfer(gpu)
    
    {p, m, v, 0, 1, saved_key}
  end

words_already_seen = rem(global_step * effective_batch_size, dataset_size)
pos_emb = DLM.Positional.build(128, 256) |> Nx.backend_transfer(gpu)

IO.puts("🚀 IGNITION: Starting V22 at Epoch #{current_epoch}, Global Step #{global_step}...")

Enum.reduce(current_epoch..max_epochs, {params, ms, vs, global_step, shuffle_key}, fn epoch, {p, m, v, current_step, s_key} ->
  IO.puts(String.duplicate("=", 50))
  IO.puts("🌊 EPOCH #{epoch} / #{max_epochs}")
  IO.puts("🔀 Shuffling dataset...")

  # ⚡ The Missing Shuffle Logic
  {shuffled_raw, next_shuffle_key} = Nx.Random.shuffle(s_key, full_dataset, axis: 0)
  shuffled_dataset = Nx.backend_copy(shuffled_raw, Nx.BinaryBackend)
  
  # Slice directly into Micro-Batches
  start_offset = if epoch == current_epoch, do: rem(current_step, total_steps_per_epoch) * effective_batch_size, else: 0

  micro_batches_stream = Stream.unfold(start_offset, fn offset ->
    if offset + micro_batch_size > dataset_size do
      nil
    else
      # ⚡ Now `shuffled_dataset` exists!
      mb = Nx.slice_along_axis(shuffled_dataset, offset, micro_batch_size, axis: 0)
      {mb, offset + micro_batch_size}
    end
  end)

  {new_p, new_m, new_v, next_epoch_step, _skips} =
    micro_batches_stream
    |> Stream.chunk_every(accumulation_steps) # ⚡ Group 4 micro-batches to make 1 effective batch
    |> Enum.reduce({p, m, v, current_step, 0}, fn micro_batches, {cp, cm, cv, cs, s_count} ->
      
      # 1. Create an empty bucket of zeros
      zero_grads = DLM.Tree.map(cp, fn t -> Nx.broadcast(0.0, t) |> Nx.backend_copy(gpu) end)

      # 2. Accumulate gradients over the 4 micro-batches
      {total_loss, accumulated_grads} = 
        Enum.reduce(micro_batches, {0.0, zero_grads}, fn micro_batch, {acc_loss, acc_grads} ->
          gpu_mb = Nx.backend_copy(micro_batch, gpu)
          
          {loss_tensor, grads} = DLM.V22Trainer.compute_grad(cp, pos_emb, gpu_mb)
          
          loss_val = Nx.to_number(loss_tensor)
          
          # ⚡ THE FIX: Safely propagate the :nan atom without crashing Erlang's + operator
          new_loss = 
            if loss_val == :nan or acc_loss == :nan do
              :nan
            else
              acc_loss + loss_val
            end

          new_grads = DLM.Tree.map(acc_grads, grads, &Nx.add/2)
          
          {new_loss, new_grads}
        end)

      # 3. Average the accumulated loss 
      # 3. Average the accumulated loss safely
      avg_loss = 
        if total_loss == :nan do
          :nan
        else
          total_loss / accumulation_steps
        end

      if avg_loss == :nan or avg_loss > 20.0 do
         IO.puts("⚠️ Step #{cs}: NaN/Spike detected (Loss: #{avg_loss}). Skipping update.")
         {cp, cm, cv, cs + 1, s_count + 1}
      else
         # 4. ⚡ Learning Rate Math
         current_lr = 
           if cs < warmup_steps do
             base_lr * (cs / warmup_steps)
           else
             progress = (cs - warmup_steps) / (total_steps - warmup_steps)
             clamped_progress = min(max(progress, 0.0), 1.0)
             min_lr + 0.5 * (base_lr - min_lr) * (1.0 + :math.cos(:math.pi() * clamped_progress))
           end

         lr_tensor = Nx.tensor(current_lr, type: :f32) |> Nx.backend_copy(gpu)
         step_tensor = Nx.tensor(cs, type: :f32) |> Nx.backend_copy(gpu)

         # 5. 🔥 Pass the ACCUMULATED bucket to the Muon Optimizer
         {up_p, up_m, up_v} = DLM.MuonHybrid.step(cp, accumulated_grads, cm, cv, step_tensor, lr_tensor)
         
         if rem(cs, 50) == 0 do
           bpc = avg_loss / :math.log(2)
           IO.puts("➡️  Step #{cs} | Loss: #{Float.round(avg_loss, 4)} | BPC: #{Float.round(bpc, 3)} | LR: #{Float.round(current_lr, 6)}")
         end

         if rem(cs, save_interval) == 0 and cs > 0 do
           IO.puts("💾 Auto-Saving Checkpoint to #{save_prefix}_step#{cs}.bin...")
           state = %{
             params: DLM.Tree.map(up_p, &Nx.backend_copy(&1, Nx.BinaryBackend)),
             ms: DLM.Tree.map(up_m, &Nx.backend_copy(&1, Nx.BinaryBackend)),
             vs: DLM.Tree.map(up_v, &Nx.backend_copy(&1, Nx.BinaryBackend)),
             step: cs, epoch: epoch,
             shuffle_key: Nx.backend_copy(next_shuffle_key, Nx.BinaryBackend) # ⚡ Save Key
           }
           File.write!("#{save_prefix}_step#{cs}.bin", :erlang.term_to_binary(state))
         end

         {up_p, up_m, up_v, cs + 1, s_count}
      end
    end)

  IO.puts("💾 Saving Completed Epoch #{epoch} State...")
  final_state = %{
    params: DLM.Tree.map(new_p, &Nx.backend_copy(&1, Nx.BinaryBackend)),
    ms: DLM.Tree.map(new_m, &Nx.backend_copy(&1, Nx.BinaryBackend)),
    vs: DLM.Tree.map(new_v, &Nx.backend_copy(&1, Nx.BinaryBackend)),
    step: next_epoch_step, epoch: epoch,
    shuffle_key: Nx.backend_copy(next_shuffle_key, Nx.BinaryBackend) # ⚡ Save Key
  }
  File.write!("#{save_prefix}_epoch#{epoch}_COMPLETE.bin", :erlang.term_to_binary(final_state))

  # ⚡ Pass the next_shuffle_key back up to the loop
  {new_p, new_m, new_v, next_epoch_step, next_shuffle_key}
end)

IO.puts("🎉 THE OVERNIGHT BAKE IS COMPLETE!")
```

