## Train

```elixir
defmodule DLM.V22Trainer do
  import Nx.Defn

  defn log_softmax(logits) do
    max_logits = Nx.reduce_max(logits, axes: [-1], keep_axes: true)
    safe_logits = logits - max_logits
    sum_exp = Nx.sum(Nx.exp(safe_logits), axes: [-1], keep_axes: true)
    safe_logits - Nx.log(sum_exp)
  end

  defn compute_loss(preds_sliced, targets) do
    log_probs = log_softmax(preds_sliced)
    target_probs = Nx.take_along_axis(log_probs, Nx.new_axis(targets, -1), axis: -1)
    target_probs = Nx.squeeze(target_probs, axes: [-1])
    mask = Nx.not_equal(targets, 0) |> Nx.as_type(:f32)
    
    total_tokens = Nx.sum(mask)
    safe_denom   = Nx.max(total_tokens, 12.8) 

    masked_loss = -target_probs * mask
    Nx.sum(masked_loss) / safe_denom
  end

  # ⚡ THE FIREWALL: Identifies NaNs/Infinities and zeroes them out before clipping!
  defn sanitize_tensor(g) do
    bad_mask = Nx.logical_or(Nx.is_nan(g), Nx.is_infinity(g))
    g_safe = Nx.select(bad_mask, 0.0, g)
    Nx.clip(g_safe, -1.0, 1.0)
  end

  defn clip_block(g_block) do
    {g_a, g_bu, g_bv, g_cu, g_cv, g_du, g_dv, g_mu1, g_mv1, g_mu2, g_mv2} = g_block
    {
      sanitize_tensor(g_a),
      sanitize_tensor(g_bu),
      sanitize_tensor(g_bv),
      sanitize_tensor(g_cu),
      sanitize_tensor(g_cv),
      sanitize_tensor(g_du),
      sanitize_tensor(g_dv),
      sanitize_tensor(g_mu1),
      sanitize_tensor(g_mv1),
      sanitize_tensor(g_mu2),
      sanitize_tensor(g_mv2)
    }
  end

  defn clip_grads(grads) do
    {g_emb, g_b1, g_b2, g_b3, g_lmw, g_lmb} = grads
    {
      sanitize_tensor(g_emb),
      clip_block(g_b1),
      clip_block(g_b2),
      clip_block(g_b3),
      sanitize_tensor(g_lmw),
      sanitize_tensor(g_lmb)
    }
  end

  defn compute_grad(params, pos_emb, batch) do
    {loss, grads} = value_and_grad(params, fn p ->
      {_embed, _b1, _b2, _b3, lm_w, lm_b} = p
      
      batch_s32 = Nx.as_type(batch, :s32)
      targets = Nx.slice_along_axis(batch_s32, 1, 127, axis: 1)

      out3 = DLM.UniversalSSM.forward_train(batch_s32, p, pos_emb)
      logits3 = Nx.slice_along_axis(Nx.dot(out3, lm_w) + lm_b, 0, 127, axis: 1)

      compute_loss(logits3, targets)
    end)

    # Pass the raw gradients through the Firewall
    safe_grads = clip_grads(grads)

    {loss, safe_grads}
  end
end
```

