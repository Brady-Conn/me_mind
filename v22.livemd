```elixir
defmodule DLM.Tree do
  @moduledoc """
  Recursively maps a function over nested tuples of tensors.
  Works perfectly both in standard Elixir AND inside Nx `defn`.
  """
  
  # --- Single Tree Traversal (Arity 2) ---
  def map(tuple, func) when is_tuple(tuple) do
    tuple
    |> Tuple.to_list()
    |> Enum.map(&map(&1, func))
    |> List.to_tuple()
  end

  def map(tensor, func) do
    func.(tensor)
  end

  # --- Dual Tree Traversal (Arity 3) ---
  # Used for Gradient Accumulation (adding two trees together)
  def map(t1, t2, func) when is_tuple(t1) and is_tuple(t2) do
    Enum.zip(Tuple.to_list(t1), Tuple.to_list(t2))
    |> Enum.map(fn {elem1, elem2} -> map(elem1, elem2, func) end)
    |> List.to_tuple()
  end

  def map(tensor1, tensor2, func) do
    func.(tensor1, tensor2)
  end
end
```

