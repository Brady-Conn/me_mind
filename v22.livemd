```elixir
defmodule BabyLM.PhasedParser do
  @sequence_length 256

  # Define our exact curriculum. (Make sure these match your actual file extensions, 
  # sometimes they download as .train instead of .txt! I've assumed .txt here).
  @curriculum %{
    "phase1_toddler" => ["childes.train.txt", "bnc_spoken.train.txt"],
    "phase2_dialogue" => ["switchboard.train.txt", "open_subtitles.train.txt"],
    "phase3_scholar" => ["simple_wiki.train.txt", "gutenberg.train.txt"]
  }

  def process_curriculum(directory_path) do
    Enum.each(@curriculum, fn {phase_name, target_files} ->
      IO.puts("\n🚀 Starting #{phase_name}...")
      
      # 1. Safely read ONLY the target files for this phase
      raw_text = 
        target_files
        |> Enum.map(fn filename -> 
          path = Path.join(directory_path, filename)
          if File.exists?(path) do
            IO.puts("  ✅ Loaded #{filename}")
            File.read!(path) |> String.replace(~r/\s+/, " ")
          else
            IO.puts("  ❌ Missing #{filename} (Skipping...)")
            ""
          end
        end)
        |> Enum.join(" ")

      text_length = String.length(raw_text)
      
      if text_length > 0 do
        IO.puts("  🧮 Tokenizing #{text_length} characters...")
        
        # 2. Tokenize (ASCII-128 mapping)
        tokens = 
          raw_text
          |> String.to_charlist()
          |> Enum.map(fn c -> if c < 128, do: c, else: 63 end) # 63 is '?'
          
        # 3. Chunk into 256-length lists
        valid_chunks = div(length(tokens), @sequence_length)
        
        chunked_lists = 
          tokens
          |> Enum.take(valid_chunks * @sequence_length)
          |> Enum.chunk_every(@sequence_length)

        # 4. Pack into Nx Tensor
        dataset_tensor = Nx.tensor(chunked_lists, type: :u8)
        
        # 5. Save phase-specific bin file
        output_file = "#{phase_name}.bin"
        File.write!(output_file, :erlang.term_to_binary(dataset_tensor))
        IO.puts("  💾 Saved #{valid_chunks} sequences to #{output_file}")
      else
        IO.puts("  ⚠️ No data found for #{phase_name}. Check your filenames.")
      end
    end)
    
    IO.puts("\n🎉 Curriculum Parsing Complete!")
  end
end
```

