## USSM, Positional, Muon_Optimizer

```elixir
defmodule DLM.UniversalSSM do
  import Nx.Defn

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn softplus(x), do: Nx.log1p(Nx.exp(x))
  defn silu(x), do: x * Nx.sigmoid(x)

  defn apply_svd_weight(x, u, v) do
    x |> Nx.dot(u) |> silu() |> Nx.dot(v)
  end

  defn ssm_recurrence(x_t, x_prev1, x_prev2, h_p, a, b, c, d, m1, m2) do
    # ⚡ We now use Nx.dot because the SVDs were pre-multiplied!
    x_mixed = x_t 
      |> Nx.add(Nx.dot(x_prev1, m1))
      |> Nx.add(Nx.dot(x_prev2, m2))
  
    # ⚡ Unified matrix math + fixed the h_prev typo (now h_p)
    delta_proj = Nx.dot(x_mixed, d)
    delta      = softplus(delta_proj)
    a_bar      = Nx.sigmoid(Nx.multiply(delta, a))
    
    b_proj     = Nx.dot(x_mixed, b)
    b_bar      = Nx.multiply(delta, b_proj)
    
    h_t        = Nx.tanh(Nx.add(Nx.multiply(a_bar, h_p), b_bar))
    
    y_ssm      = Nx.dot(h_t, c)
    y_t        = Nx.add(y_ssm, x_mixed) 
   
    {y_t, h_t}
  end

  defn run_ssm_loop(x_seq, h_init, block_params) do
    # 1. Unpack the 11-element block tuple
    {a_diag, b_u, b_v, c_u, c_v, d_u, d_v, mx_u1, mx_v1, mx_u2, mx_v2} = block_params

    # 2. Pre-compute the SVD reconstructions ONCE outside the while loop 
    b_mat  = Nx.dot(b_u, b_v)
    c_mat  = Nx.dot(c_u, c_v)
    d_mat  = Nx.dot(d_u, d_v)
    mx1_mat = Nx.dot(mx_u1, mx_v1)
    mx2_mat = Nx.dot(mx_u2, mx_v2)

    # 3. Fix the variable names (removed underscores, matched names)
    {seq_len, batch_size, embed_dim} = Nx.shape(x_seq)
    y_init     = Nx.broadcast(Nx.tensor(0.0, type: :f32), {seq_len, batch_size, embed_dim})
    zero_frame = Nx.broadcast(Nx.tensor(0.0, type: :f32), {batch_size, embed_dim})
  
    # 4. Catch the entire tuple in one variable
    result_tuple =
      while {i = 0, y_acc = y_init, h_p = h_init,
             x_prev1 = zero_frame,   # ← t-1 history
             x_prev2 = zero_frame,   # ← t-2 history
             xs = x_seq,             # ← Fixed ghost variable
             a = a_diag, 
             b = b_mat, c = c_mat, d = d_mat,       # ← Passing unified matrices!
             m1 = mx1_mat, m2 = mx2_mat},           # ← Passing unified matrices!
            Nx.less(i, seq_len) do
  
        x_t = xs[i]
  
        # ⚡ ssm_recurrence now takes 10 arguments instead of 15!
        {y_t, h_new} = ssm_recurrence(
          x_t, x_prev1, x_prev2, h_p,
          a, b, c, d, m1, m2
        )
  
        # XLA dynamically updates the tensor slice in place
        y_acc_new = Nx.put_slice(y_acc, [i, 0, 0], Nx.new_axis(y_t, 0))
  
        # Shift the history window and return the updated state
        {i + 1, y_acc_new, h_new, x_t, x_prev1, xs, a, b, c, d, m1, m2}
      end
  
    # 5. Safely extract y_acc (which is at index 1 of the tuple)
    elem(result_tuple, 1)
  end

  # Inside DLM.UniversalSSM ...

  @doc """
  Used for TRAINING. 
  Returns the normalized outputs of Block 1, Block 2, and Block 3 for Triple-Loss.
  """
  defn forward_train(indices, params, pos_emb) do
    # 1. Unpack the cleanly nested params
    {embed, block1, block2, block3, _lm_w, _lm_b} = params
    
    x_input = Nx.take(embed, indices) + pos_emb
    x_norm  = rms_norm(x_input)
    
    {batch_size, _seq_len, embed_dim} = Nx.shape(x_norm)
    h_init = Nx.broadcast(Nx.tensor(0.0, type: :f32), {batch_size, embed_dim})
    x_seq_first = Nx.transpose(x_norm, axes: [1, 0, 2])
    
    # 🧱 BLOCK 1: The Phonetic Engine (Layers 1, 2, 3)
    b1_L1 = run_ssm_loop(x_seq_first, h_init, block1)
    b1_L2 = run_ssm_loop(b1_L1,       h_init, block1)
    b1_L3 = run_ssm_loop(b1_L2,       h_init, block1)

    # 🧱 BLOCK 2: The Vocabulary Engine (Layers 4, 5, 6)
    b2_L1 = run_ssm_loop(b1_L3, h_init, block2)
    b2_L2 = run_ssm_loop(b2_L1, h_init, block2)
    b2_L3 = run_ssm_loop(b2_L2, h_init, block2)

    # 🧱 BLOCK 3: The Syntax Engine (Layers 7, 8, 9)
    b3_L1 = run_ssm_loop(b2_L3, h_init, block3)
    b3_L2 = run_ssm_loop(b3_L1, h_init, block3)
    b3_L3 = run_ssm_loop(b3_L2, h_init, block3)
    
    # Format and Normalize all three block exits
    out1 = rms_norm(Nx.transpose(b1_L3, axes: [1, 0, 2]))
    out2 = rms_norm(Nx.transpose(b2_L3, axes: [1, 0, 2]))
    out3 = rms_norm(Nx.transpose(b3_L3, axes: [1, 0, 2]))

    # Hand them all back to the Trainer!
    {out1, out2, out3}
  end

  @doc """
  Used for INFERENCE (Probing).
  Only projects and returns the final Block 3 prediction to save compute.
  """
  defn forward_inference(indices, params, pos_emb) do
    {_out1, _out2, out3} = forward_train(indices, params, pos_emb)
    {_embed, _b1, _b2, _b3, lm_w, lm_b} = params

    # Only project the final layer into the 128-vocab space
    Nx.dot(out3, lm_w) + lm_b
  end
end
