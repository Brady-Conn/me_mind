```elixir
run_prefix  = "v34_DLM_Phase_4_clip_h8_ec05_lr15"  
total_steps = 100000
batch_size = 32
seq_len = 128
save_interval = 1000

# ==============================================================================
# 1. LOAD FROZEN FOUNDATIONS (Manifold + L1 + L2)
# ==============================================================================
IO.puts("🌌 Loading Phase 1 Frozen Manifold...")
%{params: phase1_p} = File.read!("phase1_shape_diffusion_COMPLETE.bin") |> :erlang.binary_to_term()
{cpu_embeds, _w1, _w2, _key} = phase1_p
frozen_map = cpu_embeds |> Nx.backend_copy(gpu) |> DLM.Loss.l2_normalize()

IO.puts("⚙️ Loading Phase 2 Level 1 (Physics Engine)...")
base_checkpoint = File.read!("v33_DLM_Phase_2_cos_checkpoint_step_13000.bin") |> :erlang.binary_to_term()
frozen_base_p = DLM.Tree.map(base_checkpoint, &Nx.backend_copy(&1, gpu))

IO.puts("🧠 Loading Phase 3 Level 2 (Bigram Chunker)...")
# Swap this string with exactly whatever you named your final Level 2 checkpoint!
mid_checkpoint = File.read!("v34_DLM_Phase_3_Top_256_lowLR_checkpoint_step_44000.bin") |> :erlang.binary_to_term()
frozen_mid_p = DLM.Tree.map(mid_checkpoint.params, &Nx.backend_copy(&1, gpu))

# ==============================================================================
# 2. INITIALIZE / RESUME TOP LEVEL
# ==============================================================================
{load_path, start_step} = DLM.CheckpointManager.get_resume_state(run_prefix)

{starting_p, starting_m, starting_v, start_h_base, start_h_mid, start_h_top} =
  if load_path == :fresh do
    IO.puts("✨ Igniting Phase 4 Level 3 Genesis weights...")
    raw_p3 = DLM.Main_SSM_Genesis.init_params(42)
    {raw_m3, raw_v3} = DLM.Main_SSM_Genesis.init_optimizer(raw_p3)
    
    blank_h = Nx.broadcast(0.0, {batch_size, 512}) |> Nx.backend_copy(gpu)
    
    {raw_p3, raw_m3, raw_v3, blank_h, blank_h, blank_h}
  else
    ckpt = File.read!(load_path) |> :erlang.binary_to_term()
    blank_h = Nx.broadcast(0.0, {batch_size, 512}) |> Nx.backend_copy(gpu)
    
    {
      ckpt.params, 
      ckpt.ms, 
      ckpt.vs, 
      Map.get(ckpt, :h_base, blank_h),
      Map.get(ckpt, :h_mid, blank_h),
      Map.get(ckpt, :h_top, blank_h)
    }
  end

# Push standard optimizer states to GPU
p3 = DLM.Tree.map(starting_p, &Nx.backend_copy(&1, gpu))
m3 = DLM.Tree.map(starting_m, &Nx.backend_copy(&1, gpu))
v3 = DLM.Tree.map(starting_v, &Nx.backend_copy(&1, gpu))
h1 = Nx.backend_copy(start_h_base, gpu)
h2 = Nx.backend_copy(start_h_mid, gpu)
h3 = Nx.backend_copy(start_h_top, gpu)

# ==============================================================================
# 3. DATA STREAM
# ==============================================================================
IO.puts("🧠 Loading Curriculum...")
dataset_2d = File.read!("scholar_full_mixed_128.bin") |> :erlang.binary_to_term()
dataset = Nx.flatten(dataset_2d)
data_stream = DLM.DataStreamer.build_infinite_stream(dataset, batch_size, seq_len)

# ==============================================================================
# 4. THE MASTER LOOP (PHASE 4: 3-TIER CASCADE)
# ==============================================================================
if start_step != :completed do
  IO.puts("🚀 Entering 3-Tier Grammar Cascade Loop...")

  # ⚡ The accumulator now carries h1, h2, and h3
  {final_p3, _m3, _v3, _h1, _h2, _h3} =
    Enum.reduce(Enum.zip(start_step..(total_steps - 1), data_stream), {p3, m3, v3, h1, h2, h3}, 
      fn {step, cpu_batch}, {cp3, cm3, cv3, ch1, ch2, ch3} ->
        
        gpu_batch = Nx.backend_copy(cpu_batch, gpu)
        
        # ⚡ 1. The 8-Character Horizon Shift
        horizon = 8
        seq_len = Nx.axis_size(gpu_batch, 1)
        
        inputs  = Nx.slice_along_axis(gpu_batch, 0, seq_len - horizon, axis: 1)
        targets = Nx.slice_along_axis(gpu_batch, horizon, seq_len - horizon, axis: 1)

        # ⚡ 1. Learning Rate Schedule (Goldilocks: 1.5e-4)
        base_lr = 1.5e-5
        min_lr = 1.5e-6
        warmup_steps = 1000
        
        current_lr = 
          if step < warmup_steps do
            base_lr * (step / warmup_steps)
          else
            progress = min(max((step - warmup_steps) / (total_steps - warmup_steps), 0.0), 1.0)
            min_lr + 0.5 * (base_lr - min_lr) * (1.0 + :math.cos(:math.pi() * progress))
          end

        # ⚡ 2. The 3-Tier Gradient Tape
        {loss_tensor, grads, next_h1, next_h2, next_h3, avg_g3_tensor, avg_g2_tensor} = 
          DLM.Phase4_Trainer.compute_grad_and_step(
            inputs, targets, ch1, ch2, ch3, frozen_base_p, frozen_mid_p, frozen_map, cp3
          )

        loss_val = Nx.to_number(loss_tensor)
        g3_val = Nx.to_number(avg_g3_tensor)
        g2_val = Nx.to_number(avg_g2_tensor)

        # ⚡ 3. Safety Check
        if loss_val == :nan or loss_val > 20.0 do
          IO.puts("⚠️ Step #{step}: NaN/Spike detected! Flushing Hidden States.")
          clean_h = Nx.broadcast(0.0, {batch_size, 512}) |> Nx.backend_copy(gpu)
          {cp3, cm3, cv3, clean_h, clean_h, clean_h} 
        else
          # ⚡ 4. Optimizer Step (Only updating Level 3!)
          lr_tensor = Nx.tensor(current_lr, type: :f32) |> Nx.backend_copy(gpu)
          step_tensor = Nx.tensor(step, type: :f32) |> Nx.backend_copy(gpu)
          
          {up_p3, up_m3, up_v3} = DLM.MuonHybrid.step(cp3, grads, cm3, cv3, step_tensor, lr_tensor)

          # ⚡ 5. Telemetry
          if rem(step, 50) == 0 do
            # We are back to Cross-Entropy, so BPC is mathematically valid again!
            # bpc = loss_val / 0.69314718
            mem = :erlang.memory(:total) |> div(1024 * 1024)
            
            cpu_grads = DLM.Tree.map(grads, &Nx.backend_copy(&1, Nx.BinaryBackend))
            norms = DLM.Phase4_Trainer.grad_norms(cpu_grads)
            
            sorted_norms = Enum.sort_by(norms, fn {_k, v} -> v end, :desc)
            {max_name, max_norm} = hd(sorted_norms)
            
            valve3_norm = Keyword.get(norms, :valve_w) 

            IO.puts("➡️  Step #{step} | Cosine Loss (+8): #{Float.round(loss_val, 4)} | LR: #{Float.round(current_lr, 6)}")
            # ⚡ Notice the Dual-Gate readout:
            IO.puts("   ⚙️  L2 Syllable Gate: #{Float.round(g2_val * 100, 2)}% | 🧠 L3 Grammar Gate: #{Float.round(g3_val * 100, 2)}%")
            IO.puts("   📐 L3 GRADS -> Max: [#{max_name}: #{max_norm}] | L3 Valve: #{valve3_norm} | RAM: #{mem}MB")
          end

          # ⚡ 6. Auto-Save
          if rem(step, save_interval) == 0 and step > 0 do
            DLM.CheckpointManager.save_checkpoint(run_prefix, step, up_p3, up_m3, up_v3, next_h1, next_h2, next_h3)
            :erlang.garbage_collect(self())
          end

          {up_p3, up_m3, up_v3, next_h1, next_h2, next_h3}
        end
    end)

  IO.puts("🎉 THE 3-TIER CASCADE IS COMPLETE!")
  DLM.CheckpointManager.save_checkpoint("#{run_prefix}_final", total_steps, final_p3, m3, v3, h1, h2, h3)
end
