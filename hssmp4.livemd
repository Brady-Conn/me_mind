```elixir
defmodule DLM.Phase4_Trainer do
  import Nx.Defn

  # ⚡ 1. The 3-Level Cascade Forward Pass (Latent Future CPC)
  defn compute_sequence_loss(input_tokens, target_tokens, h_base_init, h_mid_init, h_top_init, frozen_base_p, frozen_mid_p, frozen_map, top3_p) do
    seq_len = Nx.axis_size(input_tokens, 1)

    # Map inputs to continuous space
    clean_in_coords = DLM.Loss.get_real_coordinates(input_tokens, frozen_map)
    inputs_time = Nx.transpose(clean_in_coords, axes: [1, 0, 2])
    
    # Map targets to continuous space
    clean_targ_coords = DLM.Loss.get_real_coordinates(target_tokens, frozen_map)
    targets_time = Nx.transpose(clean_targ_coords, axes: [1, 0, 2]) 

    zero_frame = Nx.broadcast(0.0, Nx.shape(h_top_init))

    # ⚡ Added all Target variables to the accumulator state
    result =
      while {i = 0, total_loss = 0.0, total_g3 = 0.0, total_g2 = 0.0,
             h1 = h_base_init, h2 = h_mid_init, h3 = h_top_init,
             h1_targ = h_base_init, h2_targ = h_mid_init,
             xp1_2 = zero_frame, xp2_2 = zero_frame,
             xp1_3 = zero_frame, xp2_3 = zero_frame,
             xp1_2_targ = zero_frame, xp2_2_targ = zero_frame,
             in_t = inputs_time, targ_t = targets_time,
             p1 = frozen_base_p, p2 = frozen_mid_p, p3 = top3_p, f_map = frozen_map}, 
            Nx.less(i, seq_len) do
            
        x_in_curr = in_t[i]
        x_targ_curr = targ_t[i]

        # ⚡ FIX: Unpack parameters BEFORE using them!
        {a2, bu2, bv2, cu2, cv2, du2, dv2, mu1_2, mv1_2, mu2_2, mv2_2, 
         gw2, gb2, _sw2, _sb2, _vw2, _vb2, _ow2, _ob2} = p2
         
        {a3, bu3, bv3, cu3, cv3, du3, dv3, mu1_3, mv1_3, mu2_3, mv2_3, 
         gw3, gb3, sw3, sb3, vw3, vb3, ow3, ob3} = p3

        # ==========================================
        # 🧊 INPUT TRACK
        # ==========================================
        {_y1, h1_new} = DLM.TinySSM.forward(x_in_curr, h1, p1)

        g2 = Nx.sigmoid(Nx.add(Nx.dot(h1_new, gw2), gb2))
        batch_avg_g2 = Nx.mean(g2) 
        
        {_y2, h2_candidate} = DLM.Main_SSM.ssm_recurrence(
          h1_new, xp1_2, xp2_2, h2, 
          a2, bu2, bv2, cu2, cv2, du2, dv2, mu1_2, mv1_2, mu2_2, mv2_2
        )

        h2_new = Nx.add(Nx.multiply(g2, h2_candidate), Nx.multiply(Nx.subtract(1.0, g2), h2))
        h1_flushed = Nx.multiply(h1_new, Nx.subtract(1.0, g2))

        # ==========================================
        # 🎯 TARGET TRACK (+20 Horizon)
        # ==========================================
        {_y1_targ, h1_targ_new} = DLM.TinySSM.forward(x_targ_curr, h1_targ, p1)

        g2_targ = Nx.sigmoid(Nx.add(Nx.dot(h1_targ_new, gw2), gb2))
        
        {_y2_targ, h2_targ_candidate} = DLM.Main_SSM.ssm_recurrence(
          h1_targ_new, xp1_2_targ, xp2_2_targ, h2_targ, 
          a2, bu2, bv2, cu2, cv2, du2, dv2, mu1_2, mv1_2, mu2_2, mv2_2
        )

        # Notice the target track doesn't get flushed by L3, providing a pure future state
        h2_targ_new = Nx.add(Nx.multiply(g2_targ, h2_targ_candidate), Nx.multiply(Nx.subtract(1.0, g2_targ), h2_targ))
        h1_targ_flushed = Nx.multiply(h1_targ_new, Nx.subtract(1.0, g2_targ))

        # ==========================================
        # 🔥 LEVEL 3: ACTIVE GRAMMAR ENGINE
        # ==========================================
        g3 = Nx.sigmoid(Nx.add(Nx.dot(h2_new, gw3), gb3))
        batch_avg_g3 = Nx.mean(g3) 
        
        {_y3, h3_candidate} = DLM.Main_SSM.ssm_recurrence(
          h2_new, xp1_3, xp2_3, h3, 
          a3, bu3, bv3, cu3, cv3, du3, dv3, mu1_3, mv1_3, mu2_3, mv2_3
        )

        h3_new = Nx.add(Nx.multiply(g3, h3_candidate), Nx.multiply(Nx.subtract(1.0, g3), h3))
        
        # L3 flushes L2 for the NEXT step
        h2_flushed = Nx.multiply(h2_new, Nx.subtract(1.0, g3)) 

        # ⚡ Syntax Fusion
        f_concept3 = Nx.add(Nx.dot(h2_new, sw3), sb3)
        v_syntax3 = DLM.Main_SSM.swish(Nx.add(Nx.dot(h3_new, vw3), vb3))
        
        h_fused3 = DLM.Main_SSM.rms_norm(Nx.multiply(v_syntax3, f_concept3))
        pred_latent3 = Nx.add(Nx.dot(h_fused3, ow3), ob3)

        # ⚡ THE FIX: Compare the continuous evolutionary tracks, ignoring the flush!
        raw_delta = Nx.subtract(h2_targ_candidate, h2_candidate)

        safe_delta = Nx.add(raw_delta, 1.0e-7)
        safe_pred = Nx.add(pred_latent3, 1.0e-7)

        step_loss = DLM.Loss.cosine_distance(safe_pred, safe_delta)

        # Ensure all 21 items are returned in the exact same order!
        {i + 1, total_loss + step_loss, total_g3 + batch_avg_g3, total_g2 + batch_avg_g2, 
         h1_flushed, h2_flushed, h3_new, 
         h1_targ_flushed, h2_targ_new, 
         xp1_2, xp2_2, xp1_3, xp2_3, 
         xp1_2_targ, xp2_2_targ,
         in_t, targ_t, p1, p2, p3, f_map}
      end
      
    {Nx.divide(elem(result, 1), seq_len), 
     elem(result, 4), elem(result, 5), elem(result, 6), 
     Nx.divide(elem(result, 2), seq_len), 
     Nx.divide(elem(result, 3), seq_len)} 
  end

  # ⚡ 2. The Gradient Tape
  defn compute_grad_and_step(input_tokens, target_tokens, h1_init, h2_init, h3_init, frozen_base_p, frozen_mid_p, frozen_map, top3_p) do
    {_loss, raw_grads} = value_and_grad(top3_p, fn p3 ->
      {avg_loss, _h1, _h2, _h3, avg_g3, _avg_g2} = 
        compute_sequence_loss(input_tokens, target_tokens, h1_init, h2_init, h3_init, frozen_base_p, frozen_mid_p, frozen_map, p3)
      
      # ⚡ THE 0.01 TOLL BOOTH 
      energy_cost = Nx.tensor(0.01, type: :f32) 
      gentle_penalty = Nx.multiply(energy_cost, avg_g3)

      Nx.add(avg_loss, gentle_penalty)
    end)

    {pure_loss, next_h1, next_h2, next_h3, avg_g3, avg_g2} = 
      compute_sequence_loss(input_tokens, target_tokens, h1_init, h2_init, h3_init, frozen_base_p, frozen_mid_p, frozen_map, top3_p)
    
    {pure_loss, raw_grads, next_h1, next_h2, next_h3, avg_g3, avg_g2}
  end

  # ⚡ 4. TELEMETRY HELPER
  def grad_norms(grads) do
    {g_a, g_bu, g_bv, g_cu, g_cv, g_du, g_dv, g_mu1, g_mv1, g_mu2, g_mv2, 
     g_gw, g_gb, g_spell_w, g_spell_b, g_valve_w, g_valve_b, g_out_w, g_out_b} = grads
    
    calc = fn g -> g |> Nx.pow(2) |> Nx.sum() |> Nx.sqrt() |> Nx.to_number() |> Float.round(4) end
    
    [
      a_diag: calc.(g_a), b_u: calc.(g_bu), b_v: calc.(g_bv),
      c_u: calc.(g_cu), c_v: calc.(g_cv), d_u: calc.(g_du), d_v: calc.(g_dv),
      mx_u1: calc.(g_mu1), mx_v1: calc.(g_mv1), mx_u2: calc.(g_mu2), mx_v2: calc.(g_mv2),
      gate_w: calc.(g_gw), gate_b: calc.(g_gb), 
      spell_w: calc.(g_spell_w), spell_b: calc.(g_spell_b), 
      valve_w: calc.(g_valve_w), valve_b: calc.(g_valve_b), 
      out_w: calc.(g_out_w), out_b: calc.(g_out_b)
    ]
  end
end
