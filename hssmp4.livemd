## Inferece

```elixir
defmodule DLM.BLiMP do
  import Nx.Defn

  # ⚡ 1. The Evaluation Forward Pass (Phase 4: Latent Future CPC)
  defn eval_loss(tokens, h1_init, h2_init, h3_init, p1, p2, p3, f_map) do
    seq_len = Nx.axis_size(tokens, 1)
    
    # ⚡ Use pure Elixir 'min' to keep these as compile-time integers!
    horizon = 24
    safe_horizon = min(horizon, seq_len - 1)
    eval_len = seq_len - safe_horizon

    input_tokens = Nx.slice_along_axis(tokens, 0, eval_len, axis: 1)
    target_tokens = Nx.slice_along_axis(tokens, safe_horizon, eval_len, axis: 1)

    # ⚡ Map inputs and targets to continuous space
    clean_in_coords = Nx.take(f_map, Nx.flatten(input_tokens))
                      |> Nx.reshape({1, eval_len, 512})
    in_t = Nx.transpose(clean_in_coords, axes: [1, 0, 2])

    clean_targ_coords = Nx.take(f_map, Nx.flatten(target_tokens))
                        |> Nx.reshape({1, eval_len, 512})
    targ_t = Nx.transpose(clean_targ_coords, axes: [1, 0, 2])

    zero_frame = Nx.broadcast(0.0, {1, 512})

    result =
      while {i = 0, total_loss = 0.0, 
             h1 = h1_init, h2 = h2_init, h3 = h3_init,
             h1_targ = h1_init, h2_targ = h2_init,
             xp1_2 = zero_frame, xp2_2 = zero_frame,
             xp1_3 = zero_frame, xp2_3 = zero_frame,
             xp1_2_targ = zero_frame, xp2_2_targ = zero_frame,
             x_in = in_t, y_targ = targ_t,
             p1_val = p1, p2_val = p2, p3_val = p3, map_val = f_map}, 
            Nx.less(i, eval_len) do
            
        x_in_curr = x_in[i]
        x_targ_curr = y_targ[i]

        # ⚡ Unpack Parameters
        {a2, bu2, bv2, cu2, cv2, du2, dv2, mu1_2, mv1_2, mu2_2, mv2_2, 
         gw2, gb2, _sw2, _sb2, _vw2, _vb2, _ow2, _ob2} = p2_val

        {a3, bu3, bv3, cu3, cv3, du3, dv3, mu1_3, mv1_3, mu2_3, mv2_3, 
         gw3, gb3, sw3, sb3, vw3, vb3, ow3, ob3} = p3_val

        # ==========================================
        # 🧊 INPUT TRACK
        # ==========================================
        {_y1, h1_new} = DLM.TinySSM.forward(x_in_curr, h1, p1_val)

        g2 = Nx.sigmoid(Nx.add(Nx.dot(h1_new, gw2), gb2))
        
        {_y2, h2_candidate} = DLM.Main_SSM.ssm_recurrence(
          h1_new, xp1_2, xp2_2, h2, 
          a2, bu2, bv2, cu2, cv2, du2, dv2, mu1_2, mv1_2, mu2_2, mv2_2
        )

        h2_new = Nx.add(Nx.multiply(g2, h2_candidate), Nx.multiply(Nx.subtract(1.0, g2), h2))
        h1_flushed = Nx.multiply(h1_new, Nx.subtract(1.0, g2))

        # ==========================================
        # 🎯 TARGET TRACK (Frozen L1 & L2)
        # ==========================================
        {_y1_targ, h1_targ_new} = DLM.TinySSM.forward(x_targ_curr, h1_targ, p1_val)

        g2_targ = Nx.sigmoid(Nx.add(Nx.dot(h1_targ_new, gw2), gb2))
        
        {_y2_targ, h2_targ_candidate} = DLM.Main_SSM.ssm_recurrence(
          h1_targ_new, xp1_2_targ, xp2_2_targ, h2_targ, 
          a2, bu2, bv2, cu2, cv2, du2, dv2, mu1_2, mv1_2, mu2_2, mv2_2
        )

        h2_targ_new = Nx.add(Nx.multiply(g2_targ, h2_targ_candidate), Nx.multiply(Nx.subtract(1.0, g2_targ), h2_targ))
        h1_targ_flushed = Nx.multiply(h1_targ_new, Nx.subtract(1.0, g2_targ))

        # ==========================================
        # 🔥 LEVEL 3: ACTIVE GRAMMAR ENGINE
        # ==========================================
        g3 = Nx.sigmoid(Nx.add(Nx.dot(h2_new, gw3), gb3))
        
        {_y3, h3_candidate} = DLM.Main_SSM.ssm_recurrence(
          h2_new, xp1_3, xp2_3, h3, 
          a3, bu3, bv3, cu3, cv3, du3, dv3, mu1_3, mv1_3, mu2_3, mv2_3
        )

        h3_new = Nx.add(Nx.multiply(g3, h3_candidate), Nx.multiply(Nx.subtract(1.0, g3), h3))
        
        # L3 flushes L2 for the NEXT step
        h2_flushed = Nx.multiply(h2_new, Nx.subtract(1.0, g3)) 

        # ⚡ Syntax Fusion
        f_concept3 = Nx.add(Nx.dot(h2_new, sw3), sb3)
        v_syntax3 = DLM.Main_SSM.swish(Nx.add(Nx.dot(h3_new, vw3), vb3))
        
        h_fused3 = DLM.Main_SSM.rms_norm(Nx.multiply(v_syntax3, f_concept3))
        pred_latent3 = Nx.add(Nx.dot(h_fused3, ow3), ob3)

        # ⚡ THE FIX: Compare the continuous evolutionary tracks, ignoring the flush!
        raw_delta = Nx.subtract(h2_targ_candidate, h2_candidate)

        safe_delta = Nx.add(raw_delta, 1.0e-7)
        safe_pred = Nx.add(pred_latent3, 1.0e-7)

        step_loss = DLM.Loss.cosine_distance(safe_pred, safe_delta)

        {i + 1, total_loss + step_loss, 
         h1_flushed, h2_flushed, h3_new, 
         h1_targ_flushed, h2_targ_new, 
         xp1_2, xp2_2, xp1_3, xp2_3, 
         xp1_2_targ, xp2_2_targ,
         x_in, y_targ, p1_val, p2_val, p3_val, map_val}
      end
      
    # Return average sequence Cosine Loss
    Nx.divide(elem(result, 1), eval_len)
  end

  # ⚡ 2. The Elixir Wrapper
  def evaluate_sentence(sentence, p1, p2, map_val, p3, gpu) do
    tokens = sentence |> to_charlist() |> Nx.tensor(type: :s32) |> Nx.new_axis(0) |> Nx.backend_copy(gpu)
    blank_h = Nx.broadcast(0.0, {1, 512}) |> Nx.backend_copy(gpu)

    loss_tensor = eval_loss(tokens, blank_h, blank_h, blank_h, p1, p2, p3, map_val)
    Nx.to_number(loss_tensor)
  end
end
```

