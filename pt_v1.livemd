```elixir
# Load the saved state
%{params: saved_p} = File.read!("latent_tokenizer_step3000.bin") |> :erlang.binary_to_term()

# In your TokenizerTrainer, params were packed as: {enc_w1, enc_w2, dec_w1, dec_w2}
{frozen_enc_w1, frozen_enc_w2, _dec_w1, _dec_w2} = saved_p

# Save JUST the encoder to a new, clean file for V27
File.write!("v27_frozen_encoder.bin", :erlang.term_to_binary({frozen_enc_w1, frozen_enc_w2}))
