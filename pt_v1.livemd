:ok
```

```elixir
save_interval = 500
gpu = {EXLA.Backend, client: :rocm}
batch_size = 2048 # 🔥 Massive batch size because there is no BPTT!

IO.puts("🧠 Loading Scholar Curriculum...")
full_dataset_2d = File.read!("scholar_full_mixed_128.bin") |> :erlang.binary_to_term()

# ⚡ Flatten the dataset into 1D and chunk it by our massive batch size
dataset_1d = Nx.flatten(full_dataset_2d)
total_chars = Nx.axis_size(dataset_1d, 0)
total_steps = div(total_chars, batch_size)

IO.puts("✨ Igniting FRESH Genesis state...")
raw_p = DLM.TokenizerGenesis.init_params(42)
{raw_m, raw_v} = DLM.TokenizerGenesis.init_optimizer(raw_p)

# Transfer to GPU
p = DLM.Tree.map(raw_p, &Nx.backend_copy(&1, gpu))
m = DLM.Tree.map(raw_m, &Nx.backend_copy(&1, gpu))
v = DLM.Tree.map(raw_v, &Nx.backend_copy(&1, gpu))

# Setup learning rate and keys
lr = Nx.tensor(5.0e-4, type: :f32) |> Nx.backend_copy(gpu) # Faster LR for simple models
initial_key = Nx.Random.key(42) |> Nx.backend_copy(gpu)

IO.puts("🚀 IGNITION: Training Latent Tokenizer for #{total_steps} steps...")

{final_p, _final_m, _final_v, _final_key} = 
  Enum.reduce(0..(total_steps - 1), {p, m, v, initial_key}, fn step, {cp, cm, cv, cur_key} ->
    
    # 1. Grab the next slice of data
    offset = step * batch_size
    batch_1d = Nx.slice_along_axis(dataset_1d, offset, batch_size, axis: 0)
    
    # Expand to {batch, 1} so it fits the expected matrix multiplication shapes
    gpu_batch = Nx.new_axis(batch_1d, -1) |> Nx.backend_copy(gpu)
    step_tensor = Nx.tensor(step, type: :f32) |> Nx.backend_copy(gpu)

    # 2. Forward pass and Adam Update
    {loss_tensor, up_p, up_m, up_v, next_key} = 
      DLM.TokenizerTrainer.compute_grad_and_step(cp, cm, cv, gpu_batch, cur_key, step_tensor, lr)

    # 3. Telemetry
    if rem(step, 50) == 0 do
      loss_val = Nx.to_number(loss_tensor)
      bpc = loss_val / :math.log(2)
      IO.puts("➡️  Step #{step} | Loss: #{Float.round(loss_val, 4)} | BPC: #{Float.round(bpc, 3)}")
    end

    # 4. Save State
    if rem(step, save_interval) == 0 and step > 0 do
      IO.puts("💾 Auto-Saving Tokenizer Checkpoint...")
      # Just saving the params here to keep it simple, since it trains so fast
      cpu_p = DLM.Tree.map(up_p, &Nx.backend_copy(&1, Nx.BinaryBackend))
      File.write!("latent_tokenizer_step#{step}.bin", :erlang.term_to_binary(%{params: cpu_p}))
    end

    if rem(step, 100) == 0, do: :erlang.garbage_collect(self())

    {up_p, up_m, up_v, next_key}
  end)

IO.puts("🎉 TOKENIZER TRAINING COMPLETE!")
# Save the final masterpiece
cpu_final_p = DLM.Tree.map(final_p, &Nx.backend_copy(&1, Nx.BinaryBackend))
File.write!("latent_tokenizer_COMPLETE.bin", :erlang.term_to_binary(%{params: cpu_final_p}))
```

