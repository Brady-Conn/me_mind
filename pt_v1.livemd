## Tokenizer

```elixir
defmodule DLM.LatentTokenizer do
  import Nx.Defn

  @num_bits 8
  @dim 512
  @vocab 128

  defn to_bits(tokens) do
    shifts = Nx.iota({@num_bits}) 
             |> Nx.multiply(-1) 
             |> Nx.add(@num_bits - 1)
             |> Nx.as_type(:u32)
    
    tokens_expanded = Nx.new_axis(tokens, -1)
    shifted = Nx.right_shift(tokens_expanded, shifts)
    Nx.bitwise_and(shifted, 1) |> Nx.as_type(:f32)
  end

  defn softplus(x) do
    Nx.select(x > 20.0, x, Nx.log1p(Nx.exp(x)))
  end

  @doc """
  Returns both the logits (for training the decoder) and the latents (for V27 later).
  """
  defn forward(tokens, params, key, noise_scale \\ 0.15) do
    {enc_w1, enc_w2, dec_w1, dec_w2} = params

    # 1. ENCODER: 8-bits -> 128D -> 512D
    bits = to_bits(tokens)
    hidden_enc = softplus(Nx.dot(bits, enc_w1))
    latents = Nx.dot(hidden_enc, enc_w2)

    # 2. DIFFUSION / NOISE: Inject the probability cloud
    {noise, next_key} = Nx.Random.normal(key, 0.0, 1.0, shape: Nx.shape(latents))
    noisy_latents = latents + (noise * noise_scale)

    # 3. DECODER: 512D -> 128D -> 128 Vocab Logits
    hidden_dec = softplus(Nx.dot(noisy_latents, dec_w1))
    logits = Nx.dot(hidden_dec, dec_w2)

    {logits, noisy_latents, next_key}
  end
end
```

