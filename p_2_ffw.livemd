## SSM

```elixir
defmodule DLM.SvdSSM do
  import Nx.Defn

  defn l2_normalize(tensor) do
    # Calculate Euclidean norm across the last axis natively
    norm = Nx.sqrt(Nx.sum(Nx.pow(tensor, 2), axes: [-1], keep_axes: true))
    # Divide by norm with a tiny epsilon to prevent divide-by-zero
    Nx.divide(tensor, Nx.add(norm, 1.0e-6))
  end

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn gelu(x) do
    cdf = Nx.multiply(
      Nx.tensor(0.7978845608, type: :f32),
      Nx.add(x, Nx.multiply(Nx.tensor(0.044715, type: :f32), Nx.pow(x, 3)))
    )
    Nx.multiply(Nx.multiply(Nx.tensor(0.5, type: :f32), x), Nx.add(Nx.tensor(1.0, type: :f32), Nx.tanh(cdf)))
  end

  defn amplify_svd(x, u, v) do
    hidden = Nx.dot(x, u)
    active = gelu(hidden)
    applied = Nx.dot(active, v)
    rms_norm(applied)
  end

  defn apply_svd(x, u, v) do
    hidden = Nx.dot(x, u)
    bound = Nx.tanh(hidden)
    Nx.dot(bound, v)
  end

  defn softplus(x) do
    Nx.log1p(Nx.exp(x))
  end

  import Nx.Defn

  defn softmax(t) do
    max_val = Nx.reduce_max(t, axes: [-1], keep_axes: true)
    safe_t = Nx.subtract(t, max_val)
    exps = Nx.exp(safe_t)
    sum_exps = Nx.sum(exps, axes: [-1], keep_axes: true)
    Nx.divide(exps, Nx.add(sum_exps, 1.0e-8))
  end

  defn forward_slice(xt_idx, h_prev, params) do
    {em, eq, au, av, bu, bv, cu, cv, du, dv} = params

    x_t = Nx.take(em, xt_idx)

    # svd projections
    a_proj = amplify_svd(h_prev, au, av)
    b_proj = amplify_svd(x_t, bu, bv)
    
    # Discretization
    # b_bar = Nx.multiply(a_proj, b_proj) |> Nx.sigmoid()
    
    # # Geometric Adaptation
    # a_norm_sq = Nx.add(Nx.sum(Nx.pow(a_proj, 2), axes: [-1], keep_axes: true), 1.0e-6)
    # a_unit = Nx.divide(a_proj, Nx.sqrt(a_norm_sq))
    
    # a_ol = Nx.sum(Nx.multiply(b_bar, a_unit), axes: [-1], keep_axes: true)
    # a_ov = Nx.multiply(a_ol, a_unit)
    # b_x = Nx.subtract(b_bar, a_ov)

    # Strictly Linear State Update
    h_new = Nx.add(a_proj, b_proj)

    # Latent projections
    c_latent = amplify_svd(h_new, cu, cv)
    d_latent = amplify_svd(x_t, du, dv)
    
    # d_bar = Nx.multiply(c_latent, d_latent) |> Nx.sigmoid()

    # # Geometric Adaptation
    # c_norm_sq = Nx.add(Nx.sum(Nx.pow(c_latent, 2), axes: [-1], keep_axes: true), 1.0e-6)
    # c_unit = Nx.divide(c_latent, Nx.sqrt(c_norm_sq))
    
    # c_ol = Nx.sum(Nx.multiply(d_bar, c_unit), axes: [-1], keep_axes: true)
    # c_ov = Nx.multiply(c_ol, c_unit)
    # d_x = Nx.subtract(d_bar, c_ov)

    logits = Nx.add(c_latent, d_latent) |> Nx.dot(eq)
    
    {logits, h_new}
  end

  defn forward_step(x_t, h_prev, params) do
    {l1, h1_n} = forward_slice(x_t, h_prev, params)
    l1_xt = Nx.argmax(l1)
    {l2, _h2_n} = forward_slice(l1_xt, h1_n, params)

    {l1, l2, h1_n}
  end

end
