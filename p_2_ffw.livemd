## Train

```elixir
defmodule DLM.Phase2Trainer do
  import Nx.Defn

  # Local un-meaned CE to prevent pre-diluting the loss
  defn step_cross_entropy(logits, targets) do
    vocab_size = Nx.axis_size(logits, -1)
    one_hot = Nx.equal(Nx.iota({vocab_size}), Nx.new_axis(targets, -1))
    
    max_logits = Nx.reduce_max(logits, axes: [-1], keep_axes: true)
    safe_logits = Nx.subtract(logits, max_logits)
    log_probs = Nx.subtract(safe_logits, Nx.log(Nx.sum(Nx.exp(safe_logits), axes: [-1], keep_axes: true)))
    
    # Returns a {batch_size} 1D tensor of individual sequence losses
    Nx.negate(Nx.sum(Nx.multiply(one_hot, log_probs), axes: [-1]))
  end

  defn compute_sequence_loss(input_tokens, params) do
    full_seq_len = Nx.axis_size(input_tokens, 0)
    safe_len = full_seq_len - 3
    h_start = Nx.broadcast(0.0, {32, 512})
    zero_scalar = Nx.tensor(0.0, type: :f32)
  
    result =
      while {i = 0,
             acc_t1 = zero_scalar, val_t1 = zero_scalar,
             acc_t2 = zero_scalar, val_t2 = zero_scalar,
             h = h_start, bt = input_tokens, p = params},
            Nx.less(i, safe_len) do
        
        x_curr = bt[i]
        t1_cur = bt[i+1]
        t2_cur = bt[i+2]
        
        {logits_t1, logits_t2, h_new} = DLM.SvdSSM.forward_step(x_curr, h, p)
        
        # 1. Raw Losses
        l_t1 = step_cross_entropy(logits_t1, t1_cur)
        l_t2 = step_cross_entropy(logits_t2, t2_cur)
        
        # 2. Masks
        mask_t1 = Nx.not_equal(t1_cur, 1) |> Nx.as_type(:f32)
        mask_t2 = Nx.not_equal(t2_cur, 1) |> Nx.as_type(:f32)

        n_t1_ac = Nx.add(acc_t1, Nx.sum(Nx.multiply(l_t1, mask_t1)))
        n_t1_v = Nx.add(val_t1, Nx.sum(mask_t1))

        n_t2_ac = Nx.add(acc_t2, Nx.sum(Nx.multiply(l_t2, mask_t2)))
        n_t2_v = Nx.add(val_t2, Nx.sum(mask_t2))
        
        # 3. Accumulate Valid Loss
        {i + 1,
         n_t1_ac, n_t1_v,
         n_t2_ac, n_t2_v,
         h_new, bt, p}
      end
  
    {_, a_t1, v_t1, a_t2, v_t2, _h, _, _} = result
    
    # 4. Averages
    avg_t1 = Nx.divide(a_t1, Nx.add(v_t1, 1.0e-8))
    avg_t2 = Nx.divide(a_t2, Nx.add(v_t2, 1.0e-8))
    
    # 5. Weighted Total Loss (Prioritize the immediate next character!)
    total_loss = 
      avg_t1
      |> Nx.add(Nx.multiply(avg_t2, 0.5))

    {total_loss, {avg_t1, avg_t2}}
  end

  defn compute_grad(params, batch_tokens) do
    {_batch_size, full_seq_len} = Nx.shape(batch_tokens)
    seq_len = full_seq_len - 1
    
    input_tokens  = Nx.slice_along_axis(batch_tokens, 0, seq_len, axis: 1)
    
    {{total_loss, {loss_t1, loss_t2}}, raw_grads} = 
      value_and_grad(
        params, 
        fn p -> compute_sequence_loss(input_tokens, p) end, 
        &elem(&1, 0)
      )
  
    {total_loss, loss_t1, loss_t2, raw_grads}
  end
end
```

