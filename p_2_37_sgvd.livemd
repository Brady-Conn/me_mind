```elixir
defmodule DLM.SparseMuonGD do
  import Nx.Defn

  # Correctly scales the entire matrix to preserve geometric direction
  defn clip_norm(tensor, max_norm) do
    norm = Nx.add(Nx.sqrt(Nx.sum(Nx.pow(tensor, 2))), 1.0e-8)
    scale = Nx.min(1.0, Nx.divide(max_norm, norm))
    Nx.multiply(tensor, scale)
  end

  defn newton_schulz(g) do
    cg = clip_norm(g, 2.0)
    frobenius_norm = Nx.LinAlg.norm(cg)
    x = cg / frobenius_norm
    
    {final_x, _} = while {curr_x = x, i = 0}, Nx.less(i, 5) do
      x_t_x = Nx.dot(Nx.transpose(curr_x), curr_x)
      next_x = 1.5 * curr_x - 0.5 * Nx.dot(curr_x, x_t_x)
      {next_x, i + 1}
    end
    final_x
  end
  
  defn step(param, grad, lr) do
    step = newton_schulz(grad)
    param_update = param - lr * step
    
    param_update
  end
end
