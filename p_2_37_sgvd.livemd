## SSM

```elixir
defmodule DLM.SvdSSM do
  import Nx.Defn

  defn l2_normalize(tensor) do
    # Calculate Euclidean norm across the last axis natively
    norm = Nx.sqrt(Nx.sum(Nx.pow(tensor, 2), axes: [-1], keep_axes: true))
    # Divide by norm with a tiny epsilon to prevent divide-by-zero
    Nx.divide(tensor, Nx.add(norm, 1.0e-6))
  end

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn gelu(x) do
    cdf = Nx.multiply(
      Nx.tensor(0.7978845608, type: :f32),
      Nx.add(x, Nx.multiply(Nx.tensor(0.044715, type: :f32), Nx.pow(x, 3)))
    )
    Nx.multiply(Nx.multiply(Nx.tensor(0.5, type: :f32), x), Nx.add(Nx.tensor(1.0, type: :f32), Nx.tanh(cdf)))
  end

  defn apply_svd(x, u, v) do
    hidden = Nx.dot(x, u)
    bound = Nx.tanh(hidden)
    Nx.dot(bound, v)
  end

  defn softplus(x) do
    Nx.log1p(Nx.exp(x))
  end

  defn forward_step(xt_idx, h_prev, params) do
    {em, au, av, bu, bv, cu, cv, du, dv, eu, ev, fu, fv} = params

    x_t = Nx.take(em, xt_idx)

    # svd projections
    g_proj = apply_svd(x_t, du, dv)
    h_proj = apply_svd(h_prev, au, av)
    b_proj = apply_svd(x_t, bu, bv)

    # Discretization
    b_bar = Nx.multiply(g_proj, b_proj) |> rms_norm()
    h_bar = Nx.multiply(h_proj, g_proj) |> rms_norm()

    # Geometric Adaptation
    h_norm_sq = Nx.add(Nx.sum(Nx.pow(h_prev, 2), axes: [-1], keep_axes: true), 1.0e-6)
    h_unit = Nx.divide(h_prev, Nx.sqrt(h_norm_sq))
    overlap = Nx.sum(Nx.multiply(b_bar, h_unit), axes: [-1], keep_axes: true)
    h_over = Nx.multiply(overlap, h_unit)
    b_exclusive = Nx.subtract(b_bar, h_over)

    # Strictly Orthogonal State Update
    h_new = Nx.add(Nx.multiply(h_bar, h_prev), b_exclusive)

    l_latent = apply_svd(h_new, cu, cv)
    e_latent = apply_svd(x_t, eu, ev)
    f_latent = apply_svd(x_t, fu, fv)

    e_bar = Nx.multiply(f_latent, e_latent) |> rms_norm()
    l_bar = Nx.multiply(l_latent, f_latent) |> rms_norm()

    l_norm_sq = Nx.add(Nx.sum(Nx.pow(h_new, 2), axes: [-1], keep_axes: true), 1.0e-6)
    l_unit = Nx.divide(h_new, Nx.sqrt(l_norm_sq))
    lov = Nx.sum(Nx.multiply(e_bar, l_unit), axes: [-1], keep_axes: true)
    l_over = Nx.multiply(lov, l_unit)
    e_exclusive = Nx.subtract(e_bar, l_over)
    
    logits_fwd = Nx.add(Nx.multiply(l_bar, h_new), e_exclusive)

    {logits_fwd, h_new}
  end
end
