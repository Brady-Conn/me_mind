## Dictionary Create

```elixir
# --- GENERATE SYNTHETIC DICTIONARY FILE ---
# In the future, you'll replace this with the path to a real Webster's text file.
file_path = "mini_dictionary.txt"

subjects = ["Aardvark", "Abacus", "Abe", "Aide", "Ail"]
definitions = [
  "is a nocturnal mammal of Africa.",
  "is an ancient counting tool.",
  "is a name for a person.",
  "is a helper or assistant.",
  "is to feel pain or trouble."
]

File.open!(file_path, [:write], fn file ->
  # Create 1,000 variations
  for _ <- 1..200, s <- subjects, d <- definitions do
    IO.write(file, "#{s} #{d}\n")
  end
end)

IO.puts("✅ Created #{file_path} with 1,000 entries.")
```

```elixir
# --- THE REAL ENGLISH DICTIONARY DOWNLOADER ---
dict_url = "https://raw.githubusercontent.com/benjihillard/English-Dictionary-Database/main/english%20Dictionary.csv"
dict_file = "english_dictionary.csv"

unless File.exists?(dict_file) do
  IO.puts("📥 Downloading the English Dictionary (14.5 MB)...")
  %{body: content} = Req.get!(dict_url)
  File.write!(dict_file, content)
  IO.puts("✅ Downloaded #{Float.round(byte_size(content) / 1_000_000, 2)} MB of knowledge.")
else
  IO.puts("📂 Dictionary already exists locally.")
end
```
