```elixir
defmodule DLM.TokenizerTrainer do
  import Nx.Defn

    # Add to your loss — pushes representations to use space evenly
  defn uniformity_loss(latents) do
    # Pairwise Gaussian kernel — minimizing this spreads points out
    sq_dists = pairwise_sq_distances(latents)
    Nx.mean(Nx.exp(Nx.multiply(-2.0, sq_dists)))
  end
  
  defn pairwise_sq_distances(x) do
    a = Nx.new_axis(x, 1)
    b = Nx.new_axis(x, 0)
    Nx.sum(Nx.pow(Nx.subtract(a, b), 2), axes: [-1])
  end

  defn newton_schulz(g) do
    # 1. Normalize the gradient matrix by its Frobenius norm
    norm = Nx.sqrt(Nx.sum(Nx.pow(g, 2))) + 1.0e-8
    x = g / norm

    # 2. 5-Step Orthogonal Projection
    {final_x, _} =
      while {mat = x, i = 0}, Nx.less(i, 5) do
        mat_t = Nx.transpose(mat)
        mat_mat_t = Nx.dot(mat, mat_t)
        
        # X = 1.5 * X - 0.5 * (X * X^T) * X
        term1 = mat * 1.5
        term2 = Nx.dot(mat_mat_t, mat) * 0.5
        
        {term1 - term2, i + 1}
      end

    final_x
  end

  defn muon_step(param, grad, m, v, _step, lr) do
    # Muon uses standard momentum rather than Adam's variance-scaled momentum
    beta1 = 0.95
    new_m = beta1 * m + (1.0 - beta1) * grad
    
    # Force the momentum update into a pure rotational matrix
    ortho_grad = newton_schulz(new_m)
    
    # Apply the orthogonal step
    param_update = param - (lr * ortho_grad)
    
    # Return updated param, new momentum, and pass through the untouched v
    {param_update, new_m, v}
  end

  # ⚡ Universal L2 Normalizer (Works on 2D, 3D, N-D tensors)
  defn l2_normalize(tensor) do
    # Calculate Euclidean norm across the last axis natively
    norm = Nx.sqrt(Nx.sum(Nx.pow(tensor, 2), axes: [-1], keep_axes: true))
    # Divide by norm with a tiny epsilon to prevent divide-by-zero
    Nx.divide(tensor, Nx.add(norm, 1.0e-6))
  end

  defn log_softmax(logits) do
    max_logits = Nx.reduce_max(logits, axes: [-1], keep_axes: true)
    safe_logits = logits - max_logits
    sum_exp = Nx.sum(Nx.exp(safe_logits), axes: [-1], keep_axes: true)
    safe_logits - Nx.log(sum_exp)
  end

  # ⚡ 1. Angular Alignment (Cosine Distance)
  defn cosine_distance(pred, target) do
    p_norm = l2_normalize(pred)
    t_norm = l2_normalize(target)

    # Dot product across the 512 dimension
    cos_sim = Nx.sum(Nx.multiply(p_norm, t_norm), axes: [-1])
    
    # Minimize distance (1.0 - similarity)
    Nx.mean(Nx.subtract(1.0, cos_sim))
  end

  defn compute_loss(logits, targets) do
    vocab_size = Nx.axis_size(logits, -1)
    
    # Create a 1-hot vector for the correct answer
    one_hot = Nx.equal(Nx.iota({vocab_size}), Nx.new_axis(targets, -1))
    
    # Stable Log-Softmax
    max_logits = Nx.reduce_max(logits, axes: [-1], keep_axes: true)
    safe_logits = Nx.subtract(logits, max_logits)
    log_probs = Nx.subtract(safe_logits, Nx.log(Nx.sum(Nx.exp(safe_logits), axes: [-1], keep_axes: true)))
    
    # Cross Entropy calculation
    Nx.mean(Nx.negate(Nx.sum(Nx.multiply(one_hot, log_probs), axes: [-1])))
  end

  defn compute_grad_and_step(params, ms, vs, inputs, targets, key, step, lr, gpu_table) do
    {loss, raw_grads} = value_and_grad(params, fn p ->
      {p1, p2, _p3, _p4} = p
  
      {logits, latents, _next_key} = DLM.LatentTokenizer.forward(inputs, p, gpu_table, key, 0.15)
  
      ce_loss = compute_loss(logits, targets)
  
      # In compute_grad_and_step:
      latents_sub = Nx.slice_along_axis(latents, 0, 128, axis: 0)
      targets_sub = Nx.slice_along_axis(targets, 0, 128, axis: 0)
      
      # Normalize both to unit sphere before transport
      latents_norm = l2_normalize(latents_sub)
      
      target_coords =
        DLM.LatentRadar.get_coordinates(targets_sub, p1, p2, gpu_table)
        |> l2_normalize()
        |> stop_grad()
      
      sinkhorn_loss = DLM.SinkhornOT.compute(latents_norm, target_coords)
      
      # Remove the ce_weight entirely
      geo_step = Nx.max(Nx.tensor(0.0), step - Nx.tensor(2000.0))
      sinkhorn_weight = Nx.min(Nx.tensor(0.01), Nx.tensor(0.01) * geo_step / 2000.0)
      uniformity_weight = Nx.min(Nx.tensor(0.005), Nx.tensor(0.005) * geo_step / 2000.0)
      
      ce_loss + (sinkhorn_weight * sinkhorn_loss) + (uniformity_weight * uniformity_loss(latents_norm))
    end)

    keys_tensor = Nx.Random.split(key)
    next_key = keys_tensor[0]

    # Unpack for the Muon/Adam routing
    {p1, p2, p3, p4} = params
    {g1, g2, g3, g4} = raw_grads
    {m1, m2, m3, m4} = ms
    {v1, v2, v3, v4} = vs

    # Pure Muon routing for all 2D matrices
    {u_p1, u_m1, u_v1} = muon_step(p1, g1, m1, v1, step, lr)
    {u_p2, u_m2, u_v2} = muon_step(p2, g2, m2, v2, step, lr)
    {u_p3, u_m3, u_v3} = muon_step(p3, g3, m3, v3, step, lr)
    {u_p4, u_m4, u_v4} = muon_step(p4, g4, m4, v4, step, lr)

    new_p = {u_p1, u_p2, u_p3, u_p4}
    new_m = {u_m1, u_m2, u_m3, u_m4}
    new_v = {u_v1, u_v2, u_v3, u_v4}

    {loss, new_p, new_m, new_v, next_key}
  end
end
