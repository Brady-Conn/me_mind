## Tokenizer

```elixir
defmodule DLM.ShapeDiffusion do
  import Nx.Defn

  # 1. We initialize an embedding table that will be molded by diffusion
  def init_state(vocab_size \\ 128, dim \\ 512, seed \\ 42) do
    key = Nx.Random.key(seed)
    
    # The raw clay: character embeddings
    {embeds, key} = Nx.Random.normal(key, 0.0, 0.1, shape: {vocab_size, dim})
    
    # Denoiser params (simplified MLP for example)
    {d_w1, key} = Nx.Random.normal(key, 0.0, 0.05, shape: {dim, dim * 4})
    {d_w2, key} = Nx.Random.normal(key, 0.0, 0.05, shape: {dim * 4, dim})
    
    {embeds, d_w1, d_w2, key}
  end

  # Standard L2 Norm to keep the space from expanding infinitely
  defn l2_normalize(tensor) do
    norm = Nx.sqrt(Nx.sum(Nx.pow(tensor, 2), axes: [-1], keep_axes: true))
    Nx.divide(tensor, Nx.add(norm, 1.0e-6))
  end

  # The Denoising Network
  defn denoise(x_t, d_w1, d_w2) do
    # Softplus hidden layer
    hidden = Nx.dot(x_t, d_w1)
    hidden = Nx.select(hidden > 20.0, hidden, Nx.log1p(Nx.exp(hidden)))
    
    Nx.dot(hidden, d_w2)
  end

  # ⚡ The Joint Training Step
  defn compute_grad_and_step(params, tokens, noise, alpha_cumprod, lr) do
    {embeds, d_w1, d_w2, key} = params
    
    {loss, grads} = value_and_grad(params, fn {emb, w1, w2, _k} ->
      # 1. Get the current continuous shape for the characters
      x_0 = Nx.take(emb, Nx.flatten(tokens)) 
            |> Nx.reshape({Nx.axis_size(tokens, 0), 512})
            |> l2_normalize() # Keep them on a hypersphere

      # 2. Corrupt with noise (q_sample)
      # Assuming alpha_cumprod is a scalar for the chosen random timestep t
      mean = x_0 * Nx.sqrt(alpha_cumprod)
      variance = noise * Nx.sqrt(1.0 - alpha_cumprod)
      x_t = mean + variance

      # 3. Predict the noise (or predict x_0 directly)
      pred_noise = denoise(x_t, w1, w2)
      
      # 4. The Loss: Mean Squared Error between predicted and actual noise
      # THIS gradient flows back into BOTH the denoiser AND the embedding table!
      Nx.mean(Nx.pow(pred_noise - noise, 2))
    end)

    # Apply gradients (Simplified SGD/Adam step here)
    # By updating `embeds` using the diffusion loss, the diffusion 
    # process forces the embeddings into a smooth, structured geometry.
    {g_emb, g_w1, g_w2, _gk} = grads
    
    new_emb = embeds - (g_emb * lr)
    new_w1 = d_w1 - (g_w1 * lr)
    new_w2 = d_w2 - (g_w2 * lr)
    
    {loss, {new_emb, new_w1, new_w2, key}}
  end
end
```

```elixir
defmodule DLM.LatentTokenizer do
  import Nx.Defn

  @num_bits 8

  # Drop-in replacement for to_bits/1
  # tokens: {batch} of integer codepoints
  # table:  {vocab_size, 32} precomputed lookup
  defn to_utf8_bits(tokens, table) do
    # Flatten codepoint indices → gather rows → restore batch shape
    Nx.take(table, Nx.flatten(tokens))
    |> Nx.reshape({Nx.axis_size(tokens, 0), 38})
  end

  defn softplus(x) do
    Nx.select(x > 20.0, x, Nx.log1p(Nx.exp(x)))
  end

  # ⚡ Add rms_norm to the tokenizer
  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn forward(tokens, params, table, key, noise_scale \\ 0.15) do
    {enc_w1, enc_w2, dec_w1, dec_w2} = params

    bits = to_utf8_bits(tokens, table)
    hidden_enc = softplus(Nx.dot(bits, enc_w1))
    
    # ⚡ FIX: The Latent Trap! Normalize the vectors BEFORE adding noise.
    raw_latents = Nx.dot(hidden_enc, enc_w2)
    latents = rms_norm(raw_latents)

    {noise, next_key} = Nx.Random.normal(key, 0.0, 1.0, shape: Nx.shape(latents))
    noisy_latents = latents + (noise * noise_scale)

    hidden_dec = softplus(Nx.dot(noisy_latents, dec_w1))
    logits = Nx.dot(hidden_dec, dec_w2)

    {logits, noisy_latents, next_key}
  end
end
```

