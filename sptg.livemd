## Init

```elixir
defmodule DLM.TokenizerGenesis do
  @num_bits 32
  @dim 512
  @vocab 128

  def init_params(seed \\ 69) do
    key = Nx.Random.key(seed)
    
    # Encoder
    {enc_w1, key} = Nx.Random.normal(key, 0.0, 0.02, shape: {38, 256})
    {enc_w2, key} = Nx.Random.normal(key, 0.0, 0.05, shape: {256, @dim})
    
    # Decoder
    {dec_w1, key} = Nx.Random.normal(key, 0.0, 0.05, shape: {@dim, 256})
    {dec_w2, _key} = Nx.Random.normal(key, 0.0, 0.05, shape: {256, @vocab})

    {enc_w1, enc_w2, dec_w1, dec_w2}
  end

  def init_optimizer(params) do
    zero_like = fn t -> Nx.broadcast(Nx.tensor(0.0, type: :f32), t) end
    ms = params |> Tuple.to_list() |> Enum.map(zero_like) |> List.to_tuple()
    vs = params |> Tuple.to_list() |> Enum.map(zero_like) |> List.to_tuple()
    {ms, vs} # Just Adam for this, no Muon needed!
  end
end
```

