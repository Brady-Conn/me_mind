## SSM

```elixir
defmodule DLM.SvdSSM do
  import Nx.Defn

  defn l2_normalize(tensor) do
    # Calculate Euclidean norm across the last axis natively
    norm = Nx.sqrt(Nx.sum(Nx.pow(tensor, 2), axes: [-1], keep_axes: true))
    # Divide by norm with a tiny epsilon to prevent divide-by-zero
    Nx.divide(tensor, Nx.add(norm, 1.0e-6))
  end

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn gelu(x) do
    cdf = Nx.multiply(
      Nx.tensor(0.7978845608, type: :f32),
      Nx.add(x, Nx.multiply(Nx.tensor(0.044715, type: :f32), Nx.pow(x, 3)))
    )
    Nx.multiply(Nx.multiply(Nx.tensor(0.5, type: :f32), x), Nx.add(Nx.tensor(1.0, type: :f32), Nx.tanh(cdf)))
  end

  defn swish(x) do
    Nx.multiply(x, Nx.sigmoid(x))
  end

  defn apply_svd(x, u, v) do
    Nx.dot(x, u) |> gelu() |> Nx.dot(v)
  end

  defn feed_forward_layer(x, um, bi, dm) do
    up = Nx.dot(x, um) 
    act = gelu(up)
    biased = Nx.add(act, bi)
    Nx.dot(biased, dm) 
  end

  defn softplus(x) do
    Nx.log1p(Nx.exp(x))
  end

  defn softmax(t) do
    max_val = Nx.reduce_max(t, axes: [-1], keep_axes: true)
    safe_t = Nx.subtract(t, max_val)
    exps = Nx.exp(safe_t)
    sum_exps = Nx.sum(exps, axes: [-1], keep_axes: true)
    Nx.divide(exps, Nx.add(sum_exps, 1.0e-8))
  end

  # For dimension-changing terms (B and C): gate the input, then project
  defn ffn_proj_gated(x, um, dm, bi, qr) do
    gate = Nx.multiply(x, qr) |> Nx.sigmoid()  # gate in input space, same shape as x
    gated_x = Nx.multiply(gate, x)             # [batch, vocab] or [batch, dim]
    feed_forward_layer(gated_x, um, bi, dm)    # projects to the new dim
  end
  
  # For same-dim terms (A and D): full residual gate, unchanged
  defn ffn_residual(x, um, dm, bi, qr) do
    out = feed_forward_layer(x, um, bi, dm)
    gate = Nx.multiply(x, qr) |> Nx.sigmoid()
    Nx.multiply(gate, out) |> Nx.add(x)
  end

  defn forward_step(x_t, h_prev, trainable, frozen_m) do
    {a1, a2, ab, aq, b1, b2, bb, bq, c1, c2, cb, d1, d2, db, dq} = trainable

    is_space = Nx.equal(x_t, 32) |> Nx.as_type(:f32) |> Nx.new_axis(-1)
    reset_factor = Nx.subtract(1.0, Nx.multiply(is_space, 0.3)) # too strong?
    
    u_t = Nx.take(frozen_m, x_t) |> rms_norm()

    # second hidden state that's only updated on word boundries(space)?
    a_term = ffn_residual(h_prev, a1, a2, ab, aq)
    b_term = ffn_residual(u_t, b1, b2, bb, bq)

    h_new = Nx.add(a_term, b_term) |> rms_norm()
    h_gated = Nx.multiply(h_new, reset_factor)
    
    c_term = feed_forward_layer(h_gated, c1, cb, c2)
    d_term = ffn_proj_gated(u_t, d1, d2, db, dq)

    logits = Nx.add(c_term, d_term)
    
    {logits, h_gated}
  end
end
