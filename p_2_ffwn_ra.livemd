```elixir
defmodule DLM.SvdOptimizer do
  import Nx.Defn

  defn update(params, grads, step, lr) do
    {a1, a2, ab, aq, b1, b2, bb, bq, c1, c2, cb, d1, d2, db, dq} = params   
    {ga1, ga2, gab, gaq, gb1, gb2, gbb, gbq, gc1, gc2, gcb, gd1, gd2, gdb, gdq} = grads
    
    new_step = Nx.add(step, 1)

    # optimizer update step
    a1_new = DLM.StatelessMuon.muon_step_decay(a1, ga1, lr)
    a2_new = DLM.StatelessMuon.muon_step_decay(a2, ga2, lr)
    b1_new = DLM.StatelessMuon.muon_step_decay(b1, gb1, lr)
    b2_new = DLM.StatelessMuon.muon_step_decay(b2, gb2, lr)
    c1_new = DLM.StatelessMuon.muon_step_decay(c1, gc1, lr)
    c2_new = DLM.StatelessMuon.muon_step_decay(c2, gc2, lr)
    d1_new = DLM.StatelessMuon.muon_step_decay(d1, gd1, lr)
    d2_new = DLM.StatelessMuon.muon_step_decay(d2, gd2, lr)
    ab_new = DLM.StatelessMuon.muon_step_decay(ab, gab, lr)
    bb_new = DLM.StatelessMuon.muon_step_decay(bb, gbb, lr)
    cb_new = DLM.StatelessMuon.muon_step_decay(cb, gcb, lr)
    db_new = DLM.StatelessMuon.muon_step_decay(db, gdb, lr)
    aq_new = DLM.StatelessMuon.muon_step_decay(aq, gaq, lr)
    bq_new = DLM.StatelessMuon.muon_step_decay(bq, gbq, lr)
    dq_new = DLM.StatelessMuon.muon_step_decay(dq, gdq, lr)
    
    new_params = {a1_new, a2_new, ab_new, aq_new, b1_new, b2_new, bb_new, bq_new,
                  c1_new, c2_new, cb_new, d1_new, d2_new, db_new, dq_new}

    {new_params, new_step}
  end
end
