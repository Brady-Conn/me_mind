```elixir
defmodule DLM.PhysicsGenesis do
  import Nx.Defn

  @vocab 128
  @dim 512 

  defn init(k1) do
    std_dim = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@dim, type: :f32)))
    # std_voc = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@vocab, type: :f32)))

    # projection matrices
    {a1, k2} = Nx.Random.normal(k1, 0.0, std_dim, shape: {@dim, @dim})
    {a2, k3} = Nx.Random.normal(k2, 0.0, std_dim, shape: {@dim, @dim})
    {b1, k4} = Nx.Random.normal(k3, 0.0, std_dim, shape: {@dim, @dim})
    {b2, k5} = Nx.Random.normal(k4, 0.0, std_dim, shape: {@dim, @dim})
    {c1, k6} = Nx.Random.normal(k5, 0.0, std_dim, shape: {@dim, @dim})
    {c2, k7} = Nx.Random.normal(k6, 0.0, std_dim, shape: {@dim, @vocab})
    {d1, k8} = Nx.Random.normal(k7, 0.0, std_dim, shape: {@dim, @dim})
    {d2, k9} = Nx.Random.normal(k8, 0.0, std_dim, shape: {@dim, @vocab})

    # feed forward layer bias'
    ab = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    bb = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    cb = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    db = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)

    # residual attention query vectors
    aq = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    bq = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    dq = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32) 

    trainable_params = {a1, a2, ab, aq, b1, b2, bb, bq, c1, c2, cb, d1, d2, db, dq}

    {trainable_params, k9}
  end
end
