```elixir
run_prefix  = "v39_DLM_Phase_2_sani_mask_512d_tau_hcarry"  
total_steps = 40000

# ⚡ 1. CHECK RESUME STATE
{load_path, start_step} = DLM.CheckpointManager.get_resume_state(run_prefix)

if start_step == :completed do
  IO.puts("✅ This run has already reached #{total_steps} steps. Exiting.")
else
  # 2. Load the completed Phase 1 state
  %{params: phase1_p} = File.read!("phase1_sinkGD_nomix_512sq32b5e5_6k_COMPLETE.bin") |> :erlang.binary_to_term()
  {cpu_embeds, _w1, _w2, _key} = phase1_p
  
  # Push the finalized map to the GPU and L2 Normalize it
  frozen_map = cpu_embeds
                 |> Nx.backend_copy(gpu)
                 |> DLM.Loss.l2_normalize()
  
  IO.puts("🌌 Phase 1 Frozen Manifold Loaded & Normalized!")

  batch_size = 32
  
  # ⚡ THE INFINITE CURRICULUM STREAM
  data_dir = "./data/bbylm_512_strict" 
  
  IO.puts("🧠 Initializing Lazy Curriculum Data Stream from [#{data_dir}]...")
  
  data_stream = 
    BabyLM.CurriculumStreamer.build_infinite_stream(data_dir, batch_size)
    |> Stream.drop(start_step) # ⚡ 2. THE FAST-FORWARD: Drops already-seen batches

  # ⚡ 4. BRANCHING WEIGHT INITIALIZATION
  {starting_params, initial_h, initial_key} =
    if load_path == :fresh do
      IO.puts("✨ Igniting brand new Genesis weights for #{run_prefix}...")
      DLM.PhysicsGenesis.ignite(Nx.Random.key(System.system_time()))
    else
      IO.puts("✨ Loading Weights from #{load_path}...")
      %{params: loaded_p, h: loaded_h} = File.read!(load_path) |> :erlang.binary_to_term()
      {loaded_p, loaded_h, Nx.Random.key(System.system_time())}
    end
  
  # Move everything to the GPU
  p = DLM.Tree.map(starting_params, &Nx.backend_copy(&1, gpu))
  step_count = Nx.tensor(start_step) |> Nx.backend_copy(gpu)
  h_gpu = Nx.backend_copy(initial_h, gpu)
  
  # ⚡ 5. ZIP FROM THE START_STEP
  {final_p, _key, _step, final_h} =
    Enum.reduce(Stream.zip(start_step..(total_steps - 1), data_stream), {p, initial_key, step_count, h_gpu}, fn {step, cpu_batch}, {cp, cur_key, c_step, c_h} ->        
      gpu_batch = Nx.backend_copy(cpu_batch, gpu)
      
      # The Cold Ignition Learning Rate
      base_lr = 1.0e-4
      min_lr = 3.0e-5
      warmup_steps = 600
      
      current_lr = 
        if step < warmup_steps do
          base_lr * (step / warmup_steps)
        else
          progress = min(max((step - warmup_steps) / (total_steps - warmup_steps), 0.0), 1.0)
          min_lr + 0.5 * (base_lr - min_lr) * (1.0 + :math.cos(:math.pi() * progress))
        end
      
      lr_tensor = Nx.tensor(current_lr, type: :f32) |> Nx.backend_copy(gpu)

      split_keys = Nx.Random.split(cur_key)
      next_key = split_keys[1]
      
      # Forward Pass
      {loss_tensor, fwd_tensor, retro_tensor, grads, h_new} = DLM.Phase2Trainer.compute_grad(
        cp, gpu_batch, c_h, frozen_map
      )
  
      {tot_v, fwd_v, ret_v} = {Nx.to_number(loss_tensor), Nx.to_number(fwd_tensor), Nx.to_number(retro_tensor)}

      if fwd_v == :nan or fwd_v > 100.0 or ret_v == :nan or ret_v > 100.0 do
        IO.puts("⚠️ Step #{step}: NaN/Spike detected! Flushing Hidden States.")
        clean_h = Nx.broadcast(0.0, {batch_size, 512}) |> Nx.backend_copy(gpu)
        {cp, next_key, step + 1, clean_h}
      else
        # Optimizer Update
        {up_p, up_step} = DLM.SparseSinkOptimizer.update(cp, grads, c_step, lr_tensor)
    
        # Telemetry
        if rem(step, 50) == 0 do
          IO.puts("➡️ Step #{step} | Total: #{Float.round(tot_v, 4)} | FWD: #{Float.round(fwd_v, 4)} | RETRO: #{Float.round(ret_v, 4)} | LR: #{Float.round(current_lr, 6)}")
          :erlang.garbage_collect()
        end
    
        # Checkpoint Saving
        if rem(step, 1000) == 0 and step > 0 do
          IO.puts("💾 Checkpoint reached! Saving Step #{step}...")
          cpu_snapshot = DLM.Tree.map(up_p, &Nx.backend_copy(&1, Nx.BinaryBackend))
          cpu_h = Nx.backend_copy(h_new)
          filename = "#{run_prefix}_checkpoint_step_#{step}.bin"
          File.write!(filename, :erlang.term_to_binary(%{params: cpu_snapshot, h: cpu_h}))
          :erlang.garbage_collect()
        end
    
        {up_p, next_key, up_step, h_new}
      end
    end)

  IO.puts("💾 Saving Final Gated Physics Engine Weights...")
  good_params = DLM.Tree.map(final_p, &Nx.backend_transfer(&1, Nx.BinaryBackend))
  fh_cpu = Nx.backend_copy(final_h)
  File.write!("#{run_prefix}_final.bin", :erlang.term_to_binary(%{params: good_params, h: fh_cpu}))
  IO.puts("✅ Resaved with clean CPU tensors")
  IO.puts("✅ Physics Engine Training Complete!")
end
