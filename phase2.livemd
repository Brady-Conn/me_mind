## Data stream

```elixir
defmodule DLM.DataStreamer do  # renamed from V13 to match your module convention
  def stream(path, seq_len, batch_size) do
    path
    |> File.read!()
    |> to_charlist()
    |> Stream.chunk_every(seq_len + 1, seq_len, :discard)
    |> Stream.map(fn chunk ->
      ins = chunk |> Enum.slice(0, seq_len) |> Nx.tensor(type: :s64)
      tgs = chunk |> Enum.slice(1, seq_len) |> Nx.tensor(type: :s64)
      {ins, tgs}
    end)
    |> Stream.chunk_every(batch_size, batch_size, :discard)
    |> Stream.map(fn batch ->
      {ins_list, tgs_list} = Enum.unzip(batch)
      {Nx.stack(ins_list), Nx.stack(tgs_list)}
    end)
  end
end
```

