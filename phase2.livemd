## training

```elixir
# --- Shape Sanity Check (self-contained) ---
embed_dim  = 256
ff_dim     = embed_dim * 4
vocab_size = 128
seq_len    = 256
batch_size = 12

genesis_path    = "dlm_genesis.bin"
full_state_path = "dlm_full_state.bin"
path            = "dlm_dictionary.txt"

# Load whatever checkpoint exists
{params, m_state, v_state, start_step} =
  cond do
    File.exists?(full_state_path) ->
      IO.puts("Loading full state...")
      {p, m, v, step} = File.read!(full_state_path) |> :erlang.binary_to_term()
      to_active = fn t -> Tuple.to_list(t) |> Enum.map(&Nx.backend_copy/1) |> List.to_tuple() end
      {to_active.(p), to_active.(m), to_active.(v), step}

    File.exists?(genesis_path) ->
      IO.puts("Loading genesis...")
      p = File.read!(genesis_path) |> :erlang.binary_to_term()
        |> Tuple.to_list() |> Enum.map(&Nx.backend_copy/1) |> List.to_tuple()
      zero_like = fn t -> Nx.broadcast(Nx.tensor(0.0), Nx.shape(t)) |> Nx.backend_copy() end
      m = p |> Tuple.to_list() |> Enum.map(zero_like) |> List.to_tuple()
      {p, m, m, 1}

    true ->
      IO.puts("❌ No checkpoint or genesis found.")
      System.halt(1)
  end

# 1. Param shape check
# Map index → {name, expected_shape} so we don't rely on the tuple being correct
expected = [
  {:embed, {vocab_size, embed_dim}},
  {:w_q,   {embed_dim, embed_dim}},
  {:w_k,   {embed_dim, embed_dim}},
  {:w_v,   {embed_dim, embed_dim}},
  {:w_o,   {embed_dim, embed_dim}},
  {:w_ff1, {embed_dim, ff_dim}},
  {:w_ff2, {ff_dim, embed_dim}},
  {:lm_w,  {embed_dim, vocab_size}},
  {:lm_b,  {vocab_size}},
  {:g1,    {embed_dim}},
  {:b1,    {embed_dim}},
  {:g2,    {embed_dim}},
  {:b2,    {embed_dim}}
]

IO.puts("\n--- Param Shapes (#{tuple_size(params)} tensors in tuple) ---")
params
|> Tuple.to_list()
|> Enum.zip(expected)
|> Enum.each(fn {tensor, {name, exp_shape}} ->
  actual = Nx.shape(tensor)
  status = if actual == exp_shape, do: "✅", else: "❌ MISMATCH"
  IO.puts("#{status} #{name}: expected #{inspect(exp_shape)}, got #{inspect(actual)}")
end)

# 2. Mask and pos_emb
pos_emb = DLM.Positional.build(seq_len, embed_dim) |> Nx.backend_copy()
mask    = DLM.Mask.causal(seq_len) |> Nx.backend_copy()

IO.puts("\n--- Static Assets ---")
IO.puts("pos_emb shape: #{inspect(Nx.shape(pos_emb))} (expected: {#{seq_len}, #{embed_dim}})")
IO.puts("mask shape:    #{inspect(Nx.shape(mask))} (expected: {1, #{seq_len}, #{seq_len}})")

# 3. Single test step
IO.puts("\n--- Test Step ---")
{test_ins, test_tgs} =
  DLM.DataStreamer.stream(path, seq_len, batch_size)
  |> Enum.take(1)
  |> hd()

IO.puts("ins shape: #{inspect(Nx.shape(test_ins))}")
IO.puts("tgs shape: #{inspect(Nx.shape(test_tgs))}")

{_, _, _, test_loss} =
  DLM.Optimizer.adam_step(
    test_ins, test_tgs, params, m_state, v_state,
    pos_emb, mask,
    Nx.tensor(0.0002, type: :f32),
    Nx.tensor(1, type: :s32)
  )

IO.puts("✅ Test step passed. Loss: #{Nx.to_number(test_loss)}")
IO.puts("RAM: #{round(:erlang.memory(:total) / 1_048_576)}MB")
```

```elixir
# ===========================================================================
# Configuration
# ===========================================================================
path            = "dlm_dictionary.txt"
full_state_path = "dlm_full_state.bin"
genesis_path    = "dlm_genesis.bin"

seq_len                = 256
batch_size             = 12
start_lr               = 0.00020
end_lr                 = 0.00005
epochs                 = 15
total_estimated_steps  = epochs * 5000

# ===========================================================================
# 1. Auto-Restorer — resumes from checkpoint or loads genesis weights
# ===========================================================================
to_active = fn tuple ->
  tuple |> Tuple.to_list() |> Enum.map(&Nx.backend_copy/1) |> List.to_tuple()
end

{params, m_state, v_state, start_step} =
  cond do
    File.exists?(full_state_path) ->
      IO.puts("♻️  Resuming from checkpoint...")
      {p, m, v, step} = File.read!(full_state_path) |> :erlang.binary_to_term()
      {to_active.(p), to_active.(m), to_active.(v), step}

    File.exists?(genesis_path) ->
      IO.puts("🌱 Loading genesis weights...")
      p = File.read!(genesis_path) |> :erlang.binary_to_term() |> to_active.()

      zero_like = fn t ->
        Nx.broadcast(Nx.tensor(0.0), Nx.shape(t)) |> Nx.backend_copy()
      end
      m = p |> Tuple.to_list() |> Enum.map(zero_like) |> List.to_tuple()

      {p, m, m, 1}  # v starts identical to m — no need to build twice

    true ->
      IO.puts("❌ No checkpoint or genesis found. Run the initializer first.")
      System.halt(1)
  end

IO.puts("📍 Starting at step #{start_step}")

# ===========================================================================
# 2. Static assets — built once, reused every step
# ===========================================================================
pos_emb = DLM.Positional.build(seq_len, 256) |> Nx.backend_copy()
mask    = DLM.Mask.causal(seq_len) |> Nx.backend_copy()

# ===========================================================================
# 3. Checkpoint helper — called every 500 steps
# ===========================================================================
save_checkpoint = fn path, p, m, v, step ->
  to_binary = fn tuple ->
    tuple |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple()
  end
  state = {to_binary.(p), to_binary.(m), to_binary.(v), step}
  File.write!(path, :erlang.term_to_binary(state))
  IO.puts("💾 Checkpoint saved at step #{step}")
end

# ===========================================================================
# 4. Training loop
# ===========================================================================
IO.puts("🚀 DLM Training — seq_len=#{seq_len} batch=#{batch_size}")

Enum.reduce(1..epochs, {params, m_state, v_state, start_step}, fn epoch, epoch_acc ->
  IO.puts("\n--- Epoch #{epoch} ---")

  DLM.DataStreamer.stream(path, seq_len, batch_size)
  |> Enum.reduce(epoch_acc, fn {ins, tgs}, {p, m, v, step} ->

    # Linear LR decay — wrap in tensor to prevent XLA recompilation
    progress   = min(step / total_estimated_steps, 1.0)
    lr         = Nx.tensor(start_lr - progress * (start_lr - end_lr), type: :f32)
    step_t     = Nx.tensor(step, type: :s32)

    {new_p, new_m, new_v, loss} =
      DLM.Optimizer.adam_step(ins, tgs, p, m, v, pos_emb, mask, lr, step_t)

    # High-frequency GC to prevent BEAM memory accumulation
    if rem(step, 10) == 0, do: :erlang.garbage_collect(self())

    # Logging, halting, and checkpointing every 500 steps
    if rem(step, 500) == 0 do
      loss_val = Nx.to_number(loss)
      mem_mb   = round(:erlang.memory(:total) / 1_048_576)

      cond do
        # Catch all forms of numerical instability
        is_float(loss_val) and (loss_val != loss_val or abs(loss_val) > 1_000_000) ->
          IO.puts("🛑 Step #{step}: Halting — numerical instability (loss=#{loss_val})")
          System.halt(1)  # halt/1 is cleaner than Process.exit for Livebook

        loss_val in [:nan, :inf, :"-inf"] ->
          IO.puts("🛑 Step #{step}: Halting — Nx returned symbolic #{loss_val}")
          System.halt(1)

        true ->
          IO.puts("🌱 Step #{step} | Epoch #{epoch} | Loss: #{Float.round(loss_val, 4)} | RAM: #{mem_mb}MB")
          save_checkpoint.(full_state_path, new_p, new_m, new_v, step)
      end
    end

    {new_p, new_m, new_v, step + 1}
  end)
end)

IO.puts("\n✅ Training complete.")
```
