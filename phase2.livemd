## Thx Create

```elixir
# --- V12.26: THE SEMANTIC MIXER (Dataset Augmentation) ---
input_path = "v12_structured_map.txt"
output_path = "v12_semantic_mix.txt"

regex = ~r/\[W\](.*?)\[T\](.*?)\[D\](.*)/

# Stop words to filter from "related" extractions
stop_words = ~w[a an the of or to in is are was were be been
                being have has had do does did will would could
                should may might shall can this that these those
                with for from by at as it its]

lines = File.read!(input_path) |> String.split("\n", trim: true)

mixed_lines =
  Enum.map(lines, fn line ->
    case Regex.run(regex, line) do
      [_, word, pos, definition] ->
        rand = :rand.uniform(100)

        cond do
          # 30% — Thesaurus/Relational mode
          # Extracts meaningful content words from the definition
          rand <= 30 ->
            related =
              definition
              |> String.downcase()
              |> String.replace(~r/[^a-z ]/, "")
              |> String.split(" ", trim: true)
              |> Enum.reject(&(&1 in stop_words))
              |> Enum.reject(&(String.length(&1) < 3))  # drop very short words
              |> Enum.take(3)
              |> Enum.join(", ")

            "[W]#{String.trim(word)} [R]Related: #{related}."

          # 30% — Jeopardy/reverse mode
          rand <= 60 ->
            "[D]#{String.trim(definition)} [W]#{String.trim(word)}."

          # 40% — Original structured format
          true ->
            line
        end

      _ ->
        line
    end
  end)

File.write!(output_path, Enum.join(mixed_lines, "\n"))
IO.puts("✅ Generated #{length(mixed_lines)} mixed entries.")
```

