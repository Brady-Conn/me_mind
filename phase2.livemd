## Brain

```elixir
defmodule DLM.Transformer do
  import Nx.Defn

  defn layer_norm(x, gamma, beta) do
    mean = Nx.mean(x, axes: [-1], keep_axes: true)
    variance = Nx.variance(x, axes: [-1], keep_axes: true)
    normed = Nx.divide(Nx.subtract(x, mean), Nx.sqrt(Nx.add(variance, 1.0e-5)))
    Nx.add(Nx.multiply(normed, gamma), beta)
  end

  defn attention(x, w_qkv, mask) do
    qkv = Nx.dot(x, w_qkv) 
    {q, k, v} = {qkv, qkv, qkv}
    k_t = Nx.transpose(k, axes: [0, 2, 1])

    logits = Nx.dot(q, [2], [0], k_t, [1], [0]) |> Nx.divide(Nx.sqrt(256))
    logits = Nx.add(logits, mask)
    
    # --- 🛡️ STABLE ATTENTION SOFTMAX ---
    # Subtract max logit to keep exp() inputs <= 0 (max exp result = 1.0)
    logits_max = Nx.reduce_max(logits, axes: [-1], keep_axes: true)
    exp = Nx.exp(Nx.subtract(logits, logits_max))
    sum = Nx.sum(exp, axes: [-1], keep_axes: true) |> Nx.add(1.0e-10)
    attn = Nx.divide(exp, sum)
    
    Nx.dot(attn, [2], [0], v, [1], [0])
  end

  defn block(x, a1, f1, a2, f2, g1, b1, g2, b2, mask) do
    # Layer 1: Attention
    x_norm = layer_norm(x, g1, b1)
    attn_out = attention(x_norm, a1, mask)
    x = Nx.add(x, Nx.dot(attn_out, a2))

    # Layer 2: FeedForward (Now with ReLU stability)
    x_norm = layer_norm(x, g2, b2)
    # --- 🛡️ RELU ACTIVATION ---
    # Replacing exp() with max(0, x). Much more stable.
    ff_hidden = Nx.dot(x_norm, f1) |> Nx.max(0) 
    ff_out = Nx.dot(ff_hidden, f2)
    Nx.add(x, ff_out)
  end
end

defmodule DLM.Positional do
  def build(len, dim) do
    i = Nx.iota({len, 1})
    d = Nx.iota({1, dim})
    Nx.sin(Nx.divide(i, Nx.pow(10000.0, Nx.divide(d, dim))))
  end
end

defmodule DLM.Mask do
  def causal(len) do
    Nx.iota({len, 1})
    |> Nx.less(Nx.iota({1, len}))
    |> Nx.multiply(-1.0e9)
    # Removed reshape — keep original [seq, seq] shape
    # Nx will broadcast over the batch dim naturally
  end
end

defmodule DLM.Optimizer do
  import Nx.Defn

  defn apply_adam(p, g, m, v, lr, step) do
    g = Nx.clip(g, -1.0, 1.0)

    b1 = 0.9
    b2 = 0.999
    eps = 1.0e-8

    new_m = Nx.add(Nx.multiply(b1, m), Nx.multiply(1 - b1, g))
    new_v = Nx.add(Nx.multiply(b2, v), Nx.multiply(1 - b2, Nx.pow(g, 2)))

    m_hat = Nx.divide(new_m, Nx.subtract(1, Nx.pow(b1, step)))
    v_hat = Nx.divide(new_v, Nx.subtract(1, Nx.pow(b2, step)))

    new_p = Nx.subtract(p, Nx.divide(Nx.multiply(lr, m_hat), Nx.add(Nx.sqrt(v_hat), eps)))
    {new_p, new_m, new_v}
  end

  # MUZZLE REMOVED FROM ARGUMENTS
  defn loss_fn(ins, tgs, params, pos_emb, mask) do
    {e, a1, f1, a2, f2, lmw, lmb, g1, b1, g2, b2} = params
    x = Nx.add(Nx.take(e, ins), pos_emb)
    x = DLM.Transformer.block(x, a1, f1, a2, f2, g1, b1, g2, b2, mask)
    
    # MUZZLE REMOVED FROM LOGITS
    logits = Nx.add(Nx.dot(x, lmw), lmb) 

    max_logits = Nx.reduce_max(logits, axes: [-1], keep_axes: true)
    stable_logits = Nx.subtract(logits, max_logits)
    sum_exp = Nx.sum(Nx.exp(stable_logits), axes: [-1], keep_axes: true) |> Nx.add(1.0e-10)
    log_sum_exp = Nx.add(max_logits, Nx.log(sum_exp))

    targets_exp = Nx.new_axis(tgs, -1)
    vocab_range = Nx.iota({1, 1, 128}, axis: 2)
    target_mask = Nx.equal(vocab_range, targets_exp)
    target_logits = Nx.sum(Nx.multiply(logits, target_mask), axes: [-1], keep_axes: true)

    Nx.mean(Nx.subtract(log_sum_exp, target_logits))
  end

  # MUZZLE REMOVED FROM ARGUMENTS
  defn adam_step(ins, tgs, p, m, v, pos_emb, mask, lr, step) do
    {loss, grads} = value_and_grad(p, fn params -> 
      loss_fn(ins, tgs, params, pos_emb, mask) # MUZZLE REMOVED
    end)

    {p_e, p_a1, p_f1, p_a2, p_f2, p_lmw, p_lmb, p_g1, p_b1, p_g2, p_b2} = p
    {g_e, g_a1, g_f1, g_a2, g_f2, g_lmw, g_lmb, g_g1, g_b1, g_g2, g_b2} = grads
    {m_e, m_a1, m_f1, m_a2, m_f2, m_lmw, m_lmb, m_g1, m_b1, m_g2, m_b2} = m
    {v_e, v_a1, v_f1, v_a2, v_f2, v_lmw, v_lmb, v_g1, v_b1, v_g2, v_b2} = v

    {ne, me, ve}       = apply_adam(p_e, g_e, m_e, v_e, lr, step)
    {na1, ma1, va1}    = apply_adam(p_a1, g_a1, m_a1, v_a1, lr, step)
    {nf1, mf1, vf1}    = apply_adam(p_f1, g_f1, m_f1, v_f1, lr, step)
    {na2, ma2, va2}    = apply_adam(p_a2, g_a2, m_a2, v_a2, lr, step)
    {nf2, mf2, vf2}    = apply_adam(p_f2, g_f2, m_f2, v_f2, lr, step)
    {nlmw, mlmw, vlmw} = apply_adam(p_lmw, g_lmw, m_lmw, v_lmw, lr, step)
    {nlmb, mlmb, vlmb} = apply_adam(p_lmb, g_lmb, m_lmb, v_lmb, lr, step)
    {ng1, mg1, vg1}    = apply_adam(p_g1, g_g1, m_g1, v_g1, lr, step)
    {nb1, mb1, vb1}    = apply_adam(p_b1, g_b1, m_b1, v_b1, lr, step)
    {ng2, mg2, vg2}    = apply_adam(p_g2, g_g2, m_g2, v_g2, lr, step)
    {nb2, mb2, vb2}    = apply_adam(p_b2, g_b2, m_b2, v_b2, lr, step)

    new_p = {ne, na1, nf1, na2, nf2, nlmw, nlmb, ng1, nb1, ng2, nb2}
    new_m = {me, ma1, mf1, ma2, mf2, mlmw, mlmb, mg1, mb1, mg2, mb2}
    new_v = {ve, va1, vf1, va2, vf2, vlmw, vlmb, vg1, vb1, vg2, vb2}

    {new_p, new_m, new_v, loss}
  end
end
```

