## SecScrub

```elixir
# --- V13.0: THE LEAN DICTIONARY GENERATOR ---
input_path = "v12_structured_map.txt"
output_path = "v13_lean_dictionary.txt"

# The "Victorian Fluff" we want to violently remove from the dataset
offending_phrases = [
  "the state of ", "a state of ", "state of ",
  "the act of ", "an act of ", "act of ",
  "pertaining to ", "of or pertaining to ",
  "a substance ", "the substance ",
  "one who ", "that which ", "a quality of ",
  "the quality of ", "any of a ", "a small "
]

lines = File.read!(input_path) |> String.split("\n", trim: true)

# Process the lines
cleaned_lines = Enum.map(lines, fn line ->
  # 1. Split the line to isolate the definition text so we don't mess up the tags
  case Regex.run(~r/(\[W\].*?\[T\].*?\[D\])(.*)/, line) do
    [_, tags, definition] ->
      # 2. Lowercase the definition temporarily for easier matching, 
      # but we use Regex with case-insensitivity (?i) to preserve original case
      lean_def = Enum.reduce(offending_phrases, definition, fn phrase, acc ->
        Regex.replace(~r/#{phrase}/i, acc, "")
      end)
      
      # 3. Clean up any double spaces or weird punctuation left behind
      lean_def = String.replace(lean_def, ~r/\s+/, " ") |> String.trim()
      
      "#{tags}#{lean_def}"
    _ -> 
      line # Fallback if regex fails
  end
end)

# Filter out lines that became completely empty after stripping
final_lines = Enum.reject(cleaned_lines, fn line -> 
  String.ends_with?(line, "[D]") or String.ends_with?(line, "[D] ") 
end)

File.write!(output_path, Enum.join(final_lines, "\n"))

original_count = length(lines)
new_count = length(final_lines)
removed = original_count - new_count

IO.puts("✅ V13 Lean Dictionary Generated!")
IO.puts("📉 Original Entries: #{original_count}")
IO.puts("📉 Lean Entries: #{new_count} (#{removed} completely empty entries removed)")
IO.puts("🔥 The 'State of the State' loop has been deleted from reality.")
```

