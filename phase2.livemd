## Inference module

```elixir
defmodule DLM.Inference do
  import Nx.Defn

  # --- 🏎️ THE XLA COMPILED GENERATION LOOP ---
  defn generate_loop(prompt_ids, params, pos_emb, muzzle, max_new_tokens) do
    {e, a1, f1, a2, f2, lmw, lmb, g1, b1, g2, b2} = params
    {_, prompt_len} = Nx.shape(prompt_ids)

    # 1. Pre-allocate the fixed memory buffer. 
    # By forcing the shape to be exactly {1, 256}, XLA compiles ONE static graph.
    # This is how we defeat the RAM leak!
    max_seq = 256
    buffer = Nx.broadcast(0, {1, max_seq})
    buffer = Nx.put_slice(buffer, [0, 0], prompt_ids)

    # 2. Build the Static Causal Mask ONCE
    mask = DLM.Mask.causal(max_seq)

    # 3. The XLA While Loop
    # State holds: {current_buffer_state, current_step_index}
    initial_state = {buffer, prompt_len}
    total_target_len = Nx.add(prompt_len, max_new_tokens)

    {final_buffer, _} = 
      while initial_state, fn {_, step} -> Nx.less(step, total_target_len) do
        {current_buffer, current_step} ->
          
          # --- Forward Pass (Fixed Shape: 256) ---
          # We embed the whole buffer, but the causal mask ensures the model 
          # only pays attention to tokens up to the current_step.
          x = Nx.add(Nx.take(e, current_buffer), pos_emb)
          x = DLM.Transformer.block(x, a1, f1, a2, f2, g1, b1, g2, b2, mask)

          # --- Extract Logits ---
          logits = Nx.add(Nx.dot(x, lmw), lmb) |> Nx.add(muzzle)

          # We pluck the logit for the exact token we are trying to predict
          # (current_step - 1 is the last known token)
          step_logits = Nx.slice(logits, [0, current_step - 1, 0], [1, 1, 128])
          
          # Get the most likely next ID
          next_id = Nx.argmax(step_logits, axis: -1)

          # Inject the new ID into our buffer for the next loop iteration
          updated_buffer = Nx.put_slice(current_buffer, [0, current_step], next_id)

          {updated_buffer, current_step + 1}
      end

    # Return the full buffer to standard Elixir
    final_buffer
  end

  # --- ⌨️ THE ELIXIR WRAPPER ---
  def sample(checkpoint_path, prompt_str, max_new_tokens \\ 40) do
    IO.puts("\n🤖 --- V13 GENERATOR ---")
    
    # Load weights
    params = File.read!(checkpoint_path) 
             |> :erlang.binary_to_term() 
             |> Tuple.to_list() 
             |> Enum.map(&Nx.backend_copy/1) 
             |> List.to_tuple()

    # Rebuild Static Assets for this scope
    pos_emb = DLM.Positional.build(256, 256) |> Nx.backend_copy()
    
    allowed_chars = ~c" abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789.,:;-'\"()[]"
    muzzle_cpu = Nx.broadcast(Nx.tensor(-1.0e10, type: :f32), {128})
    muzzle = Enum.reduce(allowed_chars, muzzle_cpu, fn char, acc ->
      Nx.indexed_put(acc, Nx.tensor([[char]]), Nx.tensor([0.0]))
    end) |> Nx.backend_copy()

    # Prepare Prompt
    ids = prompt_str |> to_charlist() |> Nx.tensor() |> Nx.reshape({1, :auto})
    {_, prompt_len} = Nx.shape(ids)

    # Generate!
    full_buffer = generate_loop(ids, params, pos_emb, muzzle, max_new_tokens)

    # Slice out only what we care about and convert to string
    final_ids = Nx.slice(full_buffer, [0, 0], [1, prompt_len + max_new_tokens])
    output_str = final_ids |> Nx.to_flat_list() |> List.to_string()

    IO.puts("Prompt:  #{prompt_str}")
    IO.puts("Output:  #{output_str}\n")
  end
end
```

```elixir
# Let's see if it can finish spelling "Apple" and start the definition!
DLM.Inference.sample("v13_genesis.bin", "[W]App", 50)
```

