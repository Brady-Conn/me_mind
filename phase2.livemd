## Init

```elixir
vocab_size = 128
embed_dim  = 256
ff_dim     = embed_dim * 4  # 1024

# ---------------------------------------------------------------------------
# Weight initializer
# Using 0.01 std — conservative, good for training stability on CPU.
# Kaiming/He init (std = sqrt(2/fan_in)) would be more theoretically
# motivated for ReLU networks, but 0.01 has been working for you so keep it.
# All tensors copied to BinaryBackend for CPU training.
# ---------------------------------------------------------------------------
init_param = fn shape, current_key ->
  {tensor, next_key} = Nx.Random.normal(current_key, 0.0, 0.01, shape: shape, type: :f32)
  {Nx.backend_copy(tensor, Nx.BinaryBackend), next_key}
end

key = Nx.Random.key(42)

# Embedding
{embed, key} = init_param.({vocab_size, embed_dim}, key)

# Attention — now 4 separate matrices (Q, K, V, O)
# Previously a1 was doing the job of all four — now each can specialise
{w_q, key} = init_param.({embed_dim, embed_dim}, key)
{w_k, key} = init_param.({embed_dim, embed_dim}, key)
{w_v, key} = init_param.({embed_dim, embed_dim}, key)
{w_o, key} = init_param.({embed_dim, embed_dim}, key)

# FeedForward
{w_ff1, key} = init_param.({embed_dim, ff_dim}, key)
{w_ff2, key} = init_param.({ff_dim, embed_dim}, key)

# Language model head
{lm_w, key} = init_param.({embed_dim, vocab_size}, key)

# Layer norm params — gamma=1, beta=0 is correct, these are not random
ones  = Nx.broadcast(Nx.tensor(1.0, type: :f32), {embed_dim}) |> Nx.backend_copy(Nx.BinaryBackend)
zeros = Nx.broadcast(Nx.tensor(0.0, type: :f32), {embed_dim}) |> Nx.backend_copy(Nx.BinaryBackend)
lm_b  = Nx.broadcast(Nx.tensor(0.0, type: :f32), {vocab_size}) |> Nx.backend_copy(Nx.BinaryBackend)

# Params tuple — order must match loss_fn/adam_step destructuring exactly:
# {embed, w_q, w_k, w_v, w_o, w_ff1, w_ff2, lm_w, lm_b, g1, b1, g2, b2}
genesis_weights = {embed, w_q, w_k, w_v, w_o, w_ff1, w_ff2, lm_w, lm_b, ones, zeros, ones, zeros}

File.write!("v14_genesis.bin", :erlang.term_to_binary(genesis_weights))
```

