## inline test

```elixir
defmodule DLM.Probe do
  import Nx.Defn

  # --- 🛠️ Added `mask` as a required parameter here ---
  defn get_next_token_probs(ids, params, pos_emb, mask) do
    {e, a1, f1, a2, f2, lmw, lmb, g1, b1, g2, b2} = params
    {_, len} = Nx.shape(ids)

    x = Nx.add(Nx.take(e, ids), Nx.slice(pos_emb, [0, 0], [len, 256]))
    
    # Pass the pre-computed mask straight into the Transformer block
    x = DLM.Transformer.block(x, a1, f1, a2, f2, g1, b1, g2, b2, mask)

    # Grab the hidden state of the VERY LAST token
    last_token_hidden = x[0][-1]
    
    # Calculate logits
    logits = Nx.add(Nx.dot(last_token_hidden, lmw), lmb)
    
    # Atomic Stable Softmax
    max_logits = Nx.reduce_max(logits, axes: [-1], keep_axes: true)
    stable_logits = Nx.subtract(logits, max_logits)
    exp_logits = Nx.exp(stable_logits)
    sum_exp = Nx.sum(exp_logits, axes: [-1], keep_axes: true)
    
    Nx.divide(exp_logits, sum_exp)
  end

  def run(checkpoint_path, pos_emb, prompts) do
    IO.puts("\n🔬 --- V13 PROBE TEST ---")

    params = File.read!(checkpoint_path) 
             |> :erlang.binary_to_term() 
             |> Tuple.to_list() 
             |> Enum.map(&Nx.backend_copy/1) 
             |> List.to_tuple()

    Enum.each(prompts, fn prompt_str ->
      ids = prompt_str |> to_charlist() |> Nx.tensor() |> Nx.reshape({1, :auto})
      
      # --- 🛠️ Generate the mask OUTSIDE the defn ---
      {_, len} = Nx.shape(ids)
      mask = DLM.Mask.causal(len) |> Nx.backend_copy()
      
      # Pass the mask into the XLA graph
      probs = get_next_token_probs(ids, params, pos_emb, mask) |> Nx.to_flat_list()

      top_chars =
        probs
        |> Enum.with_index()
        |> Enum.sort_by(fn {prob, _idx} -> prob end, :desc)
        |> Enum.take(3)
        |> Enum.map(fn {prob, idx} ->
          char_display = case <<idx::utf8>> do
            "\n" -> "\\n"
            " " -> "[SPACE]"
            c -> c
          end
          "#{char_display} (#{Float.round(prob * 100, 2)}%)"
        end)
        |> Enum.join("  |  ")

      IO.puts("Prompt: '#{prompt_str}'\n  ↳ #{top_chars}\n")
    end)
  end
end
```

