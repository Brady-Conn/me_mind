```elixir
# --- THE STANDALONE MANUAL FLUSH ---
IO.puts("🕵️‍♂️ Janitor entering the room...")

# 1. Clear the main training process
:erlang.garbage_collect()

# 2. Clear the binary references specifically
:erlang.garbage_collect(:erlang.whereis(:user)) 

# 3. Request a global sweep
:erlang.check_old_code(DLM.Transformer) # Triggers a check on compiled modules

IO.puts("✅ Janitor finished. Check the RAM meter in the sidebar!")
