## Checkpoint restore

```elixir
# --- THE AUTO-RESTORER ---
checkpoint_path = "v13_full_state.bin"
genesis_path = "v13_genesis.bin"

{params, m_state, v_state, start_step} = if File.exists?(checkpoint_path) do
  IO.puts("♻️ Resuming from Full State Checkpoint...")
  
  # Load the {p, m, v, step} quadruple
  {p, m, v, step} = File.read!(checkpoint_path) |> :erlang.binary_to_term()
  
  # Move everything back to the CPU backend
  p = p |> Tuple.to_list() |> Enum.map(&Nx.backend_copy/1) |> List.to_tuple()
  m = m |> Tuple.to_list() |> Enum.map(&Nx.backend_copy/1) |> List.to_tuple()
  v = v |> Tuple.to_list() |> Enum.map(&Nx.backend_copy/1) |> List.to_tuple()
  
  {p, m, v, step}
else
  IO.puts("🌱 No full checkpoint found. Loading Genesis Weights...")
  
  # Fallback to loading just the weights and initializing optimizer to zero
  p = File.read!(genesis_path) 
      |> :erlang.binary_to_term() 
      |> Tuple.to_list() 
      |> Enum.map(&Nx.backend_copy/1) 
      |> List.to_tuple()

  zero_like = fn t -> Nx.broadcast(Nx.tensor(0.0), Nx.shape(t)) |> Nx.backend_copy() end
  m = p |> Tuple.to_list() |> Enum.map(zero_like) |> List.to_tuple()
  v = m

  {p, m, v, 1}
end

IO.puts("📍 Starting at Step: #{start_step}")
```

