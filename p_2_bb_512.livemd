## SSM

```elixir
defmodule DLM.SvdSSM do
  import Nx.Defn

  defn l2_normalize(tensor) do
    # Calculate Euclidean norm across the last axis natively
    norm = Nx.sqrt(Nx.sum(Nx.pow(tensor, 2), axes: [-1], keep_axes: true))
    # Divide by norm with a tiny epsilon to prevent divide-by-zero
    Nx.divide(tensor, Nx.add(norm, 1.0e-6))
  end

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn gelu(x) do
    cdf = Nx.multiply(
      Nx.tensor(0.7978845608, type: :f32),
      Nx.add(x, Nx.multiply(Nx.tensor(0.044715, type: :f32), Nx.pow(x, 3)))
    )
    Nx.multiply(Nx.multiply(Nx.tensor(0.5, type: :f32), x), Nx.add(Nx.tensor(1.0, type: :f32), Nx.tanh(cdf)))
  end

  defn amplify_svd(x, u, v) do
    x_active = gelu(x)
    hidden = Nx.dot(x_active, u)
    hn = rms_norm(hidden)
    Nx.dot(hn, v)
  end

  defn apply_svd(x, u, v) do
    hidden = Nx.dot(x, u)
    bound = Nx.tanh(hidden)
    Nx.dot(bound, v)
  end

  defn softplus(x) do
    Nx.log1p(Nx.exp(x))
  end

  defn forward_step(xt_idx, h_prev, params) do

    {em, eq, er, au, av, bu, bv, cu, cv, du, dv, eu, ev} = params

    x_t = Nx.take(em, xt_idx)

    # svd projections
    a_proj = amplify_svd(h_prev, au, av)
    b_proj = amplify_svd(x_t, bu, bv)
    g_proj = apply_svd(x_t, du, dv)
    
    # Discretization
    b_bar = Nx.multiply(g_proj, b_proj) 
    a_bar = Nx.multiply(a_proj, g_proj)
    
    # Geometric Adaptation
    a_norm_sq = Nx.add(Nx.sum(Nx.pow(a_proj, 2), axes: [-1], keep_axes: true), 1.0e-6)
    a_unit = Nx.divide(a_proj, Nx.sqrt(a_norm_sq))
    
    a_ol = Nx.sum(Nx.multiply(b_bar, a_unit), axes: [-1], keep_axes: true)
    a_ov = Nx.multiply(a_ol, a_unit)
    b_x = Nx.subtract(b_bar, a_ov)

    # Strictly Orthogonal State Update
    h_new = Nx.add(Nx.multiply(a_bar, a_proj), b_x)

    # Latent projections
    h_latent = amplify_svd(h_new, cu, cv)
    e_latent = amplify_svd(x_t, eu, ev)
    
    logits_t1 = Nx.dot(Nx.add(h_latent, e_latent), eq)
    logits_t2 = Nx.dot(Nx.add(h_latent, e_latent), er)
    
    {logits_t1, logits_t2, h_new}
  end
end
