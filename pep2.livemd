## Train

```elixir
defmodule DLM.Phase2Trainer do
  import Nx.Defn

  defn compute_ssm_loss(predicted_latents, targets, frozen_embeds) do
    # 1. Look up the PERFECT coordinates from your Phase 1 map
    true_coords = Nx.take(frozen_embeds, Nx.flatten(targets))
                  |> Nx.reshape(Nx.shape(predicted_latents))
                  |> stop_grad()

    # 2. ⚡ THE SWAP: Use Cosine Distance instead of MSE
    DLM.Loss.soft_nn_loss(predicted_latents, true_coords, 0.1)
  end

  defn compute_sequence_loss(input_tokens, target_tokens, h_init, predictor_params, noise_key, noise_scale, frozen_embeds) do
    # 1. Convert discrete integer tokens into 512D continuous coordinates
    # We use Nx.axis_size directly here so we don't accidentally capture tensor dimensions
    input_coords =
      Nx.take(frozen_embeds, Nx.flatten(input_tokens))
      |> Nx.reshape({Nx.axis_size(input_tokens, 0), Nx.axis_size(input_tokens, 1), 512})
      |> stop_grad() 

    # 2. Transpose for the time-major loop (Seq, Batch, Dim)
    inputs_time_first = Nx.transpose(input_coords, axes: [1, 0, 2])
    targets_time_first = Nx.transpose(target_tokens, axes: [1, 0])

    # ⚡ 3. THE FIX: Pass `frozen_embeds` (as `f_embs`) into the while loop state!
    # We also use `Nx.axis_size(inputs, 0)` for the condition to avoid capturing an outer `seq_len` tensor.
    result =
      while {i = 0, total_loss = Nx.tensor(0.0, type: :f32), h = h_init, 
             inputs = inputs_time_first, targets = targets_time_first, p = predictor_params,
             key = noise_key, ns = noise_scale, f_embs = frozen_embeds},
            Nx.less(i, Nx.axis_size(inputs, 0)) do
      
        # ⚡ 4. SAFE SHAPE: Nx.shape() extracts an Elixir integer tuple at compile time!
        {noise, next_key} = Nx.Random.normal(key, 0.0, 1.0, shape: Nx.shape(inputs[0]))
        
        noisy_input = Nx.add(inputs[i], Nx.multiply(noise, ns))
   
        # Physics step
        {final_coord, h_new} = DLM.TinySSM.forward(noisy_input, h, p)
        
        # ⚡ Use the explicitly passed `f_embs` from the loop state
        step_loss = compute_ssm_loss(final_coord, targets[i], f_embs)
        
        # Return all 9 state variables perfectly intact
        {i + 1, Nx.add(total_loss, step_loss), h_new, inputs, targets, p, next_key, ns, f_embs}
      end

    accumulated_loss = elem(result, 1)
    
    Nx.divide(accumulated_loss, Nx.axis_size(inputs_time_first, 0))
  end

  defn compute_grad(params, batch_tokens, h_init, frozen_embeds, noise_key, noise_scale) do
    {_batch_size, full_seq_len} = Nx.shape(batch_tokens)
    seq_len = full_seq_len - 1
    
    input_tokens  = Nx.slice_along_axis(batch_tokens, 0, seq_len, axis: 1)
    target_tokens = Nx.slice_along_axis(batch_tokens, 1, seq_len, axis: 1)
  
    {loss, raw_grads} = value_and_grad(params, fn p ->
      compute_sequence_loss(input_tokens, target_tokens, h_init, p, noise_key, noise_scale, frozen_embeds)
    end)
  
    {g_a, g_bu, g_bv, g_cu, g_cv, g_du, g_dv} = raw_grads
  
    clipped_grads = {
      Nx.clip(g_a,   -1.0, 1.0),
      Nx.clip(g_bu,  -1.0, 1.0),
      Nx.clip(g_bv,  -1.0, 1.0),
      Nx.clip(g_cu,  -1.0, 1.0),
      Nx.clip(g_cv,  -1.0, 1.0),
      Nx.clip(g_du,  -1.0, 1.0),
      Nx.clip(g_dv,  -1.0, 1.0)
    }
  
    {loss, clipped_grads}
  end
end
