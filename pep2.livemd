## Inference

```elixir
defmodule DLM.Inference do
  import Nx.Defn

  # ⚡ 1. The Snap Function
  defn nearest_neighbor(predicted_vector, frozen_embeds) do
    # Normalize the SSM's prediction
    pred_norm = DLM.Loss.l2_normalize(predicted_vector)
    
    # Calculate cosine similarity against ALL 128 characters simultaneously
    # frozen_embeds is {128, 512}, pred_norm is {1, 512}
    similarities = Nx.dot(pred_norm, Nx.transpose(frozen_embeds))
    
    # Return the ASCII integer index of the closest character
    Nx.argmax(similarities, axis: -1) |> Nx.squeeze()
  end

  defn sample_neighbor(predicted_vector, frozen_embeds, key, temperature \\ 0.025) do # ⚡ Drop default temp to match training
    # 1. Normalize and get similarities [-1.0 to 1.0]
    pred_norm = DLM.Loss.l2_normalize(predicted_vector)
    similarities = Nx.dot(pred_norm, Nx.transpose(frozen_embeds)) |> Nx.squeeze()
    
    # ⚡ 2. REMOVED THE 30.0 HACK. Just use the sampling temperature directly.
    # A temp of 0.1 perfectly matches the soft_nn_loss scaling!
    logits = Nx.divide(similarities, Nx.add(temperature, 1.0e-5))

    # 3. Gumbel-Max Trick
    {uniform_noise, next_key} = Nx.Random.uniform(key, 0.0, 1.0, shape: Nx.shape(logits))
    gumbel_noise = Nx.negate(Nx.log(Nx.negate(Nx.log(Nx.add(uniform_noise, 1.0e-7)))))
    
    noisy_logits = Nx.add(logits, gumbel_noise)
    sampled_index = Nx.argmax(noisy_logits)
    
    {sampled_index, next_key}
  end

  # ⚡ 2. The Generation Loop
  def generate(prompt_string, num_tokens_to_generate, p2_params, frozen_embeds) do
    # Setup initial state
    key = Nx.Random.key(42)
    batch_size = 1
    dim = 512
    h = Nx.broadcast(0.0, {batch_size, dim}) |> Nx.as_type(:f32) |> Nx.backend_copy(Nx.default_backend())
    
    # Convert string prompt to a list of ASCII integers
    prompt_tokens = to_charlist(prompt_string)

    # 1. Warm up the SSM with the prompt (Build momentum in the hidden state)
    final_h = Enum.reduce(prompt_tokens, h, fn token, current_h ->
      # Grab the exact coordinate for this character
      coord = Nx.take(frozen_embeds, Nx.tensor([token]))
      
      # Step the physics engine forward
      {_predicted_next, next_h} = DLM.TinySSM.forward(coord, current_h, p2_params)
      next_h
    end)

    # 2. Autoregressive Generation
    # Start with the very last token of the prompt
    last_token = List.last(prompt_tokens)

    Enum.reduce(1..num_tokens_to_generate, {last_token, final_h, key, prompt_tokens}, 
      fn _step, {current_token, current_h, cur_key, output_acc} ->
        
        # Look up coordinate for the current token
        coord = Nx.take(frozen_embeds, Nx.tensor([current_token]))
        
        # Predict the NEXT coordinate
        {predicted_next_coord, next_h} = DLM.TinySSM.forward(coord, current_h, p2_params)
        
        # Snap the messy coordinate to the nearest real character
        {next_token, next_key} = sample_neighbor(predicted_next_coord, frozen_embeds, cur_key)
        next_token_num = Nx.to_number(next_token)
        {next_token_num, next_h, next_key, output_acc ++ [next_token_num]}
    end)
    |> elem(3)
    |> List.to_string()
  end
end
