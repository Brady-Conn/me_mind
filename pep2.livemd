## Physics test

```elixir
defmodule DLM.Phase2_Eval do
  import Nx.Defn

  # Run this on a held-out validation batch (not your training data)
  defn compute_accuracy(input_tokens, target_tokens, h_init, params, frozen_embeds) do
    # 1. Map inputs to continuous space
    input_coords =
      Nx.take(frozen_embeds, Nx.flatten(input_tokens))
      |> Nx.reshape({Nx.axis_size(input_tokens, 0), Nx.axis_size(input_tokens, 1), 512})
    
    inputs_time_first = Nx.transpose(input_coords, axes: [1, 0, 2])
    targets_time_first = Nx.transpose(target_tokens, axes: [1, 0])

    # 2. Run the pure physics engine (No noise injection here!)
    result =
      while {i = 0, correct_top1 = 0.0, total_chars = 0.0,
             h = h_init, inputs = inputs_time_first, targets = targets_time_first, 
             p = params, f_embs = frozen_embeds},
            Nx.less(i, Nx.axis_size(inputs, 0)) do
      
        {pred_coord, h_new} = DLM.TinySSM.forward(inputs[i], h, p)
        
        # 3. Calculate Cosine Similarities against ALL tokens
        pred_norm = DLM.Loss.l2_normalize(pred_coord)
        similarities = Nx.dot(pred_norm, Nx.transpose(f_embs))
        
        # 4. Did the physics engine point closest to the true target?
        predicted_indices = Nx.argmax(similarities, axis: -1)
        true_indices = targets[i]
        
        # Count matches
        matches = Nx.equal(predicted_indices, true_indices) |> Nx.sum()
        
        {i + 1, 
         Nx.add(correct_top1, matches), 
         Nx.add(total_chars, Nx.axis_size(true_indices, 0)), 
         h_new, inputs, targets, p, f_embs}
      end

    total_correct = elem(result, 1)
    total_count = elem(result, 2)
    
    # Return accuracy as a percentage
    Nx.multiply(Nx.divide(total_correct, total_count), 100.0)
  end
end
