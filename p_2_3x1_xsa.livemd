## SSM

```elixir
defmodule DLM.SvdSSM do
  import Nx.Defn

  defn l2_normalize(tensor) do
    # Calculate Euclidean norm across the last axis natively
    norm = Nx.sqrt(Nx.sum(Nx.pow(tensor, 2), axes: [-1], keep_axes: true))
    # Divide by norm with a tiny epsilon to prevent divide-by-zero
    Nx.divide(tensor, Nx.add(norm, 1.0e-6))
  end

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn gelu(x) do
    cdf = Nx.multiply(
      Nx.tensor(0.7978845608, type: :f32),
      Nx.add(x, Nx.multiply(Nx.tensor(0.044715, type: :f32), Nx.pow(x, 3)))
    )
    Nx.multiply(Nx.multiply(Nx.tensor(0.5, type: :f32), x), Nx.add(Nx.tensor(1.0, type: :f32), Nx.tanh(cdf)))
  end

  defn swish(x) do
    Nx.multiply(x, Nx.sigmoid(x))
  end

  defn apply_svd(x, u, v) do
    Nx.dot(x, u) |> Nx.tanh() |> Nx.dot(v)
  end

  defn project_svd(x, u, v) do
    Nx.dot(x, u) |> gelu() |> Nx.dot(v) |> Nx.tanh()
  end

  defn tanh_vd(x, u, v) do
    Nx.dot(x, u) |> gelu() |> Nx.dot(v) |> Nx.tanh()
  end

  defn rms_vd(x, u, v) do
    Nx.dot(x, u) |> gelu() |> Nx.dot(v) |> rms_norm()
  end

  defn swish_vd(x, u, v) do
    Nx.dot(x, u) |> gelu() |> Nx.dot(v) |> swish()
  end

  defn sig_vd(x, u, v) do
    Nx.dot(x, u) |> gelu() |> Nx.dot(v) |> Nx.sigmoid()
  end

  defn softplus(x) do
    Nx.log1p(Nx.exp(x))
  end

  defn softmax(t) do
    max_val = Nx.reduce_max(t, axes: [-1], keep_axes: true)
    safe_t = Nx.subtract(t, max_val)
    exps = Nx.exp(safe_t)
    sum_exps = Nx.sum(exps, axes: [-1], keep_axes: true)
    Nx.divide(exps, Nx.add(sum_exps, 1.0e-8))
  end

  defn forward_slice(x_t, h_prev, params) do
    {_em, eq, er, au, av, bu, bv, cu, cv, du, dv, eu, ev, fu, fv} = params

    a_proj = apply_svd(h_prev, au, av)
    b_proj = apply_svd(x_t, bu, bv)
    
    # 1. The Dynamic Projection Gate
    gate_proj = apply_svd(x_t, du, dv)
    shifted_gate = Nx.subtract(gate_proj, 1.0)
    delta = Nx.max(softplus(shifted_gate), 0.01)
    
    b_bar = Nx.multiply(delta, b_proj) |> rms_norm()
    
    # 2. XSA Geometric Adaptation
    h_norm_sq = Nx.add(Nx.sum(Nx.pow(h_prev, 2), axes: [-1], keep_axes: true), 1.0e-6)
    h_unit = Nx.divide(h_prev, Nx.sqrt(h_norm_sq))
    
    overlap = Nx.sum(Nx.multiply(b_bar, h_unit), axes: [-1], keep_axes: true)
    b_exclusive = Nx.subtract(b_bar, Nx.multiply(overlap, h_unit))
    
    h_new = Nx.add(a_proj, b_exclusive)

    h_latent = apply_svd(h_new, cu, cv)
    e_latent = apply_svd(x_t, eu, ev)

    # 1. The Dynamic Latent Gate
    gate_latent = apply_svd(x_t, fu, fv)
    shifted_latent = Nx.subtract(gate_latent, 1.0)
    theta = Nx.max(softplus(shifted_latent), 0.01)
    
    e_bar = Nx.multiply(theta, e_latent) |> rms_norm()
    
    # 2. XSA Geometric Prediction
    hn_norm_sq = Nx.add(Nx.sum(Nx.pow(h_new, 2), axes: [-1], keep_axes: true), 1.0e-6)
    hn_unit = Nx.divide(h_new, Nx.sqrt(hn_norm_sq))
    
    hn_overlap = Nx.sum(Nx.multiply(e_bar, hn_unit), axes: [-1], keep_axes: true)
    e_exclusive = Nx.subtract(e_bar, Nx.multiply(hn_overlap, hn_unit))

    f_latent = Nx.add(h_latent, e_exclusive)

    logits1 = Nx.dot(f_latent, eq)
    logits2 = Nx.dot(f_latent, er)

    {logits1, logits2, h_new}
  end

  defn forward_step(xt1_idx, h_prev, params) do
    em = elem(params, 0) |> l2_normalize()
    xt1 = Nx.take(em, xt1_idx)
    {l1, l2, h1} = forward_slice(xt1, h_prev, params)
    xt3 = softmax(l1) |> Nx.dot(em)
    {l3, l4, _h2} = forward_slice(xt3, h1, params)
    
    {l1, l2, l3, l4, h1}
  end
end
