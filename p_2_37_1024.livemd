```elixir
defmodule DLM.PhysicsGenesis do
  import Nx.Defn

  @dim 1024
  @rank 256

  defn ignite(key) do

    # ⚡ UPGRADE 1: Xavier/Glorot Initialization for all SVD Bottlenecks
    std_dev1024 = Nx.divide(1.0, Nx.sqrt(1024))
    std_dev256 = Nx.divide(1.0, Nx.sqrt(256))
    
    # a_diag: Friction/Inertia (1D Vector, fan-in doesn't apply)
    {au, k1} = Nx.Random.normal(key, 0.0, std_dev1024, shape: {@dim, @rank})
    {av, k2} = Nx.Random.normal(k1, 0.0, std_dev256, shape: {@rank, @dim})
    
    # b: Input Force Matrices
    {bu, k3} = Nx.Random.normal(k2, 0.0, std_dev1024, shape: {@dim, @rank})
    {bv, k4} = Nx.Random.normal(k3, 0.0, std_dev256, shape: {@rank, @dim}) 
    
    # c: Output Velocity Matrices
    {cu, k5} = Nx.Random.normal(k4, 0.0, std_dev1024, shape: {@dim, @rank})
    {cv, k6} = Nx.Random.normal(k5, 0.0, std_dev256, shape: {@rank, @dim})

    # d: Dynamic Gating Matrices
    {du, k7} = Nx.Random.normal(k6, 0.0, std_dev1024, shape: {@dim, @rank})
    {dv, k8} = Nx.Random.normal(k7, 0.0, std_dev256, shape: {@rank, @dim})

    # Vocab Probes (Compressing 1024D Void to 256D Vocab)
    {vw, k9} = Nx.Random.normal(k8, 0.0, std_dev1024, shape: {@dim, @rank})
    {rw, k10} = Nx.Random.normal(k9, 0.0, std_dev1024, shape: {@dim, @rank})

    # Encoder
    {em, k11} = Nx.Random.normal(k10, 0.0, 0.1, shape: {@rank, @dim})
    
    vb = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    rb = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)

    {{em, au, av, bu, bv, cu, cv, du, dv, vw, rw, vb, rb}, k11}
  end
end
