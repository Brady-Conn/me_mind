## SSM

```elixir
defmodule DLM.SvdSSM do
  import Nx.Defn

  defn gelu(x) do
    cdf = Nx.multiply(
      Nx.tensor(0.7978845608, type: :f32),
      Nx.add(x, Nx.multiply(Nx.tensor(0.044715, type: :f32), Nx.pow(x, 3)))
    )
    Nx.multiply(Nx.multiply(Nx.tensor(0.5, type: :f32), x), Nx.add(Nx.tensor(1.0, type: :f32), Nx.tanh(cdf)))
  end

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn apply_svd(x, u, v) do
    hidden = Nx.dot(x, u)
    activated = Nx.tanh(hidden) # ⚡ Let tanh handle the bounding
    Nx.dot(activated, v)
  end

  defn softplus(x) do
    Nx.select(x > 20.0, x, Nx.log1p(Nx.exp(x)))
  end

  defn forward_step(xt_idx, h_prev, params) do
    {em, au, av, bu, bv, cu, cv, du, dv, vw, vb, rb, rw} = params
    x_t = Nx.take(em, xt_idx)

    # svd projections
    g_proj = apply_svd(x_t, du, dv)
    h_proj = apply_svd(h_prev, au, av)
    b_proj = apply_svd(x_t, bu, bv)

    # Discretization
    b_bar = Nx.multiply(g_proj, b_proj) |> rms_norm()
    h_bar = Nx.multiply(h_proj, g_proj) |> rms_norm()

    # Geometric Adaptation
    h_norm_sq = Nx.add(Nx.sum(Nx.pow(h_proj, 2), axes: [-1], keep_axes: true), 1.0e-6)
    h_unit = Nx.divide(h_proj, Nx.sqrt(h_norm_sq))

    overlap = Nx.sum(Nx.multiply(b_bar, h_unit), axes: [-1], keep_axes: true)
    h_over = Nx.multiply(overlap, h_unit)
    b_exclusive = Nx.subtract(b_bar, h_over)

    # Strictly Orthogonal State Update
    h_new = Nx.add(Nx.multiply(h_bar, h_proj), b_exclusive)

    h_latent = apply_svd(h_new, cu, cv)
    logits_fwd = Nx.add(Nx.multiply(h_latent, vw), vb)
    logits_retro = Nx.add(Nx.multiply(h_latent, rw), rb)

    {logits_fwd, logits_retro, h_new}
  end
end
