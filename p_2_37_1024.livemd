```elixir
defmodule DLM.SvdOptimizer do
  import Nx.Defn
  
  defn update(params, grads, step, lr) do
    {em, au, av, bu, bv, cu, cv, du, dv, vw, rw, vb, rb} = params
    {gem, gau, gav, gbu, gbv, gcu, gcv, gdu, gdv, gvw, grw, gvb, grb} = grads

    new_step = Nx.add(step, 1)
    
    # ⚡ 2. SinkGD (2D Transformation Matrices)
    em_new = DLM.SparseSinkGD.sinkgd_step(em, gem, lr)
    au_new = DLM.SparseSinkGD.sinkgd_step(au, gau, lr)
    av_new = DLM.SparseSinkGD.sinkgd_step(av, gav, lr)
    bu_new = DLM.SparseSinkGD.sinkgd_step(bu, gbu, lr)
    bv_new = DLM.SparseSinkGD.sinkgd_step(bv, gbv, lr)
    cu_new = DLM.SparseSinkGD.sinkgd_step(cu, gcu, lr)
    cv_new = DLM.SparseSinkGD.sinkgd_step(cv, gcv, lr)
    du_new = DLM.SparseSinkGD.sinkgd_step(du, gdu, lr)
    dv_new = DLM.SparseSinkGD.sinkgd_step(dv, gdv, lr)
    vw_new = DLM.SparseSinkGD.sinkgd_step(vw, gvw, lr)
    rw_new = DLM.SparseSinkGD.sinkgd_step(rw, grw, lr)
    vb_new = DLM.SparseSinkGD.sinkgd_step(vb, gvb, lr)
    rb_new = DLM.SparseSinkGD.sinkgd_step(rb, grb, lr)
    
    new_params = {em_new, au_new, av_new, bu_new, bv_new, cu_new, cv_new, du_new, dv_new, vw_new, rw_new, vb_new, rb_new}
    
    {new_params, new_step}
  end
end
