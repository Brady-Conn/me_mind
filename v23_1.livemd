{_emb, a1, a2, _rest} = checkpoint.params |> Tuple.to_list() |> then(fn [e,a1,a2|rest] -> {e,a1,a2,rest} end)
IO.puts("a_diag1 mean: #{a1 |> Nx.mean() |> Nx.to_number()}")
IO.puts("a_diag1 std:  #{a1 |> Nx.subtract(Nx.mean(a1)) |> Nx.pow(2) |> Nx.mean() |> Nx.sqrt() |> Nx.to_number()}")
IO.puts("a_diag2 mean: #{a2 |> Nx.mean() |> Nx.to_number()}")
IO.puts("a_diag2 std:  #{a2 |> Nx.subtract(Nx.mean(a2)) |> Nx.pow(2) |> Nx.mean() |> Nx.sqrt() |> Nx.to_number()}")


