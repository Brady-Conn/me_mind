```elixir
defmodule DLM.V23Dreamer do
  import Nx.Defn

  # ⚡ The sampling logic: Temperature + Logits -> Probabilities
  defn sample_next_token(logits, temperature) do
    # Take the logits for the very last token in the sequence
    last_logits = logits[[-1]]
    
    # Apply temperature (Higher = more creative, Lower = more strict)
    scaled_logits = Nx.divide(last_logits, temperature)
    
    # Convert to probabilities
    max_logits = Nx.reduce_max(scaled_logits, axes: [-1], keep_axes: true)
    safe_logits = Nx.subtract(scaled_logits, max_logits)
    probs = Nx.exp(safe_logits) |> Nx.divide(Nx.sum(Nx.exp(safe_logits), axes: [-1]))
    
    # Argmax for deterministic, or could use categorical sampling
    Nx.argmax(probs)
  end

  # ⚡ The recursive dreaming loop
  def generate(params, pos_emb, seed_tokens, vocab_map, max_new_tokens \\ 50, temperature \\ 0.8) do
    # vocab_map should be a Map of integer -> string character
    
    Enum.reduce(1..max_new_tokens, seed_tokens, fn _step, current_sequence ->
      # ⚡ CRITICAL: The Rolling Window
      # We must slice the sequence to a maximum of 128 tokens to fit V23's context
      windowed_sequence = Enum.take(current_sequence, -128)
      
      # Convert to tensor and add batch dimension
      input_tensor = Nx.tensor([windowed_sequence], type: :s32)
      
      # Slice the positional embeddings to match the current input length
      seq_len = length(windowed_sequence)
      sliced_pos = Nx.slice_along_axis(pos_emb, 0, seq_len, axis: 0)

      # Run the V23 Forward Pass
      logits = DLM.UniversalSSM.forward(input_tensor, params, sliced_pos)
      
      # We need to squeeze the batch dimension before sampling
      logits_squeezed = Nx.squeeze(logits, axes: [0])
      
      # Sample the next token
      next_token_tensor = sample_next_token(logits_squeezed, Nx.tensor(temperature, type: :f32))
      next_token = next_token_tensor |> Nx.to_number()
      
      # Print the character to the terminal as it dreams
      IO.write(vocab_map[next_token])
      
      # Append and continue
      current_sequence ++ [next_token]
    end)
    
    IO.puts("\\n✨ Dream Complete.")
  end
end
```

