## Train

```elixir
defmodule DLM.V23Trainer do
  import Nx.Defn

  def grad_norms(grads) do
    names = ~w[embed a_diag b_u b_v c_u c_v d_u d_v mx_u1 mx_v1 mx_u2 mx_v2 lm_w lm_b]
    grads
    |> Tuple.to_list()
    |> Enum.zip(names)
    |> Enum.map(fn {g, name} ->
      norm = g |> Nx.pow(2) |> Nx.sum() |> Nx.sqrt() |> Nx.to_number()
      {name, Float.round(norm, 4)}
    end)
  end

  defn log_softmax(logits) do
    max_logits = Nx.reduce_max(logits, axes: [-1], keep_axes: true)
    safe_logits = logits - max_logits
    sum_exp = Nx.sum(Nx.exp(safe_logits), axes: [-1], keep_axes: true)
    safe_logits - Nx.log(sum_exp)
  end

  defn compute_loss(preds_sliced, targets) do
    log_probs = log_softmax(preds_sliced)
    target_probs = Nx.take_along_axis(log_probs, Nx.new_axis(targets, -1), axis: -1)
    target_probs = Nx.squeeze(target_probs, axes: [-1])
    mask = Nx.not_equal(targets, 0) |> Nx.as_type(:f32)
  
    total_tokens = Nx.sum(mask)
    min_tokens   = Nx.tensor(204.0, type: :f32)
    safe_denom   = Nx.max(total_tokens, min_tokens)
  
    masked_loss = -target_probs * mask
    Nx.sum(masked_loss) / safe_denom
  end

  # ⚡ THE UPGRADE: Stochastic Masking (Variable Ratio Reinforcement)
  # mask_prob = 0.10 means 10% of gradients are randomly dropped
  defn sanitize_and_mask(g, key, mask_prob \\ -1.0) do
    # 1. Catch NaNs (The Titanium Shield)
    bad_mask = Nx.logical_or(Nx.is_nan(g), Nx.is_infinity(g))
    safe_g = Nx.select(bad_mask, 0.0, g)

    # 2. Generate random tensor of the exact same shape
    {rand_tensor, next_key} = Nx.Random.uniform(key, shape: Nx.shape(safe_g))
    
    # 3. Create a mask: 1.0 if rand > 0.10, else 0.0
    keep_mask = Nx.greater(rand_tensor, mask_prob)

    # 4. Apply the mask
    masked_g = Nx.select(keep_mask, safe_g, 0.0)
    
    {masked_g, next_key}
  end
  
  defn compute_grad(params, pos_emb, batch, key) do
    {loss, raw_grads} = value_and_grad(params, fn p ->
      batch_s32 = Nx.as_type(batch, :s32)
      preds = DLM.UniversalSSM.forward(batch_s32, p, pos_emb)
      
      preds_sliced = Nx.slice_along_axis(preds, 0, 127, axis: 1)
      targets = Nx.slice_along_axis(batch_s32, 1, 127, axis: 1)
      compute_loss(preds_sliced, targets)
    end)

    {rg0, rg1, rg2, rg3, rg4, rg5, rg6, rg7, rg8, rg9, rg10, rg11, rg12, rg13} = raw_grads

    # ⚡ Threading the PRNG Key through the network
    {g0,  k1}  = sanitize_and_mask(rg0,  key)
    {g1,  k2}  = sanitize_and_mask(rg1,  k1)
    {g2,  k3}  = sanitize_and_mask(rg2,  k2)
    {g3,  k4}  = sanitize_and_mask(rg3,  k3)
    {g4,  k5}  = sanitize_and_mask(rg4,  k4)
    {g5,  k6}  = sanitize_and_mask(rg5,  k5)
    {g6,  k7}  = sanitize_and_mask(rg6,  k6)
    {g7,  k8}  = sanitize_and_mask(rg7,  k7)
    {g8,  k9}  = sanitize_and_mask(rg8,  k8)
    {g9,  k10} = sanitize_and_mask(rg9,  k9)
    {g10, k11} = sanitize_and_mask(rg10, k10)
    {g11, k12} = sanitize_and_mask(rg11, k11)
    {g12, k13} = sanitize_and_mask(rg12, k12)
    {g13, k14} = sanitize_and_mask(rg13, k13)

    global_norm =
      Nx.sum(Nx.pow(g0, 2))
      |> Nx.add(Nx.sum(Nx.pow(g1, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g2, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g3, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g4, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g5, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g6, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g7, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g8, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g9, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g10, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g11, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g12, 2)))
      |> Nx.add(Nx.sum(Nx.pow(g13, 2)))
      |> Nx.sqrt()

    max_norm = 0.33
    scale = Nx.min(1.0, max_norm / (global_norm + 1.0e-6))

    clipped_grads = {
      g0  * scale, g1  * scale, g2  * scale,
      g3  * scale, g4  * scale, g5  * scale,
      g6  * scale, g7  * scale, g8  * scale,
      g9  * scale, g10 * scale, g11 * scale,
      g12 * scale, g13 * scale
    }

    # Return the new key so the loop can use it on the next batch!
    {loss, clipped_grads, k14}
  end
end
```

