```elixir
defmodule DLM.SvdOptimizer do
  import Nx.Defn

  defn update(params, grads, ms, vs, step, lr) do
    {a1, a2, ab, b1, b2, bb, c1, c2, cb, d1, d2, db} = params   
    {ga1, ga2, gab, gb1, gb2, gbb, gc1, gc2, gcb, gd1, gd2, gdb} = grads
    {ma1, ma2, mab, mb1, mb2, mbb, mc1, mc2, mcb, md1, md2, mdb} = ms
    {va1, va2, vab, vb1, vb2, vbb, vc1, vc2, vcb, vd1, vd2, vdb} = vs
    
    new_step = Nx.add(step, 1.0)

    # optimizer update step
    {a1_new, a1_nm, a1_nv} = DLM.AdamOptimizer.adam_update(a1, ga1, ma1, va1, new_step, lr)
    {a2_new, a2_nm, a2_nv} = DLM.AdamOptimizer.adam_update(a2, ga2, ma2, va2, new_step, lr)
    {b1_new, b1_nm, b1_nv} = DLM.AdamOptimizer.adam_update(b1, gb1, mb1, vb1, new_step, lr)
    {b2_new, b2_nm, b2_nv} = DLM.AdamOptimizer.adam_update(b2, gb2, mb2, vb2, new_step, lr)
    {c1_new, c1_nm, c1_nv} = DLM.AdamOptimizer.adam_update(c1, gc1, mc1, vc1, new_step, lr)
    {c2_new, c2_nm, c2_nv} = DLM.AdamOptimizer.adam_update(c2, gc2, mc2, vc2, new_step, lr)
    {d1_new, d1_nm, d1_nv} = DLM.AdamOptimizer.adam_update(d1, gd1, md1, vd1, new_step, lr)
    {d2_new, d2_nm, d2_nv} = DLM.AdamOptimizer.adam_update(d2, gd2, md2, vd2, new_step, lr)
    {ab_new, ab_nm, ab_nv} = DLM.AdamOptimizer.adam_update(ab, gab, mab, vab, new_step, lr)
    {bb_new, bb_nm, bb_nv} = DLM.AdamOptimizer.adam_update(bb, gbb, mbb, vbb, new_step, lr)
    {cb_new, cb_nm, cb_nv} = DLM.AdamOptimizer.adam_update(cb, gcb, mcb, vcb, new_step, lr)
    {db_new, db_nm, db_nv} = DLM.AdamOptimizer.adam_update(db, gdb, mdb, vdb, new_step, lr)
    
    new_params = {a1_new, a2_new, ab_new, b1_new, b2_new, bb_new,
                  c1_new, c2_new, cb_new, d1_new, d2_new, db_new}

    nm = {a1_nm, a2_nm, ab_nm, b1_nm, b2_nm, bb_nm, c1_nm, c2_nm, cb_nm, d1_nm, d2_nm, db_nm}

    nv = {a1_nv, a2_nv, ab_nv, b1_nv, b2_nv, bb_nv, c1_nv, c2_nv, cb_nv, d1_nv, d2_nv, db_nv}

    {new_params, nm, nv, new_step}
  end
end
