```elixir
defmodule DLM.SvdOptimizer do
  import Nx.Defn

  # Adaptive Decay Function
  defn adaptive_decay(old_w, new_w, cg_w, lr) do
    # 1. Norms (using the CLIPPED gradients)
    w_norm = Nx.add(Nx.LinAlg.norm(old_w), 1.0e-8)
    g_norm = Nx.add(Nx.LinAlg.norm(cg_w), 1.0e-8)
    
    # 2. LARS-style adaptation: w_norm / g_norm
    dynamic_scale = Nx.divide(w_norm, g_norm) |> Nx.clip(0.01, 10.0)
    
    # 3. Apply
    tailored_wd = Nx.multiply(0.01, dynamic_scale)
    penalty = Nx.multiply(old_w, Nx.multiply(lr, tailored_wd))
    
    Nx.subtract(new_w, penalty)
  end

  defn update(params, grads, step, lr) do
    {em, au, av, bu, bv, cu, cv, du, dv} = params
    {gem, gau, gav, gbu, gbv, gcu, gcv, gdu, gdv} = grads

    new_step = Nx.add(step, 1)

    # optimizer update step
    em_new = DLM.OptimizerFunctions.sink_step(em, gem, lr)
    au_new = DLM.OptimizerFunctions.sink_step(au, gau, lr)
    av_new = DLM.OptimizerFunctions.muon_step(av, gav, lr)
    bu_new = DLM.OptimizerFunctions.sink_step(bu, gbu, lr)
    bv_new = DLM.OptimizerFunctions.muon_step(bv, gbv, lr)
    cu_new = DLM.OptimizerFunctions.sink_step(cu, gcu, lr)
    cv_new = DLM.OptimizerFunctions.muon_step(cv, gcv, lr)
    du_new = DLM.OptimizerFunctions.sink_step(du, gdu, lr)
    dv_new = DLM.OptimizerFunctions.muon_step(dv, gdv, lr)
    
    new_params = {em_new, au_new, av_new, 
                  bu_new, bv_new, cu_new, cv_new,
                  du_new, dv_new}

    {new_params, new_step}
  end
end
