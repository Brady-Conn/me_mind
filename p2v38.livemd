```elixir
defmodule DLM.HybridMuon7 do
  import Nx.Defn

  # ⚡ The Norm Limiter
  defn limit_norm(tensor, max_norm \\ 50.0) do
    # Calculate current Frobenius norm
    current_norm = Nx.sqrt(Nx.sum(Nx.pow(tensor, 2)))
    
    # If current_norm > max_norm, scale down. Otherwise, scale = 1.0
    scale_factor = Nx.select(
      current_norm > max_norm,
      Nx.divide(max_norm, Nx.add(current_norm, 1.0e-8)),
      1.0
    )
    
    Nx.multiply(tensor, scale_factor)
  end

  # -------------------------------------------------------------------------
  # AdamW (For 1D Friction/Inertia vectors)
  # -------------------------------------------------------------------------
  defn adam_step(p, g, m, v, step, lr) do
    beta1 = 0.9
    beta2 = 0.999
    flat_decay = 1.0e-4

    m_new = Nx.add(Nx.multiply(beta1, m), Nx.multiply(1.0 - beta1, g))
    v_new = Nx.add(Nx.multiply(beta2, v), Nx.multiply(1.0 - beta2, Nx.pow(g, 2)))

    m_hat = Nx.divide(m_new, Nx.subtract(1.0, Nx.pow(beta1, step)))
    v_hat = Nx.divide(v_new, Nx.subtract(1.0, Nx.pow(beta2, step)))

    update_val = Nx.multiply(lr, Nx.divide(m_hat, Nx.add(Nx.sqrt(v_hat), 1.0e-8)))

    p_decayed = Nx.subtract(p, Nx.multiply(flat_decay, p))
    p_new = Nx.subtract(p_decayed, update_val)

    # ⚡ Apply the hard ceiling!
    p_clipped = limit_norm(p_new, 50.0)

    {p_clipped, m_new, v_new}
  end

  # -------------------------------------------------------------------------
  # Muon Orthogonalization (Newton-Schulz Iteration)
  # -------------------------------------------------------------------------
  defn newton_schulz(g) do
    # 1. Normalize the gradient matrix to stabilize the iteration
    norm = Nx.sqrt(Nx.sum(Nx.pow(g, 2)))
    x_init = Nx.divide(g, Nx.add(norm, 1.0e-8))

    # 2. Run 5 loops of: X = 1.5*X - 0.5*X*(X^T*X)
    {x_final, _} =
      while {x = x_init, i = 0}, Nx.less(i, 5) do
        x_t = Nx.transpose(x)
        x_t_x = Nx.dot(x_t, x)
        term = Nx.dot(x, x_t_x)
        
        x_next = Nx.subtract(Nx.multiply(1.5, x), Nx.multiply(0.5, term))
        {x_next, i + 1}
      end
      
    x_final
  end

  # -------------------------------------------------------------------------
  # Muon Step (For 2D Transformation Matrices)
  # -------------------------------------------------------------------------
  defn muon_step(p, g, m, v, lr, max_norm \\ 50.0) do
    beta1 = 0.95
    new_m = beta1 * m + (1.0 - beta1) * g
    ortho_update = newton_schulz(new_m)
    
    r = Nx.axis_size(p, 0)
    c = Nx.axis_size(p, 1)
    scale = Nx.divide(Nx.max(r, c), 5.0) |> Nx.as_type(:f32)
    
    p_new = p - lr * scale * ortho_update
    
    # Clamp norm after update
    current_norm = Nx.sqrt(Nx.sum(Nx.pow(p_new, 2)))
    p_clipped = Nx.select(
      current_norm > max_norm,
      p_new * (max_norm / (current_norm + 1.0e-8)),
      p_new
    )
    {p_clipped, new_m, v}
  end

  # -------------------------------------------------------------------------
  # The 7-Parameter Router
  # -------------------------------------------------------------------------
  # ⚡ The 9-Parameter Strategic Router
  # defn update(params, grads, ms, vs, step, lr) do
  #   {a, bu, bv, cu, cv, du, dv, vw, vb} = params
  #   {ga, gbu, gbv, gcu, gcv, gdu, gdv, gvw, gvb} = grads
  #   {ma, mbu, mbv, mcu, mcv, mdu, mdv, mvw, mvb} = ms
  #   {va, vbu, vbv, vcu, vcv, vdu, vdv, vvw, vvb} = vs

  #   new_step = Nx.add(step, 1)

  #   # ⚡ 1. The "Mouth" & Friction (AdamW)
  #   # AdamW allows flexible magnitude scaling for the CE Logits
  #   {a_new, ma_new, va_new} = adam_step(a, ga, ma, va, new_step, lr)
  #   {vw_new, mvw_new, vvw_new} = adam_step(vw, gvw, mvw, vvw, new_step, lr)
  #   {vb_new, mvb_new, vvb_new} = adam_step(vb, gvb, mvb, vvb, new_step, lr)
    
  #   # ⚡ 2. The "Brain" (Muon)
  #   # Muon strictly enforces orthogonal, isometric rotations for the 512D physics
  #   {bu_new, mbu_new, vbu_new} = muon_step(bu, gbu, mbu, vbu, lr)
  #   {bv_new, mbv_new, vbv_new} = muon_step(bv, gbv, mbv, vbv, lr)
  #   {cu_new, mcu_new, vcu_new} = muon_step(cu, gcu, mcu, vcu, lr)
  #   {cv_new, mcv_new, vcv_new} = muon_step(cv, gcv, mcv, vcv, lr)
  #   {du_new, mdu_new, vdu_new} = muon_step(du, gdu, mdu, vdu, lr)
  #   {dv_new, mdv_new, vdv_new} = muon_step(dv, gdv, mdv, vdv, lr)

  #   new_params = {a_new, bu_new, bv_new, cu_new, cv_new, du_new, dv_new, vw_new, vb_new}
  #   new_ms = {ma_new, mbu_new, mbv_new, mcu_new, mcv_new, mdu_new, mdv_new, mvw_new, mvb_new}
  #   new_vs = {va_new, vbu_new, vbv_new, vcu_new, vcv_new, vdu_new, vdv_new, vvw_new, vvb_new}
    
  #   {new_params, new_ms, new_vs, new_step}
  # end
  
  defn update(params, grads, ms, vs, step, lr) do
    {a, bu, bv, cu, cv, du, dv, vw, vb} = params
    {ga, gbu, gbv, gcu, gcv, gdu, gdv, gvw, gvb} = grads
    {ma, mbu, mbv, mcu, mcv, mdu, mdv, mvw, mvb} = ms
    {va, vbu, vbv, vcu, vcv, vdu, vdv, vvw, vvb} = vs

    new_step = Nx.add(step, 1)

    # ⚡ Use AdamW for EVERYTHING to establish a stable baseline
    {a_new, ma_new, va_new} = adam_step(a, ga, ma, va, new_step, lr)
    
    {bu_new, mbu_new, vbu_new} = adam_step(bu, gbu, mbu, vbu, new_step, lr)
    {bv_new, mbv_new, vbv_new} = adam_step(bv, gbv, mbv, vbv, new_step, lr)
    {cu_new, mcu_new, vcu_new} = adam_step(cu, gcu, mcu, vcu, new_step, lr)
    {cv_new, mcv_new, vcv_new} = adam_step(cv, gcv, mcv, vcv, new_step, lr)
    {du_new, mdu_new, vdu_new} = adam_step(du, gdu, mdu, vdu, new_step, lr)
    {dv_new, mdv_new, vdv_new} = adam_step(dv, gdv, mdv, vdv, new_step, lr)
    {vw_new, mvw_new, vvw_new} = adam_step(vw, gvw, mvw, vvw, new_step, lr)
    {vb_new, mvb_new, vvb_new} = adam_step(vb, gvb, mvb, vvb, new_step, lr)

    new_params = {a_new, bu_new, bv_new, cu_new, cv_new, du_new, dv_new, vw_new, vb_new}
    new_ms = {ma_new, mbu_new, mbv_new, mcu_new, mcv_new, mdu_new, mdv_new, mvw_new, mvb_new}
    new_vs = {va_new, vbu_new, vbv_new, vcu_new, vcv_new, vdu_new, vdv_new, vvw_new, vvb_new}
    
    {new_params, new_ms, new_vs, new_step}
  end
end
