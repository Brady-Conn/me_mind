## BLiMP Test

```elixir
defmodule DLM.Phase2_Eval do
  import Nx.Defn

  defn compute_sentence_loss(input_tokens, target_tokens, h_init, params, frozen_map) do
    seq_len = Nx.axis_size(input_tokens, 1)
  
    # 1. Inputs still need to be mapped to the 512D continuous space
    input_coords =
      Nx.take(frozen_map, Nx.flatten(input_tokens))
      |> Nx.reshape({1, seq_len, 512})
  
    in_t = Nx.transpose(input_coords, axes: [1, 0, 2])
  
    # ⚡ 2. THE FIX: Keep targets as raw integers for Cross-Entropy! 
    # Do not map them to the frozen_map!
    targ_t = Nx.transpose(target_tokens, axes: [1, 0])
  
    # 3. Step through time
    result =
      while {i = 0, total_loss = Nx.tensor(0.0, type: :f32),
             h = h_init,
             x_in = in_t, y_targ = targ_t,
             p = params, f_map = frozen_map},
            Nx.less(i, seq_len) do
  
          x_curr = x_in[i]
  
          # ⚡ 3. Use loop state variables (h and p)
          {_latent_pred, h_new} = DLM.TinySSM.forward(x_curr, h, p)
          
          # ⚡ 4. Unpack all 9 parameters
          {_a, _bu, _bv, _cu, _cv, _du, _dv, vocab_w, vocab_b} = p
    
          # Project the 512D state to the 128D Vocabulary Space
          logits = Nx.add(Nx.dot(h_new, vocab_w), vocab_b)
          
          # Calculate Cross Entropy Loss
          step_loss = DLM.Loss.cross_entropy(logits, y_targ[i])

        {i + 1, Nx.add(total_loss, step_loss), h_new, x_in, y_targ, p, f_map}
      end
  
    # Return average loss across the sequence
    Nx.divide(elem(result, 1), seq_len)
  end
end
```

