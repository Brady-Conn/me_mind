## BLiMP

```elixir
defmodule DLM.Phase2_Eval do
  import Nx.Defn

  # ⚡ Added orig_seq_len to the signature
  defn compute_sentence_loss(input_tokens, target_tokens, orig_seq_len, h_init, params, frozen_map) do
    seq_len = Nx.axis_size(input_tokens, 1) # Will be strictly 512
    
    # 1. Map inputs to continuous Sinkhorn space
    input_coords =
      Nx.take(frozen_map, Nx.flatten(input_tokens))
      |> Nx.reshape({1, seq_len, 512})
      |> stop_grad()
  
    in_t = Nx.transpose(input_coords, axes: [1, 0, 2])
    targ_t = Nx.transpose(target_tokens, axes: [1, 0])
  
    # 2. The Physics Loop
    result =
      while {i = 0, total_loss = Nx.tensor(0.0, type: :f32),
             h = h_init,
             x_in = in_t, y_targ = targ_t,
             p = params, f_map = frozen_map, sq_ln = orig_seq_len},
            Nx.less(i, seq_len) do
  
        x_curr = x_in[i]
  
        {a, bu, bv, cu, cv, du, dv, vw, vb, _rb, _rw} = p

        # --- ⚡ 3. The Core Physics (XSA) ---
        b_proj = DLM.TinySSM.apply_svd(x_curr, bu, bv)
        gate_proj = DLM.TinySSM.apply_svd(x_curr, du, dv)
        shifted_gate = Nx.subtract(gate_proj, 3.0)
        delta = Nx.max(DLM.TinySSM.softplus(shifted_gate), 0.01)
        a_bar = Nx.exp(Nx.multiply(delta, -Nx.abs(a)))
        
        h_norm_sq = Nx.add(Nx.sum(Nx.pow(h, 2), axes: [-1], keep_axes: true), 1.0e-6)
        h_unit = Nx.divide(h, Nx.sqrt(h_norm_sq))
        overlap = Nx.sum(Nx.multiply(b_proj, h_unit), axes: [-1], keep_axes: true)
        b_exclusive = Nx.subtract(b_proj, Nx.multiply(overlap, h_unit))
        
        h_new = Nx.add(Nx.multiply(a_bar, h), b_exclusive)

        # --- ⚡ 4. The SVD Bottleneck ---
        h_latent = DLM.TinySSM.apply_svd(h_new, cu, cv)
        
        # --- ⚡ 5. Forward Logit Prediction ---
        logits = Nx.add(Nx.dot(h_latent, vw), vb)
        
        # Cross Entropy Loss against the target character
        step_loss = DLM.Loss.cross_entropy(logits, y_targ[i])
        
        # ⚡ 6. THE MASK: Zero out the loss if we are in the padded void
        valid_mask = Nx.select(Nx.less(i, sq_ln), 1.0, 0.0)
        masked_loss = Nx.multiply(step_loss, valid_mask)

        {i + 1, Nx.add(total_loss, masked_loss), h_new, x_in, y_targ, p, f_map, sq_ln}
      end
  
    # Divide the accumulated masked loss by the original true sentence length
    Nx.divide(elem(result, 1), Nx.as_type(orig_seq_len, :f32))
  end
end
