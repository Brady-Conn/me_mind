```elixir
defmodule DLM.SvdOptimizer do
  import Nx.Defn

  defn update(params, grads, step, lr) do
    {b1, b2, bb, bq, bg, be, 
     c1, c2, cb, cq, cg, ce}  = params   
    {gb1, gb2, gbb, gbq, gbg, gbe, 
     gc1, gc2, gcb, gcq, gcg, gce}  = grads
    
    new_step = Nx.add(step, 1)

    # optimizer update step    
    b1_new = DLM.StatelessMuon.step(b1, gb1, lr)
    b2_new = DLM.StatelessMuon.step(b2, gb2, lr)
    bb_new = DLM.StatelessMuon.step(bb, gbb, lr)
    bq_new = DLM.StatelessMuon.step(bq, gbq, lr)
    be_new = DLM.StatelessMuon.step(be, gbe, lr)
    bg_new = DLM.StatelessMuon.step(bg, gbg, lr)

    c1_new = DLM.StatelessMuon.step(c1, gc1, lr)
    c2_new = DLM.StatelessMuon.step(c2, gc2, lr)
    cb_new = DLM.StatelessMuon.step(cb, gcb, lr)
    cq_new = DLM.StatelessMuon.step(cq, gcq, lr)
    ce_new = DLM.StatelessMuon.step(ce, gce, lr)
    cg_new = DLM.StatelessMuon.step(cg, gcg, lr)

    
    
    new_params = {b1_new, b2_new, bb_new, bq_new, bg_new, be_new,
                  c1_new, c2_new, cb_new, cq_new, cg_new, ce_new}

    {new_params, new_step}
  end
end
