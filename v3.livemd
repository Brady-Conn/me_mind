```elixir
# --- THE BRAIN HEALTH CHECK ---
IO.puts("--- Checking Weights in Memory ---")

# Check if they are random or trained
# Trained weights usually have a specific Mean and Variance
{mean, var} = {Nx.mean(final_v7_emb) |> Nx.to_number(), Nx.variance(final_v7_emb) |> Nx.to_number()}

IO.puts("Embedding Mean: #{mean}")
IO.puts("Embedding Var:  #{var}")

if abs(mean) < 0.001 and abs(var - 1.0) < 0.1 do
  IO.puts("\n⚠️ WARNING: These look like RANDOM weights (Mean ~0, Var ~1).")
  IO.puts("The Iron Lung will start from scratch!")
else
  IO.puts("\n✅ SUCCESS: These look like TRAINED weights.")
end
