```elixir
# --- V7 BOOTSTRAP 2.1: THE EXPLICIT SHAPE VERSION ---
# (Keep your Mix.install cell at the top)

# 1. POSITIONAL (Stricter Broadcasting)
defmodule DLM.Positional do
  def build(seq_len, dim) do
    i = Nx.iota({seq_len, 1})
    j = Nx.iota({1, dim})
    # Math remains the same
    angles = Nx.divide(i, Nx.pow(10000, Nx.divide(Nx.multiply(Nx.quotient(j, 2), 2), dim)))
    
    # We pass 'j' into the math block so we can broadcast it explicitly
    compute_pos(angles, j)
  end

  import Nx.Defn
  defn compute_pos(angles, j_row) do
    # THE FIX: Explicitly broadcast the 1-row index to match the 31-row angles
    j = Nx.broadcast(j_row, angles)
    Nx.select(Nx.remainder(j, 2), Nx.cos(angles), Nx.sin(angles))
  end
end

# 2. MASK (Type-Safe)
defmodule DLM.Mask do
  def causal(size) do
    mask = Nx.iota({size, size})
    row = Nx.reshape(Nx.iota({size}), {size, 1})
    # Explicitly ensure the -1.0e10 is a 32-bit float to match the embeddings
    Nx.select(Nx.less_equal(mask, row), 0, Nx.tensor(-1.0e10, type: :f32))
  end
end

# 3. TRAINING UTILS
defmodule DLM.Training do
  import Nx.Defn
  defn softmax(logits) do
    exps = Nx.exp(Nx.subtract(logits, Nx.reduce_max(logits, axes: [-1], keep_axes: true)))
    Nx.divide(exps, Nx.sum(exps, axes: [-1], keep_axes: true))
  end

  defn layer_norm(x) do
    mean = Nx.mean(x, axes: [-1], keep_axes: true)
    variance = Nx.variance(x, axes: [-1], keep_axes: true)
    Nx.divide(Nx.subtract(x, mean), Nx.sqrt(Nx.add(variance, 1.0e-5)))
  end
end

defmodule DLM.Inference do
  import Nx.Defn
  
  # Now accepts TWO sets of weights: {aw1, fw1} and {aw2, fw2}
  defn predict_next(input_emb, aw1, fw1, aw2, fw2, mask) do
    {_batch, seq_len, _dim} = Nx.shape(input_emb)
    
    # --- LAYER 1: STRUCTURE ---
    x1 = apply_layer(input_emb, aw1, fw1, mask)
    
    # --- LAYER 2: DETAIL (Residual connection added) ---
    x2 = apply_layer(x1, aw2, fw2, mask)
    
    # Final output from the top layer
    x2 
    |> DLM.Training.layer_norm()
    |> Nx.slice_along_axis(seq_len - 1, 1, axis: 1)
  end

  # Helper to keep the code clean
  defn apply_layer(input, aw, fw, mask) do
    {_b, _s, dim} = Nx.shape(input)
    transposed = Nx.transpose(input, axes: [0, 2, 1])
    scores = Nx.dot(input, [2], [0], transposed, [1], [0])
    masked_scores = Nx.add(Nx.divide(scores, Nx.sqrt(dim)), mask)
    
    attn_weights = DLM.Training.softmax(masked_scores)
    attended = Nx.dot(attn_weights, [2], [0], input, [1], [0])
    
    # Sub-layer 1: Attention + Norm
    x = Nx.dot(attended, aw) |> DLM.Training.layer_norm()
    
    # Sub-layer 2: Feed Forward + Norm
    ff = Nx.dot(x, fw)
    ff = Nx.select(Nx.greater(ff, 0), ff, Nx.multiply(ff, 0.01))
    
    Nx.add(x, ff) |> DLM.Training.layer_norm()
  end
end

# --- THE DETERMINISTIC 625-SENTENCE MULTIVERSE ---
subjects = ["fox", "cat", "dog", "owl", "bee"]
adjectives = ["quick", "slow", "fast", "tiny", "lazy"]
colors = ["brown", "black", "white", "green", "grey"]
actions = ["jumps", "flies", "leaps", "runs", "walks"]

# Nested loops ensure we generate all 625 variations in a fixed order
v4_raw = for s <- subjects, adj <- adjectives, c <- colors, act <- actions do
  "the #{adj} #{c} #{s} #{act}." |> String.pad_trailing(32, "#")
end

v4_corpus_tensor = Nx.tensor(Enum.map(v4_raw, &to_charlist/1))

seq_len = 31
v4_inputs_ids = Nx.slice_along_axis(v4_corpus_tensor, 0, seq_len, axis: 1)
v4_targets_ids = Nx.slice_along_axis(v4_corpus_tensor, 1, seq_len, axis: 1)

pos_emb = DLM.Positional.build(seq_len, 256)
causal_mask = DLM.Mask.causal(seq_len)

IO.puts("✅ Corpus Restored: 625 Sentences in RAM.")
```

```elixir
defmodule DLM.Optimizer do
  import Nx.Defn

  defn loss(inputs, targets, emb, aw1, fw1, aw2, fw2, pos, mask) do
    x0 = Nx.take(emb, inputs) |> Nx.add(pos)
    
    # --- LAYER 1 ---
    x1 = apply_layer(x0, aw1, fw1, mask)
    
    # --- LAYER 2 ---
    x2 = apply_layer(x1, aw2, fw2, mask)
    
    prediction = x2 |> DLM.Training.layer_norm()
    target_emb = Nx.take(emb, targets)
    
    Nx.mean(Nx.pow(Nx.subtract(prediction, target_emb), 2))
  end

  defn apply_layer(input, aw, fw, mask) do
    {_b, _s, dim} = Nx.shape(input)
    transposed = Nx.transpose(input, axes: [0, 2, 1])
    scores = Nx.dot(input, [2], [0], transposed, [1], [0])
    masked_scores = Nx.add(Nx.divide(scores, Nx.sqrt(dim)), mask)
    
    attn_weights = DLM.Training.softmax(masked_scores)
    attended = Nx.dot(attn_weights, [2], [0], input, [1], [0])
    
    # Attention Sub-layer with Residual Connection
    x = Nx.dot(attended, aw) |> DLM.Training.layer_norm()
    x_res = Nx.add(input, x) 
    
    # Feed Forward Sub-layer with Residual Connection
    ff = Nx.dot(x_res, fw)
    ff = Nx.select(Nx.greater(ff, 0), ff, Nx.multiply(ff, 0.01))
    
    Nx.add(x_res, ff) |> DLM.Training.layer_norm()
  end

  defn run_chunk(inputs, targets, e, a1, f1, a2, f2, pos, mask, lr, iterations) do
    while {e, a1, f1, a2, f2, _loss_acc = 0.0, i = 0, inputs, targets, pos, mask, lr, iterations}, i < iterations do
      # Track gradients for ALL 5 variables
      {current_loss, {ge, ga1, gf1, ga2, gf2}} = 
        value_and_grad({e, a1, f1, a2, f2}, fn {e_in, a1_in, f1_in, a2_in, f2_in} -> 
          loss(inputs, targets, e_in, a1_in, f1_in, a2_in, f2_in, pos, mask) 
        end)
      
      {
        Nx.subtract(e, Nx.multiply(ge, Nx.divide(lr, 5))), # Embeddings still anchored
        Nx.subtract(a1, Nx.multiply(ga1, lr)),
        Nx.subtract(f1, Nx.multiply(gf1, lr)),
        Nx.subtract(a2, Nx.multiply(ga2, lr)),
        Nx.subtract(f2, Nx.multiply(gf2, lr)),
        current_loss, i + 1, inputs, targets, pos, mask, lr, iterations
      }
    end
  end
end
