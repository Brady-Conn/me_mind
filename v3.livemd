```elixir
# --- V7.6 DIFFERENTIAL DIAGNOSTIC ---
# This uses the final_v7_6 variables from your latest successful burn.

seeds = [
  "the fast green ",
  "the slow white ",
  "the tiny black ",
  "the lazy brown ",
  "the quick grey "
]

IO.puts("--- Running V7.6 Greedy Diagnostic ---\n")

Enum.each(seeds, fn seed_text ->
  seed_ids = seed_text |> to_charlist() |> Nx.tensor() |> Nx.reshape({1, :auto})
  IO.write("#{seed_text}")
  
  Enum.reduce_while(1..25, seed_ids, fn _i, acc_ids ->
    {_, len} = Nx.shape(acc_ids)
    p_emb = DLM.Positional.build(len, 256)
    mask = DLM.Mask.causal(len)
    
    # Inference Call
    pred_vec = DLM.Inference.predict_next(
      Nx.add(Nx.take(final_v7_emb, acc_ids), p_emb), 
      final_v7_attn, 
      final_v7_ff, 
      mask
    )
    
    # Distance Check against the NOW-STABILIZED embeddings
    diff = Nx.subtract(pred_vec, Nx.reshape(final_v7_emb, {1, 256, 256}))
    dist = Nx.sum(Nx.pow(diff, 2), axes: [-1]) |> Nx.reshape({256})
    next_id = Nx.argmin(dist) |> Nx.to_number()

    if next_id == 35 or len >= 31 do
      {:halt, acc_ids}
    else
      if next_id > 31 and next_id < 127, do: IO.write(<<next_id>>)
      {:cont, Nx.concatenate([acc_ids, Nx.reshape(Nx.tensor([next_id]), {1, 1})], axis: 1)}
    end
  end)
  IO.puts("") 
end)
```

```elixir
# --- V7.4 GREEDY DIAGNOSTIC: THE TRUTH TEST ---
# We use the 'final_v7_4' variables from your current stabilizer loop.

seeds = [
  "the fast green ",
  "the slow white ",
  "the tiny black ",
  "the lazy brown ",
  "the quick grey "
]

IO.puts("--- Running V7.4 Greedy Diagnostic ---\n")

Enum.each(seeds, fn seed_text ->
  seed_ids = seed_text |> to_charlist() |> Nx.tensor() |> Nx.reshape({1, :auto})
  IO.write("#{seed_text}")
  
  # We generate up to 20 characters to finish the sentence
  Enum.reduce_while(1..20, seed_ids, fn _i, acc_ids ->
    {_, current_len} = Nx.shape(acc_ids)
    
    # 1. Build step-specific components
    p_emb_step = DLM.Positional.build(current_len, 256)
    mask_step = DLM.Mask.causal(current_len)
    
    # 2. Get the current thought vector
    current_emb = Nx.take(final_v7_emb, acc_ids)
    
    # 3. Predict the next mathematical coordinate
    prediction_vec = DLM.Inference.predict_next(
      Nx.add(current_emb, p_emb_step), 
      final_v7_attn, 
      final_v7_ff,
      mask_step
    )
    
    # 4. Decoding: Find the absolute closest character in our frozen map
    # (Distance math: lower is better)
    emb_broadcast = Nx.reshape(final_v7_emb, {1, 256, 256})
    diff = Nx.subtract(prediction_vec, emb_broadcast)
    distances = Nx.sum(Nx.pow(diff, 2), axes: [-1]) |> Nx.reshape({256})

    # GREEDY CHOICE: Smallest distance (Argmin)
    next_id_val = Nx.argmin(distances) |> Nx.to_number()

    if next_id_val == 35 or current_len >= 31 do # Stop at # or length limit
      {:halt, acc_ids}
    else
      # Write the character to the console
      if next_id_val > 31 and next_id_val < 127, do: IO.write(<<next_id_val>>)
      {:cont, Nx.concatenate([acc_ids, Nx.reshape(Nx.tensor([next_id_val]), {1, 1})], axis: 1)}
    end
  end)
  
  IO.puts("") # New line for the next seed
end)

IO.puts("\nDiagnostic Complete.")
