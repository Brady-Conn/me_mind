# --- V7 IMPORT (SCOPED & FIXED) ---
save_path = Path.join(File.cwd!(), "v7_brain/v7_weights_complete.bin")

# We "pull" the variables out of the block by assigning the if-statement's result
{final_v7_emb, final_v7_attn, final_v7_ff} = if File.exists?(save_path) do
  brain_map = File.read!(save_path) |> :erlang.binary_to_term()
  
  IO.puts("✅ V7 Brain Awake at #{brain_map.timestamp}")
  
  # This tuple is the 'result' of the 'if' block
  {brain_map.embeddings, brain_map.attention, brain_map.feedforward}
else
  # Using raise ensures the notebook stops if the file is missing
  raise "❌ ERROR: Brain file not found at #{save_path}"
end
