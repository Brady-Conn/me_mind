## Train

```elixir
defmodule DLM.V21Trainer do
  import Nx.Defn

  defn log_softmax(logits) do
    max_logits = Nx.reduce_max(logits, axes: [-1], keep_axes: true)
    safe_logits = logits - max_logits
    sum_exp = Nx.sum(Nx.exp(safe_logits), axes: [-1], keep_axes: true)
    safe_logits - Nx.log(sum_exp)
  end

  defn compute_loss(preds_sliced, targets) do
    log_probs = log_softmax(preds_sliced)
    target_probs = Nx.take_along_axis(log_probs, Nx.new_axis(targets, -1), axis: -1)
    target_probs = Nx.squeeze(target_probs, axes: [-1])
    mask = Nx.not_equal(targets, 0) |> Nx.as_type(:f32)
    masked_loss = -target_probs * mask
    Nx.sum(masked_loss) / Nx.sum(mask)
  end

  # ✂️ THE IDIOMATIC GRADIENT CLIPPER
  defn compute_grad(params, pos_emb, batch) do
    {loss, grads} = value_and_grad(params, fn p ->
      batch_s32 = Nx.as_type(batch, :s32)
      preds = DLM.UniversalSSM.forward(batch_s32, p, pos_emb)
      preds_sliced = Nx.slice_along_axis(preds, 0, 255, axis: 1)
      targets = Nx.slice_along_axis(batch_s32, 1, 255, axis: 1)
      compute_loss(preds_sliced, targets)
    end)

    # 1. Safely Unpack the 14 Gradient Tensors
    {g0, g1, g2, g3, g4, g5, g6, g7, g8, g9, g10, g11, g12, g13} = grads

    # 2. Calculate the Global Squared Norm
    sq_norm =
      Nx.sum(Nx.pow(g0, 2)) +
      Nx.sum(Nx.pow(g1, 2)) +
      Nx.sum(Nx.pow(g2, 2)) +
      Nx.sum(Nx.pow(g3, 2)) +
      Nx.sum(Nx.pow(g4, 2)) +
      Nx.sum(Nx.pow(g5, 2)) +
      Nx.sum(Nx.pow(g6, 2)) +
      Nx.sum(Nx.pow(g7, 2)) +
      Nx.sum(Nx.pow(g8, 2)) +
      Nx.sum(Nx.pow(g9, 2)) +
      Nx.sum(Nx.pow(g10, 2)) +
      Nx.sum(Nx.pow(g11, 2)) +
      Nx.sum(Nx.pow(g12, 2)) +
      Nx.sum(Nx.pow(g13, 2))
    
    global_norm = Nx.sqrt(sq_norm)
    threshold = 1.0

    # 3. Calculate the Scaling Factor
    scale = Nx.select(
      Nx.greater(global_norm, threshold),
      threshold / (global_norm + 1.0e-6),
      1.0
    )

    # 4. Apply the Scale and Repack the Tuple
    clipped_grads = {
      g0 * scale, g1 * scale, g2 * scale, g3 * scale, g4 * scale,
      g5 * scale, g6 * scale, g7 * scale, g8 * scale, g9 * scale,
      g10 * scale, g11 * scale, g12 * scale, g13 * scale
    }

    {loss, clipped_grads}
  end
end
```

