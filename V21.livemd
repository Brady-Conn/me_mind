```elixir
defmodule DLM.DataBuilder do
  @rank 32
  @dim 256
  @seq_len 256
  @pad_token 0

  @doc """
  Takes a list of file paths, combines them, shuffles the lines 
  to prevent overfitting, and builds the static training tensors.
  """
  def build_combined_tensors(file_paths) when is_list(file_paths) do
    # 1. Read and combine all files into one massive list of lines
    raw_lines = 
      Enum.flat_map(file_paths, fn path ->
        File.stream!(path)
        |> Stream.map(&String.trim/1)
        # Skip the copyright and license headers at the top of the file
        |> Stream.reject(fn line -> String.starts_with?(line, "  ") end)
        # We must convert the stream to a list here so flat_map can merge them
        |> Enum.to_list()
      end)

    # 2. 🔀 THE CRITICAL SHUFFLE
    # We do this in standard Elixir memory before it hits the GPU
    shuffled_lines = Enum.shuffle(raw_lines)

    # 3. Format, Pad, and Tensorize
    shuffled_lines
    |> Enum.map(&parse_synset/1)
    |> Enum.reject(&is_nil/1)
    |> Nx.tensor(type: :s32)
  end

  defp parse_synset(line) do
    case String.split(line, " | ") do
      [data_chunk, gloss] ->
        tokens = String.split(data_chunk, " ", trim: true)
        
        # Token index 3 is the hex count of words in this synset
        w_cnt = String.to_integer(Enum.at(tokens, 3), 16)
        
        # Words start at index 4 and alternate with their lex_ids
        words = 
          Enum.reduce(0..(w_cnt - 1), [], fn i, acc ->
            word_index = 4 + (i * 2)
            raw_word = Enum.at(tokens, word_index)
            # WordNet uses underscores for spaces (e.g., "fountain_pen")
            clean_word = String.replace(raw_word, "_", " ")
            [clean_word | acc]
          end)
          |> Enum.reverse()

        [main_word | synonyms] = words
        
        # Build the minimalist anchor string
        raw_str = 
          if Enum.empty?(synonyms) do
            "#{main_word} = #{gloss}"
          else
            "#{main_word} = #{gloss} | #{Enum.join(synonyms, ", ")}"
          end

        format_to_tensor(raw_str)

      _ -> nil
    end
  end

  defp format_to_tensor(raw_str) do
    chars = String.to_charlist(raw_str)
    actual_len = length(chars)

    cond do
      actual_len == @seq_len -> 
        chars
      actual_len > @seq_len -> 
        Enum.take(chars, @seq_len)
      actual_len < @seq_len -> 
        chars ++ List.duplicate(@pad_token, @seq_len - actual_len)
    end
  end
end
```

