```elixir
# ===========================================================================
# V21 Forensic Data Inspector
# ===========================================================================

dataset_path = "bigbrain_phase1_data.bin"
IO.puts("🧠 Loading Dataset...")
full_dataset = File.read!(dataset_path) |> :erlang.binary_to_term() |> Nx.backend_copy(Nx.BinaryBackend)

dataset_size = Nx.axis_size(full_dataset, 0)
batch_size = 16

# 1. Recreate the EXACT shuffle from Epoch 5
# The run resumed at Global Step 32000, which seeded the shuffle
resume_step = 32000
initial_key = Nx.Random.key(resume_step)

IO.puts("🔀 Recreating Epoch 5 Shuffle...")
{shuffled_dataset, _} = Nx.Random.shuffle(initial_key, full_dataset, axis: 0)

# 2. Define our target investigation window
start_step = 32700
end_step = 32720

IO.puts("\n🔍 Inspecting batches from Global Step #{start_step} to #{end_step}...\n")

Enum.each(start_step..end_step, fn step ->
  # Calculate the exact slice offset for this step
  offset = rem(step * batch_size, dataset_size)
  
  batch_tensor = Nx.slice_along_axis(shuffled_dataset, offset, batch_size, axis: 0)
  
  # Break the batch into 16 individual sequences
  batch_lists = 
    batch_tensor
    |> Nx.to_batched(1) 
    |> Enum.map(fn t -> 
      t |> Nx.squeeze(axes: [0]) |> Nx.to_flat_list() 
    end)
  
  IO.puts(String.duplicate("=", 60))
  IO.puts("🚨 GLOBAL STEP #{step} (Offset: #{offset})")
  IO.puts(String.duplicate("=", 60))
  
  Enum.with_index(batch_lists, 1) |> Enum.each(fn {char_list, idx} ->
    # Decode integers back to text, stripping the 0 (Padding) tokens
    decoded_string = 
      char_list 
      |> Enum.reject(&(&1 == 0)) 
      |> List.to_string()
    
    IO.puts(" [Seq #{idx}] #{decoded_string}")
  end)
  IO.puts("\n")
end)
```

