```

```elixir
IO.puts("🧠 Loading Dataset into CPU Memory...")
full_dataset = File.read!("bigbrain_phase1_data.bin") 
  |> :erlang.binary_to_term()
  |> Nx.backend_copy(Nx.BinaryBackend)

dataset_size = Nx.axis_size(full_dataset, 0)
batch_size = 16
total_steps_per_epoch = div(dataset_size, batch_size)

max_epochs = 10
save_interval = 1000
base_lr = 3.0e-4
gpu = {EXLA.Backend, client: :rocm}

# 🔍 AUTO-RESUME LOGIC
latest_checkpoint = 
  Path.wildcard("v21_*.bin")
  |> Enum.reject(&String.contains?(&1, "data.bin"))
  |> Enum.max_by(fn path -> File.stat!(path).mtime end, fn -> nil end)

IO.puts("💾 Found latest checkpoint: #{latest_checkpoint}")
checkpoint = File.read!(latest_checkpoint) |> :erlang.binary_to_term()

IO.puts("🏗️ Restoring V21 Brain State...")
params = checkpoint.params |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple()
ms = checkpoint.ms |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple()
vs = checkpoint.vs |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple()

global_step = checkpoint.step 
current_epoch = div(global_step, total_steps_per_epoch) + 1
words_already_seen = rem(global_step * batch_size, dataset_size)

pos_emb = DLM.Positional.build(256, 256) |> Nx.backend_copy(gpu)
initial_key = Nx.Random.key(global_step) 

IO.puts("🚀 IGNITION: Auto-Resuming at Epoch #{current_epoch}, Global Step #{global_step}...")

Enum.reduce(current_epoch..max_epochs, {params, ms, vs, global_step, initial_key, words_already_seen}, fn epoch, {p, m, v, current_step, current_key, offset_words} ->
  IO.puts(String.duplicate("=", 50))
  
  current_lr = base_lr * :math.pow(0.9, epoch - 1)
  IO.puts("🌊 EPOCH #{epoch} / #{max_epochs} | LR: #{current_lr}")
  
  IO.puts("🔀 Shuffling dataset...")
  {shuffled_raw, next_key} = Nx.Random.shuffle(current_key, full_dataset, axis: 0)
  shuffled_dataset = Nx.backend_copy(shuffled_raw, Nx.BinaryBackend)

  # Create LR tensor ONCE per epoch
  lr_tensor = Nx.tensor(current_lr, type: :f32) |> Nx.backend_copy(gpu)

  epoch_batches = Stream.unfold(offset_words, fn offset ->
    if offset + batch_size > dataset_size, do: nil, else: {Nx.slice_along_axis(shuffled_dataset, offset, batch_size, axis: 0), offset + batch_size}
  end)

  # 🚀 INNER BATCH LOOP
  {new_p, new_m, new_v, next_epoch_step, final_skips} =
    epoch_batches
    |> Stream.with_index(1)
    |> Enum.reduce({p, m, v, current_step, 0}, fn {batch, step_in_epoch}, {cp, cm, cv, cs, s_count} ->
      gpu_batch = Nx.backend_copy(batch, gpu)
      
      # 1. Compute Gradients
      {loss_tensor, grads} = DLM.V21Trainer.compute_grad(cp, pos_emb, gpu_batch)
      loss_val = Nx.to_number(loss_tensor)

      # 2. The Safety Gate (Skip if NaN or wild spike)
      if loss_val == :nan or loss_val > 20.0 do
        if rem(step_in_epoch, 10) == 0, do: IO.puts("⚠️ Step #{cs}: NaN/Spike detected. Skipping batch.")
        {cp, cm, cv, cs + 1, s_count + 1}
      else
        # 3. Update Weights
        step_tensor = Nx.tensor(cs, type: :f32) |> Nx.backend_copy(gpu)
        {up_p, up_m, up_v} = DLM.MuonHybrid.step(cp, grads, cm, cv, step_tensor, lr_tensor)

        # 4. Logging (Every 50 steps)
        if rem(step_in_epoch, 50) == 0 do
          bpc = loss_val / :math.log(2)
          mem = :erlang.memory(:total) |> div(1024 * 1024)
          IO.puts("➡️ Step #{step_in_epoch} | Global: #{cs} | Loss: #{Float.round(loss_val, 4)} | BPC: #{Float.round(bpc, 3)} | Skips: #{s_count} | RAM: #{mem}MB")
        end

        # 5. Checkpointing (Every 1000 steps)
        if rem(cs, save_interval) == 0 do
          IO.puts("💾 Auto-Saving Checkpoint to v21_auto_step#{cs}.bin...")
          state = %{
            params: up_p |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
            ms: up_m |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
            vs: up_v |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
            step: cs, epoch: epoch
          }
          File.write!("v21_auto_step#{cs}.bin", :erlang.term_to_binary(state))
        end

        # Aggressive garbage collection
        if rem(step_in_epoch, 100) == 0, do: :erlang.garbage_collect(self())

        # Return the updated state + incremented skip count
        {up_p, up_m, up_v, cs + 1, s_count}
      end
    end)

  IO.puts("💾 Saving Completed Epoch #{epoch} State...")
  final_state = %{
    params: new_p |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
    ms: new_m |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
    vs: new_v |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
    step: next_epoch_step, epoch: epoch
  }
  File.write!("v21_auto_epoch#{epoch}_COMPLETE.bin", :erlang.term_to_binary(final_state))

  # Accumulator for the next epoch
  {new_p, new_m, new_v, next_epoch_step, next_key, 0}
end)

IO.puts("🎉 THE OVERNIGHT BAKE IS COMPLETE!")
```

