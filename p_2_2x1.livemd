```elixir
defmodule DLM.SvdOptimizer do
  import Nx.Defn

  defn update(params, grads, step, lr) do
    {em, eq, au, av, bu, bv, bw, bx, by, bz, cu, cv, du, dv, dw, dx, dy, dz} = params
    {gem, geq, gau, gav, gbu, gbv, gbw, gbx, gby, gbz, gcu, gcv, gdu, gdv, gdw, gdx, gdy, gdz} = grads

    new_step = Nx.add(step, 1)

    # optimizer update step
    em_new = DLM.SparseSinkGD.muon_step(em, gem, lr)
    eq_new = DLM.SparseSinkGD.muon_step(eq, geq, lr)
    au_new = DLM.SparseSinkGD.muon_step(au, gau, lr)
    av_new = DLM.SparseSinkGD.muon_step(av, gav, lr)
    bu_new = DLM.SparseSinkGD.muon_step(bu, gbu, lr)
    bv_new = DLM.SparseSinkGD.muon_step(bv, gbv, lr)
    bw_new = DLM.SparseSinkGD.muon_step(bw, gbw, lr)
    bx_new = DLM.SparseSinkGD.muon_step(bx, gbx, lr)
    by_new = DLM.SparseSinkGD.muon_step(by, gby, lr)
    bz_new = DLM.SparseSinkGD.muon_step(bz, gbz, lr)
    cu_new = DLM.SparseSinkGD.muon_step(cu, gcu, lr)
    cv_new = DLM.SparseSinkGD.muon_step(cv, gcv, lr)
    du_new = DLM.SparseSinkGD.muon_step(du, gdu, lr)
    dv_new = DLM.SparseSinkGD.muon_step(dv, gdv, lr)
    dw_new = DLM.SparseSinkGD.muon_step(dw, gdw, lr)
    dx_new = DLM.SparseSinkGD.muon_step(dx, gdx, lr)
    dy_new = DLM.SparseSinkGD.muon_step(dy, gdy, lr)
    dz_new = DLM.SparseSinkGD.muon_step(dz, gdz, lr)
   
    
    new_params = {em_new, eq_new, au_new, av_new, 
                  bu_new, bv_new, bw_new, bx_new, by_new, bz_new,
                  cu_new, cv_new, du_new, dv_new, dw_new, dx_new, dy_new, dz_new}

    {new_params, new_step}
  end
end
