```elixir
defmodule DLM.SvdSinkGD do
  import Nx.Defn

  defn normalize_svd_sink(grad) do
    eps = 1.0e-9
    # 1. Identify active mask
    raw_row_norms = Nx.pow(grad, 2) |> Nx.sum(axes: [-1], keep_axes: true) |> Nx.sqrt()
    active_mask = Nx.greater(raw_row_norms, eps)

    # 2. Add an SVD-like Spectral Scale
    # We estimate the "Energy" of the whole matrix (Frobenius Norm)
    # This acts as our global 'singular value' to stabilize the Sinkhorn loop
    matrix_energy = Nx.LinAlg.norm(grad)
    g_initial = Nx.divide(grad, matrix_energy + eps)

    {_, up_g, _} = while {i = 0, g = g_initial, am = active_mask}, Nx.less(i, 5) do
      # --- Row Normalization (Standard Sinkhorn) ---
      row_norms = g |> Nx.pow(2) |> Nx.sum(axes: [-1], keep_axes: true) |> Nx.sqrt()
      g = Nx.divide(g, Nx.select(am, row_norms, 1.0))
      
      # --- Column Normalization (Standard Sinkhorn) ---
      col_norms = g |> Nx.pow(2) |> Nx.sum(axes: [0], keep_axes: true) |> Nx.sqrt()
      g = Nx.divide(g, Nx.select(Nx.greater(col_norms, eps), col_norms, 1.0))

      # --- "The SVD Twist": Orthogonal Centering ---
      # SVD components are orthogonal. We can nudge the matrix to be 
      # more 'spread out' (higher entropy) by subtracting the mean 
      # of the active gradients, preventing one feature from dominating.
      g = g - (Nx.sum(g) / Nx.sum(am)) 
      
      {i + 1, g, am}
    end
    
    up_g
  end

  defn step(p, g, lr) do
    # Re-inject the Matrix Energy (the global singular scale) 
    # so the LR stays meaningful
    energy = Nx.LinAlg.norm(g)
    scaled_g = normalize_svd_sink(g)
    
    # Final Update: P - (G_normalized * Energy * LR)
    Nx.subtract(p, Nx.multiply(scaled_g, energy * lr))
  end
end

