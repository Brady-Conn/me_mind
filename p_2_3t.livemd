## SSM

```elixir
defmodule DLM.SvdSSM do
  import Nx.Defn

  defn l2_normalize(tensor) do
    # Calculate Euclidean norm across the last axis natively
    norm = Nx.sqrt(Nx.sum(Nx.pow(tensor, 2), axes: [-1], keep_axes: true))
    # Divide by norm with a tiny epsilon to prevent divide-by-zero
    Nx.divide(tensor, Nx.add(norm, 1.0e-6))
  end

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn gelu(x) do
    cdf = Nx.multiply(
      Nx.tensor(0.7978845608, type: :f32),
      Nx.add(x, Nx.multiply(Nx.tensor(0.044715, type: :f32), Nx.pow(x, 3)))
    )
    Nx.multiply(Nx.multiply(Nx.tensor(0.5, type: :f32), x), Nx.add(Nx.tensor(1.0, type: :f32), Nx.tanh(cdf)))
  end

  defn swish(x) do
    Nx.multiply(x, Nx.sigmoid(x))
  end

  defn apply_svd(x, u, v) do
    gelu(x) |> Nx.dot(u) |> Nx.tanh() |> Nx.dot(v)
  end

  defn project_svd(x, u, v) do
    Nx.dot(x, u) |> gelu() |> Nx.dot(v) |> rms_norm()
  end

  defn softplus(x) do
    Nx.log1p(Nx.exp(x))
  end

  defn softmax(t) do
    max_val = Nx.reduce_max(t, axes: [-1], keep_axes: true)
    safe_t = Nx.subtract(t, max_val)
    exps = Nx.exp(safe_t)
    sum_exps = Nx.sum(exps, axes: [-1], keep_axes: true)
    Nx.divide(exps, Nx.add(sum_exps, 1.0e-8))
  end

  defn forward_step(x_t1, x_t2, x_t3, h_prev, params) do
    {em, eq, er, es, au, av, bu, bv, cu, cv, du, dv} = params

    xt_1 = Nx.take(em, x_t1)
    xt_2 = Nx.take(em, x_t2)
    xt_3 = Nx.take(em, x_t3)

    x1_proj = project_svd(xt_1, bu, bv)
    h1_proj = project_svd(h_prev, au, av)
    h2_proj = project_svd(h1_proj + x1_proj, au, av)
    x2_proj = project_svd(x1_proj + xt_2, bu, bv)
    h3_proj = project_svd(h2_proj + x2_proj, au, av)
    x3_proj = project_svd(x2_proj + xt_3, bu, bv)
    
  
    h_new = Nx.add(h3_proj, x3_proj)

    h1_latent = project_svd(h_new, cu, cv)
    x1_latent = project_svd(xt_1, du, dv)
    h2_latent = project_svd(h1_latent + x1_latent, cu, cv)
    x2_latent = project_svd(x1_latent + xt_2, du, dv)
    h3_latent = project_svd(h2_latent + x2_latent, cu, cv)
    x3_latent = project_svd(x2_latent + xt_3, du, dv)

    latent = Nx.add(h3_latent, x3_latent)
    
    logits1 = Nx.dot(latent, eq)
    
    # x4_proj = apply_svd(logits1, bu, bv)
    # h4_proj = apply_svd(h_new, au, av)
    # h2_new = Nx.add(h4_proj, x4_proj)
    
    # h4_latent = apply_svd(h2_new, cu, cv)
    # x4_latent = apply_svd(logits1, du, dv)
    
    # latent2 = Nx.add(h4_latent, x4_latent)
    logits2 = Nx.dot(latent, er) + logits1

    # x5_proj = apply_svd(logits2, bu, bv)
    # h5_proj = apply_svd(h2_new, au, av)
    # h3_new = Nx.add(h5_proj, x5_proj)
    
    # h5_latent = apply_svd(h3_new, cu, cv)
    # x5_latent = apply_svd(logits2, du, dv)
    
    # latent3 = Nx.add(h5_latent, x5_latent)
    logits3 = Nx.dot(latent, es) + logits2

    {logits1, logits2, logits3, h_new}
  end
end
