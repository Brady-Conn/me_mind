## SSM

```elixir
defmodule DLM.SvdSSM do
  import Nx.Defn

  defn l2_normalize(tensor) do
    # Calculate Euclidean norm across the last axis natively
    norm = Nx.sqrt(Nx.sum(Nx.pow(tensor, 2), axes: [-1], keep_axes: true))
    # Divide by norm with a tiny epsilon to prevent divide-by-zero
    Nx.divide(tensor, Nx.add(norm, 1.0e-6))
  end

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn gelu(x) do
    cdf = Nx.multiply(
      Nx.tensor(0.7978845608, type: :f32),
      Nx.add(x, Nx.multiply(Nx.tensor(0.044715, type: :f32), Nx.pow(x, 3)))
    )
    Nx.multiply(Nx.multiply(Nx.tensor(0.5, type: :f32), x), Nx.add(Nx.tensor(1.0, type: :f32), Nx.tanh(cdf)))
  end

  defn swish(x) do
    Nx.multiply(x, Nx.sigmoid(x))
  end

  defn apply_svd(x, u, v) do
    gelu(x) |> Nx.dot(u) |> Nx.tanh() |> Nx.dot(v)
  end

  defn project_svd(x, u, v) do
    Nx.dot(x, u) |> gelu() |> Nx.dot(v) |> rms_norm()
  end

  defn softplus(x) do
    Nx.log1p(Nx.exp(x))
  end

  defn softmax(t) do
    max_val = Nx.reduce_max(t, axes: [-1], keep_axes: true)
    safe_t = Nx.subtract(t, max_val)
    exps = Nx.exp(safe_t)
    sum_exps = Nx.sum(exps, axes: [-1], keep_axes: true)
    Nx.divide(exps, Nx.add(sum_exps, 1.0e-8))
  end

  defn forward_step(x_t1, x_t2, x_t3, h_prev, params) do
    {em, eq, er, es, au, av, bu, bv, bw, bx, by, bz, cu, cv, cw, cx, cy, cz, du, dv, dw, dx, dy, dz} = params

    xt_1 = Nx.take(em, x_t1)
    xt_2 = Nx.take(em, x_t2)
    xt_3 = Nx.take(em, x_t3)

    # Build the deep relationship state from the 3 inputs
    x1_proj = apply_svd(xt_1, bu, bv)
    x2_proj = apply_svd(xt_2, bw, bx)
    x3_proj = apply_svd(xt_3, by, bz)

    xc_proj = x1_proj + x2_proj + x3_proj
    
    h_proj = project_svd(h_prev, au, av)
    h_new = Nx.add(h_proj, xc_proj)

    x1_latent = apply_svd(xt_1, du, dv)
    x2_latent = apply_svd(xt_2, dw, dx)
    x3_latent = apply_svd(xt_3, dy, dz)

    xc_latent = x1_latent + x2_latent + x3_latent

    # Decode 1: The immediate next character
    f_latent_1 = project_svd(h_new, cu, cv) + xc_latent
    logits1 = Nx.dot(f_latent_1, eq)

    # Decode 2: Evolve the state, predict the 2nd character
    # (By passing it through cu/cv again, the model shifts its focus forward)
    f_latent_2 = project_svd(f_latent_1, cw, cx)
    logits2 = Nx.dot(f_latent_2, er)

    # Decode 3: Evolve again, predict the 3rd
    f_latent_3 = project_svd(f_latent_2, cy, cz)
    logits3 = Nx.dot(f_latent_3, es)

    {logits1, logits2, logits3, h_new}
  end
end
