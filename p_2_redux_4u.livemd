```elixir
# --- Inference Probe ---
full_state_path = "v44_DLM_512sq_b2b64_frznf512_v4096dsm4u_checkpoint_step_1000.bin"
frozen_path = "./data/f_semantic_reservoir_512D.bin"

if File.exists?(full_state_path) do
  IO.puts("💾 Loading latest V18 Checkpoint...")
  %{trainable: t_p, frozen: _f_p} = File.read!(full_state_path) |> :erlang.binary_to_term()
  %{frozen: {f_p, _m}} = File.read!(frozen_path) |> :erlang.binary_to_term()
    params_gpu = DLM.Tree.map(t_p, &Nx.backend_copy(&1, gpu))
    frozen_gpu = DLM.Tree.map(f_p, &Nx.backend_copy(&1, gpu))


  IO.puts("✅ Model Loaded")
  
  # Fire the battery!
  DLM.Probe.run(params_gpu, frozen_gpu)
else
  IO.puts("❌ No checkpoint found at #{full_state_path}")
end
