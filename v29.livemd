```elixir
defmodule DLM.V29_Inference do
  import Nx.Defn

  # ⚡ Single-Step Forward Pass (Upgraded for 3-Layer V29)
  defn generate_step(token, pos_emb_step, states_curr, v29_p, enc_w1, enc_w2) do
    # Encode current token
    token_2d = Nx.reshape(token, {1, 1}) 
    clean_coords = DLM.PhysicsEngine.get_coordinates(token_2d, enc_w1, enc_w2)
    
    # Extract the base 512D vector and add Positional Embedding
    x_base = clean_coords[0][0]
    x_input = Nx.add(x_base, pos_emb_step)
    
    # Expand to batch dimension 1 for the SSM
    x_batch = Nx.new_axis(x_input, 0)
    
    # ⚡ Route through the full 3-layer network!
    {logits_batch, next_states} = DLM.V29_SSM.forward(x_batch, states_curr, v29_p)
    
    # Extract the 1D logits from the batch
    logits = logits_batch[0]
    
    {logits, next_states} 
  end
  
  # ⚡ Axis-locked Sampling (Unchanged)
  defn sample(logits, temperature, prng_key) do
    scaled_logits = Nx.divide(logits, temperature)
    
    {gumbel_noise, next_key} = Nx.Random.uniform(prng_key, shape: Nx.shape(logits))
    gumbel = Nx.negate(Nx.log(Nx.negate(Nx.log(gumbel_noise))))
    
    # Strictly argmax across the last axis
    sampled_token = Nx.argmax(Nx.add(scaled_logits, gumbel), axis: -1)
    {sampled_token, next_key}
  end
end

