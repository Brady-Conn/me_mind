```elixir
defmodule DLM.V29_DNI do
  import Nx.Defn

  # ⚡ 1. DATA PREP (Remains exactly the same)
  defn prep_data(batch_tokens, pos_emb, enc_w1, enc_w2, prng_key, noise_scale) do
    seq_len = Nx.axis_size(batch_tokens, 1) - 1
    {batch_size, _} = Nx.shape(batch_tokens)
    
    input_tokens = Nx.slice_along_axis(batch_tokens, 0, seq_len, axis: 1)
    target_tokens = Nx.slice_along_axis(batch_tokens, 1, seq_len, axis: 1)

    clean_coords = DLM.PhysicsEngine.get_coordinates(input_tokens, enc_w1, enc_w2)
    {noise, final_key} = Nx.Random.normal(prng_key, 0.0, 1.0, shape: {batch_size, seq_len, 512})
    noisy_coords = Nx.add(clean_coords, Nx.multiply(noise, noise_scale))

    sliced_pos_emb = Nx.slice_along_axis(pos_emb, 0, seq_len, axis: 0)
    noisy_coords = Nx.add(noisy_coords, Nx.new_axis(sliced_pos_emb, 0))

    clean_time = Nx.transpose(clean_coords, axes: [1, 0, 2])
    noisy_time = Nx.transpose(noisy_coords, axes: [1, 0, 2])
    targets_time = Nx.transpose(target_tokens, axes: [1, 0])

    {clean_time, noisy_time, targets_time, final_key}
  end

  # ⚡ 2. THE TEACHER (Remains exactly the same)
  defn get_teacher_trajectory(clean_time, h_pe_init, pe_p) do
    seq_len = Nx.axis_size(clean_time, 0)
    spots_out = Nx.broadcast(0.0, Nx.shape(clean_time))
    
    result = 
      while {i = 0, h = h_pe_init, spots = spots_out, c_t = clean_time, p = pe_p}, Nx.less(i, seq_len) do
        x_curr = c_t[i]
        {predicted, next_h} = DLM.TinySSM.forward(x_curr, h, p)
        ideal = Nx.add(x_curr, predicted)
        updated_spots = Nx.put_slice(spots, [i, 0, 0], Nx.new_axis(ideal, 0))
        {i + 1, next_h, updated_spots, c_t, p}
      end
    {elem(result, 2), elem(result, 1)}
  end

  # ⚡ 3. CORE LEARNER SEQUENCE (Upgraded to 3-Layer)
  defn compute_v29_sequence(noisy_time, states_init, v29_p) do
    seq_len = Nx.axis_size(noisy_time, 0)
    
    # Canvases for our Loss calculations
    logits_init = Nx.broadcast(0.0, {seq_len, Nx.axis_size(noisy_time, 1), 256})
    h3_init = Nx.broadcast(0.0, Nx.shape(noisy_time))
    
    result =
      while {
        i = 0, states = states_init, 
        l_acc = logits_init, h_acc = h3_init,
        n_t = noisy_time, p = v29_p 
      }, Nx.less(i, seq_len) do
            
        # Call the new 3-Layer Network!
        {logits_t, next_states} = DLM.V29_SSM.forward(n_t[i], states, p)
        
        # Extract the hidden state from Layer 3 for Teacher Distillation
        {_h1, _x1_1, _x2_1, _h2, _x1_2, _x2_2, next_h3, _x1_3, _x2_3} = next_states
        
        updated_l = Nx.put_slice(l_acc, [i, 0, 0], Nx.new_axis(logits_t, 0))
        updated_h = Nx.put_slice(h_acc, [i, 0, 0], Nx.new_axis(next_h3, 0))
          
        {i + 1, next_states, updated_l, updated_h, n_t, p}
      end
      
    {elem(result, 2), elem(result, 3), elem(result, 1)}
  end

  # ⚡ 4. THE GRADIENT TAPE (Updated to extract h3)
  defn get_v29_grads(noisy_time, targets_time, ideal_spots_time, states_init, v29_p) do
    value_and_grad(v29_p, fn p ->
      {logits_seq, h3_seq, _final_states} = compute_v29_sequence(noisy_time, states_init, p)
      
      ce_loss = DLM.Loss.cross_entropy(logits_seq, targets_time)
      
      # ⚡ Teacher Distillation targets Layer 3's state!
      latent_loss = Nx.mean(Nx.pow(Nx.subtract(ideal_spots_time, h3_seq), 2))
      
      lambda = Nx.tensor(0.1, type: :f32)
      Nx.add(ce_loss, Nx.multiply(latent_loss, lambda))
    end)
  end

  # ⚡ 5. STATE EXTRACTOR & BPC METRIC
  defn get_v29_state_and_bpc(noisy_time, targets_time, states_init, v29_p) do
    {logits_seq, _h3_seq, final_states} = compute_v29_sequence(noisy_time, states_init, v29_p)
    ce_loss = DLM.Loss.cross_entropy(logits_seq, targets_time)
    bpc = Nx.divide(ce_loss, Nx.tensor(0.69314718, type: :f32))
    {final_states, bpc}
  end

  # ⚡ 6. GRAD NORMS (Watch Layer 3's stats for structural tension)
  def grad_norms(grads) do
    {_l1, _l2, l3_g, lmw_g, _lmb_g} = grads
    {_ga, _gbu, _gbv, _gcu, g_cv, _gdu, g_dv, _mu1, _mv1, _mu2, _mv2} = l3_g
    calc = fn g -> g |> Nx.pow(2) |> Nx.sum() |> Nx.sqrt() |> Nx.to_number() |> Float.round(4) end
    [
      l3_c_v: calc.(g_cv), l3_d_v: calc.(g_dv), lm_w: calc.(lmw_g)
    ]
  end
end
```

