```elixir
defmodule DLM.V29_Genesis do
  import Nx.Defn

  # ⚡ Explicitly define the 11-parameter layer ignition to safely thread the PRNG key tensor
  defn ignite_layer(key) do
    # Friction/Inertia
    {a, k1} = Nx.Random.normal(key, -2.0, 0.1, shape: {512})
    
    # Input Matrices
    {bu, k2} = Nx.Random.normal(k1, 0.0, 0.02, shape: {512, 256})
    {bv, k3} = Nx.Random.normal(k2, 0.0, 0.02, shape: {256, 512})
    
    # Output Matrices
    {cu, k4} = Nx.Random.normal(k3, 0.0, 0.02, shape: {512, 256})
    {cv, k5} = Nx.Random.normal(k4, 0.0, 0.02, shape: {256, 512})

    # Routing Gates (Initialized near zero so they start open)
    {du, k6} = Nx.Random.normal(k5, 0.0, 0.001, shape: {512, 256})
    {dv, k7} = Nx.Random.normal(k6, 0.0, 0.001, shape: {256, 512})
    
    # Memory Mixing Matrices
    {mu1, k8} = Nx.Random.normal(k7, 0.0, 0.02, shape: {512, 256})
    {mv1, k9} = Nx.Random.normal(k8, 0.0, 0.02, shape: {256, 512})
    {mu2, k10} = Nx.Random.normal(k9, 0.0, 0.02, shape: {512, 256})
    {mv2, next_key} = Nx.Random.normal(k10, 0.0, 0.02, shape: {256, 512})

    {{a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2}, next_key}
  end

  defn ignite(key) do
    # Ignite all 3 layers sequentially, threading the key
    {layer_1, k1} = ignite_layer(key)
    {layer_2, k2} = ignite_layer(k1)
    {layer_3, k3} = ignite_layer(k2)
    
    # Ignite the Language Model Head (256 dictionary bytes)
    {lm_w, k4} = Nx.Random.normal(k3, 0.0, 0.02, shape: {512, 256})
    {lm_b, next_key} = Nx.Random.normal(k4, 0.0, 0.0, shape: {256})

    {{layer_1, layer_2, layer_3, lm_w, lm_b}, next_key}
  end

  # ⚡ Dynamically build the nested optimizer states (m, v)
  def init_optimizer(params) do
    # Create a 0.0 tensor matching the exact shape of every parameter
    m = DLM.Tree.map(params, fn p -> Nx.broadcast(0.0, Nx.shape(p)) end)
    v = DLM.Tree.map(params, fn p -> Nx.broadcast(0.0, Nx.shape(p)) end)
    
    # Return {m, v, step_count}
    {m, v, Nx.tensor(0, type: :u32)}
  end

end
```

