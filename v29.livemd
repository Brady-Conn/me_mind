```elixir
defmodule DLM.MuonHybrid do
  import Nx.Defn

  defn newton_schulz(g, iters \\ 5) do
    frobenius_norm = Nx.sqrt(Nx.sum(Nx.pow(g, 2))) + 1.0e-7
    x = g / frobenius_norm
    
    {final_x, _} = while {curr_x = x, i = 0}, Nx.less(i, iters) do
      x_t_x = Nx.dot(Nx.transpose(curr_x), curr_x)
      next_x = 1.5 * curr_x - 0.5 * Nx.dot(curr_x, x_t_x)
      {next_x, i + 1}
    end
    final_x
  end

  defn muon_update(grad, lr) do
    clipped = Nx.clip(grad, -1.0, 1.0)
    Nx.subtract(0.0, Nx.multiply(lr, newton_schulz(clipped)))
  end

  defn adam_update(param, grad, m, v, step, lr) do
    safe_step = step + 1.0
    beta1 = 0.9
    beta2 = 0.999
    eps = 1.0e-8
    
    new_m = beta1 * m + (1.0 - beta1) * grad
    new_v = beta2 * v + (1.0 - beta2) * Nx.pow(grad, 2)
    
    m_hat = new_m / (1.0 - Nx.pow(beta1, safe_step))
    v_hat = new_v / (1.0 - Nx.pow(beta2, safe_step))
    
    param_update = param - lr * m_hat / (Nx.sqrt(v_hat) + eps)
    {param_update, new_m, new_v}
  end

  # ⚡ Process a single 11-parameter SSM block
  defn update_layer(layer_p, layer_g, layer_m, layer_v, step, lr) do
    {p_a, p_bu, p_bv, p_cu, p_cv, p_du, p_dv, p_mu1, p_mv1, p_mu2, p_mv2} = layer_p
    {g_a, g_bu, g_bv, g_cu, g_cv, g_du, g_dv, g_mu1, g_mv1, g_mu2, g_mv2} = layer_g
    {m_a, m_bu, m_bv, m_cu, m_cv, m_du, m_dv, m_mu1, m_mv1, m_mu2, m_mv2} = layer_m
    {v_a, v_bu, v_bv, v_cu, v_cv, v_du, v_dv, v_mu1, v_mv1, v_mu2, v_mv2} = layer_v
    
    {up_a, nm_a, nv_a} = adam_update(p_a, g_a, m_a, v_a, step, lr)
    up_bu = p_bu + muon_update(g_bu, lr)
    up_bv = p_bv + muon_update(g_bv, lr)
    up_cu = p_cu + muon_update(g_cu, lr)
    up_cv = p_cv + muon_update(g_cv, lr)
    up_du = p_du + muon_update(g_du, lr)
    up_dv = p_dv + muon_update(g_dv, lr)
    up_mu1 = p_mu1 + muon_update(g_mu1, lr)
    up_mv1 = p_mv1 + muon_update(g_mv1, lr)
    up_mu2 = p_mu2 + muon_update(g_mu2, lr)
    up_mv2 = p_mv2 + muon_update(g_mv2, lr)
    
    new_p = {up_a, up_bu, up_bv, up_cu, up_cv, up_du, up_dv, up_mu1, up_mv1, up_mu2, up_mv2}
    new_m = {nm_a, m_bu, m_bv, m_cu, m_cv, m_du, m_dv, m_mu1, m_mv1, m_mu2, m_mv2}
    new_v = {nv_a, v_bu, v_bv, v_cu, v_cv, v_du, v_dv, v_mu1, v_mv1, v_mu2, v_mv2}
    {new_p, new_m, new_v}
  end

  # ⚡ Process all 3 layers + the LM Head
  defn step(params, grads, ms, vs, step_count, lr) do
    {l1_p, l2_p, l3_p, lmw_p, lmb_p} = params
    {l1_g, l2_g, l3_g, lmw_g, lmb_g} = grads
    {l1_m, l2_m, l3_m, lmw_m, lmb_m} = ms
    {l1_v, l2_v, l3_v, lmw_v, lmb_v} = vs
    
    {up_l1_p, up_l1_m, up_l1_v} = update_layer(l1_p, l1_g, l1_m, l1_v, step_count, lr)
    {up_l2_p, up_l2_m, up_l2_v} = update_layer(l2_p, l2_g, l2_m, l2_v, step_count, lr)
    {up_l3_p, up_l3_m, up_l3_v} = update_layer(l3_p, l3_g, l3_m, l3_v, step_count, lr)
    
    {up_lmw, nm_lmw, nv_lmw} = adam_update(lmw_p, lmw_g, lmw_m, lmw_v, step_count, lr)
    {up_lmb, nm_lmb, nv_lmb} = adam_update(lmb_p, lmb_g, lmb_m, lmb_v, step_count, lr)
    
    new_params = {up_l1_p, up_l2_p, up_l3_p, up_lmw, up_lmb}
    new_ms = {up_l1_m, up_l2_m, up_l3_m, nm_lmw, nm_lmb}
    new_vs = {up_l1_v, up_l2_v, up_l3_v, nv_lmw, nv_lmb}
    
    {new_params, new_ms, new_vs}
  end
end
