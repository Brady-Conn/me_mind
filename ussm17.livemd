```elixir
# --- V17.1 Quick Probe ---
full_state_path = "v18_full_state.bin.bin"
seq_len = 256 # Ensure this matches your current training seq_len

gpu = {EXLA.Backend, client: :rocm}
Nx.global_default_backend(gpu)

if File.exists?(full_state_path) do
  IO.puts("💾 Loading latest V18 Checkpoint...")
  %{params: params_cpu, step: step, epoch: epoch} = 
    File.read!(full_state_path) |> :erlang.binary_to_term()

  to_gpu = fn tpl -> tpl |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple() end
  params = to_gpu.(params_cpu)
  
  # Rebuild pos_emb to match current seq_len
  pos_emb = DLM.Positional.build(seq_len, 256) |> Nx.backend_copy(gpu)

  IO.puts("✅ Model Loaded (Step #{step})")
  
  # Fire the battery!
  DLM.ProbeV17.run(params, pos_emb)
else
  IO.puts("❌ No checkpoint found at #{full_state_path}")
end
