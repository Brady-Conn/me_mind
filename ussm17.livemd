## Inference, Probe, Test

```elixir
# ===========================================================================
# V17 Inference — No Mask, SSM Forward Routing
# ===========================================================================
defmodule DLM.InferenceV17 do
  import Nx.Defn

  @allowed_chars ~c" abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789.,:;-'\"()[]"

  def build_muzzle(vocab_size \\ 128, allowed \\ @allowed_chars) do
    muzzle = Nx.broadcast(Nx.tensor(-1.0e10, type: :f32), {vocab_size})
    Enum.reduce(allowed, muzzle, fn char, acc ->
      Nx.indexed_put(acc, Nx.tensor([[char]]), Nx.tensor([0.0]))
    end)
  end

  defn get_next_logits(ins, params, pos_emb, muzzle) do
    # Direct route to the SSM (No mask needed!)
    logits = DLM.UniversalSSM.forward(ins, params, pos_emb)
    logits[[0, -1, 0..-1//1]] + muzzle
  end

  # CPU-side repetition penalty (unchanged)
  defp apply_rep_penalty(logits, recent_tokens, penalty \\ 1.3) do
    Enum.reduce(recent_tokens, logits, fn token_id, acc ->
      current = Nx.to_number(acc[token_id])
      new_val = if current > 0, do: current / penalty, else: current * penalty
      Nx.indexed_put(acc, Nx.tensor([[token_id]]), Nx.tensor([new_val]))
    end)
  end

  defn sample_top_k(ins, params, pos_emb, muzzle, temp, key, opts \\ []) do
    logits = get_next_logits(ins, params, pos_emb, muzzle) / temp
    {top_values, top_indices} = Nx.top_k(logits, k: opts[:k])
    probs = Nx.exp(top_values) / Nx.sum(Nx.exp(top_values))
    {sampled_tensor, new_key} = Nx.Random.choice(key, top_indices, probs)
    {sampled_tensor[0], new_key}
  end

  def greedy(params, pos_emb, prompt, max_new_chars \\ 120, muzzle \\ nil) do
    gpu    = Nx.default_backend()
    muzzle = (muzzle || build_muzzle()) |> Nx.backend_copy(gpu)
    prompt_chars = String.to_charlist(prompt)
    seq_len = elem(Nx.shape(pos_emb), 0)

    Enum.reduce(1..max_new_chars, prompt_chars, fn step, chars ->
      pad_len = seq_len - length(chars)
      padded  = List.duplicate(0, max(0, pad_len)) ++ chars
      ins     = Nx.tensor([Enum.take(padded, -seq_len)], type: :s64)
                |> Nx.backend_copy(gpu)

      raw_logits = get_next_logits(ins, params, pos_emb, muzzle)
      recent     = Enum.take(chars, -20)
      penalized  = apply_rep_penalty(raw_logits, recent, 1.3)
      next_token = penalized |> Nx.argmax() |> Nx.to_number()

      if rem(step, 10) == 0, do: :erlang.garbage_collect(self())
      chars ++ [next_token]
    end)
    |> List.to_string()
  end

  def top_k(params, pos_emb, prompt, max_new_chars \\ 120, k \\ 5, temp \\ 0.8, muzzle \\ nil) do
    gpu    = Nx.default_backend()
    muzzle = (muzzle || build_muzzle()) |> Nx.backend_copy(gpu)
    prompt_chars = String.to_charlist(prompt)
    seq_len = elem(Nx.shape(pos_emb), 0)

    Enum.reduce(1..max_new_chars, {prompt_chars, Nx.Random.key(42)}, fn step, {chars, key} ->
      pad_len = seq_len - length(chars)
      padded  = List.duplicate(0, max(0, pad_len)) ++ chars
      ins     = Nx.tensor([Enum.take(padded, -seq_len)], type: :s64)
                |> Nx.backend_copy(gpu)

      {next_token, next_key} =
        sample_top_k(ins, params, pos_emb, muzzle, temp, key, k: k)

      if rem(step, 10) == 0, do: :erlang.garbage_collect(self())
      {chars ++ [Nx.to_number(next_token)], next_key}
    end)
    |> elem(0)
    |> List.to_string()
  end
end

IO.puts("✅ DLM.InferenceV17 loaded")
```

```elixir
# ===========================================================================
# V17 Probe — Apples-to-Apples comparison with V16
# ===========================================================================
defmodule DLM.ProbeV17 do
  def run(params, pos_emb) do
    gpu    = Nx.default_backend()
    muzzle = DLM.InferenceV17.build_muzzle() |> Nx.backend_copy(gpu)

    IO.puts("\n" <> String.duplicate("=", 60))
    IO.puts("DLM UNIVERSAL SSM INFERENCE PROBE (V17)")
    IO.puts(String.duplicate("=", 60))

    IO.puts("\n📚 IN-DISTRIBUTION")
    IO.puts(String.duplicate("-", 40))
    probe(params, pos_emb, "[W]happy [T]adj [D]",  "Definition of 'happy'", muzzle)
    probe(params, pos_emb, "[W]water [T]noun [D]", "Definition of 'water'", muzzle)
    probe(params, pos_emb, "[W]run [T]verb [D]",   "Definition of 'run'",   muzzle)

    IO.puts("\n🔄 REVERSE FORMAT")
    IO.puts(String.duplicate("-", 40))
    probe(params, pos_emb, "[D]A feeling of great pleasure [W]", "Word for pleasure", muzzle)
    probe(params, pos_emb, "[D]To move swiftly on foot [W]",     "Word for swift",    muzzle)

    IO.puts("\n🔀 NEAR-DISTRIBUTION")
    IO.puts(String.duplicate("-", 40))
    probe(params, pos_emb, "The word 'happy' means",         "Prose definition",  muzzle)
    probe(params, pos_emb, "[W]love [R]Related:",            "Relational format", muzzle)
    probe(params, pos_emb, "[W]cold [T]adj [D]The opposite", "Partial def",       muzzle)

    IO.puts("\n💬 OUT-OF-DISTRIBUTION")
    IO.puts(String.duplicate("-", 40))
    probe(params, pos_emb, "What is the meaning of life?", "Philosophical", muzzle)
    probe(params, pos_emb, "Hello, how are you?",          "Greeting",      muzzle)
    probe(params, pos_emb, "Can you define the word",      "Conversational",muzzle)

    IO.puts("\n🔤 MORPHOLOGY")
    IO.puts(String.duplicate("-", 40))
    probe(params, pos_emb, "[W]Electr", "Electr-", muzzle)
    probe(params, pos_emb, "[W]Mecha",  "Mecha-",  muzzle)
    probe(params, pos_emb, "[W]Inter",  "Inter-",  muzzle)
    probe(params, pos_emb, "[W]Ortho",  "Ortho-",  muzzle)
    probe(params, pos_emb, "[W]Trans",  "Trans-",  muzzle)

    IO.puts("\n" <> String.duplicate("=", 60))
  end

  defp probe(params, pos_emb, prompt, label, muzzle) do
    IO.puts("\n▶ #{label}")
    IO.puts("  Prompt:  #{inspect(prompt)}")

    # Call the V17 Inference
    greedy  = DLM.InferenceV17.greedy(params, pos_emb, prompt, 60, muzzle)
    sampled = DLM.InferenceV17.top_k(params, pos_emb, prompt, 60, 5, 0.8, muzzle)

    IO.puts("  Greedy:  #{inspect(String.slice(greedy,  String.length(prompt)..-1//1))}")
    IO.puts("  Top-k:   #{inspect(String.slice(sampled, String.length(prompt)..-1//1))}")

    :erlang.garbage_collect(self())
  end
end

IO.puts("✅ DLM.ProbeV17 loaded")
