## Init

```elixir
# --- V18 Genesis: 100% CPU-Safe (Fixed) ---
# 1. Force everything in this cell to use the CPU
Nx.global_default_backend(Nx.BinaryBackend)

vocab_size = 128
embed_dim  = 256
rank       = 16

# 2. Now Nx.Random.key/1 works normally, but creates the tensor on CPU
key = Nx.Random.key(180)

init_p = fn shape, k ->
  {t, next_k} = Nx.Random.normal(k, 0.0, 0.02, shape: shape, type: :f32)
  {t, next_k}
end

{embed, key} = init_p.({vocab_size, embed_dim}, key)
a_diag = Nx.broadcast(Nx.tensor(1.0, type: :f32), {embed_dim})

{b_u, key} = init_p.({embed_dim, rank}, key)
{b_v, key} = init_p.({rank, embed_dim}, key)
{c_u, key} = init_p.({embed_dim, rank}, key)
{c_v, key} = init_p.({rank, embed_dim}, key)
{delta_u, key} = init_p.({embed_dim, rank}, key)
{delta_v, key} = init_p.({rank, embed_dim}, key)

{lm_w, _key} = init_p.({embed_dim, vocab_size}, key)
lm_b = Nx.broadcast(Nx.tensor(0.0, type: :f32), {vocab_size})

v18_params = {embed, a_diag, b_u, b_v, c_u, c_v, delta_u, delta_v, lm_w, lm_b}

# 3. Clean up the old files and save the new ones
File.rm("v17_full_state.bin") 
File.write!("v18_genesis.bin", :erlang.term_to_binary(v18_params))

IO.puts("✅ V18 Genesis complete! File saved successfully.")
```

