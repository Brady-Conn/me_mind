## Brain

```elixir
defmodule DLM.UniversalSSM do
  import Nx.Defn

  # --- Helpers ---
  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn softplus(x), do: Nx.log1p(Nx.exp(x))
  defn silu(x), do: x * Nx.sigmoid(x)

  defn apply_svd_weight(x, u, v) do
    x |> Nx.dot(u) |> silu() |> Nx.dot(v)
  end

  # --- Core SSM Step ---
  defn ssm_recurrence(x_t, h_prev, a, bu, bv, cu, cv, du, dv) do
    delta_proj = apply_svd_weight(x_t, du, dv)
    delta = softplus(delta_proj) 
    
    a_bar = Nx.sigmoid(delta * a) 
    b_proj = apply_svd_weight(x_t, bu, bv)
    b_bar = delta * b_proj
    
    h_t = Nx.tanh(a_bar * h_prev + b_bar)
    y_ssm = apply_svd_weight(h_t, cu, cv)
    
    # The crucial Residual Connection
    y_t = y_ssm + x_t
    
    {y_t, h_t}
  end

  # --- The Temporal Engine ---
  defn run_ssm_loop(x_seq_first, h_init, params) do
    {_embed, a_diag, b_u, b_v, c_u, c_v, delta_u, delta_v, _lm_w, _lm_b} = params
    {seq_len, batch_size, embed_dim} = Nx.shape(x_seq_first)
    y_init = Nx.broadcast(Nx.tensor(0.0, type: :f32), {seq_len, batch_size, embed_dim})

    {_, y_seq_first, _final_h, _, _, _, _, _, _, _, _} = 
      while {i = 0, y_acc = y_init, h_p = h_init, xs = x_seq_first, 
             a = a_diag, bu = b_u, bv = b_v, cu = c_u, cv = c_v, du = delta_u, dv = delta_v}, 
            Nx.less(i, seq_len) do
        
        {y_t, h_new} = ssm_recurrence(xs[i], h_p, a, bu, bv, cu, cv, du, dv)
        y_acc_new = Nx.put_slice(y_acc, [i, 0, 0], Nx.new_axis(y_t, 0))
        {i + 1, y_acc_new, h_new, xs, a, bu, bv, cu, cv, du, dv}
      end
    y_seq_first
  end

  # --- The Forward Pass ---
  defn forward(indices, params, pos_emb) do
    {embed, _a, _bu, _bv, _cu, _cv, _du, _dv, lm_w, lm_b} = params
    
    # Initial Formatting & Pre-Norm
    x_input = Nx.take(embed, indices) + pos_emb
    x_norm  = rms_norm(x_input)
    
    {batch_size, seq_len, embed_dim} = Nx.shape(x_norm)
    h_init = Nx.broadcast(Nx.tensor(0.0, type: :f32), {batch_size, embed_dim})
    x_seq_first = Nx.transpose(x_norm, axes: [1, 0, 2])
    
    # 🧠 THE SWEET SPOT: 2-Loop Recursion
    # Loop 1: Context Gathering
    y1_seq = run_ssm_loop(x_seq_first, h_init, params)
    
    # Loop 2: Logic Refinement
    y2_seq = run_ssm_loop(y1_seq, h_init, params)
    
    # Output Projection
    y_out = Nx.transpose(y2_seq, axes: [1, 0, 2])
    y_final = rms_norm(y_out)
    
    Nx.dot(y_final, lm_w) + lm_b
  end
end
```

```elixir
defmodule DLM.Positional do
  def build(len, dim) do
    i = Nx.iota({len, 1})
    d = Nx.iota({1, dim})
    dim_f = Nx.tensor(dim, type: :f32) # 🔥 Force float math
    Nx.sin(Nx.divide(i, Nx.pow(10000.0, Nx.divide(d, dim_f))))
  end
end
```

```elixir
defmodule DLM.OptimizerV17 do
  import Nx.Defn

  # Forward pass directly calls the SSM. No mask needed!
  defn forward(ins, params, pos_emb) do
    DLM.UniversalSSM.forward(ins, params, pos_emb)
  end

  defn loss_fn(params, ins, tgs, pos_emb) do
    logits     = forward(ins, params, pos_emb)
    {b, s, v}  = Nx.shape(logits)
    logits_2d  = Nx.reshape(logits, {b * s, v})
    targets_1d = Nx.reshape(tgs, {b * s})

    max_logits  = Nx.reduce_max(logits_2d, axes: [-1], keep_axes: true)
    log_sum_exp = Nx.log(
                    Nx.sum(Nx.exp(logits_2d - max_logits),
                      axes: [-1], keep_axes: true) + 1.0e-10)
    log_probs   = (logits_2d - max_logits) - log_sum_exp

    indices = Nx.stack([Nx.iota({b * s}), targets_1d], axis: -1)
    -Nx.mean(Nx.gather(log_probs, indices))
  end

  defn adam_core(p, g, m_old, v_old, lr, t) do
    g   = Nx.clip(g, -1.0, 1.0)
    b1  = 0.9
    b2  = 0.999
    eps = 1.0e-8
    t_f = Nx.as_type(t, :f32)

    m_new = b1 * m_old + (1 - b1) * g
    v_new = b2 * v_old + (1 - b2) * (g * g)
    m_hat = m_new / (1 - Nx.pow(b1, t_f))
    v_hat = v_new / (1 - Nx.pow(b2, t_f))
    p_new = p - lr * m_hat / (Nx.sqrt(v_hat) + eps)

    {p_new, m_new, v_new}
  end

  # Unrolled for exactly 10 parameters
  defn apply_adam_unrolled(params, grads, m, v, lr, t) do
    {p0, m0, v0} = adam_core(elem(params,0), elem(grads,0), elem(m,0), elem(v,0), lr, t)
    {p1, m1, v1} = adam_core(elem(params,1), elem(grads,1), elem(m,1), elem(v,1), lr, t)
    {p2, m2, v2} = adam_core(elem(params,2), elem(grads,2), elem(m,2), elem(v,2), lr, t)
    {p3, m3, v3} = adam_core(elem(params,3), elem(grads,3), elem(m,3), elem(v,3), lr, t)
    {p4, m4, v4} = adam_core(elem(params,4), elem(grads,4), elem(m,4), elem(v,4), lr, t)
    {p5, m5, v5} = adam_core(elem(params,5), elem(grads,5), elem(m,5), elem(v,5), lr, t)
    {p6, m6, v6} = adam_core(elem(params,6), elem(grads,6), elem(m,6), elem(v,6), lr, t)
    {p7, m7, v7} = adam_core(elem(params,7), elem(grads,7), elem(m,7), elem(v,7), lr, t)
    {p8, m8, v8} = adam_core(elem(params,8), elem(grads,8), elem(m,8), elem(v,8), lr, t)
    {p9, m9, v9} = adam_core(elem(params,9), elem(grads,9), elem(m,9), elem(v,9), lr, t)

    new_p = {p0,p1,p2,p3,p4,p5,p6,p7,p8,p9}
    new_m = {m0,m1,m2,m3,m4,m5,m6,m7,m8,m9}
    new_v = {v0,v1,v2,v3,v4,v5,v6,v7,v8,v9}
    {new_p, new_m, new_v}
  end

  defn adam_step(ins, tgs, params, m, v, pos_emb, lr, t) do
    {loss, grads} = value_and_grad(params, fn p ->
      loss_fn(p, ins, tgs, pos_emb)
    end)
    {new_params, new_m, new_v} = apply_adam_unrolled(params, grads, m, v, lr, t)
    {new_params, new_m, new_v, loss}
  end
end

IO.puts("✅ DLM.OptimizerV17 loaded")
```

