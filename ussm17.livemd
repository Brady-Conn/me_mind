## Train

```elixir
# ===========================================================================
# V17 Universal SSM Training 
# ===========================================================================
path            = "v13_lean_dictionary.txt"
full_state_path = "v18_full_state.bin.bin"
genesis_path    = "v18_genesis.bin"

seq_len    = 256
batch_size = 4
epochs     = 10
start_lr   = 0.0001  
end_lr     = 0.00001
ram_limit  = 6000 # Safety limit

System.put_env("TF_GPU_ALLOCATOR", "cuda_malloc_async")

gpu = {EXLA.Backend, client: :rocm}
Nx.global_default_backend(gpu)

# 1. Load weights (Genesis or Checkpoint)
{params, m_state, v_state, start_step, start_epoch} = 
  if File.exists?(full_state_path) do
    IO.puts("♻️ Resuming V18 from checkpoint...")
    %{params: p, m: m, v: v, step: s, epoch: e} = File.read!(full_state_path) |> :erlang.binary_to_term()
    {p, m, v, s, e}
  # ... top of auto resume ...
  else
    IO.puts("🌱 No checkpoint found. Loading V18 Genesis...")
    genesis_cpu = File.read!(genesis_path) |> :erlang.binary_to_term()
    
    # NEW: We must push the CPU genesis weights to the GPU!
    to_gpu = fn tpl -> tpl |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple() end
    genesis_gpu = to_gpu.(genesis_cpu)
    
    # Initialize Optimizer buffers (m and v) to zeros on the GPU
    init_zeros = fn tpl -> tpl |> Tuple.to_list() |> Enum.map(&Nx.broadcast(0.0, Nx.shape(&1)) |> Nx.backend_copy(gpu)) |> List.to_tuple() end
    
    {genesis_gpu, init_zeros.(genesis_gpu), init_zeros.(genesis_gpu), 0, 1}
  end

# Push to GPU
to_gpu = fn tpl -> tpl |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple() end
params = to_gpu.(params)
m_state = to_gpu.(m_state)
v_state = to_gpu.(v_state)

# 2. Static Assets (Notice: No Mask!)
pos_emb = DLM.Positional.build(seq_len, 256) |> Nx.backend_copy(gpu)

# 3. Epoch Math & Fast-Forward Logic
batches_per_epoch = 178_718 |> div(batch_size)
total_steps       = epochs * batches_per_epoch
true_start_epoch  = div(start_step, batches_per_epoch) + 1

IO.puts("🚀 [V17 UNIVERSAL SSM] Training | seq_len=#{seq_len} batch=#{batch_size}")
IO.puts("📍 Resuming at Step #{start_step}, True Epoch #{true_start_epoch}")

Enum.reduce_while(true_start_epoch..epochs, {params, m_state, v_state, start_step}, fn epoch, epoch_acc ->
  IO.puts("\n--- Epoch #{epoch} ---")
  
  {_, _, _, current_step} = epoch_acc
  epoch_seed = epoch * 31337
  batches_to_skip = rem(current_step, batches_per_epoch)

  if batches_to_skip > 0 do
    IO.puts("⏩ Fast-forwarding stream by #{batches_to_skip} batches...")
  end

  epoch_result = 
    DLM.DataStreamer.stream(path, seq_len, batch_size, epoch_seed)
    |> Stream.drop(batches_to_skip)
    |> Stream.chunk_every(200)
    |> Enum.reduce_while(epoch_acc, fn batch_chunk, chunk_acc ->
      
      # Explicit destructuring avoids Tuple.insert_at memory overhead
      {p_acc, m_acc, v_acc, step_acc} = chunk_acc

      {p, m, v, step, last_loss} = Enum.reduce(batch_chunk, {p_acc, m_acc, v_acc, step_acc, 0.0}, 
        fn {ins, tgs}, {p_in, m_in, v_in, s_in, _} ->
          
          # Push to GPU right before use
          ins_gpu = Nx.backend_copy(ins, gpu)
          tgs_gpu = Nx.backend_copy(tgs, gpu)

          progress = min(s_in / total_steps, 1.0)
          lr = Nx.tensor(start_lr - progress * (start_lr - end_lr), type: :f32)
          step_t = Nx.tensor(s_in + 1, type: :s32)

          # Call the new V17 Optimizer (No Mask)
          {new_p, new_m, new_v, loss} = 
            DLM.OptimizerV17.adam_step(ins_gpu, tgs_gpu, p_in, m_in, v_in, pos_emb, lr, step_t)
          
          loss_float = Nx.to_number(loss)

          if rem(s_in, 10) == 0, do: :erlang.garbage_collect(self())

          {new_p, new_m, new_v, s_in + 1, loss_float}
        end)

      # Pit Stop: Status & GC
      mem = round(:erlang.memory(:total) / 1_048_576)
      loss_log = if is_float(last_loss) do last_loss else 4.0 end
      IO.puts("🔥 Step #{step} | Epoch #{epoch} | Loss: #{loss_log} | Sys RAM: #{mem}MB")
      
      # Save Checkpoint
      to_cpu = fn tpl -> tpl |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple() end
      checkpoint = %{params: to_cpu.(p), m: to_cpu.(m), v: to_cpu.(v), step: step, epoch: epoch}
      File.write!(full_state_path, :erlang.term_to_binary(checkpoint))

      :erlang.garbage_collect(self())
      Process.sleep(10)

      if mem > ram_limit do
        IO.puts("♻️ RAM limit reached — re-run to continue")
        {:halt, {p, m, v, step}}
      else
        {:cont, {p, m, v, step}}
      end
    end)

  mem_mb = round(:erlang.memory(:total) / 1_048_576)
  if mem_mb > ram_limit do
    {:halt, epoch_result}
  else
    {:cont, epoch_result}
  end
end)
```

