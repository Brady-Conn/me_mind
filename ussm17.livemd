## Stream

```elixir
defmodule DLM.DataStreamer do
  def stream(path, seq_len, batch_size, seed \\ nil) do
    lines =
      path
      |> File.read!()
      |> String.split("\n", trim: true)

    shuffled =
      case seed do
        nil ->
          Enum.shuffle(lines)
        s ->
          # Reset the process RNG state completely before shuffling
          # Using :rand.seed with explicit state tuple guarantees
          # the seed takes effect before Enum.shuffle is called
          rng_state = :rand.seed_s(:exsss, {s, s + 1, s + 2})
          Process.put(:rand_seed, rng_state)
          Enum.shuffle(lines)
      end

    shuffled
    |> Enum.join("\n")
    |> to_charlist()
    |> Stream.chunk_every(seq_len + 1, seq_len, :discard)
    |> Stream.map(fn chunk ->
      ins = chunk |> Enum.take(seq_len) |> Nx.tensor(type: :s64)
      tgs = chunk |> Enum.drop(1) |> Nx.tensor(type: :s64)
      {ins, tgs}
    end)
    |> Stream.chunk_every(batch_size, batch_size, :discard)
    |> Stream.map(fn batch ->
      {ins_list, tgs_list} = Enum.unzip(batch)
      {Nx.stack(ins_list), Nx.stack(tgs_list)}
    end)
  end
end
```

```elixir
defmodule DLM.SVDAudit do
  import Nx.Defn

  def audit(params) do
    # We look at the 'V' weights in our SVD pairs (e.g., B_V, C_V)
    {_embed, _a, _bu, b_v, _cu, c_v, _du, d_v, _lw, _lb} = params
    
    IO.puts("\n🔍 SVD DIMENSIONAL AUDIT")
    Enum.each([{"B_V (Input)", b_v}, {"C_V (Output)", c_v}, {"D_V (Delta)", d_v}], fn {name, tensor} ->
      # Calculate the variance of each of the 16 dimensions
      variances = Nx.variance(tensor, axes: [1])
      active_dims = Nx.greater(variances, 1.0e-5) |> Nx.sum() |> Nx.to_number()
      
      IO.puts("#{name}: #{active_dims} / 16 dimensions are actively 'carrying' data.")
    end)
  end
end
```

```elixir
# Load the weights from your Step 10600 checkpoint
%{params: p_cpu} = File.read!("v18_full_state.bin.bin") |> :erlang.binary_to_term()

# Actually run the audit function
DLM.SVDAudit.audit(p_cpu)
