```elixir
# --- V7 IMPORT SCRIPT: RECORECTING THE BRAIN ---

IO.puts("Searching for V7 Brain on disk...")
save_path = Path.join(File.cwd!(), "v7_brain/v7_weights_complete.bin")

if File.exists?(save_path) do
  # 1. Read the binary
  binary_data = File.read!(save_path)
  
  # 2. Reconstitute the Map
  brain_map = :erlang.binary_to_term(binary_data)
  
  # 3. Assign to variables
  # We use the BinaryBackend to ensure they are ready for Nx
  final_v7_emb  = brain_map.embeddings
  final_v7_attn = brain_map.attention
  final_v7_ff   = brain_map.feedforward
  pos_emb       = brain_map.positional
  
  IO.puts("✅ V7 Brain Loaded Successfully!")
  IO.puts("Model Timestamp: #{brain_map.timestamp}")
else
  IO.puts("❌ ERROR: No save file found at #{save_path}")
end
