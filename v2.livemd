```elixir
defmodule DLM.Training do
  import Nx.Defn

  defn softmax(logits) do
    exps = Nx.exp(Nx.subtract(logits, Nx.reduce_max(logits, axes: [-1], keep_axes: true)))
    Nx.divide(exps, Nx.sum(exps, axes: [-1], keep_axes: true))
  end

  defn layer_norm(x) do
    mean = Nx.mean(x, axes: [-1], keep_axes: true)
    variance = Nx.variance(x, axes: [-1], keep_axes: true)
    Nx.divide(Nx.subtract(x, mean), Nx.sqrt(Nx.add(variance, 1.0e-5)))
  end

  # THE FIX: We now pass in the raw IDs and the emb_w matrix
  defn loss_fn(input_ids, target_ids, emb_w, aw, fw, pos_emb) do
    # 1. EMBEDDING LOOKUP (Now tracked by the gradient!)
    nx = Nx.take(emb_w, input_ids) |> Nx.add(pos_emb)
    targets = Nx.take(emb_w, target_ids)
    
    {_batch, seq_len, dim} = Nx.shape(nx)
    
    # 2. SELF-ATTENTION
    transposed = Nx.transpose(nx, axes: [0, 2, 1])
    scores = Nx.dot(nx, [2], [0], transposed, [1], [0])
    
    scaled_scores = Nx.divide(scores, Nx.sqrt(dim))
    mask = DLM.Mask.causal(seq_len)
    masked_scores = Nx.add(scaled_scores, mask)
    
    attn_weights = softmax(masked_scores)
    attended_nx = Nx.dot(attn_weights, [2], [0], nx, [1], [0])
    
    # 3. FEED FORWARD
    x = Nx.dot(attended_nx, aw) |> layer_norm()
    ff = Nx.dot(x, fw)
    ff = Nx.select(Nx.greater(ff, 0), ff, Nx.multiply(ff, 0.01))
    final_x = Nx.add(x, ff) |> layer_norm()
    
    # 4. MSE
    diff = Nx.subtract(final_x, targets)
    Nx.mean(Nx.pow(diff, 2))
  end
end
```

