```elixir
defmodule DLM.Inference do
  import Nx.Defn

  # Use the same Softmax as training
  defn softmax(logits) do
    exps = Nx.exp(Nx.subtract(logits, Nx.reduce_max(logits, axes: [-1], keep_axes: true)))
    Nx.divide(exps, Nx.sum(exps, axes: [-1], keep_axes: true))
  end

  defn predict_next(input_emb, aw, fw) do
    # Dynamically extract the 256 dimension!
    {_batch, seq_len, dim} = Nx.shape(input_emb)
    
    # 1. Self-Attention (Mirroring Training Logic)
    transposed = Nx.transpose(input_emb, axes: [0, 2, 1])
    scores = Nx.dot(input_emb, [2], [0], transposed, [1], [0])
    
    # Scale and Mask
    # FIX 1: Dynamic scaling for 256-D
    scaled_scores = Nx.divide(scores, Nx.sqrt(dim))
    mask = DLM.Mask.causal(seq_len)
    masked_scores = Nx.add(scaled_scores, mask)
    
    # Probabilities & Mixing
    attn_weights = softmax(masked_scores)
    attended = Nx.dot(attn_weights, [2], [0], input_emb, [1], [0])
    
    # 2. Weights & Feed Forward
    # FIX 2: Route through the new layer_norm function
    x = Nx.dot(attended, aw) |> DLM.Training.layer_norm()
    ff = Nx.dot(x, fw)
    ff = Nx.select(Nx.greater(ff, 0), ff, Nx.multiply(ff, 0.01))
    
    # Return the final state of ONLY the last character in the sequence
    # Shape: {batch, 1, dim}
    Nx.add(x, ff) 
    |> DLM.Training.layer_norm()
    |> Nx.slice_along_axis(seq_len - 1, 1, axis: 1)
  end
end
```

