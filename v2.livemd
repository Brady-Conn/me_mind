```elixir
# --- V7 EXPORT SCRIPT: ARCHIVING THE GENERALIZED BRAIN ---

IO.puts("Preparing to immortalize the V7 Tensors...")

# 1. Define the Save Location
# This creates a 'v7_brain' folder in your current working directory
save_dir = Path.join(File.cwd!(), "v7_brain")
File.mkdir_p!(save_dir)

# 2. Package the Weights
# We use :erlang.term_to_binary because it preserves the Nx metadata 
# and the nested tuple structures (like {wq, wk, wv}) perfectly.
weights_map = %{
  embeddings: final_v7_emb,
  attention: final_v7_attn,
  feedforward: final_v7_ff,
  positional: pos_emb,
  timestamp: DateTime.utc_now() |> DateTime.to_string()
}

# 3. Serialize and Write
binary_data = :erlang.term_to_binary(weights_map)
file_path = Path.join(save_dir, "v7_weights_complete.bin")

case File.write(file_path, binary_data) do
  :ok ->
    IO.puts("\n✅ SUCCESS: The V7 Brain has been saved to disk.")
    IO.puts("Location: #{file_path}")
    IO.puts("Size: #{Float.round(byte_size(binary_data) / 1_000_000, 2)} MB")
    
  {:error, reason} ->
    IO.puts("\n❌ EXPORT FAILED: #{inspect(reason)}")
end
