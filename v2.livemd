```elixir
# --- THE V3 "BRAIN SCANNER" (TOP-K INSPECTION) ---
seed_text = "the fast green "
max_generate = 10
temp = 0.5

seed_ids = seed_text |> to_charlist() |> Nx.tensor() |> Nx.reshape({1, :auto})
generated_ids = seed_ids

IO.puts("Inception Scan for: '#{seed_text}'\n")

Enum.reduce(1..max_generate, generated_ids, fn _i, acc_ids ->
  {_, current_len} = Nx.shape(acc_ids)
  
  # Forward Pass
  current_emb = Nx.take(emb_w, acc_ids)
  p_emb = DLM.Positional.build(current_len, 128)
  input_with_pos = Nx.add(current_emb, p_emb)
  prediction_vec = DLM.Inference.predict_next(input_with_pos, final_v3_attn, final_v3_ff)
  
  # Get Probabilities
  logits = Nx.dot(prediction_vec, Nx.transpose(emb_w)) |> Nx.reshape({256})
  probs = DLM.Inference.softmax(Nx.divide(logits, temp))
  
  # --- THE SCANNER ---
  # Find the Top 5 most likely byte IDs
  {top_probs, top_indices} = Nx.top_k(probs, k: 5)
  
  top_list = Enum.zip(Nx.to_flat_list(top_indices), Nx.to_flat_list(top_probs))
  
  formatted_top = Enum.map(top_list, fn {id, p} -> 
    char = if id < 33, do: "[space]", else: <<id>>
    "#{char}: #{Float.round(p * 100, 1)}%"
  end) |> Enum.join(" | ")

  IO.puts("Next Char Options -> #{formatted_top}")

  # Pick the #1 winner to keep the sentence going
  next_id = Nx.take(top_indices, Nx.tensor([0])) |> Nx.reshape({1, 1})
  Nx.concatenate([acc_ids, next_id], axis: 1)
end)

IO.puts("\nScan Complete.")
