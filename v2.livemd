```elixir
# --- V3 GENERATIVE REVEAL (THE MULTIVERSE) ---
seed_text = "the "
max_generate = 28
temp = 0.6 # 0.6 is the "sweet spot" for this MSE

seed_ids = seed_text |> to_charlist() |> Nx.tensor() |> Nx.reshape({1, :auto})
generated_ids = seed_ids

Enum.reduce(1..max_generate, generated_ids, fn _i, acc_ids ->
  {_, current_len} = Nx.shape(acc_ids)
  
  # 1. Embeddings + Position
  current_emb = Nx.take(emb_w, acc_ids)
  p_emb = DLM.Positional.build(current_len, 128)
  input_with_pos = Nx.add(current_emb, p_emb)
  
  # 2. Predict using V3 weights
  prediction_vec = DLM.Inference.predict_next(input_with_pos, final_gen_attn, final_gen_ff)
  
  # 3. Probability Distribution (Softmax + Temp)
  logits = Nx.dot(prediction_vec, Nx.transpose(emb_w)) |> Nx.reshape({256})
  probs = DLM.Inference.softmax(Nx.divide(logits, temp))
  
  # 4. Sample the winner
  {next_id_tensor, _} = Nx.Random.choice(Nx.Random.key(System.unique_integer([:positive])), Nx.iota({256}), probs)
  next_id = Nx.reshape(next_id_tensor, {1, 1})

  # Append and Print
  new_acc = Nx.concatenate([acc_ids, next_id], axis: 1)
  char = next_id |> Nx.to_flat_list() |> List.to_string()
  IO.write(char)
  
  new_acc
end)

IO.puts("\n\nGeneration Complete.")
