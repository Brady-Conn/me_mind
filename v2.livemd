```elixir
# --- V5 DATA GENERATOR & BURN HUB ---

# ==========================================
# 1. DATA GENERATION (The Hard Stop Corpus)
# ==========================================
subjects = ["fox", "cat", "dog", "owl", "bee"]
adjectives = ["quick", "slow", "fast", "tiny", "lazy"]
colors = ["brown", "black", "white", "green", "grey"]
actions = ["jumps", "flies", "leaps", "runs", "walks"]

v4_raw = for s <- subjects, adj <- adjectives, c <- colors do
  sent = "the #{adj} #{c} #{s} #{Enum.random(actions)}."
  String.pad_trailing(sent, 32, "#")
end

# THE FIX: Let the model see all 625 combinations!
v4_sentences = Enum.shuffle(v4_raw) 

byte_lists = Enum.map(v4_sentences, &to_charlist/1)
v4_corpus_tensor = Nx.tensor(byte_lists) 

IO.puts("V4 Corpus Ready with Hard-Stop Tokens (#)")
IO.puts("Example: '#{List.first(v4_sentences)}'\n")

seq_len = 31
v4_inputs_ids = Nx.slice_along_axis(v4_corpus_tensor, 0, seq_len, axis: 1)
v4_targets_ids = Nx.slice_along_axis(v4_corpus_tensor, 1, seq_len, axis: 1)


# ==========================================
# 2. ARCHITECTURE INITIALIZATION (256-D)
# ==========================================
embed_dim = 256
vocab_size = 256
key = Nx.Random.key(42)

# Vocabulary Embeddings
{emb_w, key} = Nx.Random.uniform(key, -1.0, 0.02, shape: {vocab_size, embed_dim})

# Positional Embeddings
pos_emb = DLM.Positional.build(seq_len, embed_dim)

# The "Brain" Weights (He Initialization for stability)
he_stddev = :math.sqrt(2 / embed_dim)
{aw_init, key} = Nx.Random.normal(key, 0.0, he_stddev, shape: {embed_dim, embed_dim})
{fw_init, _key} = Nx.Random.normal(key, 0.0, he_stddev, shape: {embed_dim, embed_dim})

IO.puts("✅ V5 Weights and Embeddings successfully generated in RAM.\n")


# --- V7 THE GENERALIZATION BURN ---
max_lr = 0.5 
min_lr = 0.05
chunks = 20 # Bumped to 20 for the larger dataset
epochs_per_chunk = 400
batch_size = 16 # Bumping to 16 so it sees more of the universe at once

IO.puts("--- Starting True V7 Generalization Burn ---")

{final_v7_emb, final_v7_attn, final_v7_ff, _} = 
  Enum.reduce(1..chunks, {emb_w, aw_init, fw_init, 0.0}, fn c, {emb, aw, fw, _} ->
    current_lr = max_lr - ((max_lr - min_lr) * (c / chunks))
    
    indices = Enum.take_random(0..(length(v4_sentences) - 1), batch_size) |> Nx.tensor()
    
    batch_inputs_ids = Nx.take(v4_inputs_ids, indices) 
    batch_targets_ids = Nx.take(v4_targets_ids, indices) 

    {next_emb, next_aw, next_fw, loss} = 
       DLM.Optimizer.run_chunk(batch_inputs_ids, batch_targets_ids, emb, aw, fw, pos_emb, current_lr, iterations: epochs_per_chunk)
    
    l_val = Nx.to_number(loss)
    emb_safe = Nx.backend_copy(next_emb, Nx.BinaryBackend)
    aw_safe = Nx.backend_copy(next_aw, Nx.BinaryBackend)
    fw_safe = Nx.backend_copy(next_fw, Nx.BinaryBackend)
    
    Nx.backend_deallocate(next_emb); Nx.backend_deallocate(next_aw); Nx.backend_deallocate(next_fw); Nx.backend_deallocate(loss)
    :erlang.garbage_collect()
    
    IO.puts("Chunk #{c} | LR: #{Float.round(current_lr, 4)} | MSE: #{Float.round(l_val, 8)} | RAM: #{round(:erlang.memory(:total) / 1_000_000)}MB")
    {emb_safe, aw_safe, fw_safe, l_val}
  end)

IO.puts("\n✅ V7 Generalization Burn Complete!")
```

