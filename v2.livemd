```elixir
# --- V7 GREEDY DIAGNOSTIC (TOP-K = 1) ---
seeds = [
  "the fast green ",
  "the slow white ",
  "the tiny black ",
  "the lazy brown ",
  "the quick grey "
]

IO.puts("--- Running V7 Greedy Diagnostic ---\n")

Enum.each(seeds, fn seed_text ->
  seed_ids = seed_text |> to_charlist() |> Nx.tensor() |> Nx.reshape({1, :auto})
  
  IO.write("#{seed_text}")
  
  Enum.reduce_while(1..30, seed_ids, fn _i, acc_ids ->
    {_, current_len} = Nx.shape(acc_ids)
    
    current_emb = Nx.take(final_v7_emb, acc_ids)
    {_, _, dim} = Nx.shape(current_emb)
    
    p_emb = DLM.Positional.build(current_len, dim)
    input_with_pos = Nx.add(current_emb, p_emb)
    
    # Forward Pass
    prediction_vec = DLM.Inference.predict_next(input_with_pos, final_v7_attn, final_v7_ff)
    
    # Euclidean Distance
    emb_broadcast = Nx.reshape(final_v7_emb, {1, 256, 256})
    diff = Nx.subtract(prediction_vec, emb_broadcast)
    distances = Nx.sum(Nx.pow(diff, 2), axes: [-1]) |> Nx.reshape({256})

    # GREEDY PICK: Choose the absolute closest character (smallest distance)
    next_id_val = Nx.argmin(distances) |> Nx.to_number()
    next_id = Nx.reshape(Nx.tensor([next_id_val]), {1, 1})

    if next_id_val == 35 do # '#'
      {:halt, acc_ids}
    else
      if next_id_val > 31 and next_id_val < 127, do: IO.write(<<next_id_val>>)
      {:cont, Nx.concatenate([acc_ids, next_id], axis: 1)}
    end
  end)
  
  IO.puts("") 
end)

IO.puts("\nDiagnostic Complete.")
