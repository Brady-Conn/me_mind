```elixir
defmodule DLM.Optimizer do
  import Nx.Defn

  # THE FIX: emb_w is now in the tracking tuple!
  defn update_step(input_ids, target_ids, emb_w, aw, fw, pos_emb, lr) do
    {loss, {grad_emb, grad_aw, grad_fw}} = value_and_grad(
      {emb_w, aw, fw}, 
      fn {e, a, f} -> DLM.Training.loss_fn(input_ids, target_ids, e, a, f, pos_emb) end
    )
    
    # Update the vocabulary!
    new_emb = Nx.subtract(emb_w, Nx.multiply(grad_emb, lr))
    new_aw = Nx.subtract(aw, Nx.multiply(grad_aw, lr))
    new_fw = Nx.subtract(fw, Nx.multiply(grad_fw, lr))
    
    {new_emb, new_aw, new_fw, loss}
  end

  defn run_chunk(input_ids, target_ids, emb_w, aw, fw, pos_emb, lr, opts \\ []) do
    opts = keyword!(opts, [:iterations])
    iterations = opts[:iterations]

    {final_emb, final_aw, final_fw, final_loss, _ids, _targs, _pos, _lr} = 
      while {emb_acc = emb_w, aw_acc = aw, fw_acc = fw, _loss = 0.0, 
             ids_acc = input_ids, targs_acc = target_ids, pos_acc = pos_emb, lr_acc = lr}, 
            _i <- 1..iterations do
        
        {new_emb, new_aw, new_fw, step_loss} = 
          update_step(ids_acc, targs_acc, emb_acc, aw_acc, fw_acc, pos_acc, lr_acc)
        
        {new_emb, new_aw, new_fw, step_loss, ids_acc, targs_acc, pos_acc, lr_acc}
      end
      
    {final_emb, final_aw, final_fw, final_loss}
  end
end
```

