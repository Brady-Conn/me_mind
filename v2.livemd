```elixir
# --- V5.1 THE DEEP BURN (RESUMING TRAINING) ---
max_lr = 0.1  # Starting at a low simmer
min_lr = 0.01 # Fading to almost nothing
chunks = 20   # A long, slow bake
epochs_per_chunk = 400
batch_size = 16 # Doubled to 16 to smooth out the MSE bounce!

IO.puts("--- Resuming 256-D Burn (The Deep Bake) ---")

# CRITICAL: We pass in final_v5_attn and final_v5_ff to pick up where we left off
{deep_v5_attn, deep_v5_ff, _} = 
  Enum.reduce(1..chunks, {final_v5_attn, final_v5_ff, 0.0}, fn c, {aw, fw, _} ->
    current_lr = max_lr - ((max_lr - min_lr) * (c / chunks))
    
    indices = Enum.take_random(0..(length(v4_sentences) - 1), batch_size) |> Nx.tensor()
    
    batch_inputs = 
      v4_inputs_ids 
      |> Nx.take(indices) 
      |> then(&Nx.take(emb_w, &1)) 
      |> Nx.add(pos_emb) 

    batch_targets = 
      v4_targets_ids 
      |> Nx.take(indices) 
      |> then(&Nx.take(emb_w, &1))

    {next_aw, next_fw, loss} = 
       DLM.Optimizer.run_chunk(batch_inputs, batch_targets, aw, fw, current_lr, iterations: epochs_per_chunk)
    
    l_val = Nx.to_number(loss)
    aw_safe = Nx.backend_copy(next_aw, Nx.BinaryBackend)
    fw_safe = Nx.backend_copy(next_fw, Nx.BinaryBackend)
    
    Nx.backend_deallocate(next_aw); Nx.backend_deallocate(next_fw); Nx.backend_deallocate(loss)
    :erlang.garbage_collect()
    
    IO.puts("Deep Chunk #{c} | LR: #{Float.round(current_lr, 4)} | MSE: #{Float.round(l_val, 8)} | RAM: #{round(:erlang.memory(:total) / 1_000_000)}MB")
    {aw_safe, fw_safe, l_val}
  end)

IO.puts("\n✅ V5 Deep Burn Complete!")
```

