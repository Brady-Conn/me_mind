```elixir
# --- V5 FINAL REVEAL (NUCLEUS + REP PENALTY) ---
seed_text = "the tiny black "
max_generate = 30
temp = 0.7
top_p = 0.9
rep_penalty = 5.0 # The Stutter Crusher

seed_ids = seed_text |> to_charlist() |> Nx.tensor() |> Nx.reshape({1, :auto})
generated_ids = seed_ids

IO.write("Generating: #{seed_text}")

Enum.reduce_while(1..max_generate, generated_ids, fn _i, acc_ids ->
  {_, current_len} = Nx.shape(acc_ids)
  
  # 1. Forward Pass (Dynamic Dimension Extraction)
  current_emb = Nx.take(emb_w, acc_ids)
  {_, _, dim} = Nx.shape(current_emb)
  
  p_emb = DLM.Positional.build(current_len, dim)
  input_with_pos = Nx.add(current_emb, p_emb)
  
  # Pass to our clean Inference module
  prediction_vec = DLM.Inference.predict_next(input_with_pos, final_v5_attn, final_v5_ff)
  
  # 2. Get Logits
  logits = Nx.dot(prediction_vec, Nx.transpose(emb_w)) |> Nx.reshape({256})
  
  # 3. Apply Repetition Penalty to recent history
  # Look at the last 4 characters to strongly discourage stutter loops
  history_len = min(current_len, 4)
  recent_history = acc_ids |> Nx.slice_along_axis(current_len - history_len, history_len, axis: 1) |> Nx.to_flat_list()
  
  biased_logits = Enum.reduce(recent_history, logits, fn char_id, acc_logits ->
    mask = Nx.indexed_put(Nx.broadcast(0.0, {256}), Nx.tensor([[char_id]]), Nx.tensor([rep_penalty]))
    Nx.subtract(acc_logits, mask)
  end)

  # 4. Nucleus Sampling (Top-P)
  probs = DLM.Inference.softmax(Nx.divide(biased_logits, temp))
  sorted_indices = Nx.argsort(probs, direction: :desc)
  sorted_probs = Nx.take(probs, sorted_indices)
  mask = Nx.less_equal(Nx.cumulative_sum(sorted_probs), top_p)
  mask = Nx.put_slice(mask, [0], Nx.tensor([1], type: :u8)) 
  
  filtered_probs = Nx.multiply(sorted_probs, mask) |> then(&Nx.divide(&1, Nx.sum(&1)))
  
  # 5. Sample and Decode
  {sample_idx, _} = Nx.Random.choice(Nx.Random.key(System.unique_integer([:positive])), Nx.iota({256}), filtered_probs)
  next_id_val = Nx.take(sorted_indices, sample_idx) |> Nx.squeeze() |> Nx.to_number()
  next_id = Nx.reshape(Nx.tensor([next_id_val]), {1, 1})

  # 6. The Hard Stop Kill Switch
  if next_id_val == 35 do # ASCII for '#'
    {:halt, acc_ids}
  else
    if next_id_val > 31 and next_id_val < 127 do
      IO.write(<<next_id_val>>)
    end
    {:cont, Nx.concatenate([acc_ids, next_id], axis: 1)}
  end
end)

IO.puts("\n\nGeneration Complete.")
```

