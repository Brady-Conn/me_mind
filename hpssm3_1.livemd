## BLiMP

```elixir
defmodule DLM.Phase3_Eval do
  import Nx.Defn

  defn compute_sentence_loss(input_tokens, target_tokens, h_base_init, h_top_init, frozen_base_p, top_p, frozen_map) do
    seq_len = Nx.axis_size(input_tokens, 1)
    
    # 1. Map inputs to continuous space
    input_coords =
      Nx.take(frozen_map, Nx.flatten(input_tokens))
      |> Nx.reshape({1, seq_len, 512})
      |> stop_grad()

    in_t = Nx.transpose(input_coords, axes: [1, 0, 2])
    targ_t = Nx.transpose(target_tokens, axes: [1, 0])

    zero_frame = Nx.broadcast(0.0, Nx.shape(h_top_init))

    # 2. The Physics Loop (Continuous Deep Stack)
    result =
      while {i = 0, total_loss = Nx.tensor(0.0, type: :f32),
             h_base = h_base_init, h_top = h_top_init,
             xp1 = zero_frame, xp2 = zero_frame,
             x_in = in_t, y_targ = targ_t,
             b_p = frozen_base_p, t_p = top_p, f_map = frozen_map},
            Nx.less(i, seq_len) do

        x_curr = x_in[i]

        # Update this in DLM.Main_SSM_Trainer.compute_sequence_loss AND DLM.Phase3_Eval.compute_sentence_loss
        {a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2, valve_w, valve_b, out_w, out_b} = t_p

        # --- LAYER 1: Frozen Base ---
        {_logits_fwd, _logits_retro, h_base_new} = DLM.TinySSM.forward_step(x_curr, h_base, b_p)

        # --- LAYER 2: Main SSM (Tick 1 Only for Evaluation) ---
        {_y_top1, h_top_1} = DLM.Main_SSM.ssm_recurrence(
          h_base_new, xp1, xp2, h_top, 
          a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2, valve_w, valve_b
        )

        # ⚡ Evaluate t+1 Prediction
        # Because BLiMP evaluates 1 sentence at a time, we reshape to {1, 128}
        logits_t1 = Nx.dot(h_top_new, out_w) |> Nx.add(out_b) |> Nx.reshape({1, 128})

        # Calculate loss against the raw integer targets
        step_loss = DLM.Loss.cross_entropy(logits_t1, y_targ[i])

        # ⚡ Shift Convolutional History: xp1 becomes the new h_base_new, xp2 becomes old xp1
        {i + 1, Nx.add(total_loss, step_loss), h_base_new, h_top_new, h_base_new, xp1, x_in, y_targ, b_p, t_p, f_map}
      end

    Nx.divide(elem(result, 1), seq_len)
  end
end
```

