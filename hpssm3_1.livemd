```elixir
defmodule DLM.MuonHybrid do
  import Nx.Defn

  defn newton_schulz(g, iters \\ 5) do
    frobenius_norm = Nx.sqrt(Nx.sum(Nx.pow(g, 2))) + 1.0e-7
    x = g / frobenius_norm
    
    {final_x, _} = while {curr_x = x, i = 0}, Nx.less(i, iters) do
      x_t_x = Nx.dot(Nx.transpose(curr_x), curr_x)
      next_x = 1.5 * curr_x - 0.5 * Nx.dot(curr_x, x_t_x)
      {next_x, i + 1}
    end
    final_x
  end

  defn clip_norm(param, max_norm) do
    norm = Nx.sqrt(Nx.sum(Nx.pow(param, 2))) + 1.0e-7
    scale = Nx.min(1.0, max_norm / norm)
    Nx.multiply(param, scale)
  end

  # ⚡ REPAIRED: Muon now properly uses Momentum
  defn muon_update(param, grad, m, lr, max_norm) do
    beta1 = 0.9
    
    # 1. Accumulate the Momentum Flywheel
    new_m = beta1 * m + (1.0 - beta1) * grad
    
    # 2. Orthogonalize the MOMENTUM, not the raw gradient
    step = newton_schulz(new_m)
    
    # 3. Apply the step
    param_update = param - lr * step
    
    # 4. Enforce the geometric safety boundary
    clipped_param = clip_norm(param_update, max_norm)
    
    {clipped_param, new_m}
  end

  defn adam_update(param, grad, m, v, step, lr) do
    safe_step = step + 1.0
    beta1 = 0.9
    beta2 = 0.999
    eps = 1.0e-8
    
    new_m = beta1 * m + (1.0 - beta1) * grad
    new_v = beta2 * v + (1.0 - beta2) * Nx.pow(grad, 2)
    
    m_hat = new_m / (1.0 - Nx.pow(beta1, safe_step))
    v_hat = new_v / (1.0 - Nx.pow(beta2, safe_step))
    
    param_update = param - lr * m_hat / (Nx.sqrt(v_hat) + eps)
    {param_update, new_m, new_v}
  end

  defn step(params, grads, ms, vs, step_count, lr) do
    norm_cap = Nx.tensor(35.0, type: :f32)

    # ⚡ Unpack 15 elements
    {p_a, p_bu, p_bv, p_cu, p_cv, p_du, p_dv, p_mu1, p_mv1, p_mu2, p_mv2, 
     p_valve_w, p_valve_b, p_out_w, p_out_b} = params
  
    {g_a, g_bu, g_bv, g_cu, g_cv, g_du, g_dv, g_mu1, g_mv1, g_mu2, g_mv2, 
     g_valve_w, g_valve_b, g_out_w, g_out_b} = grads
  
    {m_a, m_bu, m_bv, m_cu, m_cv, m_du, m_dv, m_mu1, m_mv1, m_mu2, m_mv2, 
     m_valve_w, m_valve_b, m_out_w, m_out_b} = ms
  
    {v_a, v_bu, v_bv, v_cu, v_cv, v_du, v_dv, v_mu1, v_mv1, v_mu2, v_mv2, 
     v_valve_w, v_valve_b, v_out_w, v_out_b} = vs
  
    # ⚡ Adam for Scalars/Biases
    {up_a, nm_a, nv_a} = adam_update(p_a, g_a, m_a, v_a, step_count, lr)
    {up_valve_b, nm_valve_b, nv_valve_b} = adam_update(p_valve_b, g_valve_b, m_valve_b, v_valve_b, step_count, lr)
    {up_out_b, nm_out_b, nv_out_b} = adam_update(p_out_b, g_out_b, m_out_b, v_out_b, step_count, lr)
    
    # ⚡ Repaired Muon for 2D Matrices
    {up_bu, nm_bu} = muon_update(p_bu, g_bu, m_bu, lr, norm_cap)
    {up_bv, nm_bv} = muon_update(p_bv, g_bv, m_bv, lr, norm_cap)
    {up_cu, nm_cu} = muon_update(p_cu, g_cu, m_cu, lr, norm_cap)
    {up_cv, nm_cv} = muon_update(p_cv, g_cv, m_cv, lr, norm_cap)
    {up_du, nm_du} = muon_update(p_du, g_du, m_du, lr, norm_cap)
    {up_dv, nm_dv} = muon_update(p_dv, g_dv, m_dv, lr, norm_cap)
    {up_mu1, nm_mu1} = muon_update(p_mu1, g_mu1, m_mu1, lr, norm_cap)
    {up_mv1, nm_mv1} = muon_update(p_mv1, g_mv1, m_mv1, lr, norm_cap)
    {up_mu2, nm_mu2} = muon_update(p_mu2, g_mu2, m_mu2, lr, norm_cap)
    {up_mv2, nm_mv2} = muon_update(p_mv2, g_mv2, m_mv2, lr, norm_cap)
    {up_valve_w, nm_valve_w} = muon_update(p_valve_w, g_valve_w, m_valve_w, lr, norm_cap)
    {up_out_w, nm_out_w} = muon_update(p_out_w, g_out_w, m_out_w, lr, norm_cap)
  
    # Repack
    new_params = {up_a, up_bu, up_bv, up_cu, up_cv, up_du, up_dv, up_mu1, up_mv1, up_mu2, up_mv2, 
                  up_valve_w, up_valve_b, up_out_w, up_out_b}
  
    new_ms = {nm_a, nm_bu, nm_bv, nm_cu, nm_cv, nm_du, nm_dv, nm_mu1, nm_mv1, nm_mu2, nm_mv2, 
              nm_valve_w, nm_valve_b, nm_out_w, nm_out_b}
  
    new_vs = {nv_a, v_bu, v_bv, v_cu, v_cv, v_du, v_dv, v_mu1, v_mv1, v_mu2, v_mv2, 
              v_valve_w, nv_valve_b, v_out_w, nv_out_b}
  
    {new_params, new_ms, new_vs}
  end
end
```

