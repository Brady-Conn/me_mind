```elixir
defmodule DLM.PhysicsGenesis do
  import Nx.Defn

  @dim 512
  @vocab 128

  defn init(k1) do
    std_voc = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@vocab, type: :f32)))
    std_dim = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@dim, type: :f32)))

    # projection matrices
    {em, k2} = Nx.Random.normal(k1, 0.0, std_voc, shape: {@vocab, @dim})
    {de, k3} = Nx.Random.normal(k2, 0.0, std_dim, shape: {@dim, @vocab})

    trainable_params = {em, de} 
    
    {trainable_params, k3}
  end
end
