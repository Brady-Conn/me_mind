```elixir
defmodule DLM.ISDGenerator do
  import Nx.Defn

  # ⚡ 1. The Hardware-Level Stochastic Sampler
  defn sample_token(logits, key, temp, top_p) do
    # 1. Apply Temperature Scaling
    scaled_logits = Nx.divide(logits, Nx.max(temp, 1.0e-4))
    
    # 2. Convert to stable probabilities
    max_l = Nx.reduce_max(scaled_logits, axes: [-1], keep_axes: true)
    exp_l = Nx.exp(Nx.subtract(scaled_logits, max_l))
    probs = Nx.divide(exp_l, Nx.sum(exp_l, axes: [-1], keep_axes: true))
    
    # 3. Apply Top-P (Nucleus) Masking
    sorted_indices = Nx.argsort(probs, axis: -1, direction: :desc)
    sorted_probs = Nx.take_along_axis(probs, sorted_indices, axis: -1)
    cumsum = Nx.cumulative_sum(sorted_probs, axis: -1)
    
    # Keep tokens where the cumulative sum (excluding themselves) is < top_p
    mask = Nx.less(Nx.subtract(cumsum, sorted_probs), top_p)
    filtered_sorted_logits = Nx.select(mask, Nx.take_along_axis(scaled_logits, sorted_indices, axis: -1), -1.0e9)
    
    # Unsort back to original vocabulary order
    unsort_indices = Nx.argsort(sorted_indices, axis: -1, direction: :asc)
    final_logits = Nx.take_along_axis(filtered_sorted_logits, unsort_indices, axis: -1)

    # 4. Gumbel-Softmax Sampling (Roll the dice)
    {noise, new_key} = Nx.Random.uniform(key, shape: Nx.shape(final_logits), type: :f32)
    gumbel = Nx.negate(Nx.log(Nx.negate(Nx.log(Nx.add(noise, 1.0e-7)))))
    sampled_token = Nx.argmax(Nx.add(final_logits, gumbel), axis: -1)
    
    {sampled_token, new_key}
  end

  # ⚡ 2. The Core ISD Step
  defn isd_step(x_t, h_prev, frozen, retro, key, temp, top_p) do
    {logits_fwd, logits_retro, h_new} = DLM.TinySSM.forward_step(x_t, h_prev, frozen, retro)
    
    # 🎲 Proposer uses stochastic sampling
    {proposed_next_token, new_key} = sample_token(logits_fwd, key, temp, top_p)
    
    # 🔒 Verifier MUST remain strict argmax
    verified_prev_token = Nx.argmax(logits_retro, axis: -1)
    
    {proposed_next_token, verified_prev_token, h_new, new_key}
  end

  # ⚡ 3. The Multi-Step Stride
  def stride(start_token, h_init, frozen_map, retro_map, frozen_embeds, key, temp, top_p, stride_length \\ 4) do
    {final_props, final_verifs, final_states, _h, _tok, final_key} =
      Enum.reduce(1..stride_length, {[], [], [], h_init, start_token, key}, fn _step, {props, verifs, states, h_curr, x_curr, k_curr} ->
        
        x_emb = Nx.take(frozen_embeds, Nx.tensor([x_curr]))
        
        {prop_tok, verif_tok, h_next, k_next} = isd_step(x_emb, h_curr, frozen_map, retro_map, k_curr, temp, top_p)
        
        p_val = Nx.to_number(prop_tok[0])
        v_val = Nx.to_number(verif_tok[0])

        {[p_val | props], [v_val | verifs], [h_next | states], h_next, p_val, k_next}
      end)

    {Enum.reverse(final_props), Enum.reverse(final_verifs), Enum.reverse(final_states), final_key}
  end

  # ⚡ 4. Acceptance Logic (Unchanged)
  def accept_stride(base_sequence, proposals, verifications, states) do
    actual_past = [List.last(base_sequence) | Enum.drop(proposals, -1)]
    
    accepted_count =
      Enum.zip(verifications, actual_past)
      |> Enum.take_while(fn {verif, actual} -> verif == actual end)
      |> length()
      |> max(1)

    accepted_tokens = Enum.take(proposals, accepted_count)
    accepted_state = Enum.at(states, accepted_count - 1)

    {accepted_tokens, accepted_state}
  end
end
