```elixir
defmodule DLM.Tree do
  @moduledoc """
  Recursively maps a function over nested tuples AND maps of tensors.
  Works perfectly both in standard Elixir AND inside Nx `defn`.
  """
  
  # ⚡ NEW: Handle Maps (like frozen_map and retro_map)
  def map(map_data, func) when is_map(map_data) and not is_struct(map_data) do
    Map.new(map_data, fn {k, v} -> {k, map(v, func)} end)
  end

  # Handle Tuples (like the old 9-param state)
  def map(tuple_data, func) when is_tuple(tuple_data) do
    tuple_data
    |> Tuple.to_list()
    |> Enum.map(&map(&1, func))
    |> List.to_tuple()
  end

  # The base case: When it hits a tensor (or a compile-time Expr), apply the function
  def map(tensor, func) do
    func.(tensor)
  end
end
