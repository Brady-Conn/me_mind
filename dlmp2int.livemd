## Train

```elixir
defmodule DLM.Phase2Trainer do
  import Nx.Defn

  defn compute_sequence_loss(input_tokens, target_tokens, h_init, frozen, retro, frozen_embeds) do
    # 1. Continuous embeddings for the Forward pass
    input_coords =
      Nx.take(frozen_embeds, Nx.flatten(input_tokens))
      |> Nx.reshape({Nx.axis_size(input_tokens, 0), Nx.axis_size(input_tokens, 1), 512})
      |> stop_grad() 

    inputs_time_first = Nx.transpose(input_coords, axes: [1, 0, 2])
    
    # 2. Discrete integer tokens for the Cross Entropy calculations
    targets_time_first = Nx.transpose(target_tokens, axes: [1, 0])
    discrete_inputs_time_first = Nx.transpose(input_tokens, axes: [1, 0])

    result =
      while {i = 0, 
             total_fwd = Nx.tensor(0.0, type: :f32), 
             total_retro = Nx.tensor(0.0, type: :f32), 
             h = h_init, 
             inputs = inputs_time_first, 
             targets_fwd = targets_time_first, 
             targets_retro = discrete_inputs_time_first,
             f = frozen, r = retro},
            Nx.less(i, Nx.axis_size(inputs, 0)) do
      
        x_curr_emb = inputs[i]
        y_fwd = targets_fwd[i]
        y_retro = targets_retro[i] # The token we are currently processing

        # 3. The Dual Probe Step
        {logits_fwd, logits_retro, h_new} = DLM.TinySSM.forward_step(x_curr_emb, h, f, r)
        
        # 4. Calculate Both Losses
        step_loss_fwd = DLM.Loss.cross_entropy(logits_fwd, y_fwd)
        step_loss_retro = DLM.Loss.cross_entropy(logits_retro, y_retro)
        
        {i + 1, Nx.add(total_fwd, step_loss_fwd), Nx.add(total_retro, step_loss_retro), h_new, inputs, targets_fwd, targets_retro, f, r}
      end

    accumulated_fwd = elem(result, 1)
    accumulated_retro = elem(result, 2)
    seq_len_f = Nx.axis_size(inputs_time_first, 0)
    
    mean_fwd = Nx.divide(accumulated_fwd, seq_len_f)
    mean_retro = Nx.divide(accumulated_retro, seq_len_f)

    # 5. The Introspective Objective (0.3 weight to the retro probe)
    total_loss = Nx.add(mean_fwd, Nx.multiply(0.3, mean_retro))

    # ⚡ THE FIX: Bundle the auxiliary data into a single nested tuple
    {total_loss, {mean_fwd, mean_retro}}
  end

  defn compute_grad(frozen_map, retro_map, batch_tokens, h_init, frozen_embeds) do
    {_batch_size, full_seq_len} = Nx.shape(batch_tokens)
    seq_len = full_seq_len - 1
    
    input_tokens  = Nx.slice_along_axis(batch_tokens, 0, seq_len, axis: 1)
    target_tokens = Nx.slice_along_axis(batch_tokens, 1, seq_len, axis: 1)

    # ⚡ THE FIX: 1. Evaluate the full output first to extract our telemetry
    {total_loss, {fwd_loss, retro_loss}} = compute_sequence_loss(
      input_tokens, target_tokens, h_init, frozen_map, retro_map, frozen_embeds
    )
  
    # ⚡ THE FIX: 2. Run value_and_grad, but force the closure to ONLY return the total_loss scalar
    {_loss, raw_grads} = value_and_grad(retro_map, fn r ->
      {tot_loss, _aux_data} = compute_sequence_loss(
        input_tokens, target_tokens, h_init, frozen_map, r, frozen_embeds
      )
      tot_loss
    end)
  
    # Clip only the two retro gradients
    clipped_grads = %{
      rw: Nx.clip(raw_grads.rw, -1.0, 1.0),
      rb: Nx.clip(raw_grads.rb, -1.0, 1.0)
    }
  
    {total_loss, fwd_loss, retro_loss, clipped_grads}
  end
end
