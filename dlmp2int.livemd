```elixir
defmodule DLM.ProbeInference do
  import Nx.Defn

  defn prime_state(tokens_tensor, h_init, frozen_map, retro_map, frozen_embeds) do
    {_, final_h, _, _, _, _} =
      while {i = 0, h = h_init, tokens = tokens_tensor, f_map = frozen_map, r_map = retro_map, f_embeds = frozen_embeds},
            Nx.less(i, Nx.axis_size(tokens, 0)) do
        
        x_emb = Nx.take(f_embeds, Nx.new_axis(tokens[i], 0))
        # We can pass dummy temp/key here since we ignore the generated tokens during priming
        dummy_key = Nx.Random.key(1)
        {_, _, h_next, _} = DLM.ISDGenerator.isd_step(x_emb, h, f_map, r_map, dummy_key, 1.0, 1.0)
        
        {i + 1, h_next, tokens, f_map, r_map, f_embeds}
      end
    final_h
  end

  def generate(prompt_text, num_tokens, frozen_map, retro_map, frozen_embeds, temp \\ 0.8, top_p \\ 0.9) do
    gpu = {EXLA.Backend, client: :rocm}

    prompt_tokens = to_charlist(prompt_text)
    prime_tokens = Enum.drop(prompt_tokens, -1)

    IO.puts("🧠 Priming state with prompt: '#{prompt_text}'")
    h_init = Nx.broadcast(0.0, {1, 512}) |> Nx.as_type(:f32) |> Nx.backend_copy(gpu)
    
    h_primed = 
      if length(prime_tokens) > 0 do
        prime_tensor = Nx.tensor(prime_tokens, type: :s32) |> Nx.backend_copy(gpu)
        prime_state(prime_tensor, h_init, frozen_map, retro_map, frozen_embeds)
      else
        h_init
      end

    stride_length = 4
    
    # Initialize the PRNG Key and hyperparameter tensors
    initial_key = Nx.Random.key(System.system_time(:second)) |> Nx.backend_copy(gpu)
    t_tensor = Nx.tensor(temp, type: :f32) |> Nx.backend_copy(gpu)
    p_tensor = Nx.tensor(top_p, type: :f32) |> Nx.backend_copy(gpu)

    {final_sequence, _final_h, total_strides, _final_key} =
      Enum.reduce_while(1..num_tokens, {prompt_tokens, h_primed, 0, initial_key}, fn _, {current_seq, h_curr, stride_count, k_curr} ->
        
        if length(current_seq) >= length(prompt_tokens) + num_tokens do
          {:halt, {current_seq, h_curr, stride_count, k_curr}}
        else
          last_token = List.last(current_seq)

          {proposals, verifs, states, k_next} = DLM.ISDGenerator.stride(
            last_token, h_curr, frozen_map, retro_map, frozen_embeds, k_curr, t_tensor, p_tensor, stride_length
          )

          {accepted_tokens, next_h} = DLM.ISDGenerator.accept_stride(current_seq, proposals, verifs, states)

          next_seq = current_seq ++ accepted_tokens

          {:cont, {next_seq, next_h, stride_count + 1, k_next}}
        end
      end)

    generated_text = to_string(final_sequence)
    tokens_added = length(final_sequence) - length(prompt_tokens)
    efficiency = Float.round(tokens_added / total_strides, 2)

    IO.puts("\n✨ Generation Complete!")
    IO.puts("📊 Speedup Factor: #{efficiency} tokens accepted per forward stride.")
    IO.puts("\n🤖 Output:\n#{generated_text}")
    
    generated_text
  end
end
