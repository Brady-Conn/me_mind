```elixir
run_prefix  = "v38_probe_60k_graft"  
total_steps = 10000 # Short diagnostic run!

# 1. Load the frozen map (YOUR EXACT 60K SOTA FILE GOES HERE)
sota_path = "v38_DLM_Phase_2_ce_sink_adam_xsa_3e4lr_50ncap_checkpoint_step_60000.bin"
{a, bu, bv, _cu, _cv, du, dv, vw, vb} = File.read!(sota_path) |> :erlang.binary_to_term()
cpu_frozen_map = %{a_gate: a, bu: bu, bv: bv, du: du, dv: dv, vw: vw, vb: vb}
frozen_map = DLM.Tree.map(cpu_frozen_map, &Nx.backend_copy(&1, gpu))

# 2. Load the Manifold
%{params: phase1_p} = File.read!("phase1_sinkhorn_diffusion_25k_COMPLETE.bin") |> :erlang.binary_to_term()
{cpu_embeds, _w1, _w2, _key} = phase1_p
frozen_embeds = cpu_embeds |> Nx.backend_copy(gpu) |> DLM.Loss.l2_normalize()

# 3. Initialize ONLY the Retro Matrices (Dense to 128D)
initial_key = Nx.Random.key(System.system_time())
{rw, k1} = Nx.Random.normal(initial_key, 0.0, 0.02, shape: {512, 128})
rb = Nx.broadcast(0.0, {128}) |> Nx.as_type(:f32)
cpu_retro_map = %{rw: rw, rb: rb}
retro_map = DLM.Tree.map(cpu_retro_map, &Nx.backend_copy(&1, gpu))

# Initialize Optimizer state for only 2 matrices
zero_state = DLM.Tree.map(cpu_retro_map, fn p -> Nx.broadcast(0.0, Nx.shape(p)) end)
m = DLM.Tree.map(zero_state, &Nx.backend_copy(&1, gpu))
v = DLM.Tree.map(zero_state, &Nx.backend_copy(&1, gpu))
step_count = Nx.tensor(0) |> Nx.backend_copy(gpu)

# 4. Stream setup
batch_size = 32
seq_len = 128  
dataset_2d = File.read!("scholar_full_mixed_128.bin") |> :erlang.binary_to_term()
dataset = Nx.flatten(dataset_2d)
data_stream = DLM.DataStreamer.build_infinite_stream(dataset, batch_size, seq_len)

# ⚡ 5. The Diagnostic Loop
{final_retro, _m, _v, _step} = 
  Enum.reduce(Enum.zip(0..(total_steps - 1), data_stream), {retro_map, m, v, step_count}, fn {step, cpu_batch}, {cr, cm, cv, c_step} ->
    
    gpu_batch = Nx.backend_copy(cpu_batch, gpu)
    
    # Run a flat, slightly higher learning rate so the probe can learn fast
    current_lr = 1.0e-4
    lr_tensor = Nx.tensor(current_lr, type: :f32) |> Nx.backend_copy(gpu)
    h_init = Nx.broadcast(0.0, {batch_size, 512}) |> Nx.as_type(:f32) |> Nx.backend_copy(gpu)

    # Only pass the retro_map to be optimized
    {_tot_tensor, fwd_tensor, retro_tensor, grads} = DLM.Phase2Trainer.compute_grad(
      frozen_map, cr, gpu_batch, h_init, frozen_embeds
    )

    {up_r, up_m, up_v, up_step} = DLM.ProbeOptimizer.update(cr, grads, cm, cv, c_step, lr_tensor)

    # ➡️ Telemetry
    if rem(step, 50) == 0 do
      fwd_val = Nx.to_number(fwd_tensor)
      retro_val = Nx.to_number(retro_tensor)
      IO.puts("➡️  Step #{step} | FWD Loss: #{Float.round(fwd_val, 4)} | RETRO Loss: #{Float.round(retro_val, 4)}")
    end

    {up_r, up_m, up_v, up_step}
  end)

IO.puts("✅ Probe Training Complete!")
