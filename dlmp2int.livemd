```elixir
defmodule DLM.ProbeOptimizer do
  import Nx.Defn
  
  # Uses your exact AdamW math from DLM.Adam7
  defn adam_step(p, g, m, v, step, lr) do
    beta1 = 0.9
    beta2 = 0.999
    flat_decay = 1.0e-4

    m_new = Nx.add(Nx.multiply(beta1, m), Nx.multiply(1.0 - beta1, g))
    v_new = Nx.add(Nx.multiply(beta2, v), Nx.multiply(1.0 - beta2, Nx.pow(g, 2)))

    m_hat = Nx.divide(m_new, Nx.subtract(1.0, Nx.pow(beta1, step)))
    v_hat = Nx.divide(v_new, Nx.subtract(1.0, Nx.pow(beta2, step)))

    update_val = Nx.multiply(lr, Nx.divide(m_hat, Nx.add(Nx.sqrt(v_hat), 1.0e-8)))

    p_decayed = Nx.subtract(p, Nx.multiply(flat_decay, p))
    p_new = Nx.subtract(p_decayed, update_val)

    # Hard ceiling
    current_norm = Nx.sqrt(Nx.sum(Nx.pow(p_new, 2)))
    scale_factor = Nx.select(current_norm > 50.0, Nx.divide(50.0, Nx.add(current_norm, 1.0e-8)), 1.0)
    
    {Nx.multiply(p_new, scale_factor), m_new, v_new}
  end

  defn update(retro_params, grads, ms, vs, step, lr) do
    new_step = Nx.add(step, 1)
    
    {rw_new, mrw_new, vrw_new} = adam_step(retro_params.rw, grads.rw, ms.rw, vs.rw, new_step, lr)
    {rb_new, mrb_new, vrb_new} = adam_step(retro_params.rb, grads.rb, ms.rb, vs.rb, new_step, lr)

    new_params = %{rw: rw_new, rb: rb_new}
    new_ms = %{rw: mrw_new, rb: mrb_new}
    new_vs = %{rw: vrw_new, rb: vrb_new}
    
    {new_params, new_ms, new_vs, new_step}
  end
end
