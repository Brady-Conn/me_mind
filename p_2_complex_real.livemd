## Frozen Fourier Build

```elixir
defmodule DLM.FourierReservoirBuild do
  import Nx.Defn

  @dim 128 

  def build_fourier_matrix do
    pairs = div(@dim, 2)
    
    # Generate real and imaginary flattened lists
    {flat_real, flat_imag} = 
      for row <- 0..(@dim - 1), col <- 0..(@dim - 1), reduce: ([], []) do
        {real_acc, imag_acc} ->
          pair_row = div(row, 2)
          pair_col = div(col, 2)
  
          if pair_row == pair_col do
            w = 0.01 + pair_row * (:math.pi() - 0.01) / max(1, pairs - 1)
            
            # Compute Real & Imaginary components for the current element
            {real_val, imag_val} = cond do
              rem(row, 2) == 0 and rem(col, 2) == 0 -> {:math.cos(w), 0.0}
              rem(row, 2) == 0 and rem(col, 2) == 1 -> (-:math.sin(w), 0.0)
              rem(row, 2) == 1 and rem(col, 2) == 0 -> (0.0, :math.sin(w))
              rem(row, 2) == 1 and rem(col, 2) == 1 -> (0.0, :math.cos(w))
            end
            
            {[real_val | real_acc], [imag_val | imag_acc]}
          else
            {[0.0 | real_acc], [0.0 | imag_acc]}
          end
      end
      
    # Reverse accumulations since list comprehensions push to the head
    flat_real = Enum.reverse(flat_real)
    flat_imag = Enum.reverse(flat_imag)
  
    # Create complex tensor using Nx
    real_tensor = Nx.tensor(flat_real, type: :f32) |> Nx.reshape({@dim, @dim})
    imag_tensor = Nx.tensor(flat_imag, type: :f32) |> Nx.reshape({@dim, @dim})
  
    Nx.complex(real_tensor, imag_tensor)
  end


  def build_and_save(output_path) do
    fr = build_fourier_matrix()

    IO.puts("Saving tuned reservoir to #{output_path}...")
    
    cpu_f = DLM.Tree.map(fr, &Nx.backend_transfer(&1, Nx.BinaryBackend))
    
    File.write!(output_path, :erlang.term_to_binary(%{frozen: cpu_f}))
    IO.puts("file write complete")
  end
end
```

