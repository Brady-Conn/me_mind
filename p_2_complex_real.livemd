```elixir
defmodule DLM.PhysicsGenesis do
  import Nx.Defn

  @vocab 128
  @dim 512

  defn init(k1) do
    std_dim = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@dim, type: :f32)))
    std_voc = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@vocab, type: :f32)))
    std_496 = Nx.divide(1.0, Nx.sqrt(Nx.tensor(4096, type: :f32)))

    # projection matrices
    {b1r, k2} = Nx.Random.normal(k1, 0.0, std_voc, shape: {@vocab, @dim})
    {b1i, k3} = Nx.Random.normal(k2, 0.0, std_voc, shape: {@vocab, @dim})
     b1 = Nx.complex(b1r, b1i)
    {b2r, k4} = Nx.Random.normal(k3, 0.0, std_dim, shape: {@dim, @vocab})
    {b2i, k5} = Nx.Random.normal(k4, 0.0, std_dim, shape: {@dim, @vocab})
     b2 = Nx.complex(b2r, b2i)
    {c1r, k6} = Nx.Random.normal(k5, 0.0, std_voc, shape: {@vocab, @dim})
    {c1i, k7} = Nx.Random.normal(k6, 0.0, std_voc, shape: {@vocab, @dim})
     c1 = Nx.complex(c1r, c1i)
    {c2r, k8} = Nx.Random.normal(k7, 0.0, std_dim, shape: {@dim, @vocab})
    {c2i, k9} = Nx.Random.normal(k8, 0.0, std_dim, shape: {@dim, @vocab})
     c2 = Nx.complex(c2r, c2i)
    {w1r, k10} = Nx.Random.normal(k9, 0.0, std_voc, shape: {@vocab, @dim})
    {w1i, k11} = Nx.Random.normal(k10, 0.0, std_voc, shape: {@vocab, @dim})
     w1 = Nx.complex(w1r, w1i)
    {w2r, k12} = Nx.Random.normal(k11, 0.0, std_dim, shape: {@dim, @vocab})
    {w2i, k13} = Nx.Random.normal(k12, 0.0, std_dim, shape: {@dim, @vocab})
     w2 = Nx.complex(w2r, w2i)
    {wdr, k14} = Nx.Random.normal(k13, 0.0, std_496, shape: {4096, @vocab})
    {wdi, k15} = Nx.Random.normal(k14, 0.0, std_496, shape: {4096, @vocab})
     wd = Nx.complex(wdr, wdi)

    # projection bias vectors
    bbr = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    bbi = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    bb = Nx.complex(bbr, bbi)
    cbr = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    cbi = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    cb = Nx.complex(cbr, cbi)
    wbr = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    wbi = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    wb = Nx.complex(wbr, wbi)
    # projection scaling vectors
    bqr = Nx.broadcast(1.0, {@dim}) |> Nx.as_type(:f32)
    bqi = Nx.broadcast(1.0, {@dim}) |> Nx.as_type(:f32)
    bq = Nx.complex(bqr, bqi)
    cqr = Nx.broadcast(1.0, {@dim}) |> Nx.as_type(:f32)
    cqi = Nx.broadcast(1.0, {@dim}) |> Nx.as_type(:f32)
    cq = Nx.complex(cqr, cqi)
    wqr = Nx.broadcast(1.0, {@dim}) |> Nx.as_type(:f32)
    wqi = Nx.broadcast(1.0, {@dim}) |> Nx.as_type(:f32)
    wq = Nx.complex(wqr, wqi)
    # rms norm beta and gamma vectors
    ber = Nx.broadcast(0.0, {@vocab}) |> Nx.as_type(:f32)
    bei = Nx.broadcast(0.0, {@vocab}) |> Nx.as_type(:f32)
    be = Nx.complex(ber, bei)
    bgr = Nx.broadcast(1.0, {@vocab}) |> Nx.as_type(:f32)
    bgi = Nx.broadcast(1.0, {@vocab}) |> Nx.as_type(:f32)
    bg = Nx.complex(bgr, bgi)
    cer = Nx.broadcast(0.0, {@vocab}) |> Nx.as_type(:f32)
    cei = Nx.broadcast(0.0, {@vocab}) |> Nx.as_type(:f32)
    ce = Nx.complex(cer, cei)
    cgr = Nx.broadcast(1.0, {@vocab}) |> Nx.as_type(:f32)
    cgi = Nx.broadcast(1.0, {@vocab}) |> Nx.as_type(:f32)
    cg = Nx.complex(cgr, cgi)
    wer = Nx.broadcast(0.0, {@vocab}) |> Nx.as_type(:f32)
    wei = Nx.broadcast(0.0, {@vocab}) |> Nx.as_type(:f32)
    we = Nx.complex(wer, wei)
    wgr = Nx.broadcast(1.0, {@vocab}) |> Nx.as_type(:f32)
    wgi = Nx.broadcast(1.0, {@vocab}) |> Nx.as_type(:f32)
    wg = Nx.complex(wgr, wgi)
    
    trainable_params = {b1, b2, bb, bq, bg, be, 
                        c1, c2, cb, cq, cg, ce,
                        w1, w2, wb, wq, wg, we, wd} 
    
    {trainable_params, k15}
  end
end
