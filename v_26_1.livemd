## USSM, Positional, Muon_Optimizer

```elixir
defmodule DLM.DiffusionTensor do
  import Nx.Defn

  @num_bits 8
  @dim 512

  defn to_bits(tokens) do
    shifts = Nx.iota({@num_bits}) 
             |> Nx.multiply(-1) 
             |> Nx.add(@num_bits - 1)
             |> Nx.as_type(:u32)
    
    tokens_expanded = Nx.new_axis(tokens, -1)
    shifted = Nx.right_shift(tokens_expanded, shifts)
    Nx.bitwise_and(shifted, 1) |> Nx.as_type(:f32)
  end

  # ⚡ Only keep this one!
  defn project(tokens, diff_w1, diff_w2, key) do
    bits = to_bits(tokens)
    
    condition = Nx.dot(bits, diff_w1)
    {batch, seq_len, _} = Nx.shape(bits)
    {noise, next_key} = Nx.Random.normal(key, 0.0, 1.0, shape: {batch, seq_len, @dim})
    
    gate = condition * Nx.sigmoid(condition)
    manifold_shift = Nx.dot(gate, diff_w2)
    
    final_tensor = Nx.add(manifold_shift, Nx.multiply(noise, 0.01))
    
    {final_tensor, next_key}
  end
end
```

