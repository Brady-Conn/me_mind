```elixir
defmodule BabyLM.BlendedParser do
  @sequence_length 256 

  # ⚡ Added the .txt extensions!
  @datasets %{
    childes: ["childes.train.txt"], 
    bnc: ["bnc_spoken.train.txt"],
    switchboard: ["switchboard.train.txt"],
    subtitles: ["open_subtitles.train.txt"], # The raw 15MB file
    wiki: ["simple_wiki.train.txt"],
    gutenberg: ["gutenberg.train.txt"]
  }

  def build_master_curriculum(directory_path) do
    # 1. Load and chunk (The garbage filter is active inside load_and_chunk!)
    childes_chunks = load_and_chunk(directory_path, @datasets.childes)
    bnc_chunks = load_and_chunk(directory_path, @datasets.bnc)
    switchboard_chunks = load_and_chunk(directory_path, @datasets.switchboard)
    subtitles_chunks = load_and_chunk(directory_path, @datasets.subtitles)
    wiki_chunks = load_and_chunk(directory_path, @datasets.wiki)
    gutenberg_chunks = load_and_chunk(directory_path, @datasets.gutenberg)

    IO.puts("\n🧬 Mixing Continuous Curriculum Timeline...")

    # STAGE 1: The Foundation (Toddler & Basic Speech)
    # 80% Childes, 20% BNC
    stage_1 = 
      sample_chunks(childes_chunks, 0.8, 15_000) ++ 
      sample_chunks(bnc_chunks, 0.2, 15_000)
      |> Enum.shuffle()

    # STAGE 2: The Conversationalist (Injecting Subtitles & Switchboard)
    # 40% Childes, 10% BNC, 48% Subtitles, 2% Switchboard
    stage_2 = 
      sample_chunks(childes_chunks, 0.4, 25_000) ++ 
      sample_chunks(bnc_chunks, 0.1, 25_000) ++
      sample_chunks(subtitles_chunks, 0.48, 25_000) ++
      sample_chunks(switchboard_chunks, 0.02, 25_000)
      |> Enum.shuffle()

    # STAGE 3: The Scholar (The Official Baseline Target Distribution)
    # 29% Childes, 8% BNC, 20% Subtitles, 1% Switchboard, 15% Wiki, 27% Gutenberg
    stage_3 = 
      sample_chunks(childes_chunks, 0.29, 50_000) ++ 
      sample_chunks(bnc_chunks, 0.08, 50_000) ++
      sample_chunks(subtitles_chunks, 0.20, 50_000) ++
      sample_chunks(switchboard_chunks, 0.01, 50_000) ++
      sample_chunks(wiki_chunks, 0.15, 50_000) ++
      sample_chunks(gutenberg_chunks, 0.27, 50_000)
      |> Enum.shuffle()

    # Concatenate the timeline into one master list (Total: 90,000 sequences)
    master_timeline = stage_1 ++ stage_2 ++ stage_3

    IO.puts("📦 Packing #{length(master_timeline)} sequences into Nx Tensor...")

    # Pack and Save to CPU RAM
    dataset_tensor = 
      Nx.tensor(master_timeline, type: :u8)
      |> Nx.backend_transfer(Nx.BinaryBackend) 
    
    File.write!("master_curriculum.bin", :erlang.term_to_binary(dataset_tensor))
    IO.puts("🎉 master_curriculum.bin successfully generated!")
  end

  # --- Helper Functions ---

  defp load_and_chunk(dir, files) do
    raw_text = 
      files
      |> Enum.map(fn file -> 
        path = Path.join(dir, file)
        if File.exists?(path) do
          IO.puts("  ✅ Loaded #{file}")
          File.read!(path) |> String.replace(~r/\s+/, " ")
        else
          IO.puts("  ❌ Missing #{file} (Skipping...)")
          ""
        end
      end)
      |> Enum.join(" ")

    raw_text
    |> String.to_charlist()
    |> Enum.map(fn c -> if c < 128, do: c, else: 63 end)
    |> Enum.chunk_every(@sequence_length, @sequence_length, :discard)
    |> Enum.filter(fn chunk -> Enum.count(chunk, &(&1 == 63)) < 12 end)
  end

  defp sample_chunks(chunks, percentage, base_amount) do
    take_amount = round(base_amount * percentage)
    if length(chunks) == 0 do
      []
    else
      Enum.map(1..take_amount, fn _ -> Enum.random(chunks) end)
    end
  end
end
