```elixir
IO.puts("🧠 Loading Dataset into CPU Memory...")
full_dataset = File.read!("phase2_dialogue.bin") 
  |> :erlang.binary_to_term()

dataset_size = Nx.axis_size(full_dataset, 0)
batch_size = 16
total_steps_per_epoch = div(dataset_size, batch_size)
sequence_length = 256
max_epochs = 10
total_steps = total_steps_per_epoch * max_epochs
save_interval = 1000
base_lr = 3.0e-4
warmup_steps = 1000
gpu = {EXLA.Backend, client: :rocm}

# 🔍 AUTO-RESUME, WARM RESTART, OR GENESIS
save_prefix = "v21_9_phase2"
phase1_prefix = "v21_9_toddler"

latest_phase2 = 
  Path.wildcard("#{save_prefix}_*.bin")
  |> Enum.reject(&String.contains?(&1, "data.bin"))
  |> Enum.max_by(fn path -> File.stat!(path).mtime end, fn -> nil end)

latest_phase1 = 
  Path.wildcard("#{phase1_prefix}_*.bin")
  |> Enum.reject(&String.contains?(&1, "data.bin"))
  |> Enum.max_by(fn path -> File.stat!(path).mtime end, fn -> nil end)

{params, ms, vs, global_step, current_epoch} = 
  cond do
    # 🟢 TIER 1: Resume an interrupted Phase 2 run
    latest_phase2 != nil ->
      IO.puts("💾 Resuming Phase 2 from checkpoint: #{latest_phase2}")
      checkpoint = File.read!(latest_phase2) |> :erlang.binary_to_term()
      p = checkpoint.params |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple()
      m = checkpoint.ms |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple()
      v = checkpoint.vs |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple()
      {p, m, v, checkpoint.step, checkpoint.epoch}

    # 🟡 TIER 2: Graduate from Phase 1 (Warm Restart)
    latest_phase1 != nil ->
      IO.puts("🔥 WARM RESTART: Loading Phase 1 Brain from #{latest_phase1}...")
      checkpoint = File.read!(latest_phase1) |> :erlang.binary_to_term()
      
      # Keep the learned weights
      p = checkpoint.params |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple()
      
      # Zero out the optimizer momentum so the Cosine Decay wakes back up!
      zero_like = fn t -> Nx.broadcast(Nx.tensor(0.0, type: :f32), t) |> Nx.backend_copy(gpu) end
      m = p |> Tuple.to_list() |> Enum.map(zero_like) |> List.to_tuple()
      v = p |> Tuple.to_list() |> Enum.map(zero_like) |> List.to_tuple()
      
      # Reset steps and epoch to start fresh on the new data
      {p, m, v, 0, 1}

    # 🔴 TIER 3: Absolute scratch start
    true ->
      IO.puts("✨ No checkpoints found. Igniting FRESH Genesis state...")
      raw_p = DLM.V21_9Genesis.init_params(42)
      {raw_m, raw_v, _} = DLM.V21_9Genesis.init_optimizer(raw_p)
      p = raw_p |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple()
      m = raw_m |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple()
      v = raw_v |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple()
      {p, m, v, 0, 1}
  end

seqs_already_seen = rem(global_step * batch_size, dataset_size)
pos_emb = DLM.Positional.build(256, 256) |> Nx.backend_copy(gpu)

IO.puts("🚀 IGNITION: Starting V21.9 at Epoch #{current_epoch}, Global Step #{global_step}...")

Enum.reduce(current_epoch..max_epochs, {params, ms, vs, global_step, seqs_already_seen}, fn epoch, {p, m, v, current_step, offset_seqs} ->
  IO.puts(String.duplicate("=", 50))
  
  # target_lr = base_lr * :math.pow(0.9, epoch - 1)
  # IO.puts("🌊 EPOCH #{epoch} / #{max_epochs} | Target LR: #{target_lr}")
  
  IO.puts("📖 Streaming dataset sequentially (No Shuffle)...")
  # ⚡ 3. Use the sequential stream to save CPU RAM and feed it natural sentence flow
  epoch_batches = Stream.unfold(offset_seqs, fn offset ->
    if offset + batch_size > dataset_size do
      nil # End of dataset
    else
      # Slice 16 rows directly along axis 0. No reshape needed!
      batch_2d = Nx.slice_along_axis(full_dataset, offset, batch_size, axis: 0)
      
      {batch_2d, offset + batch_size}
    end
  end)

  # 🚀 INNER BATCH LOOP
  {new_p, new_m, new_v, next_epoch_step, _final_skips} =
    epoch_batches
    |> Stream.with_index(1)
    |> Enum.reduce({p, m, v, current_step, 0}, fn {batch, step_in_epoch}, {cp, cm, cv, cs, s_count} ->
      gpu_batch = Nx.backend_copy(batch, gpu)

      # 1. Compute Gradients
      {loss_tensor, grads} = DLM.V21_9Trainer.compute_grad(cp, pos_emb, gpu_batch)
      loss_val = Nx.to_number(loss_tensor)
      if loss_val == :nan or loss_val > 6.0 do
        cpu_batch = Nx.backend_copy(gpu_batch, Nx.BinaryBackend)
        sequences = Nx.to_list(cpu_batch)
        IO.puts("🔥 PATHOLOGICAL BATCH at global step #{cs}:")
        Enum.each(sequences, fn seq ->
          readable = seq |> Enum.reject(&(&1 == 0)) |> List.to_string()
          IO.puts("   > #{readable}")
        end)
      end

      # 2. Safety Gate
      if loss_val == :nan or loss_val > 20.0 do
        if rem(step_in_epoch, 10) == 0, do: IO.puts("⚠️ Step #{cs}: NaN/Spike detected. Skipping batch.")
        {cp, cm, cv, cs + 1, s_count + 1}
      else
        current_lr = 
          if cs < warmup_steps do
            # Linear Warmup
            base_lr * (cs / warmup_steps)
          else
            # Cosine Decay down to 0
            progress = (cs - warmup_steps) / (total_steps - warmup_steps)
            clamped_progress = min(max(progress, 0.0), 1.0)
            base_lr * 0.5 * (1.0 + :math.cos(:math.pi() * clamped_progress))
          end

        lr_tensor = Nx.tensor(current_lr, type: :f32) |> Nx.backend_copy(gpu)
        step_tensor = Nx.tensor(cs, type: :f32) |> Nx.backend_copy(gpu)
        
        # 4. Update Weights
        {up_p, up_m, up_v} = DLM.MuonHybrid.step(cp, grads, cm, cv, step_tensor, lr_tensor)

        # After {up_p, up_m, up_v} = DLM.MuonHybrid.step(...)
        # Unpack, rescale d_u and d_v if their combined norm has collapsed
        {p_emb, p_a1, p_a2, p_bu, p_bv, p_cu, p_cv, p_du, p_dv, 
         p_mu1, p_mv1, p_mu2, p_mv2, p_lmw, p_lmb} = up_p
        
        du_norm = p_du |> Nx.pow(2) |> Nx.sum() |> Nx.sqrt() |> Nx.to_number()
        
        up_p = if du_norm < 0.01 do
          IO.puts("   🔧 Rescuing dead delta gate (d_u norm=#{Float.round(du_norm, 5)})")
          rescaled_du = Nx.multiply(p_du, Nx.tensor(0.02 / max(du_norm, 1.0e-8)))
          rescaled_dv = Nx.multiply(p_dv, Nx.tensor(0.02 / max(du_norm, 1.0e-8)))
          {p_emb, p_a1, p_a2, p_bu, p_bv, p_cu, p_cv, rescaled_du, rescaled_dv,
           p_mu1, p_mv1, p_mu2, p_mv2, p_lmw, p_lmb}
        else
          up_p
        end
        
        # 5. Logging (Every 50 steps)
        if rem(step_in_epoch, 50) == 0 do
          bpc = loss_val / :math.log(2)
          mem = :erlang.memory(:total) |> div(1024 * 1024)
          
          # Pull grads back to CPU for norm inspection
          cpu_grads = grads |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple()
          norms = DLM.V21_9Trainer.grad_norms(cpu_grads)
          
          # Find the max so it jumps out visually
          {max_name, max_norm} = Enum.max_by(norms, fn {_name, n} -> n end)
          
          norm_str = norms |> Enum.map(fn {k, v} -> "#{k}=#{v}" end) |> Enum.join(" | ")
          
          IO.puts("➡️  Step #{step_in_epoch} | Global: #{cs} | Loss: #{Float.round(loss_val, 4)} | BPC: #{Float.round(bpc, 3)} | LR: #{Float.round(current_lr, 6)} | RAM: #{mem}MB")
          IO.puts("   📐 GRAD NORMS | MAX: #{max_name}=#{max_norm}")
          IO.puts("   #{norm_str}")
        end

        # 6. Checkpointing (Every 1000 steps)
        if rem(cs, save_interval) == 0 and cs > 0 do
          IO.puts("💾 Auto-Saving Checkpoint to #{save_prefix}_step#{cs}.bin...")
          state = %{
            params: up_p |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
            ms: up_m |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
            vs: up_v |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
            step: cs, epoch: epoch
          }
          File.write!("#{save_prefix}_step#{cs}.bin", :erlang.term_to_binary(state))
        end

        if rem(step_in_epoch, 100) == 0, do: :erlang.garbage_collect(self())

        {up_p, up_m, up_v, cs + 1, s_count}
      end
    end)

  IO.puts("💾 Saving Completed Epoch #{epoch} State...")
  final_state = %{
    params: new_p |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
    ms: new_m |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
    vs: new_v |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple(),
    step: next_epoch_step, epoch: epoch
  }
  File.write!("#{save_prefix}_epoch#{epoch}_COMPLETE.bin", :erlang.term_to_binary(final_state))

  {new_p, new_m, new_v, next_epoch_step, 0}
end)

IO.puts("🎉 THE OVERNIGHT BAKE IS COMPLETE!")
