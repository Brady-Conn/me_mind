# 🔍 DYNAMIC CHECKPOINT FINDER
latest_checkpoint = "v21_9_toddler_step7000.bin"
  # Path.wildcard("v21_9_*.bin")
  # |> Enum.reject(&String.contains?(&1, "data.bin"))
