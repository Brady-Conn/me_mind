```elixir
defmodule DLM.SvdOptimizer do
  import Nx.Defn

  defn update(params, grads, step, lr) do
     {e1, e2, e3, a, b, c1, c2, c3, 
      d1, d2, d3, h, 
      q1, q2, q3, i,
      j, k, r, s,
      f, g, n} = params   
     {ge1, ge2, ge3, ga, gb, gc1, gc2, gc3, 
      gd1, gd2, gd3, gh, gq1, gq2, gq3, gi,
      gj, gk, gr, gs,
      gf, gg, gn} = grads
    
    new_step = Nx.add(step, 1)

    # optimizer update step
    e1_new = DLM.StatelessMuon.muon_step(e1, ge1, lr)
    e2_new = DLM.StatelessMuon.muon_step(e2, ge2, lr)
    e3_new = DLM.StatelessMuon.muon_step(e3, ge3, lr)
    a_new = DLM.StatelessMuon.muon_step(a, ga, lr)
    b_new = DLM.StatelessMuon.muon_step(b, gb, lr)
    c1_new = DLM.StatelessMuon.muon_step(c1, gc1, lr)
    c2_new = DLM.StatelessMuon.muon_step(c2, gc2, lr)
    c3_new = DLM.StatelessMuon.muon_step(c3, gc3, lr)
    d1_new = DLM.StatelessMuon.muon_step(d1, gd1, lr)
    d2_new = DLM.StatelessMuon.muon_step(d2, gd2, lr)
    d3_new = DLM.StatelessMuon.muon_step(d3, gd3, lr)
    h_new = DLM.StatelessMuon.muon_step(h, gh, lr)
    q1_new = DLM.StatelessMuon.muon_step(q1, gq1, lr)
    q2_new = DLM.StatelessMuon.muon_step(q2, gq2, lr)
    q3_new = DLM.StatelessMuon.muon_step(q3, gq3, lr)
    i_new = DLM.StatelessMuon.muon_step(i, gi, lr)
    j_new = DLM.StatelessMuon.muon_step(j, gj, lr)
    k_new = DLM.StatelessMuon.muon_step(k, gk, lr)
    r_new = DLM.StatelessMuon.muon_step(r, gr, lr)
    s_new = DLM.StatelessMuon.muon_step(s, gs, lr)
    f_new = DLM.StatelessMuon.muon_step(f, gf, lr)
    g_new = DLM.StatelessMuon.muon_step(g, gg, lr)
    n_new = DLM.StatelessMuon.muon_step(n, gn, lr)
   
    
    new_params = {e1_new, e2_new, e3_new, a_new, b_new, c1_new, c2_new, c3_new,
      d1_new, d2_new, d3_new, h_new, q1_new, q2_new, q3_new, i_new,
      j_new, k_new, r_new, s_new,
      f_new, g_new, n_new}

    {new_params, new_step}
  end
end
