```elixir
defmodule DLM.PhysicsGenesis do
  import Nx.Defn

  @dim 128
  @vocab 128

  defn ignite(k1) do
    # 1. Variance Scalars
    std_vocab = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@vocab, type: :f32)))
    std_dim   = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@dim, type: :f32)))

    # 2. Block Positional Embeddings (Vocab/Dim -> Dim)
    {e1, k2} = Nx.Random.normal(k1, 0.0, std_dim, shape: {@vocab, @dim})
    {e2, k3} = Nx.Random.normal(k2, 0.0, std_dim, shape: {@vocab, @dim})
    {e3, k4} = Nx.Random.normal(k3, 0.0, std_dim, shape: {@vocab, @dim})
   
    # 3. a: Hidden State Down-Projection (Dim -> Rank)
    {a, k5} = Nx.Random.normal(k4, 0.0, std_dim, shape: {@dim, @dim})
    
    # 4. b: Input Down-Projection (Dim -> Rank)
    {b, k6}  = Nx.Random.normal(k5,  0.0, std_dim, shape: {@dim, @dim})
    
    # 5. c: Latent Up-Projection (Rank -> Dim)
    # ⚡ SHAPE FIXED: Taking the 64D attention mix back to 128D
    {c1, k7} = Nx.Random.normal(k6, 0.0, std_dim, shape: {@dim, @dim})
    
    # 6. d: Output Pathway 1 (Dim -> Dim)
    # ⚡ SHAPE FIXED: d3 correctly maps Dim -> Vocab probabilities
    {d1, k8} = Nx.Random.normal(k7, 0.0, std_vocab, shape: {@dim, @vocab})
    {d2, k9} = Nx.Random.normal(k8, 0.0, std_vocab, shape: {@dim, @vocab})
    {d3, k10} = Nx.Random.normal(k9, 0.0, std_vocab, shape: {@dim, @vocab})
    
    # 9. h: Recurrent State Up-Projection (Rank -> Dim)
    # This prepares hn1/2/3 to become the h1p/2/3p for the NEXT time step
    {h, k11} = Nx.Random.normal(k10, 0.0, std_dim, shape: {@dim, @dim})
  
    {q1, k12} = Nx.Random.normal(k11, 0.0, std_dim, shape: {@dim, @dim})
    {q2, k13} = Nx.Random.normal(k12, 0.0, std_dim, shape: {@dim, @dim})
    {q3, k14} = Nx.Random.normal(k13, 0.0, std_dim, shape: {@dim, @dim})

    {i, k15} = Nx.Random.normal(k14, 0.0, std_dim, shape: {@dim, @dim})

    {j, k16} = Nx.Random.normal(k15, 0.0, std_dim, shape: {@dim, @dim})

    {k, k17} = Nx.Random.normal(k16, 0.0, std_dim, shape: {@dim, @dim})

    {r, k18} = Nx.Random.normal(k17, 0.0, std_dim, shape: {@dim, @dim})

    {s, k19} = Nx.Random.normal(k18, 0.0, std_dim, shape: {@dim, @dim})

    {f, k20} = Nx.Random.normal(k19, 0.0, std_dim, shape: {@dim, @dim})

    {g, k21} = Nx.Random.normal(k20, 0.0, std_dim, shape: {@dim, @dim})

    {n, k22} = Nx.Random.normal(k21, 0.0, std_dim, shape: {@dim, @dim})

    {c2, k23} = Nx.Random.normal(k22, 0.0, std_dim, shape: {@dim, @dim})
    {c3, k24} = Nx.Random.normal(k23, 0.0, std_dim, shape: {@dim, @dim})

    # Return exactly the tuple structure your forward_step unpacks
    params_tuple = {e1, e2, e3, a, b, c1, c2, c3, 
                    d1, d2, d3, h, 
                    q1, q2, q3, i,
                    j, k, r, s,
                    f, g, n}

    {params_tuple, k24}
  end
end
```

