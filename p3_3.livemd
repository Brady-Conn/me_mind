## BLiMP

```elixir
defmodule DLM.Phase3_Eval do
  import Nx.Defn

  # ⚡ Added orig_seq_len to the signature to handle the padding mask
  defn compute_sentence_loss(input_tokens, target_tokens, orig_seq_len, h_base_init, h_top_init, frozen_base_p, top_p, frozen_map) do
    
    # 1. Micro SSM Unroll
    {micro_states, _h_base_carried} = DLM.HierarchicalBridge.extract_micro_states(input_tokens, h_base_init, frozen_base_p, frozen_map)

    # 2. Pool to Macro Timeline
    macro_inputs = DLM.HierarchicalBridge.pool_states(micro_states, 4)
    macro_seq_len = Nx.axis_size(macro_inputs, 1)
    batch_size = Nx.axis_size(macro_inputs, 0)

    in_t = Nx.transpose(macro_inputs, axes: [1, 0, 2])
    acc_macro_init = Nx.broadcast(0.0, {macro_seq_len, batch_size, 512})
    zero_frame = Nx.broadcast(0.0, {batch_size, 512})

    # 3. Macro SSM Unroll
    result =
      while {i = 0, h_top = h_top_init, xp1 = zero_frame, xp2 = zero_frame,
             acc = acc_macro_init, in_t, t_p = top_p},
            Nx.less(i, macro_seq_len) do

        {a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2, valve_w, valve_b, _out_w, _out_b} = t_p
        
        chunk_curr = in_t[i]

        {_y_top, h_top_new} = DLM.Main_SSM.ssm_recurrence(
          chunk_curr, xp1, xp2, h_top,
          a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2, valve_w, valve_b
        )

        acc_new = Nx.put_slice(acc, [i, 0, 0], Nx.new_axis(h_top_new, 0))
        
        {i + 1, h_top_new, chunk_curr, xp1, acc_new, in_t, t_p}
      end

    {_, _h_top_carried, _, _, macro_states_time_first, _, t_p} = result

    # 4. Decompress back to the character timeline
    macro_states = Nx.transpose(macro_states_time_first, axes: [1, 0, 2])
    expanded_states = DLM.HierarchicalBridge.decompress_states(macro_states, 4)

    # 5. Project directly to Vocabulary Logits
    {_a, _bu, _bv, _cu, _cv, _du, _dv, _mu1, _mv1, _mu2, _mv2, _vw, _vb, out_w, out_b} = t_p
    logits = Nx.dot(expanded_states, out_w) |> Nx.add(out_b)

    # 6. Calculate Masked Cross-Entropy Loss
    vocab_size = Nx.axis_size(logits, -1)
    one_hot = Nx.equal(Nx.iota({vocab_size}), Nx.new_axis(target_tokens, -1))

    max_logits = Nx.reduce_max(logits, axes: [-1], keep_axes: true)
    safe_logits = Nx.subtract(logits, max_logits)
    log_probs = Nx.subtract(safe_logits, Nx.log(Nx.sum(Nx.exp(safe_logits), axes: [-1], keep_axes: true)))

    # Raw loss for every token (including padding)
    token_losses = Nx.negate(Nx.sum(Nx.multiply(one_hot, log_probs), axes: [-1]))

    # ⚡ Create the Padding Mask: 1.0 for valid characters, 0.0 for padding
    padded_seq_len = Nx.axis_size(input_tokens, 1)
    mask = Nx.less(Nx.iota({1, padded_seq_len}), orig_seq_len)

    # Zero out the padding errors
    masked_losses = Nx.multiply(token_losses, mask)
    total_valid_loss = Nx.sum(masked_losses)

    # Return the exact mean loss based ONLY on the original sentence length
    Nx.divide(total_valid_loss, Nx.as_type(orig_seq_len, :f32))
  end
end
```

