```elixir
defmodule DLM.HierarchicalBridge do
  import Nx.Defn

  @doc """
  Runs the frozen Base SSM over all 512 characters and collects the hidden states.
  """
  defn extract_micro_states(input_tokens, h_base_init, frozen_base_p, frozen_map) do
    seq_len = Nx.axis_size(input_tokens, 1) # 512
    batch_size = Nx.axis_size(input_tokens, 0)
    
    in_t = input_tokens 
           |> DLM.Main_SSM_Trainer.get_real_coordinates(frozen_map)
           |> Nx.transpose(axes: [1, 0, 2])

    acc_init = Nx.broadcast(0.0, {seq_len, batch_size, 512})

    result =
      while {i = 0, h = h_base_init, acc = acc_init, in_t, b_p = frozen_base_p},
            Nx.less(i, seq_len) do
            
        {_fwd, _retro, h_new} = DLM.TinySSM.forward_step(in_t[i], h, b_p)
        acc_new = Nx.put_slice(acc, [i, 0, 0], Nx.new_axis(h_new, 0))
        
        {i + 1, h_new, acc_new, in_t, b_p}
      end

    {_, final_h, states_time_first, _, _} = result
    
    # Return batch-first {batch, 512, 512} and the final state
    {Nx.transpose(states_time_first, axes: [1, 0, 2]), final_h}
  end

  @doc """
  Compresses {batch, 512, 512} into {batch, 128, 512}
  """
  defn pool_states(micro_states, chunk_size \\ 4) do
    {batch, seq, dim} = Nx.shape(micro_states)
    macro_seq = div(seq, chunk_size)
    
    micro_states
    |> Nx.reshape({batch, macro_seq, chunk_size, dim})
    |> Nx.mean(axes: [2])
  end

  @doc """
  Expands {batch, 128, 512} back into {batch, 512, 512} by broadcasting,
  and injects Local Positional Awareness to break the Clone Trap.
  """
  defn decompress_states(macro_states) do
    {batch, macro_seq, _dim} = Nx.shape(macro_states)
    
    broadcasted = 
      macro_states
      |> Nx.new_axis(2) 
      |> Nx.broadcast({batch, macro_seq, 4, 512}) 
      
    # 1. Generate the Positional Wave (Inlined for EXLA compilation)
    i = Nx.iota({4, 1})
    d = Nx.iota({1, 512})
    dim_f = Nx.tensor(512, type: :f32)
    local_pos = Nx.sin(Nx.divide(i, Nx.pow(10000.0, Nx.divide(d, dim_f))))
    local_pos_reshaped = Nx.reshape(local_pos, {1, 1, 4, 512})
      
    # ⚡ 2. THE NON-LINEAR FIX
    # We MUST wrap the addition in a non-linearity to break the linear bias trap!
    enriched_states = DLM.Main_SSM.swish(Nx.add(broadcasted, local_pos_reshaped))
      
    # 3. Flatten back to the 512 timeline
    enriched_states |> Nx.reshape({batch, macro_seq * 4, 512})
  end
end
