```elixir
defmodule DLM.Main_SSM_Trainer do
  import Nx.Defn

  # 1. Maps discrete tokens to their perfect 512D spatial coordinates
  defn get_real_coordinates(batch_tokens, frozen_embeds) do
    Nx.take(frozen_embeds, Nx.flatten(batch_tokens))
      |> Nx.reshape({Nx.axis_size(batch_tokens, 0), Nx.axis_size(batch_tokens, 1), 512})
      |> stop_grad()
  end

  defn compute_sequence_loss(batch_tokens, h_base_init, h_top_init, frozen_base_p, frozen_map, top_p) do
    # 1. Micro SSM Unroll (Frozen)
    {micro_states, h_base_carried} = DLM.HierarchicalBridge.extract_micro_states(batch_tokens, h_base_init, frozen_base_p, frozen_map)
    
    # 2. Pool to Macro Timeline
    macro_inputs = DLM.HierarchicalBridge.pool_states(micro_states, 4)
    macro_seq_len = Nx.axis_size(macro_inputs, 1) # 128
    batch_size = Nx.axis_size(macro_inputs, 0)
    
    # ⚡ 3. STRICT CAUSAL SHIFT (Prepend zero chunk, drop last chunk)
    zero_chunk = Nx.broadcast(0.0, {batch_size, 1, 512})
    shifted_macro_inputs = Nx.concatenate(
      [zero_chunk, Nx.slice_along_axis(macro_inputs, 0, macro_seq_len - 1, axis: 1)], 
      axis: 1
    )

    in_t = Nx.transpose(shifted_macro_inputs, axes: [1, 0, 2])
    acc_macro_init = Nx.broadcast(0.0, {macro_seq_len, batch_size, 512})
    zero_frame = Nx.broadcast(0.0, {batch_size, 512})

    # 4. Macro SSM Unroll
    result =
      while {i = 0, h_top = h_top_init, xp1 = zero_frame, xp2 = zero_frame, 
             acc = acc_macro_init, in_t, t_p = top_p}, 
            Nx.less(i, macro_seq_len) do
        
        {a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2, valve_w, valve_b, _out_w, _out_b} = t_p
        
        chunk_curr = in_t[i]
        
        # ⚡ Note the explicit extraction of y_top_new!
        {y_top_new, h_top_new} = DLM.Main_SSM.ssm_recurrence(
          chunk_curr, xp1, xp2, h_top, 
          a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2, valve_w, valve_b
        )
        
        # ⚡ BUG FIX: Save the actual non-linear output, NOT the raw geometric state
        acc_new = Nx.put_slice(acc, [i, 0, 0], Nx.new_axis(y_top_new, 0))
        
        {i + 1, h_top_new, chunk_curr, xp1, acc_new, in_t, t_p}
      end
      
    {_, h_top_carried, _, _, macro_states_time_first, _, t_p} = result
    
    macro_outputs = Nx.transpose(macro_states_time_first, axes: [1, 0, 2])
    
    {_a, _bu, _bv, _cu, _cv, _du, _dv, _mu1, _mv1, _mu2, _mv2, _vw, _vb, out_w, out_b} = t_p
    
    # 5. Project to 512 and Reshape
    macro_logits = Nx.dot(macro_outputs, out_w) |> Nx.add(out_b) 
    
    logits = 
      macro_logits
      |> Nx.reshape({batch_size, macro_seq_len, 4, 128})
      |> Nx.reshape({batch_size, macro_seq_len * 4, 128})
    
    # ⚡ 6. Evaluate against the original unbroken batch!
    loss = DLM.Loss.cross_entropy(logits, batch_tokens)
    
    {loss, h_base_carried, h_top_carried}
  end

  # 3. GRADIENT TAPE (Now incredibly clean and simple)
  defn compute_grad_and_step(batch_tokens, h_base_init, h_top_init, frozen_base_p, frozen_map, top_p) do
    {loss, raw_grads} = value_and_grad(top_p, fn p ->
      {avg_loss, _h_base_final, _h_top_final} = 
        compute_sequence_loss(batch_tokens, h_base_init, h_top_init, frozen_base_p, frozen_map, p)
      avg_loss
    end)
    
    {_loss, final_h_base, final_h_top} = 
        compute_sequence_loss(batch_tokens, h_base_init, h_top_init, frozen_base_p, frozen_map, top_p)

    {loss, raw_grads, final_h_base, final_h_top}
  end

  # ⚡ 4. TELEMETRY HELPER
  def grad_norms(grads) do
    {g_a, g_bu, g_bv, g_cu, g_cv, g_du, g_dv, g_mu1, g_mv1, g_mu2, g_mv2, g_valve_w, g_valve_b, g_out_w, g_out_b} = grads
    
    calc = fn g -> g |> Nx.pow(2) |> Nx.sum() |> Nx.sqrt() |> Nx.to_number() |> Float.round(4) end
    
    [
      a_diag: calc.(g_a), b_u: calc.(g_bu), b_v: calc.(g_bv),
      c_u: calc.(g_cu), c_v: calc.(g_cv), d_u: calc.(g_du), d_v: calc.(g_dv),
      mx_u1: calc.(g_mu1), mx_v1: calc.(g_mv1), mx_u2: calc.(g_mu2), mx_v2: calc.(g_mv2),
      valve_w: calc.(g_valve_w), valve_b: calc.(g_valve_b), 
      out_w: calc.(g_out_w), out_b: calc.(g_out_b)
    ]
  end
end
