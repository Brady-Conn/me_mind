## Compare Sampler

```elixir
# --- V11 MULTI-EPOCH TIME MACHINE (COMPLETE) ---
epochs_to_check = [7, 8, 9, 10, 12, "settled_final"]
seed_text = "ELIXIR: "

# Using "Neutral" settings to see the raw evolution
temp = 0.7 
top_k_val = 5
rep_penalty = 1.2
seq_len = 128

IO.puts("🕰️ Starting the Multi-Epoch Comparison...")

Enum.each(epochs_to_check, fn version ->
  filename = if is_integer(version), 
    do: "v11_deep_burn_epoch_#{version}.bin", 
    else: "v11_brain_#{version}.bin"
  
  checkpoint_path = Path.join(File.cwd!(), filename)

  if File.exists?(checkpoint_path) do
    IO.puts("\n--- TESTING EPOCH #{version} ---")
    
    # 1. Load weights
    m = File.read!(checkpoint_path) |> :erlang.binary_to_term()
    # Pulling weights out of the map
    {f_e, f_a1, f_f1, f_a2, f_f2, f_lmw, f_lmb} = {m.e, m.a1, m.f1, m.a2, m.f2, m.lmw, m.lmb}
    
    # 2. Run the actual sampler
    seed_ids = seed_text |> to_charlist() |> Nx.tensor() |> Nx.reshape({1, :auto})
    IO.write("#{seed_text}")
    
    key = Nx.Random.key(System.system_time(:millisecond))

    Enum.reduce_while(1..128, {seed_ids, key}, fn _i, {acc_ids, k} ->
      {_, total_len} = Nx.shape(acc_ids)
      window_len = min(total_len, seq_len)
      window_ids = Nx.slice_along_axis(acc_ids, total_len - window_len, window_len, axis: 1)
      
      # Predict next character
      raw_logits = DLM.Inference.predict_next(
        Nx.add(Nx.take(f_e, window_ids), DLM.Positional.build(window_len, 256)), 
        f_a1, f_f1, f_a2, f_f2, f_lmw, f_lmb,
        DLM.Mask.causal(window_len), 0.0, k 
      )

      # Penalty & Sampling logic
      history = Nx.slice_along_axis(acc_ids, max(0, total_len - 15), min(total_len, 15), axis: 1)
      penalized = Enum.reduce(Nx.to_flat_list(history), raw_logits, fn id, acc ->
        v = Nx.to_number(acc[id])
        nv = if v > 0, do: v / rep_penalty, else: v * rep_penalty
        Nx.indexed_put(acc, Nx.tensor([[id]]), Nx.tensor([nv]))
      end)

      {top_vals, _} = Nx.top_k(penalized, k: top_k_val)
      kth_val = Nx.reduce_min(top_vals, axes: [-1], keep_axes: true)
      
      probs = Nx.exp(Nx.subtract(Nx.select(Nx.greater_equal(penalized, kth_val), Nx.divide(penalized, temp), Nx.tensor(-1.0e9)), Nx.reduce_max(penalized, axes: [-1], keep_axes: true)))
      probs = Nx.divide(probs, Nx.sum(probs, axes: [-1], keep_axes: true))

      {choice, nk} = Nx.Random.choice(k, Nx.iota({128}), probs)
      next_id = choice |> Nx.squeeze() |> Nx.to_number()

      if next_id == 10 do
        {:halt, {acc_ids, nk}}
      else
        if next_id >= 32 and next_id < 127, do: IO.write(<<next_id>>)
        {:cont, {Nx.concatenate([acc_ids, Nx.reshape(Nx.tensor([next_id]), {1, 1})], axis: 1), nk}}
      end
    end)
    
    IO.puts("\n")

    # 3. CRITICAL: Manual Memory Flush
    # We clear the specific tensors from memory
    f_e = nil; f_a1 = nil; f_f1 = nil; f_a2 = nil; f_f2 = nil; f_lmw = nil; f_lmb = nil; m = nil
    :erlang.garbage_collect()
  else
    IO.puts("⚠️ Checkpoint #{filename} not found.")
  end
end)
```

