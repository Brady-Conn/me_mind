## Whitelist Sampler

```elixir
# --- V11 WHITELIST RESCUE (CORRECTED) ---
checkpoint_path = Path.join(File.cwd!(), "v11_brain_settled_final.bin")
seeds = ["AARDVARK: ", "FLUMMOX: ", "ELIXIR: ", "COMPUTER: ", "WHALE: "]

# 1. Create the Mask (Space + Letters Only)
allowed_ids = [32] ++ Enum.to_list(65..90) ++ Enum.to_list(97..122)
base_mask = Nx.broadcast(Nx.tensor(-1.0e10), {128})
allowed_mask = Enum.reduce(allowed_ids, base_mask, fn id, acc ->
  Nx.indexed_put(acc, Nx.tensor([[id]]), Nx.tensor([0.0]))
end)

# 2. Chaos Settings (To break the overfit loops)
temp = 1.2
top_k_val = 15
rep_penalty = 2.0

m = File.read!(checkpoint_path) |> :erlang.binary_to_term()
{f_e, f_a1, f_f1, f_a2, f_f2, f_lmw, f_lmb} = {m.e, m.a1, m.f1, m.a2, m.f2, m.lmw, m.lmb}

IO.puts("--- Rescuing the 0.33 Loss Brain (Letters Only) ---\n")

Enum.reduce(seeds, Nx.Random.key(System.system_time(:millisecond)), fn seed_text, current_key ->
  seed_ids = seed_text |> to_charlist() |> Nx.tensor() |> Nx.reshape({1, :auto})
  IO.write("#{seed_text}")
  
  Enum.reduce_while(1..128, {seed_ids, current_key}, fn _i, {acc_ids, k} ->
    {_, total_len} = Nx.shape(acc_ids)
    window_len = min(total_len, 128)
    window_ids = Nx.slice_along_axis(acc_ids, total_len - window_len, window_len, axis: 1)
    
    # Forward Pass
    logits = DLM.Inference.predict_next(
      Nx.add(Nx.take(f_e, window_ids), DLM.Positional.build(window_len, 256)), 
      f_a1, f_f1, f_a2, f_f2, f_lmw, f_lmb,
      DLM.Mask.causal(window_len), 0.0, k 
    )

    # STEP 1: Block all symbols immediately
    logits = Nx.add(logits, allowed_mask)

    # STEP 2: Repetition Penalty
    history = Nx.slice_along_axis(acc_ids, max(0, total_len - 15), min(total_len, 15), axis: 1)
    penalized = Enum.reduce(Nx.to_flat_list(history), logits, fn id, acc ->
      v = Nx.to_number(acc[id])
      nv = if v > 0, do: v / rep_penalty, else: v * rep_penalty
      Nx.indexed_put(acc, Nx.tensor([[id]]), Nx.tensor([nv]))
    end)

    # STEP 3: Top-K & Temp (The corrected select/3 is here)
    {top_vals, _} = Nx.top_k(penalized, k: top_k_val)
    kth_val = Nx.reduce_min(top_vals, axes: [-1], keep_axes: true)
    
    # We select: if >= kth_val, divide by temp, else set to -1e9
    filtered = Nx.select(
      Nx.greater_equal(penalized, kth_val),
      Nx.divide(penalized, temp),
      Nx.tensor(-1.0e9)
    )

    # STEP 4: Softmax & Choice
    max_l = Nx.reduce_max(filtered, axes: [-1], keep_axes: true)
    probs = Nx.exp(Nx.subtract(filtered, max_l))
    probs = Nx.divide(probs, Nx.sum(probs, axes: [-1], keep_axes: true))

    {choice, nk} = Nx.Random.choice(k, Nx.iota({128}), probs)
    next_id = choice |> Nx.squeeze() |> Nx.to_number()

    if next_id >= 32 and next_id < 127, do: IO.write(<<next_id>>)
    {:cont, {Nx.concatenate([acc_ids, Nx.reshape(Nx.tensor([next_id]), {1, 1})], axis: 1), nk}}
  end)
  IO.puts("")
  current_key
end)
```

