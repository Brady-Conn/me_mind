## Burn

```elixir
# --- V11 CONTINUOUS GRAND BURN (FIXED) ---
dict_path = "english_dictionary.csv"
seq_len = 128
batch_size = 16  # Halved to protect RAM from the 16x larger attention matrix
chunk_size = 5   # Lowered to keep EXLA compilation fast
lr = 0.002
total_epochs = 5

IO.puts("🧠 Initializing fresh V11 Brain...")
key = Nx.Random.key(System.system_time(:millisecond))

# --- THE FIX: Safe Array Indexing for Key Splitting ---
s1 = Nx.Random.split(key); k1 = s1[0]
s2 = Nx.Random.split(s1[1]); k2 = s2[0]
s3 = Nx.Random.split(s2[1]); k3 = s3[0]
s4 = Nx.Random.split(s3[1]); k4 = s4[0]
s5 = Nx.Random.split(s4[1]); k5 = s5[0]
s6 = Nx.Random.split(s5[1]); k6 = s6[0]

{e, _} = Nx.Random.normal(k1, 0.0, 0.02, shape: {128, 256}) 
{a1, _} = Nx.Random.normal(k2, 0.0, 0.02, shape: {256, 256})
{f1, _} = Nx.Random.normal(k3, 0.0, 0.02, shape: {256, 256})
{a2, _} = Nx.Random.normal(k4, 0.0, 0.02, shape: {256, 256})
{f2, _} = Nx.Random.normal(k5, 0.0, 0.02, shape: {256, 256})
{lmw, _} = Nx.Random.normal(k6, 0.0, 0.02, shape: {256, 128})
lmb = Nx.broadcast(Nx.tensor(0.0), {128})

pos_emb = DLM.Positional.build(seq_len, 256)
causal_mask = DLM.Mask.causal(seq_len)

IO.puts("--- Starting The V11 Continuous Burn ---")
IO.puts("⏳ Compiling 128-Context XLA Factory (This will take 4-6 minutes)...")

final_state = Enum.reduce(1..total_epochs, {e, a1, f1, a2, f2, lmw, lmb, 0}, fn epoch, {e_acc, a1_acc, f1_acc, a2_acc, f2_acc, lmw_acc, lmb_acc, global_step} ->
  
  IO.puts("\n🚀 --- STARTING EPOCH #{epoch}/#{total_epochs} --- 🚀")

  {ne, na1, nf1, na2, nf2, nlmw, nlmb, next_step} =
    DLM.DataStreamer.stream_continuous(dict_path, seq_len, batch_size, chunk_size)
    |> Enum.reduce({e_acc, a1_acc, f1_acc, a2_acc, f2_acc, lmw_acc, lmb_acc, global_step}, fn {ins, tgs}, {ce, ca1, cf1, ca2, cf2, clmw, clmb, step} ->

      if step == 0 and epoch == 1, do: IO.puts("💓 Heartbeat: First 128-context chunk reached XLA!")

      {new_e, new_a1, new_f1, new_a2, new_f2, new_lmw, new_lmb, loss} =
        DLM.Optimizer.multi_step(ins, tgs, ce, ca1, cf1, ca2, cf2, clmw, clmb, pos_emb, causal_mask, lr)

      if rem(step, 50) == 0 do
        l_val = Nx.to_number(loss)
        total_rows = (step + 1) * chunk_size * batch_size
        IO.puts("Epoch #{epoch} | Chunk #{step} | Sequences: #{total_rows} | Loss: #{Float.round(l_val, 6)} | RAM: #{round(:erlang.memory(:total) / 1_000_000)}MB")
      end

      {
        Nx.backend_copy(new_e, Nx.BinaryBackend),
        Nx.backend_copy(new_a1, Nx.BinaryBackend),
        Nx.backend_copy(new_f1, Nx.BinaryBackend),
        Nx.backend_copy(new_a2, Nx.BinaryBackend),
        Nx.backend_copy(new_f2, Nx.BinaryBackend),
        Nx.backend_copy(new_lmw, Nx.BinaryBackend),
        Nx.backend_copy(new_lmb, Nx.BinaryBackend),
        step + 1
      }
    end)

  epoch_checkpoint = Path.join(File.cwd!(), "v11_continuous_brain_epoch_#{epoch}.bin")
  File.write!(epoch_checkpoint, :erlang.term_to_binary(%{
    e: ne, a1: na1, f1: nf1, a2: na2, f2: nf2, lmw: nlmw, lmb: nlmb
  }))
  
  IO.puts("💾 Epoch #{epoch} complete! Brain auto-saved.")
  {ne, na1, nf1, na2, nf2, nlmw, nlmb, next_step}
end)

IO.puts("\n✅ V11 Grand Burn Complete!")
```

```elixir
# --- V11 EPOCH 6: PRECISION SETTLEMENT ---
# We grab the weights directly from the 'final_state' of the previous cell
{e_5, a1_5, f1_5, a2_5, f2_5, lmw_5, lmb_5, step_5} = final_state

# We drop the learning rate significantly (5x smaller)
precision_lr = 0.0004 

IO.puts("🧊 Cooling the brain... Starting Epoch 6 with LR: #{precision_lr}")

{ne, na1, nf1, na2, nf2, nlmw, nlmb, next_step} =
  DLM.DataStreamer.stream_continuous(dict_path, seq_len, batch_size, chunk_size)
  |> Enum.reduce({e_5, a1_5, f1_5, a2_5, f2_5, lmw_5, lmb_5, step_5}, fn {ins, tgs}, {ce, ca1, cf1, ca2, cf2, clmw, clmb, step} ->

    {new_e, new_a1, new_f1, new_a2, new_f2, new_lmw, new_lmb, loss} =
      DLM.Optimizer.multi_step(ins, tgs, ce, ca1, cf1, ca2, cf2, clmw, clmb, pos_emb, causal_mask, precision_lr)

    if rem(step, 50) == 0 do
      l_val = Nx.to_number(loss)
      IO.puts("PRECISION PASS | Chunk #{step} | Loss: #{Float.round(l_val, 6)} | RAM: #{round(:erlang.memory(:total) / 1_000_000)}MB")
    end

    {
      Nx.backend_copy(new_e, Nx.BinaryBackend),
      Nx.backend_copy(new_a1, Nx.BinaryBackend),
      Nx.backend_copy(new_f1, Nx.BinaryBackend),
      Nx.backend_copy(new_a2, Nx.BinaryBackend),
      Nx.backend_copy(new_f2, Nx.BinaryBackend),
      Nx.backend_copy(new_lmw, Nx.BinaryBackend),
      Nx.backend_copy(new_lmb, Nx.BinaryBackend),
      step + 1
    }
  end)

# Save the ultimate final version
final_checkpoint = Path.join(File.cwd!(), "v11_precision_brain_final.bin")
File.write!(final_checkpoint, :erlang.term_to_binary(%{
  e: ne, a1: na1, f1: nf1, a2: na2, f2: nf2, lmw: nlmw, lmb: nlmb
}))

IO.puts("🏆 Precision Settlement Complete. Ultimate brain saved!")
