## Pipeline

```elixir
dict_url = "https://raw.githubusercontent.com/benjihillard/English-Dictionary-Database/main/english%20Dictionary.csv"
dict_file = "english_dictionary.csv"

unless File.exists?(dict_file) do
  IO.puts("📥 Downloading the English Dictionary...")
  %{body: content} = Req.get!(dict_url)
  File.write!(dict_file, content)
  IO.puts("✅ Downloaded!")
end

defmodule DLM.DataStreamer do
  NimbleCSV.define(DLM.CSVParser, separator: ",", escape: "\"")

  def stream_continuous(path, seq_len, batch_size, chunk_size) do
    IO.puts("⏳ Loading and joining dictionary into a continuous stream...")
    
    full_text = 
      path
      |> File.stream!()
      |> DLM.CSVParser.parse_stream(skip_headers: true)
      |> Stream.map(fn row -> 
        word = List.first(row) || ""
        definition = List.last(row) || ""
        "#{String.upcase(word)}: #{definition} "
        |> String.replace(~r/[^ -~]/, "")
      end)
      |> Enum.join("")
      |> to_charlist()

    IO.puts("✅ Continuous string built: #{length(full_text)} characters.")

    full_text
    |> Stream.chunk_every(seq_len + 1, seq_len, :discard)
    |> Stream.map(fn chunk ->
      t = Nx.tensor(chunk)
      {Nx.slice_along_axis(t, 0, seq_len, axis: 0), 
       Nx.slice_along_axis(t, 1, seq_len, axis: 0)}
    end)
    # --- THE FIX: Two-stage unzipping and stacking ---
    # Stage 1: Stack into Batches
    |> Stream.chunk_every(batch_size, batch_size, :discard)
    |> Stream.map(fn batch_of_pairs ->
      {ins, tgs} = Enum.unzip(batch_of_pairs)
      {Nx.stack(ins), Nx.stack(tgs)}
    end)
    # Stage 2: Stack Batches into Chunks for EXLA
    |> Stream.chunk_every(chunk_size, chunk_size, :discard)
    |> Stream.map(fn chunk_of_batches ->
      {c_ins, c_tgs} = Enum.unzip(chunk_of_batches)
      {Nx.stack(c_ins), Nx.stack(c_tgs)}
    end)
  end
end
```

```elixir
# --- THE ROBUST SYMBOL AUDIT ---
File.stream!("english_dictionary.csv")
|> Stream.flat_map(&String.to_charlist/1)
|> Stream.reject(fn c -> 
  (c >= ?a and c <= ?z) or (c >= ?A and c <= ?Z) or (c >= ?0 and c <= ?9) or c == ?\s or c == ?\n
end)
|> Enum.reduce(%{}, fn char, acc -> Map.update(acc, char, 1, &(&1 + 1)) end)
|> Enum.sort_by(fn {_char, count} -> count end, :desc)
|> Enum.take(30)
|> Enum.each(fn {char, count} -> 
  # Using inspect(<<char>>) prevents the encoding crash
  IO.puts("Byte: #{char} | Visual: #{inspect(<<char>>, binaries: :as_strings)} | Count: #{count}")
end)
