## Cooled Sampler

```elixir
# --- V11 FINAL SCHOLAR SAMPLER ---
# Pointing to the result of your Settlement Pass
checkpoint_path = Path.join(File.cwd!(), "v11_brain_settled_final.bin")

seeds = [
  "AARDVARK: ", 
  "FLUMMOX: ", 
  "ELIXIR: ",
  "COMPUTER: ",
  "WHALE: "
]

# --- THE V11 CHAOS-CORRECTION SAMPLER ---
temp = 1.2        # Ramped up to break the "Certainty Loops"
top_k_val = 20    # Much wider to give it an exit ramp from symbols
rep_penalty = 2.0 # Heavy punishment for repeating the same character

key = Nx.Random.key(System.system_time(:millisecond))

# Loading the final "Settled" weights
m = File.read!(checkpoint_path) |> :erlang.binary_to_term()
{f_e, f_a1, f_f1, f_a2, f_f2, f_lmw, f_lmb} = {m.e, m.a1, m.f1, m.a2, m.f2, m.lmw, m.lmb}

IO.puts("--- Probing The Settled Scholar (Epoch 13) ---\n")

Enum.reduce(seeds, key, fn seed_text, current_key ->
  seed_ids = seed_text |> to_charlist() |> Nx.tensor() |> Nx.reshape({1, :auto})
  IO.write("#{seed_text}")
  
  Enum.reduce_while(1..128, {seed_ids, current_key}, fn _i, {acc_ids, k} ->
    {_, total_len} = Nx.shape(acc_ids)
    window_len = min(total_len, 128)
    window_ids = Nx.slice_along_axis(acc_ids, total_len - window_len, window_len, axis: 1)
    
    raw_logits = DLM.Inference.predict_next(
      Nx.add(Nx.take(f_e, window_ids), DLM.Positional.build(window_len, 256)), 
      f_a1, f_f1, f_a2, f_f2, f_lmw, f_lmb,
      DLM.Mask.causal(window_len), 0.0, k 
    )

    # --- REPETITION PENALTY (FIXED) ---
    history = Nx.slice_along_axis(acc_ids, max(0, total_len - 15), min(total_len, 15), axis: 1)
    penalized_logits = Enum.reduce(Nx.to_flat_list(history), raw_logits, fn id, acc ->
      val = Nx.to_number(acc[id])
      new_val = if val > 0, do: val / rep_penalty, else: val * rep_penalty
      Nx.indexed_put(acc, Nx.tensor([[id]]), Nx.tensor([new_val]))
    end)

    # Top-K, Softmax, and Choice
    {top_vals, _} = Nx.top_k(penalized_logits, k: top_k_val)
    kth_val = Nx.reduce_min(top_vals, axes: [-1], keep_axes: true)
    
    filtered_logits = Nx.select(Nx.greater_equal(penalized_logits, kth_val), 
                                Nx.divide(penalized_logits, temp), 
                                Nx.tensor(-1.0e9))

    max_l = Nx.reduce_max(filtered_logits, axes: [-1], keep_axes: true)
    probs = Nx.exp(Nx.subtract(filtered_logits, max_l)) 
    probs = Nx.divide(probs, Nx.sum(probs, axes: [-1], keep_axes: true))

    {choice, nk} = Nx.Random.choice(k, Nx.iota({128}), probs)
    next_id = choice |> Nx.squeeze() |> Nx.to_number()

    if next_id == 10 do
      {:halt, {acc_ids, nk}}
    else
      if next_id >= 32 and next_id < 127, do: IO.write(<<next_id>>)
      {:cont, {Nx.concatenate([acc_ids, Nx.reshape(Nx.tensor([next_id]), {1, 1})], axis: 1), nk}}
    end
  end)
  IO.puts("")
  current_key
end)
