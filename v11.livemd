## Cooling Burn

```elixir
# --- V11 FINAL SETTLEMENT PASS (THE DEEP CHILL) ---
dict_path = "english_dictionary.csv"
checkpoint_to_load = Path.join(File.cwd!(), "v11_deep_burn_epoch_12.bin")

# Configuration (Maintaining shape for weight compatibility)
seq_len = 128
batch_size = 16 
chunk_size = 5
settle_lr = 0.0002 # 10x cooler than the main burn

# 1. Rebuild Math Constants (Required after restart)
pos_emb = DLM.Positional.build(seq_len, 256)
causal_mask = DLM.Mask.causal(seq_len)

# 2. Load the Epoch 12 Brain
IO.puts("📂 Loading Epoch 12 Brain... Preparing to settle weights.")
m = File.read!(checkpoint_to_load) |> :erlang.binary_to_term()
weights = {m.e, m.a1, m.f1, m.a2, m.f2, m.lmw, m.lmb, 0}

IO.puts("🧊 Starting Settlement Pass (Epoch 13). Target: Smoothing the Shrapnel.")

{ne, na1, nf1, na2, nf2, nlmw, nlmb, _} =
  DLM.DataStreamer.stream_continuous(dict_path, seq_len, batch_size, chunk_size)
  |> Enum.reduce(weights, fn {ins, tgs}, {ce, ca1, cf1, ca2, cf2, clmw, clmb, step} ->

    # The precision math happens here
    {new_e, new_a1, new_f1, new_a2, new_f2, new_lmw, new_lmb, loss} =
      DLM.Optimizer.multi_step(ins, tgs, ce, ca1, cf1, ca2, cf2, clmw, clmb, pos_emb, causal_mask, settle_lr)

    if rem(step, 100) == 0 do
      l_val = Nx.to_number(loss)
      IO.puts("SETTLEMENT | Chunk #{step} | Loss: #{Float.round(l_val, 6)} | RAM: #{round(:erlang.memory(:total) / 1_000_000)}MB")
    end

    # Keep that RAM lean (Crucial for 6GB systems)
    {
      Nx.backend_copy(new_e, Nx.BinaryBackend),
      Nx.backend_copy(new_a1, Nx.BinaryBackend),
      Nx.backend_copy(new_f1, Nx.BinaryBackend),
      Nx.backend_copy(new_a2, Nx.BinaryBackend),
      Nx.backend_copy(new_f2, Nx.BinaryBackend),
      Nx.backend_copy(new_lmw, Nx.BinaryBackend),
      Nx.backend_copy(new_lmb, Nx.BinaryBackend),
      step + 1
    }
  end)

# 3. Save the "Scholar" Brain
final_checkpoint = Path.join(File.cwd!(), "v11_brain_settled_final.bin")
File.write!(final_checkpoint, :erlang.term_to_binary(%{
  e: ne, a1: na1, f1: nf1, a2: na2, f2: nf2, lmw: nlmw, lmb: nlmb
}))

IO.puts("🏆 Brain Settled. Final Epoch 13 weights saved to: v11_brain_settled_final.bin")
```

