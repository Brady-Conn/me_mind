## Mouth

```elixir
# --- V11 TOP-K PRECISION SAMPLER ---
# Use v11_continuous_brain_epoch_5.bin (or the precision pass if you run it!)
checkpoint_path = Path.join(File.cwd!(), "v11_precision_brain_final.bin")

seeds = [
  "AARDVARK: ", 
  "FLUMMOX: ", 
  "ELIXIR: ",
  "COMPUTER: ",
  "TELEPHONE: "
]

# Standard LLM settings
temp = 0.7 
top_k_val = 5 # Only allow the top 5 most likely letters

key = Nx.Random.key(System.system_time(:millisecond))

weights = if File.exists?(checkpoint_path) do
  m = File.read!(checkpoint_path) |> :erlang.binary_to_term()
  {m.e, m.a1, m.f1, m.a2, m.f2, m.lmw, m.lmb}
else
  IO.puts("⚠️ Precision brain not found, looking for Epoch 5...")
  backup = Path.join(File.cwd!(), "v11_continuous_brain_epoch_5.bin")
  m = File.read!(backup) |> :erlang.binary_to_term()
  {m.e, m.a1, m.f1, m.a2, m.f2, m.lmw, m.lmb}
end

{f_e, f_a1, f_f1, f_a2, f_f2, f_lmw, f_lmb} = weights

IO.puts("--- Running V11 Sampler (Top-K: #{top_k_val}) ---\n")

Enum.reduce(seeds, key, fn seed_text, current_key ->
  seed_ids = seed_text |> to_charlist() |> Nx.tensor() |> Nx.reshape({1, :auto})
  IO.write("#{seed_text}")
  
  # Generation up to 128 characters
  {_final_ids, next_seed_key} = Enum.reduce_while(1..128, {seed_ids, current_key}, fn _i, {acc_ids, k} ->
    {_, total_len} = Nx.shape(acc_ids)
    
    # 128-Context Sliding Window
    window_len = min(total_len, 128)
    window_ids = Nx.slice_along_axis(acc_ids, total_len - window_len, window_len, axis: 1)
    
    p_emb = DLM.Positional.build(window_len, 256)
    mask = DLM.Mask.causal(window_len)
    
    new_keys = Nx.Random.split(k)
    inf_key = new_keys[0]
    dice_key = new_keys[1]
    
    raw_logits = DLM.Inference.predict_next(
      Nx.add(Nx.take(f_e, window_ids), p_emb), 
      f_a1, f_f1, f_a2, f_f2, f_lmw, f_lmb,
      mask, 0.0, inf_key 
    )

    # --- TOP-K FILTER ---
    {top_vals, _} = Nx.top_k(raw_logits, k: top_k_val)
    kth_val = Nx.reduce_min(top_vals, axes: [-1], keep_axes: true)
    top_k_mask = Nx.greater_equal(raw_logits, kth_val)
    
    # Kill the bad options and scale by temperature
    filtered_logits = Nx.select(top_k_mask, Nx.divide(raw_logits, temp), Nx.tensor(-1.0e9))

    # Safe Softmax (The "NaN Shield")
    max_logit = Nx.reduce_max(filtered_logits, axes: [-1], keep_axes: true)
    safe_logits = Nx.subtract(filtered_logits, max_logit)
    final_probs = Nx.exp(safe_logits) |> Nx.divide(Nx.sum(Nx.exp(safe_logits), axes: [-1], keep_axes: true))

    {choice_tensor, nk} = Nx.Random.choice(dice_key, Nx.iota({128}), final_probs)
    next_id = choice_tensor |> Nx.squeeze() |> Nx.to_number()

    # ASCII filter and Stop at newline
    if next_id == 10 or total_len >= 128 do
      {:halt, {acc_ids, nk}}
    else
      if next_id >= 32 and next_id < 127, do: IO.write(<<next_id>>)
      new_acc = Nx.concatenate([acc_ids, Nx.reshape(Nx.tensor([next_id]), {1, 1})], axis: 1)
      {:cont, {new_acc, nk}}
    end
  end)
  
  IO.puts("\n") 
  next_seed_key
end)
```
