```elixir
defmodule DLM.PhysicsGenesis do
  import Nx.Defn

  @vocab 128
  @dim 512

  defn init(k1) do
    std_dim = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@dim, type: :f32)))
    std_voc = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@vocab, type: :f32)))
    std_496 = Nx.divide(1.0, Nx.sqrt(Nx.tensor(4096, type: :f32)))

    sqrt_2 = Nx.sqrt(2.0)
    c_std_dim = Nx.divide(std_dim, sqrt_2)
    c_std_voc = Nx.divide(std_voc, sqrt_2)
    c_std_496 = Nx.divide(std_496, sqrt_2)

    # 1. Initialize Matrices with a trailing channel: {Rows, Cols, 2}
    {b1_r, k2} = Nx.Random.normal(k1, 0.0, c_std_voc, shape: {@vocab, @dim}, type: :f32)
    {b1_i, k3} = Nx.Random.normal(k2, 0.0, c_std_voc, shape: {@vocab, @dim}, type: :f32)
    b1 = Nx.stack([b1_r, b1_i], axis: -1)

    {b2_r, k4} = Nx.Random.normal(k3, 0.0, c_std_dim, shape: {@dim, @vocab}, type: :f32)
    {b2_i, k5} = Nx.Random.normal(k4, 0.0, c_std_dim, shape: {@dim, @vocab}, type: :f32)
    b2 = Nx.stack([b2_r, b2_i], axis: -1)

    {c1_r, k6} = Nx.Random.normal(k5, 0.0, c_std_voc, shape: {@vocab, @dim}, type: :f32)
    {c1_i, k7} = Nx.Random.normal(k6, 0.0, c_std_voc, shape: {@vocab, @dim}, type: :f32)
    c1 = Nx.stack([c1_r, c1_i], axis: -1)

    {c2_r, k8} = Nx.Random.normal(k7, 0.0, c_std_dim, shape: {@dim, @vocab}, type: :f32)
    {c2_i, k9} = Nx.Random.normal(k8, 0.0, c_std_dim, shape: {@dim, @vocab}, type: :f32)
    c2 = Nx.stack([c2_r, c2_i], axis: -1)

    {w1_r, k10} = Nx.Random.normal(k9, 0.0, c_std_voc, shape: {@vocab, @dim}, type: :f32)
    {w1_i, k11} = Nx.Random.normal(k10, 0.0, c_std_voc, shape: {@vocab, @dim}, type: :f32)
    w1 = Nx.stack([w1_r, w1_i], axis: -1)

    {w2_r, k12} = Nx.Random.normal(k11, 0.0, c_std_dim, shape: {@dim, @vocab}, type: :f32)
    {w2_i, k13} = Nx.Random.normal(k12, 0.0, c_std_dim, shape: {@dim, @vocab}, type: :f32)
    w2 = Nx.stack([w2_r, w2_i], axis: -1)

    {wd_r, k14} = Nx.Random.normal(k13, 0.0, c_std_496, shape: {4096, @vocab}, type: :f32)
    {wd_i, k15} = Nx.Random.normal(k14, 0.0, c_std_496, shape: {4096, @vocab}, type: :f32)
    wd = Nx.stack([wd_r, wd_i], axis: -1)

    # 2. Initialize Scaling/Bias vectors with an explicit trailing channel: {Dim, 2}
    make_2ch_vector = fn base_val, dim_size ->
      r = Nx.broadcast(base_val, {dim_size}) |> Nx.as_type(:f32)
      i = Nx.broadcast(0.0, {dim_size}) |> Nx.as_type(:f32)
      Nx.stack([r, i], axis: -1)
    end

    bb = make_2ch_vector.(0.0, @dim)
    cb = make_2ch_vector.(0.0, @dim)
    wb = make_2ch_vector.(0.0, @dim)
    
    bq = make_2ch_vector.(1.0, @dim)
    cq = make_2ch_vector.(1.0, @dim)
    wq = make_2ch_vector.(1.0, @dim)
    
    be = make_2ch_vector.(0.0, @vocab)
    bg = make_2ch_vector.(1.0, @vocab)
    ce = make_2ch_vector.(0.0, @vocab)
    cg = make_2ch_vector.(1.0, @vocab)
    we = make_2ch_vector.(0.0, @vocab)
    wg = make_2ch_vector.(1.0, @vocab)
    
    trainable_params = {b1, b2, bb, bq, bg, be, 
                        c1, c2, cb, cq, cg, ce,
                        w1, w2, wb, wq, wg, we, wd} 
    
    {trainable_params, k15}
  end
end

