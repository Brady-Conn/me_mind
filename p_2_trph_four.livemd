```elixir
defmodule DLM.StatelessMuon do
  import Nx.Defn

  # Helper to pull a specific channel from the final axis (-1)
  defn get_channel(tensor, channel_index) do
    Nx.slice_along_axis(tensor, channel_index, 1, axis: -1) |> Nx.squeeze(axes: [-1])
  end

  # Helper to compute complex matrix multiplication: X @ Y for 2-channel tensors
  defn complex_dot_2ch(x, y) do
    xr = get_channel(x, 0)
    xi = get_channel(x, 1)
    yr = get_channel(y, 0)
    yi = get_channel(y, 1)

    real_part = Nx.dot(xr, yr) - Nx.dot(xi, yi)
    imag_part = Nx.dot(xr, yi) + Nx.dot(xi, yr)
    Nx.stack([real_part, imag_part], axis: -1)
  end

  # Helper to compute the complex adjoint (conjugate transpose) of a 2D 2-channel matrix
  defn complex_adjoint_2ch(x) do
    xr = get_channel(x, 0)
    xi = Nx.negate(get_channel(x, 1))
    
    xr_t = Nx.transpose(xr, axes: [1, 0])
    xi_t = Nx.transpose(xi, axes: [1, 0])
    
    Nx.stack([xr_t, xi_t], axis: -1)
  end

  # Custom Frobenius norm for 3D 2-channel tensors
  defn frobenius_norm_3d(tensor) do
    flat_vector = Nx.flatten(tensor)
    # Add a small epsilon to guarantee we never divide by zero
    Nx.sqrt(Nx.sum(Nx.pow(flat_vector, 2))) + 1.0e-9
  end

  # Helper to flip the primary row/col dimensions of a 2-channel matrix
  defn transpose_2ch(x) do
    xr = get_channel(x, 0)
    xi = get_channel(x, 1)
    Nx.stack([Nx.transpose(xr), Nx.transpose(xi)], axis: -1)
  end

  defn newton_schulz(g) do
    # 1. Determine if the matrix is tall/wide asymmetric (Rows > Cols)
    rows = Nx.axis_size(g, 0)
    cols = Nx.axis_size(g, 1)
    is_tall = rows > cols

    # 2. If tall (like wd), flip dimensions so it works on the smaller square manifold
    g_working = if is_tall, do: transpose_2ch(g), else: g

    f_norm = frobenius_norm_3d(g_working)
    x = g_working / f_norm
    
    {final_x, _} = while {curr_x = x, i = 0}, Nx.less(i, 5) do
      curr_x_adjoint = complex_adjoint_2ch(curr_x)
      x_t_x = complex_dot_2ch(curr_x_adjoint, curr_x)
      
      term1 = 1.5 * curr_x
      term2 = 0.5 * complex_dot_2ch(curr_x, x_t_x)
      next_x = Nx.subtract(term1, term2)
      
      {next_x, i + 1}
    end

    # 3. If we transposed at the start, transpose back to restore the original shape
    if is_tall, do: transpose_2ch(final_x), else: final_x
  end

  defn muon_step(em, grad, lr) do
    # Check rank based on structural dimensions (Matrix with channel has rank 3)
    if Nx.rank(em) == 3 do
      ns_grad = newton_schulz(grad)
      update = lr * ns_grad
      Nx.subtract(em, update)
    else
      Nx.subtract(em, lr * grad)
    end
  end
end
