## SSM

```elixir
defmodule DLM.SvdSSM do
  import Nx.Defn

  defn rms_norm(x, gamma, beta, epsilon \\ 1.0e-6) do
    # Returns a pure :f32 variance array
    variance_map = DLM.ComplexMath.magnitude_sq(x)
    variance = Nx.mean(variance_map, axes: [-1], keep_axes: true)
    
    # Broadcast variance back to match the 2-channel layout shape
    variance_3d = Nx.new_axis(variance, -1)
    norm = Nx.multiply(x, Nx.rsqrt(variance_3d + epsilon))
    
    # Apply scaling parameters across both real/imag channels uniformly
    # Note: gamma and beta are initialized with an implicit trailing channel too!
    Nx.add(DLM.ComplexMath.multiply(norm, gamma), beta)
  end

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance_map = DLM.ComplexMath.magnitude_sq(x)
    variance = Nx.mean(variance_map, axes: [-1], keep_axes: true)
    variance_3d = Nx.new_axis(variance, -1)
    Nx.multiply(x, Nx.rsqrt(variance_3d + epsilon))
  end

  # Split the input, activate independently, then restack
  defn apply_complex_activation(x, activation_fn) do
    r = DLM.ComplexMath.get_channel(x, 0) |> activation_fn.()
    i = DLM.ComplexMath.get_channel(x, 1) |> activation_fn.()
    Nx.stack([r, i], axis: -1)
  end

  defn gelu_real(x) do
    cdf = Nx.multiply(
      Nx.tensor(0.7978845608, type: :f32),
      Nx.add(x, Nx.multiply(Nx.tensor(0.044715, type: :f32), Nx.pow(x, 3)))
    )
    Nx.multiply(Nx.multiply(Nx.tensor(0.5, type: :f32), x), Nx.add(Nx.tensor(1.0, type: :f32), Nx.tanh(cdf)))
  end
  
  defn feed_forward_layer(x, um, ga, bi, dm) do
    up = DLM.ComplexMath.dot(x, um) 
    act = apply_complex_activation(up, &gelu_real/1)
    scaled = DLM.ComplexMath.multiply(act, ga)
    biased = Nx.add(scaled, bi)
    DLM.ComplexMath.dot(biased, dm) 
  end

  # Softmax over magnitude to preserve valid real probabilities
  defn softmax(t) do
    magnitudes = Nx.abs(t)
    max_val = Nx.reduce_max(magnitudes, axes: [-1], keep_axes: true)
    safe_t = Nx.subtract(magnitudes, max_val)
    exps = Nx.exp(safe_t)
    sum_exps = Nx.sum(exps, axes: [-1], keep_axes: true)
    Nx.divide(exps, Nx.add(sum_exps, 1.0e-8))
  end

  defn apply_xsa(x, y) do
    y_norm_sq = Nx.sum(DLM.ComplexMath.magnitude_sq(y), axes: [-1], keep_axes: true) |> Nx.add(1.0e-6)
    y_norm_sq_3d = Nx.new_axis(y_norm_sq, -1)
    y_unit = Nx.divide(y, Nx.sqrt(y_norm_sq_3d))
    
    # Project utilizing complex dot product rule: Sum(X * conj(Y_unit))
    conj_y_unit = DLM.ComplexMath.conjugate(y_unit)
    y_ov_raw = DLM.ComplexMath.multiply(x, conj_y_unit)
    y_ov = Nx.sum(y_ov_raw, axes: [-2], keep_axes: true) # sum across embedding axis
    
    Nx.subtract(x, DLM.ComplexMath.multiply(y_ov, y_unit))
  end

  defn apply_attention(q, v) do
    # Split value matrix channels
    vr = DLM.ComplexMath.get_channel(v, 0)
    vi = DLM.ComplexMath.get_channel(v, 1)
    
    # Extract query components
    qr = DLM.ComplexMath.get_channel(q, 0)
    qi = DLM.ComplexMath.get_channel(q, 1)

    # Compute complex scores using standard Nx dot rules
    # score_r = QR @ VR^T + QI @ VI^T
    # score_i = QI @ VR^T - QR @ VI^T
    r = Nx.axis_size(v, 1)
    qu_r = Nx.new_axis(qr, 1)
    qu_i = Nx.new_axis(qi, 1)
    
    k_r = Nx.transpose(vr, axes: [0, 2, 1])
    k_i = Nx.transpose(vi, axes: [0, 2, 1])

    score_r = Nx.dot(qu_r, [2], [0], k_r, [1], [0]) + Nx.dot(qu_i, [2], [0], k_i, [1], [0])
    score_i = Nx.dot(qu_i, [2], [0], k_r, [1], [0]) - Nx.dot(qu_r, [2], [0], k_i, [1], [0])

    # Convert score back to absolute scalar values for softmax gating
    score_magnitude = Nx.sqrt(Nx.pow(score_r, 2) + Nx.pow(score_i, 2))
    scaled_score = Nx.divide(score_magnitude, Nx.sqrt(r))
    soft_score = softmax(scaled_score) # Returns pure real weights

    # Apply weights across real and imaginary streams to build output matrix
    out_r = Nx.dot(soft_score, [2], [0], vr, [1], [0]) |> Nx.squeeze(axes: [1])
    out_i = Nx.dot(soft_score, [2], [0], vi, [1], [0]) |> Nx.squeeze(axes: [1])

    Nx.stack([out_r, out_i], axis: -1)
  end

  defn forward_step(x_t, spell_mem, word_mem, solver, em, p) do
    {b1, b2, bb, bq, bg, be, 
     c1, c2, cb, cq, cg, ce,
     w1, w2, wb, wq, wg, we, wd} = p

    # 1. Token Retrieval from 2-Channel Embedding Matrix
    u_raw = Nx.take(em, x_t) 
    u_t = DLM.ComplexMath.dot(u_raw, em)

    # 2. Extract Phase Angles & create Dynamic Time-Scale Decay Gating
    phase_angles = DLM.ComplexMath.phase(u_raw)
    decay_gate = Nx.sigmoid(phase_angles) 
    
    # Broadcast decay across channels to multiply {Batch, 32, 128, 2}
    decay_gate_4d = Nx.new_axis(decay_gate, 1) |> Nx.new_axis(-1)

    wm_scaled = Nx.multiply(word_mem, decay_gate_4d)
    sm_scaled = Nx.multiply(spell_mem, decay_gate_4d)

    # 3. Handle Space Token Reset
    is_space = Nx.equal(x_t, 32) |> Nx.as_type(:f32) |> Nx.new_axis(1)
    is_space_4d = Nx.new_axis(is_space, 1) |> Nx.new_axis(-1)
    reset_factor_4d = Nx.subtract(1.0, is_space_4d)
    
    sm_set = Nx.multiply(sm_scaled, reset_factor_4d)

    # 4. Update Spelling Sequence Memory
    sl_sm = Nx.slice_along_axis(sm_set, 1, 31, axis: 1)
    sm_new = Nx.concatenate([sl_sm, Nx.new_axis(u_t, 1)], axis: 1)

    # 5. Down-project Spelling and Embed
    wrd = Nx.reshape(sm_new, {:auto, 4096, 2}) |> DLM.ComplexMath.dot(wd) |> DLM.ComplexMath.dot(em)

    # 6. Update Word Memory with 2-Channel Blending
    sl_wm_nonspace = Nx.slice_along_axis(wm_scaled, 0, 127, axis: 1)
    sl_wm_space    = Nx.slice_along_axis(wm_scaled, 1, 127, axis: 1)

    sl_wm = Nx.multiply(sl_wm_space, is_space_4d)
            |> Nx.add(Nx.multiply(sl_wm_nonspace, Nx.subtract(1.0, is_space_4d)))
    wm_new = Nx.concatenate([sl_wm, Nx.new_axis(wrd, 1)], axis: 1)

    # 7. Context Processing Blocks
    sp_ctx = apply_attention(u_t, sm_new)
    spxa = apply_xsa(sp_ctx, u_t)
    b_in = Nx.add(u_t, spxa)
    b_term = feed_forward_layer(b_in, b1, bq, bb, b2)
    b_norm = rms_norm(b_term, bg, be)

    wm_ctx = apply_attention(u_t, wm_new)
    wmxa = apply_xsa(wm_ctx, u_t)
    w_in = Nx.add(u_t, wmxa)
    w_term = feed_forward_layer(w_in, w1, wq, wb, w2)
    w_norm = rms_norm(w_term, wg, we)

    # 8. Manage Thinking Workspace Space
    solv_sl = Nx.slice_along_axis(solver, 1, 126, axis: 1)
    solv_cur = Nx.concatenate([Nx.new_axis(b_norm, 1), solv_sl, Nx.new_axis(w_norm, 1)], axis: 1)

    solv_ctx = apply_attention(u_t, solv_cur)
    c_term = feed_forward_layer(solv_ctx, c1, cq, cb, c2)
    c_norm = rms_norm(c_term, cg, ce)

    # 9. Extract Final Logits
    logits = DLM.ComplexMath.dot(c_norm, em)
    
    # Extract only the real component (channel 0) to feed into your cross-entropy
    real_logits = DLM.ComplexMath.get_channel(logits, 0)

    {real_logits, sm_new, wm_new}
  end
end
```

