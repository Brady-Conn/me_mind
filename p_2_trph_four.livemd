## Fourier Embedding Gen

```elixir
defmodule DLM.ComplexEmbedding do
  import Nx.Defn

  @dim 128

  def build_matrix, do: build_matrix_defn()

  defn build_matrix_defn do
    pairs = div(@dim, 2)
    rows_int = Nx.iota({@dim, 1}, type: :s32)
    cols_int = Nx.iota({1, @dim}, type: :s32)

    pair_rows_int = Nx.quotient(rows_int, 2)
    pair_cols_int = Nx.quotient(cols_int, 2)
    block_mask = Nx.equal(pair_rows_int, pair_cols_int)

    pair_rows_f32 = Nx.as_type(pair_rows_int, :f32)
    denom = Nx.max(1.0, pairs - 1)
    w = 0.01 + pair_rows_f32 * (Nx.Constants.pi() - 0.01) / denom

    row_even = Nx.equal(Nx.remainder(rows_int, 2), 0)
    col_even = Nx.equal(Nx.remainder(cols_int, 2), 0)
    row_odd = Nx.logical_not(row_even)
    col_odd = Nx.logical_not(col_even)

    real_mask = Nx.logical_or(Nx.logical_and(row_even, col_even), Nx.logical_and(row_odd, col_odd))
    real_tensor = Nx.select(real_mask, Nx.cos(w), 0.0) |> Nx.select(block_mask, 0.0)

    imag_tensor = Nx.select(Nx.logical_and(row_even, col_odd), -Nx.sin(w), 0.0) +
                  Nx.select(Nx.logical_and(row_odd, col_even), Nx.sin(w), 0.0)
    imag_tensor = Nx.select(block_mask, imag_tensor, 0.0)

    # FIX: Stack real and imaginary channels on a final axis. 
    # Shape becomes: {128, 128, 2}, Type: :f32
    Nx.stack([real_tensor, imag_tensor], axis: -1)
  end
end

