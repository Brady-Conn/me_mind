```elixir
run_prefix  = "v44_DLM_256sq_complex_v1"
total_steps = 32000

{load_path, start_step} = DLM.CheckpointManager.get_resume_state(run_prefix)

if start_step == :completed do
  IO.puts("This run has already reached #{total_steps} steps. Exiting.") 
else
  batch_size = 64
  data_dir = "./data/babylm_high_sanitize" 
  
  IO.puts("Initializing Lazy Curriculum Data Stream from [#{data_dir}]...")
  
  data_stream = 
    BabyLM.CurriculumStreamer.build_infinite_stream(data_dir, batch_size)

    |> Stream.drop(start_step) 

  {starting_trainable, starting_frozen, initial_key} =
    if load_path == :fresh do
      IO.puts("Igniting brand new Complex Trainable weights for #{run_prefix}...")
      {ip, ik} = DLM.PhysicsGenesis.init(Nx.Random.key(System.system_time()))
      
      # Generating your static complex Fourier Matrix from our vectorized module
      fourier_matrix = DLM.ComplexEmbedding.build_matrix()
      {ip, fourier_matrix, ik}
    else
      IO.puts("Loading Trainable Weights from #{load_path}...")
      %{trainable: t_p, frozen: f_p} = File.read!(load_path) |> :erlang.binary_to_term()
      {t_p, f_p, Nx.Random.key(System.system_time())}
    end
  
  trainable_gpu = DLM.Tree.map(starting_trainable, &Nx.backend_copy(&1, gpu))
  frozen_gpu = DLM.Tree.map(starting_frozen, &Nx.backend_copy(&1, gpu))
  step_count = Nx.tensor(start_step) |> Nx.backend_copy(gpu)
  
  # ZIP FROM THE START_STEP
  {final_p, final_f, _key, _step} =
    Enum.reduce(Stream.zip(start_step..(total_steps - 1), data_stream), 
      {trainable_gpu, frozen_gpu, initial_key, step_count}, 
      fn {step, cpu_batch}, {cur_tr, frzn, cur_key, c_step} ->        
        
      gpu_batch = Nx.backend_copy(cpu_batch, gpu)
     
      base_lr = 5.0e-5
      min_lr = 5.0e-6
      warmup_steps = 1600
      cooldown_start = 6000
      
      current_lr = 
        if step < warmup_steps do
          base_lr * (step / warmup_steps)
        else
          if step < cooldown_start do
            base_lr
          else
            progress = min(max((step - cooldown_start) / (total_steps - cooldown_start), 0.0), 1.0) 
            min_lr + 0.5 * (base_lr - min_lr) * (1.0 + :math.cos(:math.pi() * progress))
          end
        end
      
      # Match LR precision to f32
      lr_tensor = Nx.tensor(current_lr, type: :f32) |> Nx.backend_copy(gpu)

      split_keys = Nx.Random.split(cur_key)
      next_key = split_keys[1]
      
      # 1. Extract complex gradients via our updated trainer module
      {loss_tensor, grads} = DLM.Phase2Trainer.compute_grad(cur_tr, frzn, gpu_batch)
      loss_val = Nx.to_number(loss_tensor)

      # 2. Map updates across parameters tuple handling mixed types
      param_list = Tuple.to_list(cur_tr)
      grad_list = Tuple.to_list(grads)

      updated_list =
        Enum.zip(param_list, grad_list)

        |> Enum.map(fn {param, grad} ->
          # Muon handles complex matrices and scales real vectors identically via standard GD bounds
          DLM.StatelessMuon.muon_step(param, grad, lr_tensor)
        end)

      up_tr = List.to_tuple(updated_list)
      up_step = Nx.add(c_step, 1)
  
      # Telemetry with Complex Magnitude Norm Tracking
      if rem(step, 100) == 0 do
        {b1, b2, bb, bq, bg, be, c1, c2, cb, cq, cg, ce, w1, w2, wb, wq, wg, we, wd} = up_tr

        b1_norm = DLM.Phase2Trainer.complex_norm_fn(b1) |> Nx.to_number() |> Float.round(4)
        b2_norm = DLM.Phase2Trainer.complex_norm_fn(b2) |> Nx.to_number() |> Float.round(4)
        bb_norm = DLM.Phase2Trainer.complex_norm_fn(bb) |> Nx.to_number() |> Float.round(4)
        bq_norm = DLM.Phase2Trainer.complex_norm_fn(bq) |> Nx.to_number() |> Float.round(4)
        bg_norm = DLM.Phase2Trainer.complex_norm_fn(bg) |> Nx.to_number() |> Float.round(4)
        be_norm = DLM.Phase2Trainer.complex_norm_fn(be) |> Nx.to_number() |> Float.round(4)
        
        c1_norm = DLM.Phase2Trainer.complex_norm_fn(c1) |> Nx.to_number() |> Float.round(4)
        c2_norm = DLM.Phase2Trainer.complex_norm_fn(c2) |> Nx.to_number() |> Float.round(4)
        cb_norm = DLM.Phase2Trainer.complex_norm_fn(cb) |> Nx.to_number() |> Float.round(4)
        cq_norm = DLM.Phase2Trainer.complex_norm_fn(cq) |> Nx.to_number() |> Float.round(4)
        cg_norm = DLM.Phase2Trainer.complex_norm_fn(cg) |> Nx.to_number() |> Float.round(4)
        ce_norm = DLM.Phase2Trainer.complex_norm_fn(ce) |> Nx.to_number() |> Float.round(4)
        
        w1_norm = DLM.Phase2Trainer.complex_norm_fn(w1) |> Nx.to_number() |> Float.round(4)
        w2_norm = DLM.Phase2Trainer.complex_norm_fn(w2) |> Nx.to_number() |> Float.round(4)
        wb_norm = DLM.Phase2Trainer.complex_norm_fn(wb) |> Nx.to_number() |> Float.round(4)
        wq_norm = DLM.Phase2Trainer.complex_norm_fn(wq) |> Nx.to_number() |> Float.round(4)
        wg_norm = DLM.Phase2Trainer.complex_norm_fn(wg) |> Nx.to_number() |> Float.round(4)
        we_norm = DLM.Phase2Trainer.complex_norm_fn(we) |> Nx.to_number() |> Float.round(4)
        wd_norm = DLM.Phase2Trainer.complex_norm_fn(wd) |> Nx.to_number() |> Float.round(4)

        IO.puts("➡️ Step #{step} | LR: #{Float.round(current_lr, 6)} | Loss: #{Float.round(loss_val, 4)} |  wd #{wd_norm}")
        IO.puts("➡️ PN 1: b1 #{b1_norm} |  b2 #{b2_norm} |  bb #{bb_norm} |  bq #{bq_norm} |  be #{be_norm} |  bg #{bg_norm}")
        IO.puts("➡️ PN 2: c1 #{c1_norm} |  c2 #{c2_norm} |  cb #{cb_norm} |  cq #{cq_norm} |  ce #{ce_norm} |  cg #{cg_norm}")
        IO.puts("➡️ PN 3: w1 #{w1_norm} |  w2 #{w2_norm} |  wb #{wb_norm} |  wq #{wq_norm} |  we #{we_norm} |  wg #{wg_norm}")
        :erlang.garbage_collect()
      end
  
      # Checkpoint Saving (Native serialization fully handles complex types out of the box)
      if rem(step, 1000) == 0 and step > 0 do
        IO.puts("Checkpoint reached! Saving Step #{step}...")
        cpu_tr = DLM.Tree.map(up_tr, &Nx.backend_copy(&1, Nx.BinaryBackend))
        cpu_fr = DLM.Tree.map(frzn, &Nx.backend_copy(&1, Nx.BinaryBackend))
        filename = "#{run_prefix}_checkpoint_step_#{step}.bin"
        File.write!(filename, :erlang.term_to_binary(%{trainable: cpu_tr, frozen: cpu_fr}))
        :erlang.garbage_collect()
      end
  
      {up_tr, frzn, next_key, up_step}
    end)

  IO.puts("Saving Final Fourier Reservoir Weights...")
  fin_t = DLM.Tree.map(final_p, &Nx.backend_copy(&1, Nx.BinaryBackend))
  fin_f = DLM.Tree.map(final_f, &Nx.backend_copy(&1, Nx.BinaryBackend))
  File.write!("#{run_prefix}_final.bin", :erlang.term_to_binary(%{trainable: fin_t, frozen: fin_f}))
  IO.puts("Training Complete!")
end
