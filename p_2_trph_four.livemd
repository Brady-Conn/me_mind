```elixir
defmodule DLM.ComplexMath do
  import Nx.Defn

  # Helper to pull a specific channel from the final axis (-1)
  defn get_channel(tensor, channel_index) do
    # Pulls a slice of width 1 along the final axis, then squashes the empty dimension
    Nx.slice_along_axis(tensor, channel_index, 1, axis: -1) |> Nx.squeeze(axes: [-1])
  end

  # Complex Multiplication: (a + bi)(c + di) = (ac - bd) + (ad + bc)i
  defn multiply(x, y) do
    xr = get_channel(x, 0)
    xi = get_channel(x, 1)
    yr = get_channel(y, 0)
    yi = get_channel(y, 1)

    real_part = xr * yr - xi * yi
    imag_part = xr * yi + xi * yr
    Nx.stack([real_part, imag_part], axis: -1)
  end

  # Matrix Multiplication for 2-channel complex tensors
  defn dot(x, y) do
    xr = get_channel(x, 0)
    xi = get_channel(x, 1)
    yr = get_channel(y, 0)
    yi = get_channel(y, 1)

    real_part = Nx.dot(xr, yr) - Nx.dot(xi, yi)
    imag_part = Nx.dot(xr, yi) + Nx.dot(xi, yr)
    Nx.stack([real_part, imag_part], axis: -1)
  end

  # Complex Conjugate: a + bi -> a - bi
  defn conjugate(x) do
    real_part = get_channel(x, 0)
    imag_part = Nx.negate(get_channel(x, 1))
    Nx.stack([real_part, imag_part], axis: -1)
  end

  # Magnitude Squared: |x|^2 = a^2 + b^2 (Returns a pure real float)
  defn magnitude_sq(x) do
    Nx.pow(get_channel(x, 0), 2) + Nx.pow(get_channel(x, 1), 2)
  end

  # Phase extraction: theta = atan2(imag, real) (Returns a pure real float)
  defn phase(x) do
    Nx.atan2(get_channel(x, 1), get_channel(x, 0))
  end
end

