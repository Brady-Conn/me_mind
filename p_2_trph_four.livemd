## Train

```elixir
defmodule DLM.Phase2Trainer do
  import Nx.Defn

  # 1. Complex-compatible Step Cross Entropy Loss
  # Standard cross-entropy expects real numbers; real_logits is passed automatically
  defn step_cross_entropy(real_logits, targets) do
    vocab_size = Nx.axis_size(real_logits, -1)
    one_hot = Nx.equal(Nx.iota({vocab_size}), Nx.new_axis(targets, -1))
    
    max_logits = Nx.reduce_max(real_logits, axes: [-1], keep_axes: true)
    safe_logits = Nx.subtract(real_logits, max_logits)
    log_probs = Nx.subtract(safe_logits, Nx.log(Nx.sum(Nx.exp(safe_logits), axes: [-1], keep_axes: true)))
    
    Nx.negate(Nx.sum(Nx.multiply(one_hot, log_probs), axes: [-1]))
  end

  defn compute_sequence_loss(input_tokens, em, params) do
    batch_size = Nx.axis_size(input_tokens, 0)

    # Natively real float layouts! No compiler type conversion conflicts possible.
    sm_start = Nx.broadcast(0.0, {batch_size, 32, 128, 2}) |> Nx.as_type(:f32)
    wm_start = Nx.broadcast(0.0, {batch_size, 128, 128, 2}) |> Nx.as_type(:f32)
    solver   = Nx.broadcast(0.0, {batch_size, 128, 128, 2}) |> Nx.as_type(:f32)
    
    zero_scalar = Nx.tensor(0.0, type: :f32)

    result =
      while {i = 0, 
             total_loss = zero_scalar, 
             valid_tokens = zero_scalar,
             sm = sm_start,
             wm = wm_start,
             sl = solver,
             fr = em,
             inf = input_tokens,
             tp = params},
            Nx.less(i, Nx.axis_size(inf, 1) - 1) do

        x_t = inf[[.., i]]
        t_t = inf[[.., i + 1]]
        
        {logits, sm_new, wm_new} = DLM.SvdSSM.forward_step(x_t, sm, wm, sl, fr, tp)
        
        step_loss = step_cross_entropy(logits, t_t)
        mask = Nx.not_equal(t_t, 1) |> Nx.as_type(:f32)
        
        masked_loss_scalar = Nx.sum(Nx.multiply(step_loss, mask))
        valid_tokens_scalar = Nx.sum(mask)

        {i + 1, 
         Nx.add(total_loss, masked_loss_scalar), 
         Nx.add(valid_tokens, valid_tokens_scalar),
         sm_new, wm_new, sl, fr, inf, tp}
      end
  
    {_, acc_loss, val_tokens, _, _, _, _, _, _} = result
    Nx.divide(acc_loss, Nx.add(val_tokens, 1.0e-8))
  end

  defn compute_grad(params, em, batch_tokens) do
    seq_len = Nx.axis_size(batch_tokens, 1) - 1
    input_tokens  = Nx.slice_along_axis(batch_tokens, 0, seq_len, axis: 1)

    {loss, raw_grads} = 
      value_and_grad(params, fn p -> compute_sequence_loss(input_tokens, em, p) end)
      
    {loss, raw_grads}
  end

  defn complex_norm_fn(tensor) do
    tensor
      |> Nx.pow(2)
      |> Nx.sum()
      |> Nx.sqrt()
  end
end
