## Inference, probe, test

```elixir
# ===========================================================================
# V16 Inference — adds repetition penalty to greedy
# ===========================================================================
defmodule DLM.Inference do
  import Nx.Defn

  @allowed_chars ~c" abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789.,:;-'\"()[]"

  def build_muzzle(vocab_size \\ 128, allowed \\ @allowed_chars) do
    muzzle = Nx.broadcast(Nx.tensor(-1.0e10, type: :f32), {vocab_size})
    Enum.reduce(allowed, muzzle, fn char, acc ->
      Nx.indexed_put(acc, Nx.tensor([[char]]), Nx.tensor([0.0]))
    end)
  end

  defn get_next_logits(ins, params, pos_emb, mask, muzzle) do
    logits = DLM.Optimizer.forward(ins, params, pos_emb, mask)
    logits[[0, -1, 0..-1//1]] + muzzle
  end

  defn predict_greedy(ins, params, pos_emb, mask, muzzle) do
    get_next_logits(ins, params, pos_emb, mask, muzzle) |> Nx.argmax()
  end

  def sample_top_k(ins, params, pos_emb, mask, muzzle, temp, key, opts \\ []) do
    k = Keyword.get(opts, :k, 5)
    do_sample_top_k(ins, params, pos_emb, mask, muzzle, temp, key, k: k)
  end

  defn do_sample_top_k(ins, params, pos_emb, mask, muzzle, temp, key, opts \\ []) do
    logits = get_next_logits(ins, params, pos_emb, mask, muzzle) / temp
    {top_values, top_indices} = Nx.top_k(logits, k: opts[:k])
    probs = Nx.exp(top_values) / Nx.sum(Nx.exp(top_values))
    {sampled_tensor, new_key} = Nx.Random.choice(key, top_indices, probs)
    {sampled_tensor[0], new_key}
  end

  # Repetition penalty — applied on CPU side to recent tokens
  defp apply_rep_penalty(logits, recent_tokens, penalty \\ 1.3) do
    Enum.reduce(recent_tokens, logits, fn token_id, acc ->
      current = Nx.to_number(acc[token_id])
      new_val = if current > 0, do: current / penalty, else: current * penalty
      Nx.indexed_put(acc, Nx.tensor([[token_id]]), Nx.tensor([new_val]))
    end)
  end

  def greedy(params, pos_emb, mask, prompt, max_new_chars \\ 120, muzzle \\ nil) do
    gpu    = Nx.default_backend()
    muzzle = (muzzle || build_muzzle()) |> Nx.backend_copy(gpu)
    prompt_chars = String.to_charlist(prompt)
    seq_len = elem(Nx.shape(pos_emb), 0)

    Enum.reduce(1..max_new_chars, prompt_chars, fn step, chars ->
      pad_len = seq_len - length(chars)
      padded  = List.duplicate(0, max(0, pad_len)) ++ chars
      ins     = Nx.tensor([Enum.take(padded, -seq_len)], type: :s64)
                |> Nx.backend_copy(gpu)

      # Get logits then apply rep penalty on CPU
      raw_logits = get_next_logits(ins, params, pos_emb, mask, muzzle)
      recent     = Enum.take(chars, -20)  # penalise last 20 tokens
      penalized  = apply_rep_penalty(raw_logits, recent, 1.3)
      next_token = penalized |> Nx.argmax() |> Nx.to_number()

      if rem(step, 10) == 0, do: :erlang.garbage_collect(self())
      chars ++ [next_token]
    end)
    |> List.to_string()
  end

  def top_k(params, pos_emb, mask, prompt, max_new_chars \\ 120,
            k \\ 5, temp \\ 0.8, muzzle \\ nil) do
    gpu    = Nx.default_backend()
    muzzle = (muzzle || build_muzzle()) |> Nx.backend_copy(gpu)
    prompt_chars = String.to_charlist(prompt)
    seq_len = elem(Nx.shape(pos_emb), 0)

    Enum.reduce(1..max_new_chars, {prompt_chars, Nx.Random.key(42)},
      fn step, {chars, key} ->
        pad_len = seq_len - length(chars)
        padded  = List.duplicate(0, max(0, pad_len)) ++ chars
        ins     = Nx.tensor([Enum.take(padded, -seq_len)], type: :s64)
                  |> Nx.backend_copy(gpu)

        {next_token, next_key} =
          sample_top_k(ins, params, pos_emb, mask, muzzle, temp, key, k: k)

        if rem(step, 10) == 0, do: :erlang.garbage_collect(self())
        {chars ++ [Nx.to_number(next_token)], next_key}
      end)
    |> elem(0)
    |> List.to_string()
  end
end

IO.puts("✅ DLM.Inference loaded")
```

```elixir
# ===========================================================================
# V16 Probe — unchanged from V15
# ===========================================================================
defmodule DLM.Probe do
  def run(params, pos_emb, mask) do
    gpu    = Nx.default_backend()
    muzzle = DLM.Inference.build_muzzle() |> Nx.backend_copy(gpu)

    IO.puts("\n" <> String.duplicate("=", 60))
    IO.puts("DLM UNIVERSAL INFERENCE PROBE (V16)")
    IO.puts(String.duplicate("=", 60))

    IO.puts("\n📚 IN-DISTRIBUTION")
    IO.puts(String.duplicate("-", 40))
    probe(params, pos_emb, mask, "[W]happy [T]adj [D]",  "Definition of 'happy'", muzzle)
    probe(params, pos_emb, mask, "[W]water [T]noun [D]", "Definition of 'water'", muzzle)
    probe(params, pos_emb, mask, "[W]run [T]verb [D]",   "Definition of 'run'",   muzzle)

    IO.puts("\n🔄 REVERSE FORMAT")
    IO.puts(String.duplicate("-", 40))
    probe(params, pos_emb, mask, "[D]A feeling of great pleasure [W]", "Word for pleasure", muzzle)
    probe(params, pos_emb, mask, "[D]To move swiftly on foot [W]",     "Word for swift",    muzzle)

    IO.puts("\n🔀 NEAR-DISTRIBUTION")
    IO.puts(String.duplicate("-", 40))
    probe(params, pos_emb, mask, "The word 'happy' means",         "Prose definition",  muzzle)
    probe(params, pos_emb, mask, "[W]love [R]Related:",            "Relational format", muzzle)
    probe(params, pos_emb, mask, "[W]cold [T]adj [D]The opposite", "Partial def",       muzzle)

    IO.puts("\n💬 OUT-OF-DISTRIBUTION")
    IO.puts(String.duplicate("-", 40))
    probe(params, pos_emb, mask, "What is the meaning of life?", "Philosophical", muzzle)
    probe(params, pos_emb, mask, "Hello, how are you?",          "Greeting",      muzzle)
    probe(params, pos_emb, mask, "Can you define the word",      "Conversational",muzzle)

    IO.puts("\n🔤 MORPHOLOGY")
    IO.puts(String.duplicate("-", 40))
    probe(params, pos_emb, mask, "[W]Electr", "Electr-", muzzle)
    probe(params, pos_emb, mask, "[W]Mecha",  "Mecha-",  muzzle)
    probe(params, pos_emb, mask, "[W]Inter",  "Inter-",  muzzle)
    probe(params, pos_emb, mask, "[W]Ortho",  "Ortho-",  muzzle)
    probe(params, pos_emb, mask, "[W]Trans",  "Trans-",  muzzle)

    IO.puts("\n" <> String.duplicate("=", 60))
  end

  defp probe(params, pos_emb, mask, prompt, label, muzzle) do
    IO.puts("\n▶ #{label}")
    IO.puts("  Prompt:  #{inspect(prompt)}")

    greedy  = DLM.Inference.greedy(params, pos_emb, mask, prompt, 60, muzzle)
    sampled = DLM.Inference.top_k(params, pos_emb, mask, prompt, 60, 5, 0.8, muzzle)

    IO.puts("  Greedy:  #{inspect(String.slice(greedy,  String.length(prompt)..-1//1))}")
    IO.puts("  Top-k:   #{inspect(String.slice(sampled, String.length(prompt)..-1//1))}")

    :erlang.garbage_collect(self())
  end
end

IO.puts("✅ DLM.Probe loaded")
```

