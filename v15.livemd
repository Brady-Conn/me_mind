## Init

```elixir
# --- V15 Universal Genesis (16 Tensors) ---
vocab_size = 128
embed_dim  = 256
ff_dim     = 1024 # 4x Expansion for the Gated FF
max_loops  = 8    # Maximum possible "depth"

gpu = {EXLA.Backend, client: :rocm}
cpu = Nx.BinaryBackend

init_p = fn shape, key ->
  {t, next_k} = Nx.Random.normal(key, 0.0, 0.02, shape: shape, type: :f32)
  {Nx.backend_copy(t, gpu), next_k}
end

key = Nx.Random.key(15)

# Tensors 1-2: Input Logic
{embed, key}      = init_p.({vocab_size, embed_dim}, key)
{iter_embed, key} = init_p.({max_loops, embed_dim}, key) # The "Internal Clock"

# Tensors 3-6: Shared Attention Block
{w_q, key} = init_p.({embed_dim, embed_dim}, key)
{w_k, key} = init_p.({embed_dim, embed_dim}, key)
{w_v, key} = init_p.({embed_dim, embed_dim}, key)
{w_o, key} = init_p.({embed_dim, embed_dim}, key)

# Tensors 7-9: Gated FeedForward (SwiGLU)
{w_gate, key} = init_p.({embed_dim, ff_dim}, key)
{w_up, key}   = init_p.({embed_dim, ff_dim}, key)
{w_down, key} = init_p.({ff_dim, embed_dim}, key)

# Tensors 10-14: Layer Norms (Gain & Bias)
g1 = Nx.broadcast(Nx.tensor(1.0, type: :f32), {embed_dim}) |> Nx.backend_copy(gpu)
b1 = Nx.broadcast(Nx.tensor(0.0, type: :f32), {embed_dim}) |> Nx.backend_copy(gpu)
g2 = Nx.broadcast(Nx.tensor(1.0, type: :f32), {embed_dim}) |> Nx.backend_copy(gpu)
b2 = Nx.broadcast(Nx.tensor(0.0, type: :f32), {embed_dim}) |> Nx.backend_copy(gpu)
final_g = Nx.broadcast(Nx.tensor(1.0, type: :f32), {embed_dim}) |> Nx.backend_copy(gpu)

# Tensors 15-16: Output Head
{lm_w, key} = init_p.({embed_dim, vocab_size}, key)
lm_b = Nx.broadcast(Nx.tensor(0.0, type: :f32), {vocab_size}) |> Nx.backend_copy(gpu)

# Pack the 16-tensor tuple
v15_params = {
  embed, iter_embed,        
  w_q, w_k, w_v, w_o,       
  w_gate, w_up, w_down,     
  g1, b1, g2, b2, final_g,  
  lm_w, lm_b                
}

# Save to disk
to_bin = fn tpl -> tpl |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, cpu)) |> List.to_tuple() end
File.write!("v15_genesis.bin", :erlang.term_to_binary(to_bin.(v15_params)))
IO.puts("✅ V15 Universal Genesis complete. 16 tensors saved to v15_genesis.bin")
```

