full_state_path = "v16_full_state.bin"
seq_len = 256

# Lock to GPU
gpu = {EXLA.Backend, client: :rocm}
Nx.global_default_backend(gpu)

IO.puts("💾 Loading V16 Checkpoint...")
%{params: params_cpu, step: step, epoch: epoch} = 
  File.read!(full_state_path) |> :erlang.binary_to_term()

# Push assets to RX 7600
