## streamer

```elixir
defmodule DLM.DataStreamer do
  def stream(path, seq_len, batch_size, seed \\ nil) do
    # Load and shuffle once, then immediately start streaming
    # rather than holding the joined string in memory
    lines =
      path
      |> File.read!()
      |> String.split("\n", trim: true)

    shuffled = case seed do
      nil -> Enum.shuffle(lines)
      s   ->
        rng_state = :rand.seed_s(:exsss, {s, s + 1, s + 2})
        Process.put(:rand_seed, rng_state)
        Enum.shuffle(lines)
    end

    # Release the original list immediately
    # by not keeping a reference to it
    shuffled
    |> Stream.flat_map(fn line ->
      # Stream line by line instead of joining to one giant charlist
      (line <> "\n") |> to_charlist()
    end)
    |> Stream.chunk_every(seq_len + 1, seq_len, :discard)
    |> Stream.map(fn chunk ->
      ins = chunk |> Enum.take(seq_len) |> Nx.tensor(type: :s64)
      tgs = chunk |> Enum.drop(1)      |> Nx.tensor(type: :s64)
      {ins, tgs}
    end)
    |> Stream.chunk_every(batch_size, batch_size, :discard)
    |> Stream.map(fn batch ->
      {ins_list, tgs_list} = Enum.unzip(batch)
      {Nx.stack(ins_list), Nx.stack(tgs_list)}
    end)
  end
end
```
