## Train

```elixir
# ===========================================================================
# V16 Training Loop — fixes:
#   1. Explicit chunk_acc destructuring (no Tuple.insert_at)
#   2. GPU tensor push inside loop (CPU copies freed promptly)
#   3. Correct batch_size in log message
#   4. RAM safety halt preserved
# ===========================================================================
path            = "v13_lean_dictionary.txt"
full_state_path = "v16_full_state.bin"   # new file — loads v15 checkpoint below
v15_state_path  = "v15_full_state.bin"   # source checkpoint

seq_len    = 256
batch_size = 4
epochs     = 10
start_lr   = 0.0001
end_lr     = 0.00001
ram_limit  = 6000  # MB

gpu = {EXLA.Backend, client: :rocm}
Nx.global_default_backend(gpu)

to_gpu = fn tpl ->
  tpl |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, gpu)) |> List.to_tuple()
end
to_cpu = fn tpl ->
  tpl |> Tuple.to_list() |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend)) |> List.to_tuple()
end

# Load — prefer v16 checkpoint, fall back to v15, then genesis
{params, m_state, v_state, start_step, start_epoch} =
  cond do
    File.exists?(full_state_path) ->
      IO.puts("♻️  Resuming V16 from checkpoint...")
      %{params: p, m: m, v: v, step: s, epoch: e} =
        File.read!(full_state_path) |> :erlang.binary_to_term()
      {to_gpu.(p), to_gpu.(m), to_gpu.(v), s, e}

    File.exists?(v15_state_path) ->
      IO.puts("🔄 Migrating from V15 checkpoint...")
      %{params: p, m: m, v: v, step: s, epoch: e} =
        File.read!(v15_state_path) |> :erlang.binary_to_term()
      # Reset Adam momentum since we fixed the training loop
      # (old momentum was computed with double forward pass, now invalid)
      zero_like = fn t ->
        Nx.broadcast(Nx.tensor(0.0), Nx.shape(t)) |> Nx.backend_copy(Nx.BinaryBackend)
      end
      fresh_m = p |> Tuple.to_list() |> Enum.map(zero_like) |> List.to_tuple()
      IO.puts("   Weights carried over, Adam momentum reset (training loop changed)")
      {to_gpu.(p), to_gpu.(fresh_m), to_gpu.(fresh_m), s, e}

    true ->
      IO.puts("❌ No checkpoint found — run genesis initializer first")
      System.halt(1)
  end

IO.puts("📍 Step #{start_step}, Epoch #{start_epoch}")

pos_emb = DLM.Positional.build(seq_len, 256) |> Nx.backend_copy(gpu)
mask    = DLM.Mask.causal(seq_len) |> Nx.backend_copy(gpu)

batches_per_epoch = 178_718 |> div(batch_size)
total_steps       = epochs * batches_per_epoch

# FIX 1: Override the saved epoch with reality to break the time loop
true_start_epoch = div(start_step, batches_per_epoch) + 1

IO.puts("📊 #{batches_per_epoch} batches/epoch → #{total_steps} total steps")
IO.puts("🚀 [V16] Training | seq=#{seq_len} batch=#{batch_size}")
IO.puts("📍 Resuming at Step #{start_step}, True Epoch #{true_start_epoch}")

save_checkpoint = fn p, m, v, step, epoch ->
  # Snapshot references before spawning
  p_ref = p
  m_ref = m
  v_ref = v

  Task.async(fn ->
    to_bin = fn tpl ->
      tpl
      |> Tuple.to_list()
      |> Enum.map(&Nx.backend_copy(&1, Nx.BinaryBackend))
      |> List.to_tuple()
    end
    state = %{
      params: to_bin.(p_ref),
      m:      to_bin.(m_ref),
      v:      to_bin.(v_ref),
      step:   step,
      epoch:  epoch
    }
    File.write!(full_state_path, :erlang.term_to_binary(state))
    IO.puts("💾 Saved step #{step} (epoch #{epoch})")
  end)
  |> Task.await(60_000)  # wait up to 60s for save to complete
end

# FIX 2: Use true_start_epoch here instead of start_epoch
Enum.reduce_while(true_start_epoch..epochs, {params, m_state, v_state, start_step},
  fn epoch, epoch_acc ->
    IO.puts("\n--- Epoch #{epoch} ---")

    # Extract the current step from the accumulator
    {_, _, _, current_step} = epoch_acc

    # FIX 3: Tie the seed ONLY to the epoch. 
    # This guarantees the shuffle order for Epoch N is always the same.
    epoch_seed = epoch * 31337

    # FIX 4: Figure out how many batches we've already done in this epoch
    batches_to_skip = rem(current_step, batches_per_epoch)
    
    if batches_to_skip > 0 do
      IO.puts("⏩ Fast-forwarding stream by #{batches_to_skip} batches...")
    end

    epoch_result =
      DLM.DataStreamer.stream(path, seq_len, batch_size, epoch_seed)
      |> Stream.drop(batches_to_skip) # <-- THE FAST-FORWARD
      |> Stream.chunk_every(200)
      |> Enum.reduce_while(epoch_acc, fn batch_chunk, chunk_acc ->

        {p_acc, m_acc, v_acc, step_acc} = chunk_acc

        {p, m, v, step, last_loss} =
          Enum.reduce(batch_chunk, {p_acc, m_acc, v_acc, step_acc, 0.0},
            fn {ins, tgs}, {p_in, m_in, v_in, s_in, _} ->
              
              ins_gpu = Nx.backend_copy(ins, gpu)
              tgs_gpu = Nx.backend_copy(tgs, gpu)

              progress = min(s_in / total_steps, 1.0)
              lr       = Nx.tensor(start_lr - progress * (start_lr - end_lr), type: :f32)
              step_t   = Nx.tensor(s_in + 1, type: :s32)

              {new_p, new_m, new_v, loss} =
                DLM.Optimizer.adam_step(ins_gpu, tgs_gpu, p_in, m_in, v_in,
                                        pos_emb, mask, lr, step_t)

              loss_float = Nx.to_number(loss)

              if s_in < 1000 or rem(s_in, 5) == 0, do: :erlang.garbage_collect(self())

              {new_p, new_m, new_v, s_in + 1, loss_float}
            end)

        mem_mb = round(:erlang.memory(:total) / 1_048_576)
        IO.puts("🔥 Step #{step} | Epoch #{epoch} | Loss: #{Float.round(last_loss, 4)} | RAM: #{mem_mb}MB")

        save_checkpoint.(p, m, v, step, epoch)
        :erlang.garbage_collect(self())
        Process.sleep(10)

        if mem_mb > ram_limit do
          IO.puts("♻️  RAM limit reached — re-run to continue")
          {:halt, {p, m, v, step}}
        else
          {:cont, {p, m, v, step}}
        end
      end)

    mem_mb = round(:erlang.memory(:total) / 1_048_576)
    if mem_mb > ram_limit do
      {:halt, epoch_result}
    else
      {:cont, epoch_result}
    end
  end)
```

