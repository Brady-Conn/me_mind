## Transformer, mask, optimizer

```elixir
# ===========================================================================
# V16 Transformer — identical to V15, no changes needed
# ===========================================================================
defmodule DLM.TransformerV16 do
  import Nx.Defn

  defn layer_norm(x, g, b) do
    mean = Nx.mean(x, axes: [-1], keep_axes: true)
    var  = Nx.variance(x, axes: [-1], keep_axes: true)
    ((x - mean) / Nx.sqrt(var + 1.0e-5)) * g + b
  end

  defn universal_block(x, w_q, w_k, w_v, w_o, w_gate, w_up, w_down, g1, b1, g2, b2, mask) do
    # Pre-norm attention
    norm_x = layer_norm(x, g1, b1)
    q = Nx.dot(norm_x, w_q)
    k = Nx.dot(norm_x, w_k)
    v = Nx.dot(norm_x, w_v)

    scale  = Nx.sqrt(Nx.tensor(256.0, type: :f32))
    scores = Nx.dot(q, [2], [0], k, [2], [0]) / scale
    scores = scores + Nx.broadcast(mask, Nx.shape(scores))

    logits_max = Nx.reduce_max(scores, axes: [-1], keep_axes: true)
    exp        = Nx.exp(scores - logits_max)
    attn       = exp / (Nx.sum(exp, axes: [-1], keep_axes: true) + 1.0e-10)

    attn_out = Nx.dot(attn, [2], [0], v, [1], [0])
    x = x + Nx.dot(attn_out, w_o)

    # Pre-norm SwiGLU feedforward
    norm_x2 = layer_norm(x, g2, b2)
    gate    = Nx.dot(norm_x2, w_gate)
    gate    = gate * Nx.sigmoid(gate)
    up      = Nx.dot(norm_x2, w_up)
    ff_out  = Nx.dot(gate * up, w_down)

    x + ff_out
  end
end

IO.puts("✅ DLM.TransformerV16 loaded")
```

```elixir
# ===========================================================================
# V16 Positional + Mask
# ===========================================================================
defmodule DLM.Positional do
  def build(len, dim) do
    i     = Nx.iota({len, 1})
    d     = Nx.iota({1, dim})
    dim_f = Nx.tensor(dim, type: :f32)
    Nx.sin(Nx.divide(i, Nx.pow(10000.0, Nx.divide(d, dim_f))))
  end
end

defmodule DLM.Mask do
  def causal(len) do
    Nx.iota({len, 1})
    |> Nx.less(Nx.iota({1, len}))
    |> Nx.multiply(-1.0e9)
  end
end

IO.puts("✅ DLM.Positional + DLM.Mask loaded")
```

```elixir
# ===========================================================================
# V16 Optimizer — fixes:
#   1. value_and_grad instead of double forward pass
#   2. Explicit chunk_acc destructuring (no Tuple.insert_at)
#   3. gradient clipping in adam_core
# ===========================================================================
defmodule DLM.Optimizer do
  import Nx.Defn

  defn forward(ins, params, pos_emb, mask) do
    {embed, iter_embed, w_q, w_k, w_v, w_o, w_gate, w_up, w_down,
     g1, b1, g2, b2, final_g, lm_w, lm_b} = params

    x = Nx.take(embed, ins) + pos_emb

    x = x + Nx.take(iter_embed, Nx.tensor(0))
    x = DLM.TransformerV16.universal_block(
          x, w_q, w_k, w_v, w_o, w_gate, w_up, w_down, g1, b1, g2, b2, mask)

    x = x + Nx.take(iter_embed, Nx.tensor(1))
    x = DLM.TransformerV16.universal_block(
          x, w_q, w_k, w_v, w_o, w_gate, w_up, w_down, g1, b1, g2, b2, mask)

    x = x + Nx.take(iter_embed, Nx.tensor(2))
    x = DLM.TransformerV16.universal_block(
          x, w_q, w_k, w_v, w_o, w_gate, w_up, w_down, g1, b1, g2, b2, mask)

    x = DLM.TransformerV16.layer_norm(x, final_g, 0.0)
    Nx.dot(x, lm_w) + lm_b
  end

  defn loss_fn(params, ins, tgs, pos_emb, mask) do
    logits     = forward(ins, params, pos_emb, mask)
    {b, s, v}  = Nx.shape(logits)
    logits_2d  = Nx.reshape(logits, {b * s, v})
    targets_1d = Nx.reshape(tgs, {b * s})

    max_logits  = Nx.reduce_max(logits_2d, axes: [-1], keep_axes: true)
    log_sum_exp = Nx.log(
                    Nx.sum(Nx.exp(logits_2d - max_logits),
                      axes: [-1], keep_axes: true) + 1.0e-10)
    log_probs   = (logits_2d - max_logits) - log_sum_exp

    indices = Nx.stack([Nx.iota({b * s}), targets_1d], axis: -1)
    -Nx.mean(Nx.gather(log_probs, indices))
  end

  defn adam_core(p, g, m_old, v_old, lr, t) do
    # Gradient clipping
    g   = Nx.clip(g, -1.0, 1.0)
    b1  = 0.9
    b2  = 0.999
    eps = 1.0e-8
    t_f = Nx.as_type(t, :f32)

    m_new = b1 * m_old + (1 - b1) * g
    v_new = b2 * v_old + (1 - b2) * (g * g)
    m_hat = m_new / (1 - Nx.pow(b1, t_f))
    v_hat = v_new / (1 - Nx.pow(b2, t_f))
    p_new = p - lr * m_hat / (Nx.sqrt(v_hat) + eps)

    {p_new, m_new, v_new}
  end

  defn apply_adam_unrolled(params, grads, m, v, lr, t) do
    {p0,  m0,  v0}  = adam_core(elem(params,0),  elem(grads,0),  elem(m,0),  elem(v,0),  lr, t)
    {p1,  m1,  v1}  = adam_core(elem(params,1),  elem(grads,1),  elem(m,1),  elem(v,1),  lr, t)
    {p2,  m2,  v2}  = adam_core(elem(params,2),  elem(grads,2),  elem(m,2),  elem(v,2),  lr, t)
    {p3,  m3,  v3}  = adam_core(elem(params,3),  elem(grads,3),  elem(m,3),  elem(v,3),  lr, t)
    {p4,  m4,  v4}  = adam_core(elem(params,4),  elem(grads,4),  elem(m,4),  elem(v,4),  lr, t)
    {p5,  m5,  v5}  = adam_core(elem(params,5),  elem(grads,5),  elem(m,5),  elem(v,5),  lr, t)
    {p6,  m6,  v6}  = adam_core(elem(params,6),  elem(grads,6),  elem(m,6),  elem(v,6),  lr, t)
    {p7,  m7,  v7}  = adam_core(elem(params,7),  elem(grads,7),  elem(m,7),  elem(v,7),  lr, t)
    {p8,  m8,  v8}  = adam_core(elem(params,8),  elem(grads,8),  elem(m,8),  elem(v,8),  lr, t)
    {p9,  m9,  v9}  = adam_core(elem(params,9),  elem(grads,9),  elem(m,9),  elem(v,9),  lr, t)
    {p10, m10, v10} = adam_core(elem(params,10), elem(grads,10), elem(m,10), elem(v,10), lr, t)
    {p11, m11, v11} = adam_core(elem(params,11), elem(grads,11), elem(m,11), elem(v,11), lr, t)
    {p12, m12, v12} = adam_core(elem(params,12), elem(grads,12), elem(m,12), elem(v,12), lr, t)
    {p13, m13, v13} = adam_core(elem(params,13), elem(grads,13), elem(m,13), elem(v,13), lr, t)
    {p14, m14, v14} = adam_core(elem(params,14), elem(grads,14), elem(m,14), elem(v,14), lr, t)
    {p15, m15, v15} = adam_core(elem(params,15), elem(grads,15), elem(m,15), elem(v,15), lr, t)

    new_p = {p0,p1,p2,p3,p4,p5,p6,p7,p8,p9,p10,p11,p12,p13,p14,p15}
    new_m = {m0,m1,m2,m3,m4,m5,m6,m7,m8,m9,m10,m11,m12,m13,m14,m15}
    new_v = {v0,v1,v2,v3,v4,v5,v6,v7,v8,v9,v10,v11,v12,v13,v14,v15}
    {new_p, new_m, new_v}
  end

  defn adam_step(ins, tgs, params, m, v, pos_emb, mask, lr, t) do
    # Fix: value_and_grad instead of two forward passes
    {loss, grads} = value_and_grad(params, fn p ->
      loss_fn(p, ins, tgs, pos_emb, mask)
    end)
    {new_params, new_m, new_v} = apply_adam_unrolled(params, grads, m, v, lr, t)
    {new_params, new_m, new_v, loss}
  end
end

IO.puts("✅ DLM.Optimizer loaded")
```

