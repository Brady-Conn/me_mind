## Data

```elixir
defmodule BabyLM.ScholarParser do
  @sequence_length 512 

  @datasets %{
    childes: ["childes.train.txt"], 
    bnc: ["bnc_spoken.train.txt"],
    switchboard: ["switchboard.train.txt"],
    subtitles: ["open_subtitles.train.txt"], 
    wiki: ["simple_wiki.train.txt"],
    gutenberg: ["gutenberg.train.txt"]
  }

  def generate_dataset_shards(directory_path, strict \\ true, bin \\ true) do
    IO.puts("\n🔪 Slicing dataset into continuous document shards...")

    Enum.each(@datasets, fn {dataset_name, files} ->
      Enum.each(files, fn file ->
        process_and_save_shard(directory_path, dataset_name, file, strict, bin)
      end)
    end)

    IO.puts("\n🎉 All dataset shards successfully generated!")
  end

  defp process_and_save_shard(dir, dataset_name, file, strict, bin) do
    path = Path.join(dir, file)
    
    if File.exists?(path) do
      IO.puts("  ✅ Processing #{file} [Domain: #{dataset_name}]")
      
      # 1. Read the raw text
      raw_text = File.read!(path)

      # 2. Apply Domain-Specific Cleaning (The new routing switch)
      cleaned_text = clean_text(dataset_name, raw_text, strict)

      # 3. Normalize ASCII, Chunk, and Filter
      chunks =
        cleaned_text
        |> String.to_charlist()
        |> Enum.map(&normalize_char/1)
        |> Enum.chunk_every(@sequence_length, @sequence_length, :discard)
        |> Enum.filter(fn chunk -> 
          Enum.count(chunk, &(&1 == 1)) < 8   # Less than 3% replacement tokens
        end)

      if bin do
        # 4. Pack into Nx Tensor and Save
        if length(chunks) > 0 do
          dataset_tensor = 
            Nx.tensor(chunks, type: :u8)
            |> Nx.backend_transfer(Nx.BinaryBackend) 
          
          # Output format: shard_childes_childes.train.txt_256.bin
          out_filename = "shard_#{dataset_name}_#{file}_strict_#{strict}_512.bin"
          File.write!(out_filename, :erlang.term_to_binary(dataset_tensor))
          IO.puts("     📦 Saved #{length(chunks)} sequences to #{out_filename}")
        else
          IO.puts("     ⚠️ Warning: #{file} resulted in 0 valid chunks after filtering.")
        end
      else
        if length(chunks) > 0 do
          
          out_filename = "shard_#{dataset_name}_#{file}_strict_#{strict}_512.txt"
          File.write!(out_filename, chunks)
          IO.puts("     📦 Saved #{length(chunks)} sequences to #{out_filename}")
        else
          IO.puts("     ⚠️ Warning: #{file} resulted in 0 valid chunks after filtering.")
        end
      end
      

    else
      IO.puts("  ❌ Missing #{file} (Skipping...)")
    end
  end

 # =========================================================================
  # 🧹 DOMAIN-SPECIFIC CLEANING PROTOCOLS
  # =========================================================================

  # ⚡ The "Light" Sanitation Catch-All (strict == false)
  # If strict is false, it ignores the domain and just collapses whitespace.
  defp clean_text(_domain, raw_text, false) do
    finalize_text(raw_text)
  end

  # ⚡ The "Strict" Sanitation Functions (strict == true)
  
  defp clean_text(:childes, raw_text, true) do
    raw_text
    |> String.replace(~r/\[.*?\]/s, " ")
    |> String.replace(~r/\*[A-Z]+:/, " ")
    |> finalize_text()
  end

  defp clean_text(:switchboard, raw_text, true) do
    raw_text
    |> String.replace(~r/[A-Z]:/, " ")
    |> finalize_text()
  end

  defp clean_text(:wiki, raw_text, true) do
    raw_text
    |> String.replace(~r/(?:=\s*){2,}([^=]+?)(?:\s*=){2,}/, "\\1.")
    |> finalize_text()
  end

  defp clean_text(:gutenberg, raw_text, true) do
    raw_text
    |> String.replace(~r/\nINDEX\s*\n.*?(?=\nCHAPTER|\nTHE END\.|\n=\s*=\s*=|\z)/is, " ")
    |> String.replace(~r/FOOTNOTES:\s*\n/i, " ")
    |> String.replace(~r/^\[\d+\].*$/m, " ")
    |> String.replace(~r/\[\d+\]/, "")
    |> String.replace(~r/\[(?:Illustration|Frontispiece):.*?\]/i, " ")
    |> String.replace(~r/(?:\*\s*){3,}/, " ")
    |> String.replace(~r/=\s*=\s*=\s*PG\d+\s*=\s*=\s*=/i, " ")
    |> finalize_text()
  end

  defp clean_text(:subtitles, raw_text, true) do
    raw_text
    |> String.replace(~r/♪/, " ")
    |> String.replace(~r/\[.*?\]|\(.*?\)/s, " ")
    |> String.replace(~r/^(?:CAPTIONING MADE POSSIBLE|Sub Provided By|Sync and corrections).*?$/mi, " ")
    |> String.replace(~r/^[A-Z0-9\s\.\-']+:\s*\n?/m, " ")
    |> String.replace(~r/^-\s*/m, " ")
    |> finalize_text()
  end

  # The generic fallback for datasets that don't need strict regex (like BNC)
  defp clean_text(:bnc, raw_text, true) do
    finalize_text(raw_text)
  end

  # =========================================================================
  # 🧹 COMMON HELPERS
  # =========================================================================
  
  # The Great Collapse: Turns all newlines, tabs, and multi-spaces into a single space, then trims.
  defp finalize_text(text) do
    text
    |> String.replace(~r/\s+/, " ")
    |> String.trim()
  end

  # =========================================================================
  # 🔤 ASCII NORMALIZATION
  # =========================================================================
  defp normalize_char(c) do
    cond do
      c < 128 -> c              # ASCII passthrough
      
      # Common accented Latin — map to base character
      c in 0xC0..0xC5 -> ?A     # À Á Â Ã Ä Å
      c in 0xC8..0xCB -> ?E     # È É Ê Ë
      c in 0xCC..0xCF -> ?I     # Ì Í Î Ï
      c in 0xD2..0xD6 -> ?O     # Ò Ó Ô Õ Ö
      c in 0xD9..0xDC -> ?U     # Ù Ú Û Ü
      c in 0xE0..0xE5 -> ?a     # à á â ã ä å
      c in 0xE8..0xEB -> ?e     # è é ê ë
      c in 0xEC..0xEF -> ?i     # ì í î ï
      c in 0xF2..0xF6 -> ?o     # ò ó ô õ ö
      c in 0xF9..0xFC -> ?u     # ù ú û ü
      c == 0xD1 -> ?N           # Ñ
      c == 0xF1 -> ?n           # ñ
      c == 0xC7 -> ?C           # Ç
      c == 0xE7 -> ?c           # ç
      c == 0xDF -> ?s           # ß -> ss would be ideal but single char is fine
      c == 0xD8 -> ?O           # Ø
      c == 0xF8 -> ?o           # ø
      c == 0xC6 -> ?A           # Æ
      c == 0xE6 -> ?a           # æ
  
      # Smart quotes -> straight quotes
      c in [0x2018, 0x2019] -> ?'
      c in [0x201C, 0x201D] -> ?"
      
      # Dashes
      c in [0x2013, 0x2014] -> ?-   # en-dash, em-dash
      
      # Ellipsis
      c == 0x2026 -> ?.
      
      # Everything else — use a dedicated replacement token
      # Use ASCII 1 (SOH) which never appears naturally in text
      true -> 1
    end
  end
end
