```elixir
batch_size = 32
seq_len = 512
key = Nx.Random.key(42) |> Nx.backend_copy(gpu)

embeds = Nx.Random.normal(key, 0.0, 0.1, shape: {128, 512}) |> elem(0) |> Nx.backend_copy(gpu)
lr = Nx.tensor(5.0e-5, type: :f32) |> Nx.backend_copy(gpu)

# ⚡ THE INFINITE CURRICULUM STREAM
  # Point this string to wherever your newly generated shard_*.bin files are saved
  data_dir = "./data/bbylm_512_strict" 
  
  IO.puts("🧠 Initializing Lazy Curriculum Data Stream from [#{data_dir}]...")
  data_stream = BabyLM.CurriculumStreamer.build_infinite_stream(data_dir, batch_size)

total_steps = 6000
IO.puts("🚀 IGNITION: Phase 1 SinkGD Training...")

final_embeds =
  Enum.reduce(
    Stream.zip(0..(total_steps - 1), data_stream),
    embeds,
    fn {step, batch}, e ->
      gpu_batch = Nx.backend_copy(batch, gpu) |> Nx.as_type(:s32)
      step_t = Nx.tensor(step, type: :f32) |> Nx.backend_copy(gpu)

      {loss, new_e} =
        DLM.ContextualEmbedTrainer.compute_grad_and_step(e, gpu_batch, step_t, lr)

      if rem(step, 100) == 0 do
        IO.puts("Step #{step} | Loss: #{Float.round(Nx.to_number(loss), 4)}")
        :erlang.garbage_collect()
      end

      new_e
    end
  )

IO.puts("🎉 PHASE 1 TRAINING COMPLETE!")

# Save — embeddings only, matching the format your downstream code expects
cpu_embeds = Nx.backend_copy(final_embeds, Nx.BinaryBackend)

# ⚡ Match the tuple format your Phase 2 loader expects:
# %{params: phase1_p} -> {cpu_embeds, _w1, _w2, _key}
dummy = Nx.broadcast(0.0, {1}) |> Nx.backend_copy(Nx.BinaryBackend)
File.write!(
  "phase1_sinkGD_nomix_512sq32b5e5_6k_COMPLETE.bin",
  :erlang.term_to_binary(%{params: {cpu_embeds, dummy, dummy, dummy}})
)
