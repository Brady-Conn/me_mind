```elixir
defmodule DLM.SvdOptimizer do
  import Nx.Defn

  defn update(params, grads, step, lr) do
    {a, b, c, d, em, ed, hq} = params   
    {ga, gb, gc, gd, gem, ged, ghq} = grads
    
    new_step = Nx.add(step, 1)

    # optimizer update step
    a_new = DLM.StatelessMuon.muon_step(a, ga, lr)
    b_new = DLM.StatelessMuon.muon_step(b, gb, lr)
    c_new = DLM.StatelessMuon.muon_step(c, gc, lr)
    d_new = DLM.StatelessMuon.muon_step(d, gd, lr)

    em_new = DLM.StatelessMuon.muon_step(em, gem, lr)
    ed_new = DLM.StatelessMuon.muon_step(ed, ged, lr)
    hq_new = DLM.StatelessMuon.muon_step(hq, ghq, lr)
    
    new_params = {a_new, b_new, c_new, d_new, em_new, ed_new, hq_new}

    {new_params, new_step}
  end
end
```

