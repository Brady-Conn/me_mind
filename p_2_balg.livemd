```elixir
defmodule DLM.PhysicsGenesis do
  import Nx.Defn

  @vocab 128
  @dim 512

  defn init(k1) do
    std_dim = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@dim, type: :f32)))
    std_voc = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@vocab, type: :f32)))

    # projection matrices
    
    {b, k2} = Nx.Random.normal(k1, 0.0, std_dim, shape: {@dim, @dim})
    {c, k3} = Nx.Random.normal(k2, 0.0, std_dim, shape: {@dim, @dim})
    {d, k4} = Nx.Random.normal(k3, 0.0, std_dim, shape: {@dim, @dim})
    {em, k5} = Nx.Random.normal(k4, 0.0, std_voc, shape: {@vocab, @dim})
    {ed, k6} = Nx.Random.normal(k5, 0.0, std_dim, shape: {@dim, @vocab})
    {hq, k7} = Nx.Random.normal(k6, 0.0, std_dim, shape: {@dim, @dim})
    a = Nx.broadcast(0.5, {@dim}) |> Nx.as_type(:f32)

    trainable_params = {a, b, c, d, em, ed, hq}
    
    {trainable_params, k7}
  end
end
