## SSM

```elixir
defmodule DLM.SvdSSM do
  import Nx.Defn

  defn l2_normalize(tensor) do
    # Calculate Euclidean norm across the last axis natively
    norm = Nx.sqrt(Nx.sum(Nx.pow(tensor, 2), axes: [-1], keep_axes: true))
    # Divide by norm with a tiny epsilon to prevent divide-by-zero
    Nx.divide(tensor, Nx.add(norm, 1.0e-6))
  end

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn gelu(x) do
    cdf = Nx.multiply(
      Nx.tensor(0.7978845608, type: :f32),
      Nx.add(x, Nx.multiply(Nx.tensor(0.044715, type: :f32), Nx.pow(x, 3)))
    )
    Nx.multiply(Nx.multiply(Nx.tensor(0.5, type: :f32), x), Nx.add(Nx.tensor(1.0, type: :f32), Nx.tanh(cdf)))
  end

  defn apply_svd(x, u, v) do
    hidden = Nx.dot(x, u)
    bound = Nx.tanh(hidden)
    Nx.dot(bound, v)
  end

  defn swish_vd(x, u, v) do
    active = gelu(x)
    hidden = Nx.dot(active, u)
    applied = Nx.dot(hidden, v)
    Nx.sigmoid(applied) |> Nx.multiply(applied)
  end

  defn softplus(x) do
    Nx.log1p(Nx.exp(x))
  end

  defn forward_step(xt_idx, h_prev, params) do

    {em, eq, er, es, au, av, zu, zv} = params

    x_t = Nx.take(em, xt_idx)

    # svd projections
    a_proj = swish_vd(h_prev, au, av)
    b_proj = swish_vd(x_t, au, av)
    
    h_new = Nx.add(a_proj, b_proj)

    h_latent = swish_vd(h_new, zu, zv)
    d_latent = swish_vd(x_t, zu, zv)

    logits_fwd1 = Nx.dot(Nx.add(h_latent, d_latent), eq)
    logits_fwd2 = Nx.dot(Nx.add(h_latent, d_latent), er) 
    logits_fwd3 = Nx.dot(Nx.add(h_latent, d_latent), es) 

    {logits_fwd1, logits_fwd2, logits_fwd3, h_new}
  end
end
