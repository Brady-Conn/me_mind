```elixir
defmodule DLM.SvdOptimizer do
  import Nx.Defn

  defn update(params, grads, step, lr) do
    {em, eq, er, es, au, av, zu, zv} = params
    {gem, geq, ger, ges, gau, gav, gzu, gzv} = grads

    new_step = Nx.add(step, 1)

    # optimizer update step
    em_new = DLM.SparseSinkGD.sink_step(em, gem, lr)
    eq_new = DLM.SparseSinkGD.sink_step(eq, geq, lr)
    er_new = DLM.SparseSinkGD.sink_step(er, ger, lr)
    es_new = DLM.SparseSinkGD.sink_step(es, ges, lr)
    au_new = DLM.SparseSinkGD.sink_step(au, gau, lr)
    av_new = DLM.SparseSinkGD.sink_step(av, gav, lr)
    zu_new = DLM.SparseSinkGD.sink_step(zu, gzu, lr)
    zv_new = DLM.SparseSinkGD.sink_step(zv, gzv, lr)
    
    new_params = {em_new, eq_new, er_new, es_new, au_new, av_new, 
                  zu_new, zv_new}

    {new_params, new_step}
  end
end
