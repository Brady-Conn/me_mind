```elixir
# [ Incoming Character (x_t) ] ➔ (Pulled from Frozen 512D Map)
#        │
#        ├──➔ 1. THE ROUTER (du, tw) ──────────────┐
#        │      • Compress x_t to 256D             │
#        │      • Reshape to 16x16 Affinity        │
#        │      • Sinkhorn Loop (heated by tw)     │
#        │                                         ▼
#        │                              [ 16x16 Transport Plan ]
#        │                                         │
# [ Previous Void (h_prev) ] ──────────────────────┴➔ [ Routed Void (h_routed) ]
#        │                                                      │
#        ├──➔ 2. THE INTENSITY GATE (dv) ──────────┐            │
#        │      • Expand 256D latent back to 512D  │            │
#        │      • Softplus activation ➔ (Delta)    │            │
#        │                                         ▼            │
#        │                              [ Dynamic Delta (Δ) ]   │
#        │                                         │            │
#        ├──➔ 3. THE PHYSICS UPDATE (a, bu, bv) ───┴────────────┤
#        │      • Calculate Friction: a_bar = exp(Δ * -abs(a))  │
#        │      • Calculate Input Force: b_bar = Δ * (x_t*bu*bv)│
#        │      • Apply strictly orthogonal combination         │
#        │                                                      ▼
#        └───────────────────────────────────────────➔ [ New Void (h_new) ]
#                                                               │
#                                                               ├──➔ (Pass to next step)
#                                                               │
#                                                      4. OUTPUT SVD (cu, cv)
#                                                               │
#                                                               ├──➔ [ FWD Logits (vw, vb) ]
#                                                               └──➔ [ RETRO Logits (rw, rb) ]
```

<!-- livebook:{"branch_parent_index":0} -->

## Train

```elixir
defmodule DLM.Phase2Trainer do
  import Nx.Defn

  defn compute_sequence_loss(input_tokens, target_tokens, h_init, params, embeds) do
    input_coords =
      Nx.take(embeds, Nx.flatten(input_tokens))
      |> Nx.reshape({Nx.axis_size(input_tokens, 0), Nx.axis_size(input_tokens, 1), 512})
      |> stop_grad()
  
    inputs_time_first = Nx.transpose(input_coords, axes: [1, 0, 2])
    targets_fwd_time_first = Nx.transpose(target_tokens, axes: [1, 0])
    targets_retro_time_first = Nx.transpose(input_tokens, axes: [1, 0])
  
    # The main unroll loop
    result =
      while {i = 0, total_fwd = 0.0, total_retro = 0.0, h = h_init, 
             inf = inputs_time_first, tf = targets_fwd_time_first, tr = targets_retro_time_first, p = params},
            Nx.less(i, Nx.axis_size(inf, 0)) do
        
        x_curr = inf[i]
        
        # ⚡ This now uses the FULL forward_step where p contains all trainable weights
        {logits_fwd, logits_retro, h_new} = DLM.SinkhornSSM.forward_step(x_curr, h, p)
        
        fwd_norm = DLM.Loss.l2_normalize(logits_fwd)
        retro_norm = DLM.Loss.l2_normalize(logits_retro)

        tf_norm = DLM.Loss.l2_normalize(tf[i])
        tr_norm = DLM.Loss.l2_normalize(tr[i])
        
        # Calculate OT across the batch cloud
        l_fwd = DLM.SinkhornOT.compute(fwd_norm, tf_norm, 1.0, 5)
        l_retro = DLM.SinkhornOT.compute(retro_norm, tr_norm, 1.0, 5)
        
        {i + 1, total_fwd + l_fwd, total_retro + l_retro, h_new, inf, tf, tr, p}
      end
  
    # ⚡ NEW: Extract the final hidden state (the 4th element in the tuple)
    {_, acc_fwd, acc_retro, final_h, _, _, _, _} = result
    
    seq_len = Nx.axis_size(inputs_time_first, 0)
    mean_fwd = acc_fwd / seq_len
    mean_retro = acc_retro / seq_len
    
    total_loss = mean_fwd + (0.3 * mean_retro)
    
    # ⚡ NEW: Pass final_h out of the function
    {total_loss, {mean_fwd, mean_retro, final_h}}
  end

 defn compute_grad(params, batch_tokens, h_init, frozen_embeds) do
    {_batch_size, full_seq_len} = Nx.shape(batch_tokens)
    seq_len = full_seq_len - 1
    
    input_tokens  = Nx.slice_along_axis(batch_tokens, 0, seq_len, axis: 1)
    target_tokens = Nx.slice_along_axis(batch_tokens, 1, seq_len, axis: 1)

    # ⚡ CATCH h_new HERE!
    {total_loss, {fwd_loss, retro_loss, h_new}} = compute_sequence_loss(
      input_tokens, target_tokens, h_init, params, frozen_embeds
    )
  
    {_loss, raw_grads} = value_and_grad(params, fn p ->
      {tot_loss, _aux} = compute_sequence_loss(input_tokens, target_tokens, h_init, p, frozen_embeds)
      tot_loss
    end)
  
    # ⚡ RETURN h_new
    {total_loss, fwd_loss, retro_loss, raw_grads, h_new}
  end
end
```

