```elixir
defmodule DLM.SinkhornOT do
  import Nx.Defn

  defn cost_matrix(pred, target) do
    # ⚡ MEMORY OPTIMIZATION: Use the algebraic expansion a^2 + b^2 - 2ab
    # This prevents the EXLA compiler from creating a 32GB intermediate tensor!
    p_sq = Nx.sum(Nx.pow(pred, 2), axes: [-1], keep_axes: true)
    t_sq = Nx.sum(Nx.pow(target, 2), axes: [-1], keep_axes: true) |> Nx.transpose()
    
    dot_prod = Nx.dot(pred, target)
    
    # Add the squares, subtract 2 * dot_product, and clamp to 0.0 for safety
    Nx.add(p_sq, t_sq) |> Nx.subtract(Nx.multiply(2.0, dot_prod)) |> Nx.max(0.0)
  end

  defn compute(pred, target, epsilon \\ 1.0, max_iters \\ 4) do
    batch_size = Nx.axis_size(pred, 0)
    seq_len = Nx.axis_size(pred, 1)
    
    c = cost_matrix(pred, target)
    k = Nx.exp(Nx.divide(Nx.negate(c), epsilon))
    
    mass = 1.0 / seq_len
    mu = Nx.broadcast(mass, {batch_size, seq_len})
    nu = Nx.broadcast(mass, {batch_size, seq_len})

    {_final_k, u_final, v_final, _mu, _nu, _i} =
      while {k_mat = k, 
             u = Nx.broadcast(1.0, {batch_size, seq_len}), 
             _v = Nx.broadcast(1.0, {batch_size, seq_len}), # ⚡ Warning silenced
             m = mu, n = nu, i = 0},
            Nx.less(i, max_iters) do
            
        # Transpose K for the u update
        k_t = Nx.transpose(k_mat, axes: [0, 2, 1])
        
        # Expand dims to [batch, seq, 1] to allow batched matrix-vector multiplication
        u_exp = Nx.new_axis(u, 2)
        k_u = Nx.dot(k_t, [2], [0], u_exp, [1], [0]) |> Nx.squeeze(axes: [2])
        denom_v = Nx.add(k_u, 1.0e-8)
        v_new = Nx.divide(n, denom_v)
        
        v_new_exp = Nx.new_axis(v_new, 2)
        k_v = Nx.dot(k_mat, [2], [0], v_new_exp, [1], [0]) |> Nx.squeeze(axes: [2])
        denom_u = Nx.add(k_v, 1.0e-8)
        u_new = Nx.divide(m, denom_u)

        {k_mat, u_new, v_new, m, n, i + 1}
      end

    u_exp = Nx.new_axis(u_final, 2)
    v_exp = Nx.new_axis(v_final, 1)
    
    p = Nx.multiply(Nx.multiply(u_exp, k), v_exp)

    Nx.sum(Nx.multiply(p, c))
  end
end
