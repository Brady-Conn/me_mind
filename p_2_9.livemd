```elixir
defmodule BabyLM.CurriculumStreamer do
  @moduledoc """
  Dynamically streams all pre-compiled .bin shards from a specified directory.
  Shuffles files at the document level every epoch to preserve continuous h_prev context.
  """

  def build_infinite_stream(directory_path, batch_size) do
    # 1. Gather all .bin files in the target directory
    target_shards = 
      Path.join(directory_path, "*.bin")
      |> Path.wildcard()

    if length(target_shards) == 0 do
      raise "CRITICAL: No .bin shards found in directory: #{directory_path}"
    end

    # 2. Infinite Lazy Loop
    Stream.iterate(1, &(&1 + 1))
    |> Stream.flat_map(fn epoch ->
      # This IO.puts will now ONLY fire when the previous epoch's batches are completely exhausted
      IO.puts("\n🔄 Epoch #{epoch} Started | Shuffling #{length(target_shards)} shards...")
      
      shuffled_shards = Enum.shuffle(target_shards)

      Stream.flat_map(shuffled_shards, fn path ->
        tensor = 
          File.read!(path)
          |> :erlang.binary_to_term()

        # ⚡ CRITICAL FIX: Enum.to_list() forces the Nx.Batched struct into a standard 
        # Elixir list, guaranteeing Stream.flat_map consumes every single batch.
        tensor
        |> Nx.to_batched(batch_size)
        |> Enum.to_list()
      end)
    end)
  end
end
