```elixir
defmodule DLM.SvdOptimizer do
  import Nx.Defn

  defn update(params, grads, step, lr) do
    {em, eq, er, es, qp, au, av, aw, ax, ay, az, bu, bv, bw, bx, by, bz, cu, cv, cw, cx, cy, cz, du, dv, dw, dx, dy, dz} = params
    {gem, geq, ger, ges, gqp, gau, gav, gaw, gax, gay, gaz, gbu, gbv, gbw, gbx, gby, gbz, gcu, gcv, gcw, gcx, gcy, gcz, gdu, gdv, gdw, gdx, gdy, gdz} = grads

    new_step = Nx.add(step, 1)

    # optimizer update step
    em_new = DLM.StatelessMuon.muon_step(em, gem, lr)
    eq_new = DLM.StatelessMuon.muon_step(eq, geq, lr)
    er_new = DLM.StatelessMuon.muon_step(er, ger, lr)
    es_new = DLM.StatelessMuon.muon_step(es, ges, lr)
    qp_new = DLM.StatelessMuon.muon_step(qp, gqp, lr)
    au_new = DLM.StatelessMuon.muon_step(au, gau, lr)
    av_new = DLM.StatelessMuon.muon_step(av, gav, lr)
    aw_new = DLM.StatelessMuon.muon_step(aw, gaw, lr)
    ax_new = DLM.StatelessMuon.muon_step(ax, gax, lr)
    ay_new = DLM.StatelessMuon.muon_step(ay, gay, lr)
    az_new = DLM.StatelessMuon.muon_step(az, gaz, lr)
    bu_new = DLM.StatelessMuon.muon_step(bu, gbu, lr)
    bv_new = DLM.StatelessMuon.muon_step(bv, gbv, lr)
    bw_new = DLM.StatelessMuon.muon_step(bw, gbw, lr)
    bx_new = DLM.StatelessMuon.muon_step(bx, gbx, lr)
    by_new = DLM.StatelessMuon.muon_step(by, gby, lr)
    bz_new = DLM.StatelessMuon.muon_step(bz, gbz, lr)
    cu_new = DLM.StatelessMuon.muon_step(cu, gcu, lr)
    cv_new = DLM.StatelessMuon.muon_step(cv, gcv, lr)
    cw_new = DLM.StatelessMuon.muon_step(cw, gcw, lr)
    cx_new = DLM.StatelessMuon.muon_step(cx, gcx, lr)
    cy_new = DLM.StatelessMuon.muon_step(cy, gcy, lr)
    cz_new = DLM.StatelessMuon.muon_step(cz, gcz, lr)
    du_new = DLM.StatelessMuon.muon_step(du, gdu, lr)
    dv_new = DLM.StatelessMuon.muon_step(dv, gdv, lr)
    dw_new = DLM.StatelessMuon.muon_step(dw, gdw, lr)
    dx_new = DLM.StatelessMuon.muon_step(dx, gdx, lr)
    dy_new = DLM.StatelessMuon.muon_step(dy, gdy, lr)
    dz_new = DLM.StatelessMuon.muon_step(dz, gdz, lr)
   
    
    new_params = {em_new, eq_new, er_new, es_new, qp_new, 
                  au_new, av_new, aw_new, ax_new, ay_new, az_new,
                  bu_new, bv_new, bw_new, bx_new, by_new, bz_new,
                  cu_new, cv_new, cw_new, cx_new, cy_new, cz_new,
                  du_new, dv_new, dw_new, dx_new, dy_new, dz_new}

    {new_params, new_step}
  end
end
