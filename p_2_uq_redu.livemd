```elixir
defmodule DLM.PhysicsGenesis do
  import Nx.Defn

  @vocab 128
  @rank 256
  @dim 512

  defn init(k1) do
    std_dim = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@dim, type: :f32)))
    std_voc = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@vocab, type: :f32)))
    std_rnk = Nx.divide(1.0, Nx.sqrt(Nx.tensor(@rank, type: :f32)))
    std_1024 = Nx.divide(1.0, Nx.sqrt(Nx.tensor(1024, type: :f32)))

    # projection matrices
    a = Nx.broadcast(0.5, {@dim}) |> Nx.as_type(:f32)
    {b, k2} = Nx.Random.normal(k1, 0.0, std_voc, shape: {@vocab, @vocab})
    {d1, k3} = Nx.Random.normal(k2, 0.0, std_rnk, shape: {@dim, @dim})
    {d2, k4} = Nx.Random.normal(k3, 0.0, std_1024, shape: {@dim, @dim})

    # projection bias'
    db = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)

    dq = Nx.broadcast(1.0, {@dim}) |> Nx.as_type(:f32)
    
    # rms norm beta and gamma
    de = Nx.broadcast(0.0, {@dim}) |> Nx.as_type(:f32)
    dg = Nx.broadcast(1.0, {@dim}) |> Nx.as_type(:f32)

    {em, k5} = Nx.Random.normal(k4, 0.0, std_voc, shape: {@vocab, @vocab})
    {ed, k6} = Nx.Random.normal(k5, 0.0, std_dim, shape: {@dim, @vocab})
    {uq, k7} = Nx.Random.normal(k6, 0.0, 0.0, shape: {@dim, @dim})
    {hq, k8} = Nx.Random.normal(k7, 0.0, std_rnk, shape: {@dim, @dim})

    trainable_params = {a, b, d1, d2, db, dq, dg, de, hq, em, ed, uq}
    
    {trainable_params, k8}
  end
end
