```elixir
defmodule DLM.SvdOptimizer do
  import Nx.Defn

  defn update(params, grads, step, lr) do
    {a, b, d1, d2, db, dq, dg, de, hq, em, ed, uq} = params   
    {ga, gb, gd1, gd2, gdb, gdq, gdg, gde, ghq, gem, ged, guq}= grads
    
    new_step = Nx.add(step, 1)

    # optimizer update step
    a_new = DLM.StatelessMuon.muon_step(a, ga, lr)
    b_new = DLM.StatelessMuon.muon_step(b, gb, lr)
    d1_new = DLM.StatelessMuon.muon_step(d1, gd1, lr)
    d2_new = DLM.StatelessMuon.muon_step(d2, gd2, lr)

    db_new = DLM.StatelessMuon.muon_step(db, gdb, lr)

    dq_new = DLM.StatelessMuon.muon_step(dq, gdq, lr)

    de_new = DLM.StatelessMuon.muon_step(de, gde, lr)
    dg_new = DLM.StatelessMuon.muon_step(dg, gdg, lr)

    hq_new = DLM.StatelessMuon.muon_step(hq, ghq, lr)
    uq_new = DLM.StatelessMuon.muon_step(uq, guq, lr)
    em_new = DLM.StatelessMuon.muon_step(em, gem, lr)
    ed_new = DLM.StatelessMuon.muon_step(ed, ged, lr)
    
    new_params = {a_new, b_new,
                  d1_new, d2_new, db_new, dq_new, dg_new, de_new,
                  hq_new, em_new, ed_new, uq_new}

    {new_params, new_step}
  end
end
