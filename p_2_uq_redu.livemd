## SSM

```elixir
defmodule DLM.SvdSSM do
  import Nx.Defn

  defn rms_norm(x, gamma, beta, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    norm = x * Nx.rsqrt(variance + epsilon)
    scaled = gamma * norm
    scaled + beta
  end

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn gelu(x) do
    cdf = Nx.multiply(
      Nx.tensor(0.7978845608, type: :f32),
      Nx.add(x, Nx.multiply(Nx.tensor(0.044715, type: :f32), Nx.pow(x, 3)))
    )
    Nx.multiply(Nx.multiply(Nx.tensor(0.5, type: :f32), x), Nx.add(Nx.tensor(1.0, type: :f32), Nx.tanh(cdf)))
  end
  
  defn feed_forward_layer(x, um, ga, bi, dm) do
    up = Nx.dot(x, um) 
    act = gelu(up) #was tanh
    scaled = Nx.multiply(ga, act)
    biased = Nx.add(scaled, bi)
    Nx.dot(biased, dm) 
  end

  defn softmax(t) do
    max_val = Nx.reduce_max(t, axes: [-1], keep_axes: true)
    safe_t = Nx.subtract(t, max_val)
    exps = Nx.exp(safe_t)
    sum_exps = Nx.sum(exps, axes: [-1], keep_axes: true)
    Nx.divide(exps, Nx.add(sum_exps, 1.0e-8))
  end

  defn forward_step(x_t, h_prev, hl_prev, p) do
    {a, b, d1, d2, db, dq, dg, de, hq, em, ed, uq} = p
    # turn is_space into a learned scalar that triggers when it's greater than a certain value
    u_t = Nx.take(em, x_t) # -> {batch, 128}
    b_u = Nx.dot(u_t, b)

    hp_p = Nx.reshape(h_prev, {:auto, 512})
    hp_pts = Nx.multiply(hp_p, a) # apply timescale to h_prev projection
    h_ts = Nx.reshape(hp_pts, {:auto, 4, 128})
    hn_bsl = Nx.slice_along_axis(h_ts, 1, 3, axis: 1)
    hnb = Nx.concatenate([hn_bsl, Nx.new_axis(b_u, 1)], axis: 1)

    hn_p = Nx.reshape(hnb, {:auto, 512})

    # increase to 128? add scale to query based on root of axis 1 size
    up_msl = Nx.slice_along_axis(hl_prev, 0, 63, axis: 1)
    up_mem = Nx.concatenate([up_msl, Nx.new_axis(hn_p, 1)], axis: 1)
    
    sig_val = Nx.dot(hn_p, uq) |> Nx.sigmoid()
    is_reset_hard = Nx.greater(sig_val, 0.5)
    is_reset = Nx.add(sig_val, stop_grad(Nx.subtract(Nx.as_type(is_reset_hard, :f32), sig_val)))
    reset_factor = Nx.subtract(1.0, Nx.multiply(is_reset, 1.0))
    # is_reset is already [batch, 128] float, just add one more axis
    is_reset_3d = Nx.new_axis(is_reset, 1)  # [batch, 1, 1]
    hnp_gated = Nx.multiply(hn_p, reset_factor)

    sl_hlp_nonspace = Nx.slice_along_axis(up_mem, 0, 63, axis: 1)
    sl_hlp_space    = Nx.slice_along_axis(up_mem, 1, 63, axis: 1)
    # blend: space items get sl_hlp_space, others get sl_hlp_nonspace
    sl_hlp = Nx.multiply(sl_hlp_space, is_reset_3d)
               |> Nx.add(Nx.multiply(sl_hlp_nonspace, Nx.subtract(1.0, is_reset_3d)))

    hl_new = Nx.concatenate([sl_hlp, Nx.new_axis(hnp_gated, 1)], axis: 1)
    # query
    qh = Nx.dot(hn_p, hq) |> Nx.new_axis(1)
    hlnt = Nx.transpose(up_mem, axes: [0, 2, 1])
    # score
    rshl = Nx.dot(qh, [2], [0], hlnt, [1], [0])
    # softmax normalization
    #scshl = Nx.divide(rshl, 8.0) # 8.0 - 64, 11.3137 - 128
    sfsc = softmax(rshl)
    ctxhl = Nx.dot(sfsc, [2], [0], up_mem, [1], [0]) |> Nx.squeeze(axes: [1])

    c_term = Nx.multiply(hn_p, a)
    d_term = feed_forward_layer(ctxhl, d1, dq, db, d2)
    d_norm = rms_norm(d_term, dg, de)

    latent = Nx.add(c_term, d_norm)
    
    logits = Nx.dot(latent, ed)

    {logits, hnb, hl_new}
  end
end
```

