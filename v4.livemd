```elixir
# --- V8.0 THE DEEP DIVE (FIXED CHECKPOINTING) ---
max_lr = 0.02 
min_lr = 0.001
chunks = 20 
epochs_per_chunk = 400 
batch_size = 32 

IO.puts("--- Starting V8.0 Deep Dive (2-Layer) ---")

{final_v8_emb, final_v8_a1, final_v8_f1, final_v8_a2, final_v8_f2, _} = 
  Enum.reduce(1..chunks, {start_emb, start_a1, start_f1, start_a2, start_f2, 0.0}, fn c, {e, a1, f1, a2, f2, _} ->
    current_lr = max_lr - ((max_lr - min_lr) * (c / chunks))
    
    indices = Enum.take_random(0..(length(v4_raw) - 1), batch_size) |> Nx.tensor()
    b_in = Nx.take(v4_inputs_ids, indices) 
    b_tg = Nx.take(v4_targets_ids, indices) 

    {ne, na1, nf1, na2, nf2, loss} = 
       DLM.Optimizer.run_chunk(b_in, b_tg, e, a1, f1, a2, f2, pos_emb, causal_mask, current_lr, epochs_per_chunk)
    
    l_val = Nx.to_number(loss)
    
    # FIX: Safely copy the tensors to pure Elixir Binary memory BEFORE saving
    if rem(c, 5) == 0 do
      path = Path.join(File.cwd!(), "v8_brain_checkpoint.bin")
      safe_checkpoint = %{
        e: Nx.backend_copy(ne, Nx.BinaryBackend),
        a1: Nx.backend_copy(na1, Nx.BinaryBackend),
        f1: Nx.backend_copy(nf1, Nx.BinaryBackend),
        a2: Nx.backend_copy(na2, Nx.BinaryBackend),
        f2: Nx.backend_copy(nf2, Nx.BinaryBackend)
      }
      File.write!(path, :erlang.term_to_binary(safe_checkpoint))
    end

    # Explicit memory cleanup
    eb = Nx.backend_copy(ne, Nx.BinaryBackend)
    a1b = Nx.backend_copy(na1, Nx.BinaryBackend)
    f1b = Nx.backend_copy(nf1, Nx.BinaryBackend)
    a2b = Nx.backend_copy(na2, Nx.BinaryBackend)
    f2b = Nx.backend_copy(nf2, Nx.BinaryBackend)
    
    Nx.backend_deallocate(ne); Nx.backend_deallocate(na1); Nx.backend_deallocate(nf1); 
    Nx.backend_deallocate(na2); Nx.backend_deallocate(nf2); Nx.backend_deallocate(loss)
    :erlang.garbage_collect()
    
    IO.puts("Deep Chunk #{c} | MSE: #{Float.round(l_val, 6)} | RAM: #{round(:erlang.memory(:total) / 1_000_000)}MB")
    {eb, a1b, f1b, a2b, f2b, l_val}
  end)
```
