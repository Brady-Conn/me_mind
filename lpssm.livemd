```

```elixir
# ===========================================================================
# THE PHYSICS ENGINE (Geometric Loss & BPTT)
# ===========================================================================
defmodule DLM.PhysicsEngine do
  import Nx.Defn

  # Maps raw ASCII tokens directly to 512D Coordinates using frozen Tokenizer
  defn get_coordinates(tokens, enc_w1, enc_w2) do
    bits = DLM.LatentTokenizer.to_bits(tokens)
    hidden_enc = DLM.LatentTokenizer.softplus(Nx.dot(bits, enc_w1))
    raw_latents = Nx.dot(hidden_enc, enc_w2)
    DLM.LatentTokenizer.rms_norm(raw_latents) 
  end

  defn predict_step(current_coord, h_prev, predictor_params) do
    # 1. Calculate the momentum vector
    {predicted_vector, h_new} = DLM.TinySSM.forward(current_coord, h_prev, predictor_params)
    
    # 2. Apply velocity to current position to get the absolute landing spot
    predicted_landing_spot = Nx.add(current_coord, predicted_vector)
    
    {predicted_landing_spot, h_new}
  end

  defn compute_sequence_loss(input_coords, target_coords, h_init, predictor_params) do
    {batch, seq_len, dim} = Nx.shape(input_coords)
    inputs_time_first = Nx.transpose(input_coords, axes: [1, 0, 2])
    targets_time_first = Nx.transpose(target_coords, axes: [1, 0, 2])

    # ⚡ Blank canvas to hold the generated trajectory
    predictions_init = Nx.broadcast(0.0, {seq_len, batch, dim})

    result =
      while {
        i = 0, 
        h = h_init, 
        preds = predictions_init, 
        inputs = inputs_time_first, 
        p = predictor_params
      }, Nx.less(i, seq_len) do
        
        # ⚡ Get the absolute coordinate landing spot for this step
        {landing_spot, h_new} = predict_step(inputs[i], h, p)
        
        # ⚡ Paint the landing spot onto the trajectory canvas
        updated_preds = Nx.put_slice(preds, [i, 0, 0], Nx.new_axis(landing_spot, 0))

        {i + 1, h_new, updated_preds, inputs, p}
      end

    # Extract the fully painted trajectory tensor
    predicted_seq = elem(result, 2)

    # ⚡ Fire the Tri-Fold Geometric Loss (MSE + Cosine + Soft-NN) on the whole sequence
    DLM.PhysicsLoss.compute(predicted_seq, targets_time_first)
  end

  defn compute_grad(params, batch_tokens, h_init, frozen_w1, frozen_w2) do
    # Slice sequence of 17 into 16 inputs and 16 targets
    {_batch_size, full_seq_len} = Nx.shape(batch_tokens)
    seq_len = full_seq_len - 1
    
    input_tokens = Nx.slice_along_axis(batch_tokens, 0, seq_len, axis: 1)
    target_tokens = Nx.slice_along_axis(batch_tokens, 1, seq_len, axis: 1)

    # Project to 512D
    input_coords = get_coordinates(input_tokens, frozen_w1, frozen_w2)
    target_coords = get_coordinates(target_tokens, frozen_w1, frozen_w2)

    value_and_grad(params, fn p ->
      compute_sequence_loss(input_coords, target_coords, h_init, p)
    end)
  end
end
```

