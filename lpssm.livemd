```elixir
# ===========================================================================
# THE EXECUTION LOOP
# ===========================================================================
IO.puts("🧊 Loading Frozen Micro-Diffusion Tokenizer...")
{fw1, fw2} = File.read!("v27_frozen_encoder.bin") |> :erlang.binary_to_term()
frozen_w1 = Nx.backend_copy(fw1, gpu)
frozen_w2 = Nx.backend_copy(fw2, gpu)

# ⚡ UPGRADE: Scale the batch and seq_len for the new geometric horizon
batch_size = 32 # You might need to lower this to 64 or 32 depending on VRAM!
seq_len = 128  
total_steps = 10_000 
gpu = {EXLA.Backend, client: :rocm}

IO.puts("🧠 Loading LPSSM 128seqlen training data CPU Memory...")
# ⚡ UPGRADE: Point this to your 128-length dataset!
dataset_2d = File.read!("scholar_full_mixed_128.bin") |> :erlang.binary_to_term()

dataset = Nx.flatten(dataset_2d)
dataset_size = Nx.axis_size(dataset, 0)

data_stream = DLM.DataStreamer.build_infinite_stream(dataset, batch_size, seq_len)

IO.puts("✨ Igniting 512D GATED Physics Engine...")
{p, next_key} = DLM.PhysicsGenesis.ignite(Nx.Random.key(42))
{m, v, step_count} = DLM.PhysicsGenesis.init_optimizer(p)

p = DLM.Tree.map(p, &Nx.backend_copy(&1, gpu))
m = DLM.Tree.map(m, &Nx.backend_copy(&1, gpu))
v = DLM.Tree.map(v, &Nx.backend_copy(&1, gpu))
step_count = Nx.backend_copy(step_count, gpu)
current_key = next_key

{final_p, _m, _v, _key, _step} = 
  Enum.reduce(Enum.zip(0..(total_steps - 1), data_stream), {p, m, v, current_key, step_count}, fn {step, cpu_batch}, {cp, cm, cv, cur_key, c_step} ->
    
    gpu_batch = Nx.backend_copy(cpu_batch, gpu)

    current_lr = cond do
      step < 500 -> 1.0e-5 + (3.0e-4 - 1.0e-5) * (step / 500) 
      step < 5000 -> 3.0e-4                                   
      true ->
        progress = (step - 5000) / (total_steps - 5000)
        1.0e-5 + (3.0e-4 - 1.0e-5) * 0.5 * (1.0 + :math.cos(:math.pi() * progress))
    end
    lr_tensor = Nx.tensor(current_lr, type: :f32) |> Nx.backend_copy(gpu)

    h_init = Nx.broadcast(0.0, {batch_size, 512}) |> Nx.as_type(:f32) |> Nx.backend_copy(gpu)

    {loss_tensor, grads} = DLM.PhysicsEngine.compute_grad(
      cp, gpu_batch, h_init, frozen_w1, frozen_w2
    )

    # ⚡ UPGRADE: Change to AdamW7 (or your 7-param optimizer module)
    {up_p, up_m, up_v, up_step} = DLM.AdamW7.update(
      cp, grads, cm, cv, c_step, lr_tensor
    )

    if rem(step, 50) == 0 do
      loss_val = Nx.to_number(loss_tensor)
      
      # ⚡ UPGRADE: Unpack all 7 params to prevent MatchError
      {_a, _bu, bv, _cu, _cv, _du, dv} = up_p
      
      bv_norm = bv |> Nx.pow(2) |> Nx.sum() |> Nx.sqrt() |> Nx.to_number()
      dv_norm = dv |> Nx.pow(2) |> Nx.sum() |> Nx.sqrt() |> Nx.to_number()

      IO.puts("➡️  Step #{step} | Geometric Loss: #{Float.round(loss_val, 4)} | LR: #{Float.round(current_lr, 6)} | bv: #{Float.round(bv_norm, 4)} | dv: #{Float.round(dv_norm, 4)}")
    end

    {up_p, up_m, up_v, cur_key, up_step}
  end)

IO.puts("💾 Saving Gated Physics Engine Weights...")
good_params = DLM.Tree.map(final_p, &Nx.backend_transfer(&1, Nx.BinaryBackend))
# ⚡ UPGRADE: Protect your old checkpoints by renaming the output!
File.write!("v29_physics_gated_128.bin", :erlang.term_to_binary(good_params))
IO.puts("✅ Resaved with clean CPU tensors")

IO.puts("✅ Physics Engine Training Complete!")
```

