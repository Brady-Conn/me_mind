```elixir
defmodule DLM.BilliardsProbe do
  import Nx.Defn

  # 1. Run the sequence through the SSM to build momentum
  defn predict_next_coord(input_coords, h_init, predictor_params) do
    {_batch, seq_len, _dim} = Nx.shape(input_coords)
    inputs_time_first = Nx.transpose(input_coords, axes: [1, 0, 2])

    result =
      while {i = 0, h = h_init, inputs = inputs_time_first, p = predictor_params, 
             last_landing = Nx.broadcast(0.0, {1, 512})},
            Nx.less(i, seq_len) do
            
        current_coord = inputs[i]
        {predicted_vector, h_new} = DLM.TinySSM.forward(current_coord, h, p)
        
        # Calculate exactly where the vector lands in the void
        landing_spot = Nx.add(current_coord, predicted_vector)
        
        {i + 1, h_new, inputs, p, landing_spot}
      end
    
    # Return the very last predicted landing spot
    elem(result, 4)
  end
  
  # 2. Elixir helper to measure the distance to the whole vocabulary and sort it
  def check_pockets(landing_spot, all_vocab_coords, k \\ 5) do
    # Calculate Euclidean distance to all 128 characters
    diff = Nx.subtract(all_vocab_coords, landing_spot)
    distances = Nx.sqrt(Nx.sum(Nx.pow(diff, 2), axes: [-1]))
    
    # Convert to Elixir list for easy sorting
    dist_list = Nx.to_flat_list(distances)
    
    # Pair each distance with its ASCII index: {ascii_index, distance}
    vocab_with_dists = Enum.with_index(dist_list) |> Enum.map(fn {dist, idx} -> {idx, dist} end)
    
    # Sort by closest distance
    Enum.sort_by(vocab_with_dists, fn {_idx, dist} -> dist end)
    |> Enum.take(k)
  end
end

# ===========================================================================
# EXECUTION: Test the Physics Engine
# ===========================================================================

# 1. Load the frozen Tokenizer & the trained Physics Engine
{enc_w1, enc_w2} = File.read!("v27_frozen_encoder.bin") |> :erlang.binary_to_term()
trained_physics_params = File.read!("v27_physics_engine_fixed.bin") |> :erlang.binary_to_term()

# 2. Get the absolute coordinates of all 128 pockets
all_vocab = Nx.iota({128})
all_vocab_coords = DLM.PhysicsEngine.get_coordinates(all_vocab, enc_w1, enc_w2)

# 3. Create a test sequence
text_sequence = "The cat sat on the m"
# We want to see what the engine predicts comes after 'm'
tokens = DLM.LatentTokenizer.to_ascii_tokens(text_sequence) |> Nx.new_axis(0)

# Project the text sequence into the 512D void
input_coords = DLM.PhysicsEngine.get_coordinates(tokens, enc_w1, enc_w2)

# 4. Generate the prediction!
h_init = Nx.broadcast(0.0, {1, 512})
landing_spot = DLM.BilliardsProbe.predict_next_coord(input_coords, h_init, trained_physics_params)

# 5. Check which pockets the vector landed near
top_predictions = DLM.BilliardsProbe.check_pockets(landing_spot, all_vocab_coords)

IO.puts("🎱 512D Billiards Probe 🎱")
IO.puts("Sequence: '#{text_sequence}'")
IO.puts("---------------------------------")
Enum.each(top_predictions, fn {ascii, dist} ->
  char = List.to_string([ascii])
  # Clean up unprintable characters for the terminal
  char_display = if String.printable?(char) and char != "\n", do: "'#{char}'", else: "[ASCII #{ascii}]"
  IO.puts("Pocket: #{char_display} | Distance: #{Float.round(dist, 4)}")
end)
