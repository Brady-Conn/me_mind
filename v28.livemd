```elixir
defmodule DLM.BLiMP_Evaluator do
  import Nx.Defn

  # ⚡ Calculate the mathematical "surprise" (Loss) of a sentence
  defn evaluate_sentence(ascii_tokens, v28_params, pe_w1, pe_w2) do
    seq_len = Nx.axis_size(ascii_tokens, 0)

    # 1. Slice and add Batch Dimension -> Shape: {1, seq_len - 1}
    input_tokens = Nx.slice_along_axis(ascii_tokens, 0, seq_len - 1, axis: 0) |> Nx.new_axis(0)
    target_tokens = Nx.slice_along_axis(ascii_tokens, 1, seq_len - 1, axis: 0) |> Nx.new_axis(0)

    # 2. Satisfy the forward() signature for pure inference
    noise_scale = Nx.tensor(0.0, type: :f32)
    key = Nx.Random.key(42) 
    pos_emb = Nx.broadcast(0.0, {1, seq_len - 1, 512})

    # 3. Call your V27_SSM forward pass!
    logits = DLM.V27_SSM.forward(
      input_tokens, 
      v28_params, 
      pos_emb, 
      key, 
      pe_w1, 
      pe_w2, 
      noise_scale
    )

    # 4. Calculate Total Sequence Surprise
    DLM.Loss.cross_entropy(logits, target_tokens)
  end
end
