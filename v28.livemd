```elixir
save_interval = 1000
gpu = {EXLA.Backend, client: :rocm}

IO.puts("🧊 Loading Frozen Micro-Diffusion Tokenizer...")
{fw1, fw2} = File.read!("semantic_muon_sinkhorn_frozen_encoder.bin") |> :erlang.binary_to_term()
frozen_w1 = Nx.backend_copy(fw1, gpu)
frozen_w2 = Nx.backend_copy(fw2, gpu)

IO.puts("🧊 Loading Frozen Language Physics Engine...")
pe_params_raw = File.read!("v31_sinkhorn_muon_noisy_sms_final.bin") |> :erlang.binary_to_term()

frozen_pe_params = DLM.Tree.map(pe_params_raw, &Nx.backend_copy(&1, gpu))

IO.puts("🧠 Loading 128seqlen Curriculum into CPU Memory...")
full_dataset = File.read!("scholar_full_mixed_128.bin") |> :erlang.binary_to_term()

# ⚡ Micro-Batching Math
batch_size = 16            # The physical VRAM batch size

dataset_size = Nx.axis_size(full_dataset, 0)
total_steps_per_epoch = div(dataset_size, batch_size)
max_epochs = 9
total_steps = total_steps_per_epoch * max_epochs

save_prefix = "v28_sinkhorn"

latest_scholar =
  Path.wildcard("#{save_prefix}_*.bin")
  |> Enum.reject(&String.contains?(&1, "data.bin"))
  |> Enum.max_by(fn path -> File.stat!(path).mtime end, fn -> nil end)

# ⚡ Threading the hidden states through the initialization
{params, ms, vs, global_step, current_epoch, h_v28, h_pe, saved_key} =
  cond do
    latest_scholar != nil ->
      IO.puts("💾 Resuming from checkpoint: #{latest_scholar}")
      checkpoint = File.read!(latest_scholar) |> :erlang.binary_to_term()
      p = DLM.Tree.map(checkpoint.params, &Nx.backend_copy(&1, gpu))
      m = DLM.Tree.map(checkpoint.ms, &Nx.backend_copy(&1, gpu))
      v = DLM.Tree.map(checkpoint.vs, &Nx.backend_copy(&1, gpu))
      
      # ⚡ Safely load saved momentum, fallback to zeros if it's an old checkpoint
      loaded_h_v28 = Map.get(checkpoint, :h_v28, Nx.broadcast(0.0, {batch_size, 512})) |> Nx.backend_copy(gpu)
      loaded_h_pe = Map.get(checkpoint, :h_pe, Nx.broadcast(0.0, {batch_size, 512})) |> Nx.backend_copy(gpu)
      
      saved_key = Map.get(checkpoint, :shuffle_key, Nx.Random.key(42)) |> Nx.backend_copy(gpu)
      
      {p, m, v, checkpoint.step, checkpoint.epoch, loaded_h_v28, loaded_h_pe, saved_key}

    true ->
      IO.puts("✨ No checkpoint found. Igniting FRESH Genesis state...")
      raw_p = DLM.V28_Genesis.init_params(42)
      {raw_m, raw_v, _} = DLM.V28_Genesis.init_optimizer(raw_p)
      p = DLM.Tree.map(raw_p, &Nx.backend_copy(&1, gpu))
      m = DLM.Tree.map(raw_m, &Nx.backend_copy(&1, gpu))
      v = DLM.Tree.map(raw_v, &Nx.backend_copy(&1, gpu))
      saved_key = Nx.Random.key(42) |> Nx.backend_copy(gpu)
      
      # Initialize blank momentum for BOTH models
      h_v28_init = Nx.broadcast(0.0, {batch_size, 512}) |> Nx.backend_copy(gpu)
      h_pe_init = Nx.broadcast(0.0, {batch_size, 512}) |> Nx.backend_copy(gpu)
      
      {p, m, v, 0, 1, h_v28_init, h_pe_init, saved_key}
  end

base_lr = 3.0e-4
min_lr  = 1.0e-6
warmup_steps = 500

pos_emb = DLM.Positional.build(128, 512) |> Nx.backend_copy(gpu)
IO.puts("🚀 IGNITION: Starting V28 DNI at Epoch #{current_epoch}, Global Step #{global_step}...")

# Force all params to be concrete GPU tensors before the loop starts
# params = DLM.Tree.map(params, &Nx.backend_copy(&1, gpu))
# frozen_pe_params = DLM.Tree.map(frozen_pe_params, &Nx.backend_copy(&1, gpu))
# h_v28 = Nx.backend_copy(h_v28, gpu)
# h_pe = Nx.backend_copy(h_pe, gpu)
# pos_emb = Nx.backend_copy(pos_emb, gpu)
IO.puts("✅ All tensors materialized, entering training loop...")
# ⚡ Outer Epoch Loop
Enum.reduce(current_epoch..max_epochs, {params, ms, vs, global_step, h_v28, h_pe, saved_key},
  fn epoch, {p, m, v, current_step, current_hv, current_hp, shuffle_key} ->
  IO.puts(String.duplicate("=", 50))
  IO.puts("🌊 EPOCH #{epoch} / #{max_epochs}")
  IO.puts("🔀 Shuffling dataset...")

  {shuffled_raw, next_shuffle_key} = Nx.Random.shuffle(shuffle_key, full_dataset, axis: 0)
  shuffled_dataset = Nx.backend_copy(shuffled_raw, Nx.BinaryBackend)

  start_offset = 
    if epoch == current_epoch do
      rem(current_step, total_steps_per_epoch) * (batch_size)
    else
      0
    end

  # Stream chunks of 4 (micro-batch size)
  epoch_batches = Stream.unfold(start_offset, fn offset ->
    if offset + batch_size > dataset_size do
      nil
    else
      batch_2d = Nx.slice_along_axis(shuffled_dataset, offset, batch_size, axis: 0)
      {batch_2d, offset + batch_size}
    end
  end)

  initial_key = Nx.Random.key(System.system_time(:second))

  {new_p, new_m, new_v, next_epoch_step, _skips, next_hv, next_hp, _final_key} =
    epoch_batches
    |> Stream.with_index(1)
    |> Enum.reduce({p, m, v, current_step, 0, current_hv, current_hp, initial_key}, fn {batch, step_in_epoch}, {cp, cm, cv, cs, s_count, ch_v28, ch_pe, cur_key} ->
      
      gpu_batch = Nx.backend_copy(batch, gpu)
      
      progress = cs / total_steps
      cosine_factor = 0.5 * (1.0 + :math.cos(:math.pi() * progress))
      current_noise = 0.015 * cosine_factor
      noise_tensor = Nx.tensor(current_noise, type: :f32) |> Nx.backend_copy(gpu)

      # ⚡ 1. Prep Data
      {clean_t, noisy_t, targets_t, k_next} = DLM.V28_DNI.prep_data(
        gpu_batch, pos_emb, frozen_w1, frozen_w2, cur_key, noise_tensor
      )

      # ⚡ 2. Get Physics Engine Trajectory
      {ideal_spots_t, h_p_next} = DLM.V28_DNI.get_teacher_trajectory(
        clean_t, ch_pe, frozen_pe_params
      )

      # ⚡ 3. Get V28 Loss and Gradients
      {loss_tensor, grads} = DLM.V28_DNI.get_v28_grads(
        noisy_t, targets_t, ideal_spots_t, ch_v28, cp
      )
      
      # ⚡ 4. Extract next hidden state AND pure BPC
      {h_v_next, bpc_tensor} = DLM.V28_DNI.get_v28_state_and_bpc(
        noisy_t, targets_t, ch_v28, cp
      )
      
      loss_val = Nx.to_number(loss_tensor)
      bpc_val = Nx.to_number(bpc_tensor)

      # ⚡ Safe Erlang NaN/Float check (In Erlang, Atoms like :nan are mathematically > 10.0!)
      is_nan_or_spike? = loss_val == :nan or (is_float(loss_val) and loss_val > 10.0)

      if is_nan_or_spike? do
        if rem(step_in_epoch, 10) == 0,
          do: IO.puts("⚠️ Step #{cs}: NaN/Spike detected. Flushing momentum state.")
        
        # ⚡ FIX: Do NOT pass the poisoned h_v_next forward. Reset to a clean zero-state!
        clean_h_v = Nx.broadcast(0.0, {batch_size, 512}) |> Nx.backend_copy(gpu)
        
        {cp, cm, cv, cs + 1, s_count + 1, clean_h_v, h_p_next, k_next}
      else
        current_lr = 
          if cs < warmup_steps do
            base_lr * (cs / warmup_steps)
          else
            lr_progress = (cs - warmup_steps) / (total_steps - warmup_steps)
            clamped_progress = min(max(lr_progress, 0.0), 1.0)
            min_lr + 0.5 * (base_lr - min_lr) * (1.0 + :math.cos(:math.pi() * clamped_progress))
          end

          lr_tensor = Nx.tensor(current_lr, type: :f32) |> Nx.backend_copy(gpu)
          step_tensor = Nx.tensor(cs, type: :f32) |> Nx.backend_copy(gpu)
  
          {up_p, up_m, up_v} = DLM.MuonHybrid.step(cp, grads, cm, cv, step_tensor, lr_tensor)

          {p_a, p_bu, p_bv, p_cu, p_cv, p_du, p_dv,
           p_mu1, p_mv1, p_mu2, p_mv2, p_lmw, p_lmb} = up_p
  
          du_norm = p_du |> Nx.pow(2) |> Nx.sum() |> Nx.sqrt() |> Nx.to_number()
  
          up_p = if du_norm < 0.01 do
            IO.puts("   🔧 Rescuing dead gate")
            rescaled_du = Nx.multiply(p_du, Nx.tensor(0.02 / max(du_norm, 1.0e-8)))
            rescaled_dv = Nx.multiply(p_dv, Nx.tensor(0.02 / max(du_norm, 1.0e-8)))
            
            {p_a, p_bu, p_bv, p_cu, p_cv, rescaled_du, rescaled_dv,
             p_mu1, p_mv1, p_mu2, p_mv2, p_lmw, p_lmb}
          else
            up_p
        end

        if rem(step_in_epoch, 50) == 0 do
          mem = :erlang.memory(:total) |> div(1024 * 1024)
          cpu_grads = DLM.Tree.map(grads, &Nx.backend_copy(&1, Nx.BinaryBackend))
          norms = DLM.V28_DNI.grad_norms(cpu_grads) 
          {max_name, max_norm} = Enum.max_by(norms, fn {_name, n} -> n end)
          
          IO.puts("➡️  Step #{step_in_epoch} | Global: #{cs} | Combined Loss: #{Float.round(loss_val, 4)} | BPC: #{Float.round(bpc_val, 3)} | LR: #{Float.round(current_lr, 6)} | RAM: #{mem}MB")
          IO.puts("   📐 MAX GRAD: #{max_name}=#{max_norm}")
        end

        if rem(cs, save_interval) == 0 and cs > 0 do
          IO.puts("💾 Auto-Saving Checkpoint...")
          # ⚡ Safely move all current state to the CPU before serializing
          checkpoint_state = %{
            params: DLM.Tree.map(up_p, &Nx.backend_copy(&1, Nx.BinaryBackend)),
            ms: DLM.Tree.map(up_m, &Nx.backend_copy(&1, Nx.BinaryBackend)),
            vs: DLM.Tree.map(up_v, &Nx.backend_copy(&1, Nx.BinaryBackend)),
            step: cs, 
            epoch: epoch,
            h_v28: Nx.backend_copy(h_v_next, Nx.BinaryBackend),
            h_pe: Nx.backend_copy(h_p_next, Nx.BinaryBackend),
            shuffle_key: Nx.backend_copy(k_next, Nx.BinaryBackend)
          }
          
          File.write!("v28_sinkhorn_step#{cs}.bin", :erlang.term_to_binary(checkpoint_state))
        end

        if rem(step_in_epoch, 100) == 0, do: :erlang.garbage_collect(self())

        {up_p, up_m, up_v, cs + 1, s_count, h_v_next, h_p_next, k_next}
      end
    end)

  IO.puts("💾 Saving Completed Epoch #{epoch} State...")
  final_state = %{
    params: DLM.Tree.map(new_p, &Nx.backend_copy(&1, Nx.BinaryBackend)),
    ms: DLM.Tree.map(new_m, &Nx.backend_copy(&1, Nx.BinaryBackend)),
    vs: DLM.Tree.map(new_v, &Nx.backend_copy(&1, Nx.BinaryBackend)),
    step: next_epoch_step, epoch: epoch,
    h_v28: Nx.backend_copy(next_hv, Nx.BinaryBackend),
    h_pe: Nx.backend_copy(next_hp, Nx.BinaryBackend),
    shuffle_key: Nx.backend_copy(next_shuffle_key, Nx.BinaryBackend)
  }
  File.write!("#{save_prefix}_epoch#{epoch}_COMPLETE.bin", :erlang.term_to_binary(final_state))

  {new_p, new_m, new_v, next_epoch_step, next_hv, next_hp, next_shuffle_key}
end)

IO.puts("🎉 THE OVERNIGHT BAKE IS COMPLETE!")
