```elixir
defmodule DLM.V28_Inference do
  import Nx.Defn

  # ⚡ Single-Step Forward Pass
  defn generate_step(token, pos_emb_step, h_v_curr, xp1_curr, xp2_curr, v28_p, enc_w1, enc_w2) do
    {a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2, lm_w, lm_b} = v28_p
    
    # Encode current token
    token_2d = Nx.reshape(token, {1, 1}) 
    clean_coords = DLM.PhysicsEngine.get_coordinates(token_2d, enc_w1, enc_w2)
    
    # Apply Positional Embedding (Crucial for long-term memory!)
    x_input = Nx.add(clean_coords[0][0], pos_emb_step)
    x_norm = DLM.V27_SSM.rms_norm(x_input)
    
    # Expand to batch dimension for SSM
    x_batch = Nx.new_axis(x_norm, 0)
    
    {y_t, next_h_v} = DLM.V27_SSM.ssm_recurrence(
      x_batch, 
      xp1_curr, xp2_curr, h_v_curr, 
      a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2
    )
    
    y_final = DLM.V27_SSM.rms_norm(y_t[0])
    logits = Nx.add(Nx.dot(y_final, lm_w), lm_b)
    
    {logits, next_h_v, x_batch, xp1_curr} 
  end
  
  # ⚡ Axis-locked Sampling
  defn sample(logits, temperature, prng_key) do
    scaled_logits = Nx.divide(logits, temperature)
    probs = Nx.exp(scaled_logits) |> Nx.divide(Nx.sum(Nx.exp(scaled_logits)))
    
    {gumbel_noise, next_key} = Nx.Random.uniform(prng_key, shape: Nx.shape(logits))
    gumbel = Nx.negate(Nx.log(Nx.negate(Nx.log(gumbel_noise))))
    
    # Strictly argmax across the last axis
    sampled_token = Nx.argmax(Nx.add(scaled_logits, gumbel), axis: -1)
    {sampled_token, next_key}
  end
end

# ==============================================================================
# THE DRIVER
# ==============================================================================
checkpoint = File.read!("v28_auto_step118000.bin") |> :erlang.binary_to_term()
v28_params = DLM.Tree.map(checkpoint.params, &Nx.backend_copy(&1, gpu))

IO.puts("🧊 Loading Frozen Micro-Diffusion Tokenizer...")
{fw1, fw2} = File.read!("v27_frozen_encoder.bin") |> :erlang.binary_to_term()
frozen_w1 = Nx.backend_copy(fw1, gpu)
frozen_w2 = Nx.backend_copy(fw2, gpu)

h_v_init = Nx.broadcast(0.0, {1, 512}) |> Nx.backend_copy(gpu)
xp1_init = Nx.broadcast(0.0, {1, 512}) |> Nx.backend_copy(gpu)
xp2_init = Nx.broadcast(0.0, {1, 512}) |> Nx.backend_copy(gpu)

prompt_text = "Do state space models dream of recursive sheep?"
prompt_tokens_tensor = DLM.LatentTokenizer.to_ascii_tokens(prompt_text)
prompt_tokens = Nx.to_flat_list(prompt_tokens_tensor)

temperature = Nx.tensor(0.65, type: :f32) |> Nx.backend_copy(gpu) # Lowered slightly for coherence
prng_key = Nx.Random.key(System.system_time(:second)) |> Nx.backend_copy(gpu)

max_new_tokens = 200
total_inference_steps = length(prompt_tokens) + max_new_tokens

# GENERATE POSITIONAL EMBEDDINGS
pos_emb = DLM.Positional.build(total_inference_steps, 512)

IO.puts("🧠 Awakening V28 from checkpoint...")

# ⚡ BURN-IN
{final_h_v, final_xp1, final_xp2, last_token} = 
  Enum.reduce(Enum.with_index(prompt_tokens), {h_v_init, xp1_init, xp2_init, nil}, fn {tok, step}, {h, x1, x2, _} ->
    tok_tensor = Nx.tensor(tok, type: :u32) |> Nx.backend_copy(gpu)
    pos_tensor = pos_emb[step] |> Nx.backend_copy(gpu) # ⚡ STEP IS USED HERE
    
    {_, next_h, next_x1, next_x2} = DLM.V28_Inference.generate_step(
      tok_tensor, pos_tensor, h, x1, x2, v28_params, frozen_w1, frozen_w2
    )
    
    {next_h, next_x1, next_x2, tok_tensor}
  end)

IO.puts("\nPrompt: \"#{prompt_text}\"\n")
IO.write("V28: ")

# ⚡ GENERATION
Enum.reduce(length(prompt_tokens)..(total_inference_steps - 1), {final_h_v, final_xp1, final_xp2, last_token, prng_key}, fn step, {h, x1, x2, current_token, key} ->
  
  pos_tensor = pos_emb[step] |> Nx.backend_copy(gpu) # ⚡ STEP IS USED HERE
  
  {logits, next_h, next_x1, next_x2} = DLM.V28_Inference.generate_step(
    current_token, pos_tensor, h, x1, x2, v28_params, frozen_w1, frozen_w2
  )
  
  {next_token, next_key} = DLM.V28_Inference.sample(logits, temperature, key)
  token_id = Nx.to_number(next_token)
  
  # Cast directly to a byte string
  IO.write(<<token_id>>)
  
  {next_h, next_x1, next_x2, next_token, next_key}
end)

IO.puts("\n\n🐑 Dream Complete.")
```

