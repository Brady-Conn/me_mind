## USSM, Positional, Muon_Optimizer

```elixir
defmodule DLM.V27_SSM do
  import Nx.Defn

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn softplus(x) do
    # ⚡ UNBREAKABLE SOFTPLUS: Guaranteed stable in forward AND backward passes
    Nx.max(x, 0.0) + Nx.log1p(Nx.exp(-Nx.abs(x)))
  end

  defn apply_svd_weight(x, u, v) do
    # ⚡ FIX: Replaced silu() with softplus() to keep the local mixers alive
    x |> Nx.dot(u) |> softplus() |> Nx.dot(v)
  end

  defn ssm_recurrence(x_t, x_p1, x_p2, h_prev, a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2) do
    # 1. Local Mixers
    mix1 = apply_svd_weight(x_p2, mu1, mv1)
    mix2 = apply_svd_weight(x_p1, mu2, mv2)
    x_mixed = Nx.add(x_t, Nx.add(mix1, mix2))
    
    # 2. Input Force
    b_proj = apply_svd_weight(x_mixed, bu, bv)
    delta = Nx.tensor(0.1, type: :f32)
    
    # 3. Friction
    a_bar = Nx.exp(Nx.multiply(delta, -Nx.abs(a)))
    b_bar = Nx.multiply(delta, b_proj)
    
    # 4. Momentum Update
    h_new = Nx.tanh(Nx.add(Nx.multiply(a_bar, h_prev), b_bar))
    
    # 5. Output Velocity
    out_proj = apply_svd_weight(h_new, cu, cv)
    
    # 6. Skip Connection
    skip = apply_svd_weight(x_t, du, dv)
    
    y_t = Nx.add(out_proj, skip)
    
    {y_t, h_new}
  end

  defn run_ssm_loop(x_time, h_init, a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2) do
    seq_len = Nx.axis_size(x_time, 0)
    batch_size = Nx.axis_size(x_time, 1)
    
    zero_frame = Nx.broadcast(0.0, {batch_size, 512})
    
    # Pre-allocate an empty tensor to collect the outputs over time
    y_out = Nx.broadcast(0.0, Nx.shape(x_time))

    # Thread all parameters through the while loop to avoid context errors!
    result =
      while {i = 0, h = h_init, xp1 = zero_frame, xp2 = zero_frame, ys = y_out,
             x_in = x_time,
             p_a = a, p_bu = bu, p_bv = bv, p_cu = cu, p_cv = cv,
             p_du = du, p_dv = dv, p_mu1 = mu1, p_mv1 = mv1, p_mu2 = mu2, p_mv2 = mv2},
            Nx.less(i, seq_len) do

        x_t = x_in[i]

        # ⚡ The Single Source of Truth!
        {y_t, next_h} = ssm_recurrence(
          x_t, xp1, xp2, h,
          p_a, p_bu, p_bv, p_cu, p_cv, p_du, p_dv, p_mu1, p_mv1, p_mu2, p_mv2
        )

        # Slice the new y_t into our pre-allocated output tensor
        updated_ys = Nx.put_slice(ys, [i, 0, 0], Nx.new_axis(y_t, 0))

        # Shift the local mixers back one step in time
        {i + 1, next_h, x_t, xp1, updated_ys, x_in, 
         p_a, p_bu, p_bv, p_cu, p_cv, p_du, p_dv, p_mu1, p_mv1, p_mu2, p_mv2}
      end

    final_ys = elem(result, 4)
    final_h = elem(result, 1)

    {final_ys, final_h}
  end

  # Helper to convert bits (same as before)
  defn to_bits(tokens) do
    shifts = Nx.iota({8}) |> Nx.multiply(-1) |> Nx.add(7) |> Nx.as_type(:u32)
    tokens_expanded = Nx.new_axis(tokens, -1)
    shifted = Nx.right_shift(tokens_expanded, shifts)
    Nx.bitwise_and(shifted, 1) |> Nx.as_type(:f32)
  end

  defn forward(indices, params, pos_emb, key, frozen_enc_w1, frozen_enc_w2, noise_scale) do
    # ⚡ 1. Unpack ALL 13 parameters so they can be passed as flat tensors
    {a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2, lm_w, lm_b} = params
  
    # 1. THE FROZEN LATENT PROJECTION
    bits = to_bits(indices)
    hidden_enc = softplus(Nx.dot(bits, frozen_enc_w1))
    latents = Nx.dot(hidden_enc, frozen_enc_w2)
  
    # 2. INJECT THE DYNAMIC LATENT NOISE
    {batch, seq_len, dim} = Nx.shape(latents)
    {noise, _next_key} = Nx.Random.normal(key, 0.0, 1.0, shape: {batch, seq_len, dim})
    
    noisy_latents = Nx.add(latents, Nx.multiply(noise, noise_scale))
    
    # 3. STANDARD SSM LOOP
    x_input = Nx.add(noisy_latents, pos_emb)
    x_norm  = rms_norm(x_input)
  
    h_init = Nx.broadcast(Nx.tensor(0.0, type: :f32), {batch, dim})
    x_seq_first = Nx.transpose(x_norm, axes: [1, 0, 2])
  
    # ⚡ 2. Pass flat tensors and unpack the new tuple return signature
    {y_seq, _final_h} = run_ssm_loop(
      x_seq_first, h_init, 
      a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2
    )
  
    y_out   = Nx.transpose(y_seq, axes: [1, 0, 2])
    y_final = rms_norm(y_out)
    
    # 4. TRAINABLE OUTPUT HEAD
    Nx.add(Nx.dot(y_final, lm_w), lm_b)
  end
end
