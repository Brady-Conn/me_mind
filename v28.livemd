```elixir
IO.puts("🚀 Igniting V28 BLiMP Harness...")

# ==============================================================================
# 1. LOAD THE FROZEN TEACHER (PHYSICS ENGINE)
# ==============================================================================
# You already have these files from your distillation run setup
{fw1, fw2} = File.read!("semantic_muon_sinkhorn_frozen_encoder.bin") |> :erlang.binary_to_term()
pe_w1 = Nx.backend_copy(fw1, Nx.default_backend())
pe_w2 = Nx.backend_copy(fw2, Nx.default_backend())

# ==============================================================================
# 2. LOAD THE LATEST V28 STUDENT WEIGHTS
# ==============================================================================
latest_checkpoint = "v28_sinkhorn_step123000.bin" # Update to your latest
IO.puts("🧠 Awakening V28 Student from: #{latest_checkpoint}")

raw_checkpoint = File.read!(latest_checkpoint) |> :erlang.binary_to_term()

# ⚡ Extract ONLY the weights tuple, leaving the optimizer momentum behind
v28_params = DLM.Tree.map(raw_checkpoint.params, fn tensor -> 
  Nx.backend_copy(tensor, Nx.default_backend()) 
end)

# (Make sure you also loaded fw1 and fw2 into pe_w1 and pe_w2 here)

IO.puts("✅ All weights successfully materialized to GPU.")

# Read the JSONL file line by line - distractor_agreement_relative_clause.jsonl
blimp_file = "./blimp_data/regular_plural_subject_verb_agreement_1.jsonl" # Update with your file path

results = 
  File.stream!(blimp_file)
  |> Enum.map(fn line -> Jason.decode!(line) end)
  |> Enum.map(fn pair ->
    good_text = pair["sentence_good"]
    bad_text = pair["sentence_bad"]

    # Convert text to ASCII tensors
    good_tokens = DLM.LatentTokenizer.to_ascii_tokens(good_text) |> Nx.backend_copy(gpu)
    bad_tokens = DLM.LatentTokenizer.to_ascii_tokens(bad_text) |> Nx.backend_copy(gpu)

    # Calculate Loss
    good_loss = DLM.BLiMP_Evaluator.evaluate_sentence(good_tokens, v28_params, pe_w1, pe_w2) |> Nx.to_number()
    bad_loss = DLM.BLiMP_Evaluator.evaluate_sentence(bad_tokens, v28_params, pe_w1, pe_w2) |> Nx.to_number()

    # The model scores a point if the GOOD sentence has a LOWER loss
    is_correct = if good_loss < bad_loss, do: 1, else: 0

    {is_correct, good_loss, bad_loss, good_text}
  end)

# Calculate Final Score
total_pairs = length(results)
correct_answers = Enum.count(results, fn {score, _, _, _} -> score == 1 end)
accuracy = (correct_answers / total_pairs) * 100.0

IO.puts("\n==================================================")
IO.puts("📊 BLiMP BENCHMARK RESULTS")
IO.puts("Task: #{blimp_file}")
IO.puts("Accuracy: #{Float.round(accuracy, 2)}% (#{correct_answers}/#{total_pairs})")
IO.puts("==================================================\n")

# Print a few examples to see the loss deltas
IO.puts("🔍 Sample Decisions:")
results |> Enum.take(3) |> Enum.each(fn {score, g_loss, b_loss, text} ->
  status = if score == 1, do: "✅ PASS", else: "❌ FAIL"
  IO.puts("#{status} | Good: #{Float.round(g_loss, 4)} | Bad: #{Float.round(b_loss, 4)} | \"#{text}\"")
end)
