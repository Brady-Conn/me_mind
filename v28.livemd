```elixir
defmodule DLM.V28_DNI do
  import Nx.Defn

  # ⚡ 1. DATA PREP 
  defn prep_data(batch_tokens, pos_emb, enc_w1, enc_w2, prng_key, noise_scale) do
    seq_len = Nx.axis_size(batch_tokens, 1) - 1
    {batch_size, _} = Nx.shape(batch_tokens)
    
    input_tokens = Nx.slice_along_axis(batch_tokens, 0, seq_len, axis: 1)
    target_tokens = Nx.slice_along_axis(batch_tokens, 1, seq_len, axis: 1)

    clean_coords = DLM.PhysicsEngine.get_coordinates(input_tokens, enc_w1, enc_w2)
    
    {noise, final_key} = Nx.Random.normal(prng_key, 0.0, 1.0, shape: {batch_size, seq_len, 512})
    noisy_coords = Nx.add(clean_coords, Nx.multiply(noise, noise_scale))

    sliced_pos_emb = Nx.slice_along_axis(pos_emb, 0, seq_len, axis: 0)
    noisy_coords = Nx.add(noisy_coords, Nx.new_axis(sliced_pos_emb, 0))

    clean_time = Nx.transpose(clean_coords, axes: [1, 0, 2])
    noisy_time = Nx.transpose(noisy_coords, axes: [1, 0, 2])
    targets_time = Nx.transpose(target_tokens, axes: [1, 0])

    {clean_time, noisy_time, targets_time, final_key}
  end

  # ⚡ 2. THE RECURRENT TEACHER (Fixed)
  defn get_teacher_trajectory(clean_time, h_pe_init, pe_p) do
    seq_len = Nx.axis_size(clean_time, 0)
    spots_out = Nx.broadcast(0.0, Nx.shape(clean_time))
    
    result = 
      while {
        i = 0, h = h_pe_init, spots = spots_out, 
        c_t = clean_time, 
        p = pe_p # ⚡ Opaque tuple thread
      }, Nx.less(i, seq_len) do
        
        x_curr = c_t[i]
        
        # ⚡ THE FIX: Call the Pondering Teacher!
        # This triggers the internal 5-step while loop, executing the deep reasoning,
        # and returns the final, perfectly settled coordinate.
        {ideal, next_h} = DLM.PhysicsEngine.predict_step(x_curr, h, p)
        
        updated_spots = Nx.put_slice(spots, [i, 0, 0], Nx.new_axis(ideal, 0))
        
        {i + 1, next_h, updated_spots, c_t, p}
      end
      
    {elem(result, 2), elem(result, 1)}
  end

  # --- CORE LEARNER LOGIC (NO LOSS CALCULATION HERE!) ---
  defn compute_v28_sequence(noisy_time, h_v28_init, v28_p) do
    seq_len = Nx.axis_size(noisy_time, 0)
    batch_size = Nx.axis_size(noisy_time, 1)
    zero_frame = Nx.broadcast(0.0, {batch_size, 512})
    
    h_out_init = Nx.broadcast(0.0, Nx.shape(noisy_time))
    y_out_init = Nx.broadcast(0.0, Nx.shape(noisy_time))
    
    result =
      while {
        i = 0, h_v = h_v28_init, 
        xp1 = zero_frame, xp2 = zero_frame,
        h_acc = h_out_init, y_acc = y_out_init,
        n_t = noisy_time, 
        p = v28_p # ⚡ Tucked safely back into an opaque tuple!
      }, Nx.less(i, seq_len) do
            
        x_noisy_curr = DLM.V27_SSM.rms_norm(n_t[i])
        
        # ⚡ Unpack INSIDE the body
        {a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2, _lm_w, _lm_b} = p

        {y_t, next_h_v28} = DLM.V27_SSM.ssm_recurrence(
          x_noisy_curr, xp1, xp2, h_v, 
          a, bu, bv, cu, cv, du, dv, mu1, mv1, mu2, mv2
        )
        
        y_final = DLM.V27_SSM.rms_norm(y_t)
        
        updated_h = Nx.put_slice(h_acc, [i, 0, 0], Nx.new_axis(next_h_v28, 0))
        updated_y = Nx.put_slice(y_acc, [i, 0, 0], Nx.new_axis(y_final, 0))
          
        {
          i + 1, next_h_v28, x_noisy_curr, xp1,
          updated_h, updated_y, n_t,
          p
        }
      end
      
    {elem(result, 4), elem(result, 5), elem(result, 1)}
  end

  # ⚡ 3. THE GRADIENT TAPE
  defn get_v28_grads(noisy_time, targets_time, ideal_spots_time, h_v28_init, v28_p) do
    value_and_grad(v28_p, fn p ->
      {_a, _bu, _bv, _cu, _cv, _du, _dv, _mu1, _mv1, _mu2, _mv2, lm_w, lm_b} = p
      
      {h_seq, y_seq, _hv} = compute_v28_sequence(noisy_time, h_v28_init, p)
      
      logits_seq = Nx.add(Nx.dot(y_seq, lm_w), lm_b)
      
      ce_loss = DLM.Loss.cross_entropy(logits_seq, targets_time)
      latent_loss = Nx.mean(Nx.pow(Nx.subtract(ideal_spots_time, y_seq), 2))
      
      lambda = Nx.tensor(0.1, type: :f32)
      Nx.add(ce_loss, Nx.multiply(latent_loss, lambda))
    end)
  end

  # ⚡ 4. STATE EXTRACTOR & BPC METRIC (Graph 4)
  defn get_v28_state_and_bpc(noisy_time, targets_time, h_v28_init, v28_p) do
    # Unpack to get the output head weights
    {_a, _bu, _bv, _cu, _cv, _du, _dv, _mu1, _mv1, _mu2, _mv2, lm_w, lm_b} = v28_p
    
    # Run the clean forward pass
    {_h_seq, y_seq, final_h} = compute_v28_sequence(noisy_time, h_v28_init, v28_p)
    
    # Generate the pure logits and cross-entropy without the MSE penalty
    logits_seq = Nx.add(Nx.dot(y_seq, lm_w), lm_b)
    ce_loss = DLM.Loss.cross_entropy(logits_seq, targets_time)
    
    # BPC = CE_Loss / ln(2)
    bpc = Nx.divide(ce_loss, Nx.tensor(0.69314718, type: :f32))
    
    {final_h, bpc}
  end

  def grad_norms(grads) do
    {g_a, g_bu, g_bv, g_cu, g_cv, g_du, g_dv, g_mu1, g_mv1, g_mu2, g_mv2, g_lmw, g_lmb} = grads
    calc = fn g -> g |> Nx.pow(2) |> Nx.sum() |> Nx.sqrt() |> Nx.to_number() |> Float.round(4) end
    [
      a_diag: calc.(g_a), b_u: calc.(g_bu), b_v: calc.(g_bv),
      c_u: calc.(g_cu), c_v: calc.(g_cv), d_u: calc.(g_du), d_v: calc.(g_dv),
      mx_u1: calc.(g_mu1), mx_v1: calc.(g_mv1), mx_u2: calc.(g_mu2), mx_v2: calc.(g_mv2),
      lm_w: calc.(g_lmw), lm_b: calc.(g_lmb)
    ]
  end
end
