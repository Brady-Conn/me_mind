```elixir
defmodule DLM.MuonHybrid do
  import Nx.Defn

  def init_state(params) do
    gpu = {EXLA.Backend, client: :rocm}
    zero_like = fn t -> Nx.broadcast(0.0, t) |> Nx.backend_copy(gpu) end

    %{
      step: Nx.tensor(1, type: :s32) |> Nx.backend_copy(gpu),
      m_emb: zero_like.(params.emb),
      v_emb: zero_like.(params.emb),
      m_head: zero_like.(params.head),
      v_head: zero_like.(params.head),
      layers: params.layers
      |> Tuple.to_list()
      |> Enum.map(fn layer ->
        %{
          m_conv: zero_like.(layer.conv),
          v_conv: zero_like.(layer.conv),
          m_norm: zero_like.(layer.norm),
          v_norm: zero_like.(layer.norm)
        }
      end)
      |> List.to_tuple()
    }
  end

  # ⚡ Unrolled Newton-Schulz (Prevents ROCm dynamic buffer crashes)
  deftransform newton_schulz(g) do
    frobenius_norm = Nx.sqrt(Nx.sum(Nx.pow(g, 2))) |> Nx.add(1.0e-7)
    x = Nx.divide(g, frobenius_norm)
  
    final_x =
      Enum.reduce(1..5, x, fn _, curr_x ->
        x_t_x = Nx.dot(Nx.transpose(curr_x), [1], curr_x, [0])
        x_x_t_x = Nx.dot(curr_x, [1], x_t_x, [0])
        Nx.subtract(Nx.multiply(curr_x, 1.5), Nx.multiply(x_x_t_x, 0.5))
      end)
  
    Nx.multiply(final_x, frobenius_norm)
  end

  deftransform adam_update(param, grad, m, v, step, lr) do
    beta1 = 0.9
    beta2 = 0.999
    eps = 1.0e-8
  
    new_m = Nx.add(Nx.multiply(beta1, m), Nx.multiply(1.0 - beta1, grad))
    new_v = Nx.add(Nx.multiply(beta2, v), Nx.multiply(1.0 - beta2, Nx.pow(grad, 2)))
  
    m_hat = Nx.divide(new_m, Nx.subtract(1.0, Nx.pow(beta1, step)))
    v_hat = Nx.divide(new_v, Nx.subtract(1.0, Nx.pow(beta2, step)))
  
    param_update = Nx.subtract(param, Nx.multiply(lr, Nx.divide(m_hat, Nx.add(Nx.sqrt(v_hat), eps))))
    {param_update, new_m, new_v}
  end

  deftransform update_layers(params, grads, state, step_count, lr) do
    Enum.zip([
      Tuple.to_list(params.layers),
      Tuple.to_list(grads.layers),
      Tuple.to_list(state.layers)
    ])
    |> Enum.map(fn {l_param, l_grad, l_state} ->
      {up_conv, nm_conv, nv_conv} = adam_update(l_param.conv, l_grad.conv, l_state.m_conv, l_state.v_conv, step_count, lr)
      {up_norm, nm_norm, nv_norm} = adam_update(l_param.norm, l_grad.norm, l_state.m_norm, l_state.v_norm, step_count, lr)
      schulz_grad = newton_schulz(l_grad.proj)
      up_proj = Nx.subtract(l_param.proj, Nx.multiply(lr, schulz_grad))
  
      {%{conv: up_conv, norm: up_norm, proj: up_proj},
       %{m_conv: nm_conv, v_conv: nv_conv, m_norm: nm_norm, v_norm: nv_norm}}
    end)
    |> Enum.unzip()
    |> then(fn {lp, ls} -> {List.to_tuple(lp), List.to_tuple(ls)} end)
  end

  defn step(params, grads, state, lr) do
    step_count = state.step
  
    {up_emb, nm_emb, nv_emb}   = adam_update(params.emb, grads.emb, state.m_emb, state.v_emb, step_count, lr)
    {up_head, nm_head, nv_head} = adam_update(params.head, grads.head, state.m_head, state.v_head, step_count, lr)
  
    {new_layer_params, new_layer_states} = update_layers(params, grads, state, step_count, lr)
  
    new_params = %{emb: up_emb, layers: new_layer_params, head: up_head}
    new_state  = %{step: step_count + 1,
                   m_emb: nm_emb, v_emb: nv_emb,
                   m_head: nm_head, v_head: nv_head,
                   layers: new_layer_states}
    {new_params, new_state}

  end
end
