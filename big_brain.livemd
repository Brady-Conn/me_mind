```elixir
# In your Init cell, BEFORE building tensors
Nx.global_default_backend(Nx.BinaryBackend)  # ← force CPU for dataset creation

files = ["data.noun", "data.verb", "data.adj", "data.adv"]
IO.puts("Parsing WordNet and shuffling dataset...")
training_tensors = DLM.DataBuilder.build_combined_tensors(files)

# Verify it's on CPU before saving
# IO.puts("Backend: #{inspect(Nx.backend(training_tensors))}")  # should show BinaryBackend

binary_data = :erlang.term_to_binary(training_tensors)
File.write!("bigbrain_phase1_data.bin", binary_data)
IO.puts("Done!")

# Restore GPU as default after saving
Nx.global_default_backend({EXLA.Backend, client: :rocm})
