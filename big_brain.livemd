```elixir
# 1. Load the Cached Data (1 millisecond!)
IO.puts("🧠 Loading BigBrain Dataset...")
full_dataset = File.read!("bigbrain_phase1_data.bin") 
  |> :erlang.binary_to_term()
  |> Nx.backend_copy(Nx.BinaryBackend)  # ← force onto CPU before anything else
# IO.puts("Dataset backend: #{inspect(Nx.backend(full_dataset))}")

# 2. Setup Hyperparameters
batch_size = 1
epochs = 2
save_interval = 1000
lr = 3.0e-4
gpu = {EXLA.Backend, client: :rocm}

# Chunk the massive dataset into GPU-sized batches
batches = Nx.to_batched(full_dataset, batch_size)
total_steps_per_epoch = Nx.axis_size(full_dataset, 0) |> div(batch_size)

# 3. Initialize Model, Positional Embeddings, and Optimizer
IO.puts("🏗️ Initializing Rank 64 Architecture...")
params = DLM.BigBrainSSM.init_params() |> Nx.backend_copy(gpu)
pos_emb = DLM.Positional.build(256, 64) |> Nx.backend_copy(gpu) # Note: Dim 64 now!

opt_state = DLM.MuonHybrid.init_state(params)

# 4. The Outer Training Loop
IO.puts("🚀 IGNITION: Starting Epoch 1...")

Enum.reduce(1..epochs, {params, opt_state}, fn epoch, {current_params, current_opt_state} ->
  IO.puts("🌊 EPOCH #{epoch} / #{epochs}")

  # ✅ Recreate stream fresh each epoch, lazily sliced on CPU
  epoch_batches = Stream.unfold(0, fn offset ->
    if offset >= Nx.axis_size(full_dataset, 0) do
      nil
    else
      actual_size = min(batch_size, Nx.axis_size(full_dataset, 0) - offset)
      batch = Nx.slice_along_axis(full_dataset, offset, actual_size, axis: 0)
      {batch, offset + batch_size}
    end
  end)

  epoch_batches
  |> Stream.with_index(1)
  |> Enum.reduce({current_params, current_opt_state}, fn {batch, step}, {p, opt} ->
    IO.puts("🔬 Step #{step}")
    # Move the current batch to the GPU
    gpu_batch = Nx.backend_copy(batch, gpu)

    IO.puts("🔬 Testing single step... batch on gpu")

    {loss_tensor, grads} = DLM.BigBrainTrainer.compute_grad(p, pos_emb, gpu_batch)
    IO.puts("🔬 Testing single step... grads computed")
    {new_p, new_opt} = DLM.MuonHybrid.step(p, grads, opt, lr)
    IO.puts("🔬 Testing single step... new p and opt calculated")

    loss_val = Nx.to_number(loss_tensor)  # pulls to CPU and frees GPU buffer
    # Logging
    if rem(step, 10) == 0 do
      mem = :erlang.memory(:total) |> div(1024 * 1024)
      IO.puts("➡️ Epoch #{epoch} | Step #{step}/#{total_steps_per_epoch} | Loss: #{loss_val} | RAM: #{mem}MB")
    end

    if rem(step, save_interval) == 0 do
      IO.puts("💾 Checkpointing...")
      state_to_save = %{
        params: Nx.backend_copy(new_p, Nx.BinaryBackend),    # ← copy, not transfer
        opt_state: Nx.backend_copy(new_opt, Nx.BinaryBackend),
        step: step
      }
      File.write!("bigbrain_epoch#{epoch}_step#{step}.bin", :erlang.term_to_binary(state_to_save))
    end

    # Garbage Collect to keep Elixir RAM low
    if rem(step, 50) == 0, do: :erlang.garbage_collect(self())

    {new_p, new_opt}
  end)
end)

IO.puts("🎉 BIG BRAIN PRE-TRAINING COMPLETE!")
```

