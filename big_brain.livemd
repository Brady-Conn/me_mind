## Transformer, positional, optimizer

```elixir
defmodule DLM.BigBrainSSM do
  import Nx.Defn

  @rank 32
  @vocab_size 128
  @dim 256
  @layers 3

  def init_params() do
    key = Nx.Random.key(42)
    {emb_w, key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@vocab_size, @dim})
    
    layers = Enum.map(1..@layers, fn _ ->
      {conv_w, key} = Nx.Random.normal(key, 0.0, 0.02, shape: {3, @dim, @dim})
      {proj_w, key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@dim, @dim})
      {norm_w, key} = Nx.Random.normal(key, 1.0, 0.0, shape: {@dim})
      %{conv: conv_w, proj: proj_w, norm: norm_w}
    end)

    {head_w, _key} = Nx.Random.normal(key, 0.0, 0.02, shape: {@dim, @vocab_size})
    %{emb: emb_w, layers: List.to_tuple(layers), head: head_w}
  end

  deftransform rms_norm(x, weight, eps \\ 1.0e-5) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    normed = Nx.multiply(x, Nx.rsqrt(Nx.add(variance, eps)))
    Nx.multiply(normed, weight)
  end

  deftransform apply_layers(x, layers) do
    Enum.reduce(Tuple.to_list(layers), x, fn layer, acc ->
      normed = rms_norm(acc, layer.norm)
      padded = Nx.pad(normed, 0.0, [{0, 0, 0}, {2, 0, 0}, {0, 0, 0}])
  
      conved = Nx.conv(padded, layer.conv,
        padding: :valid,
        input_permutation: [0, 2, 1],
        kernel_permutation: [2, 1, 0],   # ← fixed
        output_permutation: [0, 2, 1]
      )
  
      activated = Nx.multiply(conved, Nx.sigmoid(conved))  # ← Nx.multiply, not *
      projected = Nx.dot(activated, [2], layer.proj, [0])
      Nx.add(acc, projected)                               # ← Nx.add, not +
    end)
  end

  defn forward(ins, params, pos_emb) do
    x = Nx.take(params.emb, ins) + pos_emb
    x = apply_layers(x, params.layers)
    Nx.dot(x, [2], params.head, [0])
  end
end
```

