## SSM

```elixir
defmodule DLM.SvdSSM do
  import Nx.Defn

  defn rms_norm(x, gamma, beta, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    norm = x * Nx.rsqrt(variance + epsilon)
    scaled = norm * gamma
    scaled + beta
  end

  defn rms_norm(x, epsilon \\ 1.0e-6) do
    variance = Nx.mean(Nx.pow(x, 2), axes: [-1], keep_axes: true)
    x * Nx.rsqrt(variance + epsilon)
  end

  defn gelu(x) do
    cdf = Nx.multiply(
      Nx.tensor(0.7978845608, type: :f32),
      Nx.add(x, Nx.multiply(Nx.tensor(0.044715, type: :f32), Nx.pow(x, 3)))
    )
    Nx.multiply(Nx.multiply(Nx.tensor(0.5, type: :f32), x), Nx.add(Nx.tensor(1.0, type: :f32), Nx.tanh(cdf)))
  end
  
  defn feed_forward_layer(x, um, ga, bi, dm) do
    up = Nx.dot(x, um) 
    act = gelu(up) #was tanh
    scaled = Nx.multiply(act, ga)
    biased = Nx.add(scaled, bi)
    Nx.dot(biased, dm) 
  end

  defn softmax(t) do
    max_val = Nx.reduce_max(t, axes: [-1], keep_axes: true)
    safe_t = Nx.subtract(t, max_val)
    exps = Nx.exp(safe_t)
    sum_exps = Nx.sum(exps, axes: [-1], keep_axes: true)
    Nx.divide(exps, Nx.add(sum_exps, 1.0e-8))
  end

  defn apply_xsa(x, y) do
    y_norm_sq = Nx.add(Nx.sum(Nx.pow(y, 2), axes: [-1], keep_axes: true), 1.0e-6)
    y_unit = Nx.divide(y, Nx.sqrt(y_norm_sq))
    y_ov = Nx.sum(Nx.multiply(x, y_unit), axes: [-1], keep_axes: true)
    Nx.subtract(x, Nx.multiply(y_ov, y_unit))
  end

  defn apply_attention(q, v) do
    k = Nx.transpose(v, axes: [0, 2, 1])
    r = Nx.axis_size(v, 1)
    qu = Nx.new_axis(q, 1)
    score = Nx.dot(qu, [2], [0], k, [1], [0])
    scaled_score = Nx.divide(score, Nx.sqrt(r))
    soft_score = softmax(scaled_score)
    Nx.dot(soft_score, [2], [0], v, [1], [0]) |> Nx.squeeze(axes: [1])
  end

  defn forward_step(x_t, spell_mem, word_mem, pr_mem, z_t, frzn, solver, p) do
    {c1, c2, cb, cq, cg, ce,
     w1, w2, wb, wq, wg, we, wd, em} = p
    # apply time scale
    time_scale = Nx.rsqrt(Nx.Constants.pi())
    wm_scaled = Nx.multiply(word_mem, time_scale)
    sm_scaled = Nx.multiply(spell_mem, time_scale)
    pm_scaled = Nx.multiply(pr_mem, time_scale)
    # determine word boundry, apply resest, check for "-"(ascii 45) too?
    is_space = Nx.equal(x_t, 32) |> Nx.as_type(:f32) |> Nx.new_axis(1)
    is_space_3d = Nx.new_axis(is_space, 1)
    reset_factor_3d = Nx.subtract(1.0, is_space) |> Nx.new_axis(1)
    sm_set = Nx.multiply(sm_scaled, reset_factor_3d)
    # process current character -> {batch, 128}
    u_t = Nx.take(em, x_t)
    # update spelling
    sl_sm = Nx.slice_along_axis(sm_set, 1, 31, axis: 1)
    sm_new = Nx.concatenate([sl_sm, Nx.new_axis(u_t, 1)], axis: 1)
    # reshape for word update {batch, 32, 16} -> {batch, 512}
    wrd = Nx.reshape(sm_new, {:auto, 4096}) |> Nx.dot(wd)
    w_term = feed_forward_layer(wrd, w1, wq, wb, w2)
    w_norm = rms_norm(w_term, wg, we)
    # update word memory
    sl_wm_nonspace = Nx.slice_along_axis(wm_scaled, 0, 127, axis: 1)
    sl_wm_space    = Nx.slice_along_axis(wm_scaled, 1, 127, axis: 1)
    # blended slice
    sl_wm = Nx.multiply(sl_wm_space, is_space_3d)
               |> Nx.add(Nx.multiply(sl_wm_nonspace, Nx.subtract(1.0, is_space_3d)))
    # actual update - is space batches will get new entry, non is space will update in place
    wm_new = Nx.concatenate([sl_wm, Nx.new_axis(wrd, 1)], axis: 1)
    # get spelling attention try subtracting from previous w_norm to get w_delta
    qw = Nx.dot(w_norm, frzn)
    sp_ctx = apply_attention(qw, wm_new)
    spxa = apply_xsa(sp_ctx, w_norm)
    pm_sl = Nx.slice_along_axis(pm_scaled, 1, 3, axis: 1)
    pmn_b = Nx.concatenate([pm_sl, z_t], axis: 1)
    pmn_p = Nx.reshape(pmn_b, {:auto, 512})
    pmp_n = Nx.add(pmn_p, spxa)
    slv_sl = Nx.slice_along_axis(solver, 1, 62, axis: 1)
    pslv = Nx.concatenate([Nx.new_axis(w_norm, 1), slv_sl, Nx.new_axis(spxa, 1)], axis: 1)
    
    c_ib = apply_attention(qw, pslv)
    c_in = Nx.add(c_ib, pmp_n)
    # 512 -> 512
    c_term = feed_forward_layer(c_in, c1, cq, cb, c2)
    c_norm = rms_norm(c_term, cg, ce)
    pr_new = Nx.reshape(c_norm, {:auto, 4, 128})
    logits = Nx.take(pr_new, 0, axis: 1)
    
    {logits, sm_new, wm_new, pr_new}
  end
end
```

